<?xml version="1.0" encoding="utf-8"?>
<opml version="2.0">
  <head>
    <title></title>
    <flavor>dynalist</flavor>
    <source>https://dynalist.io</source>
    <ownerName>Ferb</ownerName>
    <ownerEmail>jedibender@gmail.com</ownerEmail>
  </head>
  <body>
    <outline text="General Reasoning Guide        Pre-Alpha v0.4.9" _note="Last updated: July 20th">
      <outline text="Guide guide" heading="1" colorLabel="6" collapsed="true">
        <outline text="Intro" heading="1" colorLabel="6" collapsed="true">
          <outline text="This guide is based on classical logic." collapsed="true">
            <outline text="If you&apos;re looking for a guide on reasoning that explicitly includes non-classical logic, you&apos;ll have to look elsewhere."/>
          </outline>
          <outline text="[Tips](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-Il1yeUSmN55HEgrKIyG4cdT)"/>
          <outline text="[FAQs](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zKXsMJmmMm-VEFAVMo0P4xWB)"/>
        </outline>
        <outline text="Meanings" heading="1" colorLabel="6" collapsed="true">
          <outline text="Color meanings" heading="3" colorLabel="6" collapsed="true">
            <outline text="COLORLESS" heading="3"/>
            <outline text="^ Descriptions or largely plain text mostly."/>
            <outline text="RED" heading="3" colorLabel="1"/>
            <outline text="^ Psychology / Limitation / Detriment / Counterargument" collapsed="true">
              <outline text="Limitations don&apos;t necessarily lower the importance of a topic. Occasionally, they can even raise the importance, especially when it&apos;s important to understand the topic to better understand its limitations."/>
              <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kKQAr5M3XUuysAL4VVWIGYza"/>
            </outline>
            <outline text="ORANGE" heading="3" colorLabel="2"/>
            <outline text="^ Practical / Informal  stuff that doesn&apos;t fit in the other categories (aside from &quot;other&quot;)."/>
            <outline text="YELLOW" heading="3" colorLabel="3"/>
            <outline text="^ Semantics / Meaning / Link"/>
            <outline text="GREEN" heading="3" colorLabel="4"/>
            <outline text="^ Induction / Benefit / Supporting argument" collapsed="true">
              <outline text="In supporting/countering argument chains, green/red only indicates the argument&apos;s relationship with its parent, not the argument&apos;s &quot;side&quot; at the broadest level."/>
            </outline>
            <outline text="BLUE" heading="3" colorLabel="5"/>
            <outline text="^ Deduction / Structure / Formal"/>
            <outline text="PURPLE" heading="3" colorLabel="6"/>
            <outline text="^ Category / Other / Example"/>
          </outline>
          <outline text="Structure meanings" heading="3" colorLabel="5">
            <outline text="Meta" heading="1" collapsed="true">
              <outline text="Overview" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The categories that go by the same name and cover the same types of stuff across many different items throughout the guide."/>
                  <outline text="These typically have slightly smaller text and are like the overview of the category."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="The [definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bAOoPhuoAV8ngQvymvpd4MA5) and [importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=SpAdvmVUTCf0uiPjAB8tROLs) sections."/>
                  </outline>
                </outline>
                <outline text="Where / appearance" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Most &quot;overview&quot; [sections](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VF2zJimzdBsHCko-KcOysRm7) can be found at the top."/>
                  <outline text="The [related](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BxLhf75NtFcuS3m_vqfuN2Jc) and [source(s)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XpWtogldKW_8ifgzI80ZzdT1) sections are always at the bottom."/>
                </outline>
              </outline>
              <outline text="Main sections" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Items that are largely specific to the item you&apos;re under, which usually have bigger titles." collapsed="true">
                    <outline text="Like this" heading="1"/>
                    <outline text="Or this" heading="2"/>
                    <outline text="But still sometimes this" heading="3"/>
                  </outline>
                  <outline text="These items usually have most of the relevant content of their parent section, and are often sections in themselves, structured just like other sections."/>
                </outline>
                <outline text="Where / appearance" heading="3" colorLabel="5" collapsed="true">
                  <outline text="They are under the top [overview](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1CGpbJ44h3_7o-Lu68aD5Iu4) sections and above any [bottom overview](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=E42zEx0CwqT0EXFNeGbd1f1o) sections (&quot;sources&quot; and &quot;related&quot;)."/>
                </outline>
                <outline text="Order" heading="3" colorLabel="6" collapsed="true">
                  <outline text="These are typically in descending order of importance and/or intended reading order." collapsed="true">
                    <outline text="So it&apos;s typically best to read from top to the bottom of the main sections if you will read them."/>
                    <outline text="^ However be careful not to fall into the trap of reading the whole guide like a book, as this [causes problems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FpuJ8fBur34CeimORIHZUivK)." colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Misc" heading="3" collapsed="true">
                <outline text="Oftentimes (as referenced in [color meanings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq)) red and green items will represent arguments for/against (or benefits/detriments of) their parent." collapsed="true">
                  <outline text="Example:"/>
                  <outline text="[color meanings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq) clearly states that they can be benefits/detriments and [supporting arguments] or counterarguments." colorLabel="4"/>
                  <outline text="It would be quite confusing to use the same color to mean very different things, and green is used for induction and red is used for psychology. So [color meanings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq) is likely wrong." colorLabel="1" collapsed="true">
                    <outline text="Dynalist only has 6 colors, so it is an unfortunate compromise." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Non-hidden details" heading="3" collapsed="true">
                  <outline text="Sometimes items will have details that you don&apos;t need to expand to see."/>
                  <outline text="^ Example:"/>
                  <outline text="^ This is an example."/>
                  <outline text="These will always be denoted using the ^ symbol."/>
                </outline>
              </outline>
              <outline text="The notes (small, grey text) under most items here explain what the kinds of items mean throughout the rest of the guide."/>
              <outline text="Inside of each item with a note is info about this topic (structure meanings) that fits within the type of parent item it is in." collapsed="true">
                <outline text="This acts as both examples of how these kinds of items typically work, and data about this topic."/>
              </outline>
            </outline>
            <outline text="Definition (specific)" _note="The definition(s) of/[relevant to] the topic. Often the word(s) in the parentheses (if there are any) will give a rough idea of the kind of definition being used, and how important it is to read it." heading="3" colorLabel="3" collapsed="true">
              <outline text="Explanation of how the [general reasoning guide](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EXMieZTy9YWWZzCW-QtW3ay5) is organized and what different parts of sections mean."/>
              <outline text="Synonym(s)" _note="Other term(s) that mean the same thing." heading="3" colorLabel="3"/>
              <outline text="Distinction(s)" _note="Important distinction(s) between this concept and (a) similar one(s)." heading="3" colorLabel="3"/>
            </outline>
            <outline text="Importance" _note="Reasons for why this topic is important, and what limitations/drawbacks of the topic to keep in mind. Will typically be in roughly descending order of importance for the particular topic, though descendants of these fundamental reasons will be sorted by likelihood/relevance first. Red/green colors are used to represent whether a claim is supporting or contesting **its parent claim** (or the importance of the topic overall, if they are the immediate children of &quot;importance&quot;)." heading="3" colorLabel="2" collapsed="true">
              <outline text="**Navigation:**   Getting a better understanding of what the different sections mean can help with navigation." colorLabel="4"/>
              <outline text="**Reading comprehension:**   Getting a better understanding of what the different sections mean can help with reading comprehension (of this specific guide)." colorLabel="4"/>
              <outline text="**Difficult:**   The structure is difficult to adapt to." colorLabel="4" collapsed="true">
                <outline text="Almost no reasoning guides follow formats like this." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="There&apos;s little past experience to draw on when navigating this guide." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="So it would be easy to get lost and be much less efficient in navigation at first, if you don&apos;t know what different aspects of the structure mean." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Some of the terms are misleading." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="&quot;Definition(s)&quot; can also include synonym(s)."/>
                  <outline text="&quot;Definitions&quot; includes multiple definitions, sometimes both recommended and unrecommended definitions." collapsed="true">
                    <outline text="This is partially to explain why to avoid certain definitions."/>
                    <outline text="This is partially to avoid the potential for conflations." collapsed="true">
                      <outline text="This is achieved by showing the difference between definitions that might otherwise be conflated."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="**Common:**   The guide typically follows this format." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="Therefore learning about [structure meanings] would be very helpful across most of the guide." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="The [general reasoning guide](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EXMieZTy9YWWZzCW-QtW3ay5) is still probably a bit confusing to follow even with this little tutorial." _note="Relevance" colorLabel="1" collapsed="true">
                  <outline text="However it should still be significantly less confusing after reading the tutorial." _note="Relevance" colorLabel="1"/>
                  <outline text="One can always return to this section (and eg. have it open in another tab) when they continue to be confused by certain things." _note="Relevance" colorLabel="1" collapsed="true">
                    <outline text="This would be especially useful when they&apos;re first starting out." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Nuances" _note="The substantial nuances of the topic." heading="3" colorLabel="2"/>
            <outline text="Reducible" _note="How the topic is reducible (at least to a noteworthy degree) to a more central/important topic. Typically ommitted (or in this case left empty) if there isn&apos;t a noteworthy way in which the topic is reducible." heading="3" colorLabel="5"/>
            <outline text="How to view it" _note="A description of how to look at the topic in general." heading="3" colorLabel="2" collapsed="true">
              <outline text="An optional tutorial to understand the structure of the [general reasoning guide](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EXMieZTy9YWWZzCW-QtW3ay5) better."/>
            </outline>
            <outline text="Items" heading="2" colorLabel="5" collapsed="true">
              <outline text="We call every bit of text paired with a bullet point an &quot;item&quot;." colorLabel="3"/>
            </outline>
            <outline text="Sections" heading="1" colorLabel="5" collapsed="true">
              <outline text="Almost every colored item with children (that isn&apos;t an argument for/against its parent or an example) is a section." colorLabel="3"/>
              <outline text="These are the big categories present in topics, or the topics themselves, or the categories of topics, etc." colorLabel="2"/>
              <outline text="Main sections" heading="3" colorLabel="5" collapsed="true">
                <outline text="Sections which contain other section(s)." colorLabel="3"/>
              </outline>
            </outline>
            <outline text="[Likelihood / Relevance / etc. notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N_T4CmtomxjUdht4WY5yTNja)" heading="3" colorLabel="5"/>
            <outline text="[Square brackets]" heading="2" colorLabel="2" collapsed="true">
              <outline text="Square brackets are used to specify the &quot;order of operations&quot; of the sentence. You can think of them as being similar to (parentheses) in math, or even sometimes quotation marks in text." colorLabel="3"/>
              <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                <outline text="[color meanings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq) clearly states that they can be benefits/detriments and [supporting arguments] or counterarguments. ([source](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j8et2YW49PWgbi581-d1YrhY))" collapsed="true">
                  <outline text="Without the square brackets, it would be less clear whether the &quot;supporting&quot; is supposed to apply to both &quot;arguments&quot; and &quot;counterarguments&quot;, or just &quot;arguments&quot;." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" _note="Topic(s) (usually linked) that are related (typically closely), but usually not very important to immediately visit." heading="3" colorLabel="6" collapsed="true">
              <outline text="[Item](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ysqXDunJUGkagJZq3yN87Atd) order" heading="3" colorLabel="5" collapsed="true">
                <outline text="Typically (at a high level) the item order is roughly sorted in descending order of importance." colorLabel="4" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="In a set of sibling nodes (without considering parents or children) more important nodes will tend to be higher up while less important nodes will tend to be lower down."/>
                  </outline>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="High importance" heading="3" colorLabel="4"/>
                    <outline text="Medium importance" heading="3" colorLabel="3"/>
                    <outline text="Low importance" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Oftentimes the item order is instead **roughly** sorted in order of what should be read sooner/later." colorLabel="4" collapsed="true">
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Ideally read first" heading="3" colorLabel="4"/>
                    <outline text="Ideally read third" _note="Keyword: roughly" heading="3" colorLabel="2"/>
                    <outline text="Ideally read second" _note="Keyword: roughly" heading="3" colorLabel="3"/>
                    <outline text="Ideally read fourth" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
              <outline text="[Specific definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TZz9odkUoU2o9D24hIObNxov)" heading="3" colorLabel="3"/>
            </outline>
            <outline text="Source(s)" _note="Source(s), if it&apos;s less fitting to place them under the [definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bAOoPhuoAV8ngQvymvpd4MA5)." heading="3" colorLabel="6"/>
          </outline>
          <outline text="Less important meanings" heading="3" colorLabel="1">
            <outline text="You can skip these if you want. Although might be worth peeking at the [importance notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N_T4CmtomxjUdht4WY5yTNja) section."/>
            <outline text="Note meanings" heading="3" colorLabel="3">
              <outline text="General" heading="1" colorLabel="6" collapsed="true">
                <outline text="Notes are often used to covey little bits of information that seem useful"/>
              </outline>
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="&quot;Here&quot; means that the definition is specific to the topic it&apos;s used in, and doesn&apos;t apply to things beyond that."/>
              </outline>
              <outline text="Importance notes" heading="3" colorLabel="2" collapsed="true">
                <outline text="**Likelihood:**   The item supports/contests the parent&apos;s likelihood."/>
                <outline text="**Relevance:**   The item supports/contests the parent&apos;s relevance/impact."/>
                <outline text="**Addressed:**   This item has been addressed, at the end of the current reasoning it seems to be inadequately supported to make much of a difference." collapsed="true">
                  <outline text="These sections will typically be crossed out." colorLabel="3" collapsed="true">
                    <outline text="Like this." complete="true" colorLabel="6"/>
                  </outline>
                  <outline text="You&apos;ll often see this this listed alongside (just to the right) of the &quot;likelihood&quot; or &quot;relevance&quot; note." colorLabel="3"/>
                  <outline text="This is much less common than likelihood or relevance." colorLabel="1"/>
                </outline>
                <outline text="Relevance and likelihood describe relevance and likelihood of the parent item." heading="3" collapsed="true">
                  <outline text="This is very important to keep in mind when navigating links in [importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=SpAdvmVUTCf0uiPjAB8tROLs) sections."/>
                  <outline text="If a linked item has a likelihood/relevance note, that applies to the link&apos;s parent, not the original item&apos;s parent."/>
                  <outline text="If you click on a linked item to see the original and look at its children, its children&apos;s &quot;relevance&quot; sections only apply to their parent (the original item), not any links of their parent. Because relevance describes the strength of the link between a parent and its grandparent. It does not account for link grandparents, only originals."/>
                  <outline text="However an item&apos;s grandchildren&apos;s &quot;relevance&quot; can be relevant to linked instances of the item, since they would be supporting/contesting the relevance of the item&apos;s children on the item, which would be relevant to any linked instances of the item as well as the original."/>
                </outline>
              </outline>
              <outline text="Reasoning level terms" heading="3" colorLabel="5" collapsed="true">
                <outline text="You&apos;ll notice a lot of notes like &quot;~advanced&quot;, these are vague labels meant to make it easier for me to create the guide guide and/or create versions of the guide which include/exclude more complex/easily misunderstood parts in the future."/>
              </outline>
            </outline>
            <outline text="Unique/niche definitions" heading="3" colorLabel="3" collapsed="true">
              <outline text="[Unusual definitions that are used here](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=v2Qbx5hlAHPeFgzbHSTvpu4g)" colorLabel="6"/>
            </outline>
            <outline text="Text size meanings" heading="3" colorLabel="2" collapsed="true">
              <outline text="" _note="Note" collapsed="true">
                <outline text="[Note meanings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ICe9ZqO8ecaquM_1sjWt6vAb)"/>
              </outline>
              <outline text="Normal text" collapsed="true">
                <outline text="Normal text is typically used for the main content of the guide. You&apos;ll find it when you dig deep enough in most categories."/>
              </outline>
              <outline text="Headings" heading="3" collapsed="true">
                <outline text="Headings are typically used for categories."/>
                <outline text="Heading size typically doesn&apos;t mean much, it&apos;s often arbitrary for the sake of making text look/wrap nicer."/>
                <outline text="But usually the standard categories present in many places throughout the guide are given the smallest heading (heading 3), while categories specific to the parent category are given the largest heading (heading 1)."/>
                <outline text="Links are one of the more common exceptions to this, since the text in links doesn&apos;t wrap. They are often given heading 3 even if they are specific to the parent category."/>
                <outline text="Sometimes relative importance will be used to make important categories seem bigger and unimportant categories seem smaller." collapsed="true">
                  <outline text="This is common for categories of main categories." collapsed="true">
                    <outline text="Categories of main categories are usually colored purple." colorLabel="6"/>
                  </outline>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Heading 3" heading="3"/>
                  <outline text="Heading 2" heading="2"/>
                  <outline text="Heading 1" heading="1"/>
                </outline>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="Tips" heading="1" colorLabel="6" collapsed="true">
          <outline text="Reading tips" heading="1" colorLabel="2" collapsed="true">
            <outline text="Read it like a very general service manual, not a book" heading="3" colorLabel="2" collapsed="true">
              <outline text="Reading it like a generally useful service manual" heading="3" colorLabel="4" collapsed="true">
                <outline text="[It saves time](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=m5py-ZBd4JXt_U2ab0deuEbm)" heading="3" colorLabel="4"/>
              </outline>
              <outline text="Reading it like a very specialized service manual" heading="3" colorLabel="1" collapsed="true">
                <outline text="This is likely to cause you not to read much of it, which is likely to cause you to miss a lot of very generally important things." colorLabel="1"/>
              </outline>
              <outline text="Reading it like a book" heading="3" colorLabel="1" collapsed="true">
                <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="The issues listed here have important consequences/[relevance items] that are not immediately obvious. So if you are still unconvinced, I advise reading their child items."/>
                </outline>
                <outline text="You&apos;re unlikely to retain the vast majority of the info." colorLabel="1" collapsed="true">
                  <outline text="Unlike many similar guides and learning resources in general, this one intentionally tries to minimize repetition." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Why?" heading="3" colorLabel="3" collapsed="true">
                      <outline text="**Wasted time:**   Repetition often leads to a lot of wasted time for people who have already adequately learned the info in question."/>
                      <outline text="**Rereading:**   The intended experience involves rereading a lot of important portions of the guide. See [reading order](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hcPLgV8Us5L8ci7jwCugXrQw) for more details."/>
                      <outline text="**Future practice resources:**   We intend to eventually create [practice/training] [resources/community] to accompany the guide, which will provide some repetition."/>
                    </outline>
                    <outline text="Repetition helps a lot with being able to retain info." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="People tend to feel like they will retain way more info than they actually do." _note="Likelihood &amp; Relevance" colorLabel="4" collapsed="true">
                    <outline text="Therefore your intuition likely overestimates your ability to retain info as well." _note="Relevance" colorLabel="4"/>
                    <outline text="**Retaining the info is very important:**   Many of the abilities/strategies/tactics throughout this guide have an effectively multiplicative effect with one another." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Difficulty of re-learning missing info of this guide." _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                        <outline text="With most resources, this isn&apos;t really an issue because you can look up the missing info when you need it." colorLabel="4" collapsed="true">
                          <outline text="Eg. If you forget something in trigonometry, you can look it up and relearn it when needed." colorLabel="6"/>
                        </outline>
                        <outline text="However a lot of the resources in the guide are not taught elsewhere or are taught badly elsewhere." colorLabel="4" collapsed="true">
                          <outline text="Eg. Fallacies are often taught in a simplified and misleading manner." colorLabel="6" collapsed="true">
                            <outline text="Eg. The [appeal to authority](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=T7IqrZ1O4oXouYyjJ5MojzQU) fallacy." colorLabel="6"/>
                          </outline>
                        </outline>
                        <outline text="And if you&apos;ve already read this guide like a book, you&apos;re likely to feel like frequently rereading lots of parts is a waste of time." colorLabel="4"/>
                      </outline>
                      <outline text="Usefulness of info" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                        <outline text="In a lot of topics (eg. math), missing a significant amount of info is not a huge problem, because you won&apos;t use a lot of that info much anyway." colorLabel="4"/>
                        <outline text="Reasoning is much more generally useful than most topics, such that a much greater portion of the domain is much more useful to a much greater number of people in a much greater number of situations." _note="Provide support" colorLabel="4"/>
                      </outline>
                      <outline text="Strong multiplicative effect" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                        <outline text="Because [so much of reasoning is so useful in so many situations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qWqOEfXR6xsMD-zcL0KJuxM4), the guide was able to be filled with dozens of abilities/techniques/strategies/etc. that generally have a multiplicative effect on important other \[ability/technique/strategy/etc.](s)." _note="Likelihood" colorLabel="4"/>
                        <outline text="This means that retaining even 50% of the info would only give you (**very** roughly) 10% of the benefit that retaining 100% would give." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="And retaining 25% would only give you like 2% of the benefit, and so on." _note="2% instead of 1% because ostensibly the first 25% would be more important than the second 25% making up the aforementioned 50%." colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="There are memory techniques to retain a lot more info than one otherwise would." _note="Relevance" colorLabel="1" collapsed="true">
                    <outline text="Most people have not learned to use these techniques very well." _note="Relevance" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Likely to involve reading a lot of largely useless info." colorLabel="1" collapsed="true">
                  <outline text="Much of the guide is meant to be skipped by the vast majority of people, just intended to clarify things for the minority who needs it." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="We are all members of those minorities in some cases, but usually not most cases." colorLabel="3"/>
                  </outline>
                  <outline text="This would likely make the experience more boring." _note="Relevance, maybe link to boredom under motivation or something." colorLabel="4"/>
                  <outline text="The time could instead be spent practicing and/or re-reading the more important things." _note="Links to practice and re-reading" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hcPLgV8Us5L8ci7jwCugXrQw" heading="3" colorLabel="6"/>
                <outline text="[Deciding what to skip](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lQefzxW-0G800Ba6h4Q6lsoL)" heading="3" colorLabel="2"/>
                <outline text="[Why non-linear format](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cHXvnvL9lag7l80zyCvqoF9R)" heading="3"/>
              </outline>
            </outline>
            <outline text="Deciding what to skip" heading="2" colorLabel="2" collapsed="true">
              <outline text="Already read/visited" heading="3" collapsed="true">
                <outline text="Rereading parts of sections in the context of other sections." collapsed="true">
                  <outline text="It can be helpful for getting a better grasp on how they are connected."/>
                </outline>
                <outline text="Rereading sections to better remember them."/>
                <outline text="Rereading sections to better understand them."/>
              </outline>
              <outline text="Will read/visit later" heading="3" collapsed="true">
                <outline text="Maybe" heading="3" collapsed="true">
                  <outline text="Typically you should be careful about skipping things with the intention of reading them later, since you might forget."/>
                </outline>
                <outline text="Interesting / useful" heading="3" collapsed="true">
                  <outline text="If you&apos;re in a section that seems very interesting / useful to you, you&apos;ll probably want to at least check roughly what the things you&apos;re planning on skipping look like, in case it&apos;s not in the reading guide and you forget to come back to it."/>
                </outline>
                <outline text="Notes" heading="3" collapsed="true">
                  <outline text="Feel free to take notes about what sections you would like to come back to."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&quot;Related&quot; sections are used largely to say &quot;unless you want to learn this topic thoroughly, it&apos;s ok to skip for now&quot;." _note="So they should generally be things that you&apos;ll either already have read, read in the future, or rightfully completely skip."/>
                  <outline text="When trying to learn a topic thoroughly, it&apos;s often useful to think about how related topics connect (to build an intuition of how the topic applies in various areas and/or what it can be boiled down to), and thus it can be useful to follow the links."/>
                </outline>
                <outline text="Link-only items" heading="3" collapsed="true">
                  <outline text="When an item has only link(s), it should be read as though all the links were in a [&quot;related&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nH0Y8mswCAeqBhWg6YWvU9M5) category."/>
                </outline>
              </outline>
              <outline text="Potentially permanent skip" heading="3" collapsed="true">
                <outline text="Unless your chosen [reading order](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hcPLgV8Us5L8ci7jwCugXrQw) suggests to skip it, it&apos;s generally best to read almost all [main sections](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O4GqSyi7g0FcCQGkFXRV75kC) (linked sections are the main exception, more on that below)."/>
                <outline text="Links" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Permanently skipping linked sections."/>
                  </outline>
                  <outline text="In &quot;related&quot;" _note="Or other categories if there are other categories for links." heading="3" colorLabel="6" collapsed="true">
                    <outline text="Most links will be put here."/>
                    <outline text="These are typically fine to skip, but for more important sections it&apos;s often worthwhile to first check if there&apos;s anything that seems worth checking out."/>
                  </outline>
                  <outline text="Main links" heading="3" collapsed="true">
                    <outline text="Typically if you&apos;re going to do this, you should at least check its &quot;importance&quot; section (if it has one) and make sure you find the reasons insufficiently compelling to be worth considering further." collapsed="true">
                      <outline text="It&apos;s easy" heading="3" collapsed="true">
                        <outline text="When the topic is unimportant, it&apos;s typically easy to tell based on its &quot;importance&quot; section or lack thereof."/>
                        <outline text="Easy to return to where you were via [back/forward page](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0vvszUOIfAqqrZYS2RFS9KTD)"/>
                        <outline text="&quot;Importance&quot; sections are typically not very long."/>
                      </outline>
                      <outline text="It&apos;s important" heading="3" collapsed="true">
                        <outline text="People very often overestimate their knowledge/abilities in many of these areas and have permanent and large reasoning weaknesses as a result."/>
                        <outline text="Many of the areas are much more important than they seem."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Category-specific" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definitions" heading="3" collapsed="true">
                  <outline text="Generally if the definition is unusual or confusing, there will be a word in parentheses next to it." collapsed="true">
                    <outline text="The word is used to describe why you might not know the definition being used even if you initially think that you do."/>
                  </outline>
                  <outline text="^ Example:"/>
                  <outline text="Definition (unusual)" heading="3" colorLabel="3"/>
                  <outline text="If there isn&apos;t a word like this and it&apos;s just like normal and you think you understand it, it&apos;s probably fine to skip."/>
                </outline>
                <outline text="Importance" heading="3" collapsed="true">
                  <outline text="If you think the topic is: "/>
                  <outline text="Very important" heading="3" collapsed="true">
                    <outline text="You can generally skip over the importance section."/>
                  </outline>
                  <outline text="Somewhat or pretty important" heading="3" collapsed="true">
                    <outline text="It&apos;s likely still worth taking a look if it&apos;s a big section, because there&apos;s likely sufficient evidence there to suggest that the topic is more important than you think."/>
                  </outline>
                  <outline text="Not very important, or unimportant" heading="3" collapsed="true">
                    <outline text="You almost certainly want to check out the importance section, as it likely has things you haven&apos;t considered about how important it is."/>
                  </outline>
                </outline>
                <outline text="Limitations" heading="3" collapsed="true">
                  <outline text="Limitations are usually important to read even if you already feel like you understand the limitations."/>
                  <outline text="^ There are often more than you would expect or unique angles we present for them."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="These sections can usually be skipped without missing too much." collapsed="true">
                    <outline text="They mostly contain links to other sections or (relatively) less important things."/>
                  </outline>
                  <outline text="They are intended for people who really want to get a deep grasp of the topic." collapsed="true">
                    <outline text="The links (and common accompanying explanations) help intuitively grasp important relations with other topics."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Thinking of applications" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Thinking of different practical ways in which a topic or idea can apply to important things."/>
                <outline text="Example" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Many of these topics are likely applicable to many different things that are important to you."/>
                <outline text="Understanding how ideas connect to each other." _note="Link (create if needed)" collapsed="true">
                  <outline text="Useful for getting a better understanding of what reduces to what." _note="Move to linked section"/>
                </outline>
                <outline text="Understanding how ideas appear in practice."/>
              </outline>
              <outline text="Typical types of applicability" heading="3" colorLabel="5" collapsed="true">
                <outline text="To you" heading="3" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="This can help you fix your reasoning flaws."/>
                    <outline text="^ This can help you identify your reasoning flaws." collapsed="true">
                      <outline text="You&apos;re sure to have __some__ reasoning flaws." colorLabel="4"/>
                      <outline text="Your reasoning flaws are likely to be initially unintuitive and hard to see for you." colorLabel="4" collapsed="true">
                        <outline text="Otherwise you probably would have fixed them by now." colorLabel="4"/>
                        <outline text="We all have some things that are less intuitive and harder to see for us." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="To someone(s) you know" heading="3"/>
                <outline text="To a system" heading="3"/>
                <outline text="To someone(s) you don&apos;t know" heading="3"/>
              </outline>
            </outline>
            <outline text="Sorted by importance" heading="2" colorLabel="2" collapsed="true">
              <outline text="Most sections of the guide are (very roughly) sorted from top to bottom by importance to read."/>
              <outline text="The sections that are common to a bunch of items such as &quot;definition&quot;, &quot;importance&quot;, &quot;reducible&quot;, &quot;related&quot;, etc. are exceptions to this rule. They are layed out in a standard fashion that doesn&apos;t change depending on their importance, to make them easy to find."/>
            </outline>
            <outline text="Zoom &gt; Expansion" heading="1" colorLabel="6" collapsed="true">
              <outline text="It&apos;s easy to expand too much." colorLabel="1" collapsed="true">
                <outline text="Expanding a lot can easily make people feel overwhelmed at the amount of info displayed at once." colorLabel="4" collapsed="true">
                  <outline text="Especially when expanding the more dense sections." colorLabel="4" collapsed="true">
                    <outline text="&quot;Dense&quot; as in both intellectual dense and lots of items having many children." colorLabel="3"/>
                  </outline>
                  <outline text="Especially for high-level sections" colorLabel="4" collapsed="true">
                    <outline text="&quot;High-level&quot; as in high in the hierarchy of items, not necessarily intellectually dense." colorLabel="3" collapsed="true"/>
                    <outline text="Expanding a high-level section using ctrl+shift+. will typically result in expanding a lot more at once." colorLabel="4" collapsed="true"/>
                  </outline>
                </outline>
                <outline text="If you expand too much at once (by using ctrl+shift+.) at a high level section, it can cause significant lag." colorLabel="4" collapsed="true">
                  <outline text="This is not an issue on mobile, only PC." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="You can typically zoom in/out instead of expanding/collapsing." colorLabel="1" collapsed="true">
                <outline text="It tends to make it easier to focus on particular things." colorLabel="4"/>
              </outline>
            </outline>
          </outline>
          <outline text="Software/dynalist tips" heading="1" colorLabel="5" collapsed="true">
            <outline text="Basic" heading="1">
              <outline text="Expanding/collapsing" heading="3" colorLabel="2">
                <outline text="You can click/tap the **+** to the right of each collapsed item to expand it, and likewise click/tap the **-** to the right of each expanded item to collapse it. Or use the keyboard shortcut:  **ctrl + .**"/>
                <outline text="You can use **ctrl + shift + .** or **double-click on the +/-** to expand/collapse the item and all their sub-items." collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2">
                    <outline text="This is often extremely useful for low-level sections where you don&apos;t want to click/tap to read every little sentence." colorLabel="4"/>
                    <outline text="It&apos;s not recommended to use this for higher-level sections. For more info: [Zoom &gt; expansion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HMS_X04HFtdH9lir6DFniCe7)" colorLabel="1"/>
                    <outline text="There is unfortunately not a mobile equivalent as far as I&apos;m aware." colorLabel="1"/>
                  </outline>
                  <outline text="Multiple items at once" heading="3" collapsed="true">
                    <outline text="Can do this with multiple items at once by selecting items by clicking and dragging over them, then using **ctrl + shift + .**"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Back/forward page" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Your web browser&apos;s back /forward page buttons."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Very handy for quickly going back to where you were, especially after clicking/tapping [link tips](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1iM0MaIKWFWgOiU0FTW26yHj)"/>
                </outline>
              </outline>
              <outline text="Link tips" heading="3" colorLabel="5" collapsed="true">
                <outline text="[Back/forward page](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0vvszUOIfAqqrZYS2RFS9KTD)" collapsed="true">
                  <outline text="If you want to go to a linked section of the guide and then return to where you were, you can use the back page button to easily return."/>
                </outline>
                <outline text="[Knowing location](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HyzIkypIL116medzP3QCMUyk)" collapsed="true">
                  <outline text="Navigating links can be quite disorienting."/>
                </outline>
                <outline text="[Font size](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=DFEz-ZKHvTY3Uh3UmFSOrjSR)" collapsed="true">
                  <outline text="[Link text cannot wrap around on mobile [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fJAL99zn08IjQi4kVk78zQ_t)"/>
                </outline>
              </outline>
              <outline text="Knowing location" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Figuring out where you are in this document."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Especially useful after using [links](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1iM0MaIKWFWgOiU0FTW26yHj)" collapsed="true">
                    <outline text="They can be quite disorienting."/>
                  </outline>
                </outline>
                <outline text="Method" heading="3" colorLabel="5" collapsed="true">
                  <outline text="At the top, you should see something like &quot;General Reasoning Guide [...]   &gt;   Guide guide   &gt;   Tips   &gt;   Software tips   &gt;   Basic   &gt;&quot;"/>
                  <outline text="This displays the location you&apos;re currently zoomed into." collapsed="true">
                    <outline text="You can expand sections without zooming into them, so if you do that, you won&apos;t be able to use this method alone to see exactly where you&apos;re at." collapsed="true">
                      <outline text="This is part of the reason I recommend zooming in instead of expanding most of the time." collapsed="true">
                        <outline text="[Zoom &gt; expansion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HMS_X04HFtdH9lir6DFniCe7)"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Specifically, you&apos;re in &quot;Method&quot; inside of &quot;Knowing location&quot; inside of &quot;Basic&quot; inside of &quot;Software tips&quot; inside of &quot;Tips&quot; inside of &quot;Guide guide&quot; inside of &quot;[General Reasoning Guide](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EXMieZTy9YWWZzCW-QtW3ay5)&quot;."/>
                </outline>
              </outline>
              <outline text="Font size" _note="Recommended for mobile" heading="3" colorLabel="3" collapsed="true">
                <outline text="**Definition:** Text size." colorLabel="3"/>
                <outline text="Finding the setting" heading="3" colorLabel="5" collapsed="true">
                  <outline text="1. Tap the **three dots** in the top-right corner."/>
                  <outline text="2. Tap &quot;**Settings**&quot;"/>
                  <outline text="3. Scroll down to the &quot;**Font options**&quot; section." collapsed="true">
                    <outline text="Should be blue text."/>
                  </outline>
                  <outline text="4. Tap on &quot;**Font size**&quot;"/>
                </outline>
                <outline text="What font size to choose" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Small" _note="Recommended (mobile)" heading="3" collapsed="true">
                    <outline text="Mobile: readable links" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Link text cannot wrap-around on mobile, meaning that it&apos;s often hard to see the names of the linked sections with a larger font sizes."/>
                    </outline>
                    <outline text="Less scrolling" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="More can be on screen at once, so you don&apos;t have to scroll around as much."/>
                    </outline>
                    <outline text="Harder to read most text" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="Small text may be harder on eyesight and make things generally harder to read."/>
                    </outline>
                    <outline text="Overwhelming" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Especially on desktop." colorLabel="4"/>
                      <outline text="There can be more on screen at once, which can feel more overwhelming." colorLabel="4"/>
                      <outline text="With less [list density](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wDNhOmGeIN9cu1VLoKMiRH02), this is not so bad." colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="Medium" _note="Recommended (desktop)" heading="3"/>
                  <outline text="Large" heading="3" collapsed="true">
                    <outline text="Easier to read most text" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="Large text is easier on eyesight and easier to read."/>
                    </outline>
                    <outline text="Less overwhelming" heading="3" colorLabel="4" collapsed="true">
                      <outline text="There&apos;s less on screen at once, so it&apos;s less overwhelming." colorLabel="4"/>
                      <outline text="It may be better to achieve this with less [list density](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wDNhOmGeIN9cu1VLoKMiRH02)" colorLabel="1" collapsed="true">
                        <outline text="It may feel less overwhelming to see larger padding between items, rather than larger items." colorLabel="4"/>
                        <outline text="[Link text cannot wrap around on mobile [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fJAL99zn08IjQi4kVk78zQ_t)" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Mobile: unreadable links" heading="3" colorLabel="1" collapsed="true">
                      <outline text="[Link text cannot wrap around on mobile [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fJAL99zn08IjQi4kVk78zQ_t)" colorLabel="4"/>
                    </outline>
                    <outline text="More scrolling" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="Less can be on screen at once, so you have to scroll around a lot more."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Proactive" heading="1" collapsed="true">
              <outline text="Search" heading="3" colorLabel="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Using the Dynalist search feature for this guide."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Looking for part you&apos;ve seen before" heading="3"/>
                  <outline text="Looking up definitions" heading="3"/>
                  <outline text="Looking up advice" heading="3"/>
                  <outline text="Example situations" heading="3" colorLabel="6" collapsed="true">
                    <outline text="You heard someone bring up the [slippery slope fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=q8f2vFegczgxQcWuoRciRil1) and you want to learn what it means."/>
                  </outline>
                </outline>
                <outline text="Method" heading="3" colorLabel="5"/>
              </outline>
              <outline text="Copy" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Copying this doc."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Notes" heading="3" collapsed="true">
                    <outline text="This allows you to easily add notes wherever you want within the guide."/>
                  </outline>
                  <outline text="Crossing out" heading="3" collapsed="true">
                    <outline text="You can add checkboxes or mark items as done directly to cross them out." colorLabel="3"/>
                    <outline text="Could be useful for keeping track of what you&apos;ve read before." colorLabel="2"/>
                  </outline>
                  <outline text="Edits" _note="~Adept" heading="3" collapsed="true">
                    <outline text="Expansion" heading="3" collapsed="true">
                      <outline text="You can add anything that you think would be helpful for you to add to your copy." _note="If you think something would be useful as part of the guide that everyone can get a copy of, contact me." colorLabel="3"/>
                      <outline text="New links" heading="3" collapsed="true">
                        <outline text="You can link any sections together that you think should be linked."/>
                      </outline>
                    </outline>
                    <outline text="Modification" heading="3" collapsed="true">
                      <outline text="You can modify any parts you like, however you think would be best." colorLabel="3"/>
                      <outline text="Definitions" heading="3" collapsed="true">
                        <outline text="You can modify definitions to be more clear for yourself."/>
                      </outline>
                      <outline text="Re-ordering" heading="3" collapsed="true">
                        <outline text="Maybe you want to prioritize things in a different order. In the case you could move items higher/lower in the lists."/>
                      </outline>
                    </outline>
                    <outline text="Deletion" heading="3" collapsed="true">
                      <outline text="You can delete sections that seem unimportant to you." colorLabel="3"/>
                      <outline text="Risky" heading="3" colorLabel="1" collapsed="true">
                        <outline text="While there are undoubtedly going to be sections that are pointless to you, it&apos;s likely that some sections will seem unimportant to you despite being pretty important to you. "/>
                        <outline text="Be careful to check the deletion candidate&apos;s &quot;importance&quot; item to be safe."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Method" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Using the left menu, you can create a copy of this doc/file." _note="Make this much less vague."/>
                </outline>
              </outline>
              <outline text="List density" _note="Recommended for mobile" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The setting that determines the density (compactness) of the list of items in Dynalist."/>
                  <outline text="In other words: it controls how large the areas between the items are."/>
                </outline>
                <outline text="Finding the setting" heading="3" colorLabel="5" collapsed="true">
                  <outline text="1. Tap the **three dots** in the top-right corner."/>
                  <outline text="2. Tap &quot;**Settings**&quot;"/>
                  <outline text="3. Find the &quot;**Appearance**&quot; section at the top." collapsed="true">
                    <outline text="Should be blue text."/>
                  </outline>
                  <outline text="4. Tap on &quot;**List density**&quot;"/>
                </outline>
                <outline text="What list density to choose" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Comfortable" heading="3" collapsed="true">
                    <outline text="Less overwhelming" heading="3" colorLabel="4" collapsed="true">
                      <outline text="There&apos;s less on screen at once, so it&apos;s less overwhelming." colorLabel="4"/>
                    </outline>
                    <outline text="More scrolling" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="Less can be on screen at once, so you have to scroll around a lot more."/>
                    </outline>
                  </outline>
                  <outline text="Cozy" _note="Recommended (desktop)" heading="3"/>
                  <outline text="Compact" _note="Recommended (mobile)" heading="3" collapsed="true">
                    <outline text="Less scrolling" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Especially on mobile."/>
                      <outline text="More can be on screen at once, so you don&apos;t have to scroll around as much."/>
                    </outline>
                    <outline text="More overwhelming" heading="3" colorLabel="1" collapsed="true">
                      <outline text="There&apos;s more on screen at once, so it&apos;s more overwhelming."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Advanced" heading="1" collapsed="true">
              <outline text="Show backlinks" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Method" heading="3" colorLabel="5" collapsed="true">
                  <outline text="In the settings menu." _note="Clarify this."/>
                </outline>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="Reading order" heading="1" colorLabel="6" collapsed="true">
          <outline text="Meta" heading="3" colorLabel="1" collapsed="true">
            <outline text="Colors" heading="3" collapsed="true">
              <outline text="Based on average importance."/>
              <outline text="Only applies to everything inside &quot;Reading order&quot;." collapsed="true">
                <outline text="Except this &quot;colors&quot; section of course, since it is just showing the colors that will be used."/>
              </outline>
              <outline text="Nuances" heading="3" collapsed="true">
                <outline text="Subjects may be more or less important to you specifically."/>
                <outline text="Impacted somewhat by the reading order selected, since things will be more/less important based on how you&apos;re approaching the whole guide."/>
              </outline>
              <outline text=""/>
              <outline text="Absurdly important" colorLabel="1"/>
              <outline text="Extremely important" colorLabel="2"/>
              <outline text="Very important" colorLabel="3"/>
              <outline text="Pretty important" colorLabel="4"/>
              <outline text="Somewhat important" colorLabel="5"/>
              <outline text="Pretty unimportant" colorLabel="6"/>
              <outline text="!!! READ THIS !!!" heading="1" collapsed="true">
                <outline text="This color scheme does NOT apply to sections which are outside of the &quot;Reading order&quot; section but merely __linked__ inside." collapsed="true">
                  <outline text="Eg. The colors in https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CAUurOYjAYcX8-6gqZgbc468 mean [something else](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq)" collapsed="true">
                    <outline text="Any section outside of &quot;Reading order&quot; will use [that color system](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BvA-Ns5nJf2Z5-QHDqubfehq)"/>
                  </outline>
                  <outline text="See [knowing location](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HyzIkypIL116medzP3QCMUyk) to learn how to figure out where you are at any time."/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Methods" heading="3" colorLabel="1" collapsed="true">
            <outline text="Rainbow repetitions" heading="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Starting by only reading the most important sections, then re-reading with less important sections again and again until everything is read."/>
                <outline text="Explicit" heading="3" collapsed="true">
                  <outline text="Starting with just reading the things in the red sections (without the things inside the things in the red sections unless they are also red), then re-reading everything inside the red sections and also orange sections (same nuance as above but for orange now), then everything in red, orange and yellow sections, etc."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Good for better remembering the more important material and really internalizing what you learn."/>
              </outline>
              <outline text="Nuances" heading="3" colorLabel="1" collapsed="true">
                <outline text="It may be better to start by reading red and orange sections, since there probably won&apos;t be much directly inside the red sections."/>
                <outline text="For the final re-read, it may be best not to read the purple sections unless you really think they would be useful."/>
              </outline>
            </outline>
          </outline>
          <outline text="General" heading="3" colorLabel="1" collapsed="true">
            <outline text="You should generally read from the top [main section](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O4GqSyi7g0FcCQGkFXRV75kC) to the bottom one."/>
          </outline>
          <outline text="Read this before following an order" heading="3" colorLabel="2" collapsed="true">
            <outline text="Remember, if you click a link to a section outside of &quot;Reading order&quot;, you probably shouldn&apos;t (unless otherwise instructed like &quot;read everything here&quot;) expand or zoom any further and should just go back a page to return once you finish reading what is immediately visible."/>
          </outline>
          <outline text="Standard order" heading="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2"/>
            <outline text="Order" heading="1" colorLabel="1"/>
          </outline>
          <outline text="Epistemic order" heading="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="An order that starts with axioms and primarily follows the emergence/reasoning that leads to the kinds of reasoning processes we typically do."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Useful for learning act-based reasoning." colorLabel="3"/>
              <outline text="Useful for understanding why certain reasoning processes are used." colorLabel="4"/>
            </outline>
            <outline text="Order" heading="1" colorLabel="1" collapsed="true">
              <outline text="[Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)" heading="1" colorLabel="1" collapsed="true">
                <outline text="Read most of this."/>
              </outline>
              <outline text="[Standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)" heading="1" colorLabel="2"/>
              <outline text="[Probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)" heading="1" colorLabel="2"/>
              <outline text="[Practical techniques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yQVWivooam-CWEWkiSH8D5Gu)" heading="1" colorLabel="2"/>
              <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="1" colorLabel="3"/>
            </outline>
          </outline>
        </outline>
        <outline text="Misc" heading="3" colorLabel="6" collapsed="true">
          <outline text="Objections" heading="3" colorLabel="1" collapsed="true">
            <outline text="There are many unsupported claims." collapsed="true">
              <outline text="1. This guide is unfinished."/>
              <outline text="2. The reasoning that is transparent is usually well-done, indicating that the less-transparent reasoning is likely usually well-done as well. So there is some indirect support for the claims via that fact."/>
            </outline>
            <outline text="This doesn&apos;t account for non-classical logic." collapsed="true">
              <outline text="True, we consider non-classical logics to be absurd and/or redundant." collapsed="true">
                <outline text="[If you&apos;re looking for a reasoning guide based on non-classical logic [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hSc19VuEaob-EgAMRollKVwq)"/>
              </outline>
            </outline>
            <outline text="This guide is missing a lot of very important ideas." collapsed="true">
              <outline text="Likelihood" heading="3" collapsed="true">
                <outline text="Much of this knowledge is a form of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) which people are almost always very bad at." colorLabel="4"/>
                <outline text="In general, more important ideas are easier to find. " colorLabel="1" collapsed="true">
                  <outline text="P1. In general, the more important knowledge (such as reasoning tricks) is, the more generally causally impactful it has to be." collapsed="true">
                    <outline text="P1. Importance in this context refers to wide usefulness."/>
                    <outline text="P2. In general, the more widely useful knowledge is, the more generally causally impactful it has to be (to be more widely useful)."/>
                  </outline>
                  <outline text="P2. And typically the more generally causally impactful something is, the easier it is to discover it." collapsed="true">
                    <outline text="Because there would be more opportunities to discover it, since it is more likely to influence you more often and in more impactful (and thus obvious) ways."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Impact if true" heading="3" collapsed="true">
                <outline text="This guide is very unfinished, over time it will be filled with a lot more important ideas." colorLabel="1"/>
                <outline text="Even if true, it can still be quite helpful to use this guide alongside other resources." colorLabel="1"/>
              </outline>
            </outline>
          </outline>
          <outline text="Other ways to categorize the landscape of reasoning" heading="3" collapsed="true">
            <outline text="Deduction (broad)" _note="Likely move somewhere in the actual guide, and link here." heading="1" colorLabel="5">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The logical process of reasoning from general premises to a conclusion in a &quot;certain&quot; manner."/>
                <outline text="**&quot;certain&quot;:**   Not fully certain. We can make mistakes with our deductive reasoning due to the [semi-reliability of our mental faculties](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b_aWAORb1OU0XVl_fRpRpFsj)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[All reasoning can be reduced to this](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6TylIep-sVpCiTF65ZAxoq0c)" colorLabel="4"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)" heading="2" colorLabel="5"/>
                <outline text="[Probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)" heading="2" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Formal reasoning" heading="1" colorLabel="5" collapsed="true">
              <outline text="[Formal deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zsOpjP92dDsI8MqzcQASsNlD)" heading="1" colorLabel="5"/>
              <outline text="[Formal induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=JkdoJEE2Fv96zEnmDwnRHQOR)" heading="1" colorLabel="4"/>
              <outline text="[Formal fallacies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XMviTTO83AtDTslnBLhUbkTn)" heading="3" colorLabel="2"/>
              <outline text="[Translating natural logic to formal logic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2XSw0DpqJzPwV50bTDS7Do-h)" colorLabel="5"/>
            </outline>
          </outline>
        </outline>
        <outline text="FAQs" heading="3" colorLabel="6" collapsed="true">
          <outline text="What is special about this guide?" collapsed="true">
            <outline text="[Comprehensive material](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FJKT-EyQwhNAz5UGLb-VGk-S)"/>
            <outline text="[Efficient format](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cHXvnvL9lag7l80zyCvqoF9R)"/>
            <outline text="Minimal questionable shortcuts" collapsed="true">
              <outline text="In many guides, things like fallacies will be explained with oversimplified descriptions and proclamations about how to treat them, which can cause people to make severe mistakes." collapsed="true">
                <outline text="Mistake example: there&apos;s a common notion that an &quot;appeal to authority&quot; is always a fallacy, when in fact if the authority is sufficiently relevant, it is not a fallacy and can actually be an important piece of evidence to consider." colorLabel="6"/>
              </outline>
              <outline text="This guide attempts to be very careful with its definitions and its coverage of the topics, to avoid simplifications like that."/>
            </outline>
          </outline>
          <outline text="Why is the format non-linear?" collapsed="true">
            <outline text="It allows people to easily learn specific things more deeply" colorLabel="4" collapsed="true">
              <outline text="Very useful if they have an idea of some of their weaknesses." colorLabel="4"/>
              <outline text="It allows us to make the guide essentially as big as we want, without worrying about people having to read too much to read it or to read particular sections." _note="Likelihood" colorLabel="4" collapsed="true">
                <outline text="[Because it allows us to easily skip/skim less important parts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=m5py-ZBd4JXt_U2ab0deuEbm)" _note="Likelihood" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="It allows people to easily [skip](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lQefzxW-0G800Ba6h4Q6lsoL)/skim less important parts" colorLabel="4" collapsed="true">
              <outline text="At a broad level" heading="3" collapsed="true">
                <outline text="Eg. Skipping propositional logic" colorLabel="6" collapsed="true">
                  <outline text="If you&apos;re already very familiar with it, it&apos;s unlikely you&apos;ll gain much from reading that section." colorLabel="4"/>
                </outline>
                <outline text="Complemented by the interlinked nature of the guide. " colorLabel="4" collapsed="true">
                  <outline text="It typically allows one to skip a broad category without skipping important sub-components of that category." colorLabel="4"/>
                  <outline text="^ Because you can almost always find links to those very important sub-components in the other broad categories." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="At a detailed level" heading="3" collapsed="true">
                <outline text="Eg. Skipping an example" colorLabel="6" collapsed="true">
                  <outline text="Often useful if you already understand the concept well enough." colorLabel="4"/>
                  <outline text="Often possible if you know that non-link purple items are almost always examples." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="It saves time if you already know what you&apos;re skipping." _note="Relevance" colorLabel="4"/>
            </outline>
            <outline text="It helps form useful associations" colorLabel="4" collapsed="true">
              <outline text="By showing people how various things are connected." colorLabel="4"/>
              <outline text="^ Especially in areas that people have decided to learn more thoroughly, since the reading order instructs them to investigate those connections." _note="Link" colorLabel="4"/>
            </outline>
            <outline text="We attempt to mitigate its detriments" colorLabel="4" collapsed="true">
              <outline text="We believe this guide guide (especially [reading tips](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=egDX0-z_anOQr8xolmXO0DTu)) should be able to teach people how to mitigate the detriments of this format." colorLabel="4"/>
            </outline>
            <outline text="It allows for a better reading order" colorLabel="4" collapsed="true">
              <outline text="It better allows us to adjust the reading order, since with a linear format it would typically take a lot more work to adjust the order." colorLabel="4"/>
              <outline text="^ A lot of the required knowledge to read a bunch of paragraphs in a given section would be dependent on understanding a section elsewhere, such that it would be difficult to know what we can move without breaking stuff." colorLabel="4"/>
            </outline>
            <outline text="It makes it easier to include more links" colorLabel="4" collapsed="true">
              <outline text="Since we&apos;re already creating lots of links to make the non-linear format work decently well, we have the practice/knowledge to easily create a lot of links for things like definitions/related sections." _note="Likelihood" colorLabel="4"/>
              <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dvuNaCPXkDDm-gIrfq6DJDLG" _note="Relevance" colorLabel="4" collapsed="true">
                <outline text="**Example:**   It allows people to more easily view relevant definitions." _note="Likelihood" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NdorHkkOSy1uTnsEsONr8RfF"/>
            </outline>
          </outline>
          <outline text="What does &quot;reasoning&quot; mean?" collapsed="true">
            <outline text="Technically, our definition is typically just [forming inferences from premises](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tidBfeMc49cDSByr_ccxguW6)"/>
            <outline text="However the guide is specifically trying to teach how to reason __well__, which might be defined more along the lines of [epistemic rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZcLNKNmVyYYwMjNA5z_NhQs)."/>
            <outline text="There are also a lot of different ways to improve one&apos;s ability to form inferences from premises. So to clarify: This guide is aiming to become a standalone, comprehensive, general resource for all major aspects of reasoning. It covers topics relevant to all experience levels, and all domains where reasoning plays a substantial role."/>
            <outline text="Learn more about our definition [here](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PN-ghKTcl4UlzOcT7GoE4CIs)."/>
          </outline>
          <outline text="Who is this guide for?" collapsed="true">
            <outline text="Primarily for people who are willing to take the time to properly learn general reasoning from the ground up, and who want a practical guide with all the necessary information to learn it."/>
            <outline text="I want to bring it to everyone who&apos;s interested in reasoning, and ideally (though probably not) it (or something like it) could become recognized and become part of standard education to be taught to a ton of people, even those who aren&apos;t as interested in reasoning for its own sake. But until I finish enough of the material and the reading order and stuff (which will likely take a long time, if I ever finish it), I&apos;m mainly hoping to distribute it to people who are already (relatively) very good at reasoning, but who could still improve a lot with the guide."/>
          </outline>
          <outline text="What is the plan for this guide?" collapsed="true">
            <outline text="My plan is to add all of the most important knowledge about reasoning I can find/think of, refine it and organize it well, and then create a reading order that should eventually be able to take people through the sections in an order that can bring them from no knowledge to (if they are willing to go through all the important parts) being capable of much more advanced and consistent reasoning than basically anyone else currently is. "/>
          </outline>
          <outline text="Why isn&apos;t X in this guide?" collapsed="true">
            <outline text="Broad" heading="3" collapsed="true">
              <outline text="The guide is very unfinished. However:"/>
              <outline text="There are a few criteria (in roughly descending order of importance) I use to judge whether to add something to the guide:"/>
              <outline text="^ How impactful is it for reasoning abilities?"/>
              <outline text="^ How easy is the information to derive from other information?" collapsed="true">
                <outline text="Eg. If it&apos;s very easy to derive, I trust that once the reader has properly learned the important sections, they will almost certainly do fine on the topic without a dedicated section. " colorLabel="6" collapsed="true">
                  <outline text="And this guide is designed for people willing to properly learn the important sections."/>
                  <outline text="^ [Primarily for people willing to take the time to learn general reasoning from the ground up](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ntR-jNYuThFory4paR7XDM-n)"/>
                </outline>
              </outline>
              <outline text="^ How well-known is it?" collapsed="true">
                <outline text="If it&apos;s already very well-known, it might not even be worth mentioning."/>
              </outline>
              <outline text="^ How well has it been taught elsewhere?" collapsed="true">
                <outline text="For many important and relevant topics (eg. math), there are likely tons of resources far better than what I would make."/>
                <outline text="So in such cases, I will typically link to a place where it is better taught and perhaps explain relevant things left out of their explanation, like how it [relates to / can be used in] reasoning."/>
              </outline>
              <outline text="^ How time consuming is it to add?"/>
            </outline>
            <outline text="Specific" heading="3" collapsed="true">
              <outline text="Why isn&apos;t there a section on morality?" collapsed="true">
                <outline text="I was very tempted on many occasions to make section(s) dedicated to morality, but in all cases I felt that what I had in mind could either: "/>
                <outline text="^ Be applied in other areas (and thus that morality should be confined to examples)."/>
                <outline text="^ Be reduced to / solved by other things, such that making a section on specifically morality or a moral issue would be unworthwhile." collapsed="true">
                  <outline text="While I think the perfect guide might have a section dedicated to morality, I think it would be difficult to write it in a useful way without making it very contentious and large, and for now I think the benefit in this guide would not be nearly as great as refining other sections which are more fundamental to reasoning."/>
                </outline>
              </outline>
            </outline>
            <outline text="If you feel that I&apos;ve missed something, feel free to contact me on discord. My username is:"/>
            <outline text="ferbalot"/>
          </outline>
          <outline text="Why so few sources?" collapsed="true">
            <outline text="The guide is unfinished, over time many more sources will be added."/>
            <outline text="Often I write sections from scratch, so I have no sources I can easily give."/>
            <outline text="Some of the topics would not benefit from sources." collapsed="true">
              <outline text="Eg. Cases in which all the important material from a source was already put into the guide and the sources are just less organized/efficient, with no other useful content." colorLabel="6"/>
            </outline>
            <outline text="Sometimes the sources are actually present, just in the definition item rather than a source item."/>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[There are many unsupported claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r5WEbuLDvz6bw-Odi_mpZhYG)"/>
            </outline>
          </outline>
          <outline text="Why is X in this guide?" collapsed="true">
            <outline text="This guide is broad" heading="3" collapsed="true">
              <outline text="The guide covers a lot of topics that are relevant to reasoning but often excluded from other reasoning guides."/>
              <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Semantics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lBiODKi3GfA1ljyacnht3gB1)" colorLabel="3"/>
                <outline text="[Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HagLAcGpEX9BhJZv91n3zyH2)" colorLabel="5"/>
              </outline>
            </outline>
            <outline text="Why is [Semantics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R) taught?" collapsed="true">
              <outline text="A huge aspect of cooperative reasoning is effective communication, and that heavily involves being careful about both making and interpreting vague/clear definitions, making good decisions about how long to think/talk about a given problem/point, seeing where people are over-relying on conflations/vague arguments that are ultimately held up with an overreliance on intuition, etc."/>
            </outline>
            <outline text="Why are [Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd) taught?" collapsed="true">
              <outline text="Few guides get into the fundamental axioms that all reasoning (or at least all reasoning in the guide) is supposed to be based upon, and people often disagree or have confusion about axioms."/>
            </outline>
            <outline text="Why are so many abstract things included?" collapsed="true">
              <outline text="In general I think most guides tend to focus too much on immediately obvious reasoning mistakes, rather than the more fundamental errors that are causing people to consistently make such mistakes. We are often taught to recognize and memorize specific fallacies or biases, but not taught about how they arise, what they&apos;re built on or how to effectively combat them."/>
            </outline>
            <outline text="Why include the &quot;[reducible](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=crKQ1NRqMtJGbuYlSAvwU4Aa)&quot; category?" collapsed="true">
              <outline text="To explain how subjects/ideas reduce to other subjects/ideas."/>
              <outline text="^ This helps better understand how the subjects/ideas fundamentally work."/>
              <outline text="^ This allows people to change gears in a discussion when a certain level of abstraction is not working well enough." collapsed="true">
                <outline text="Example: If people are relying on simplified principle like &quot;competition drives innovation&quot; and &quot;extrinsic motivation reduces intrinsic motivation&quot; and arguing for two competing ideas using these principles, it would likely be beneficial to make it clear what the reasoning underlying those peoples&apos; trust in those principles is, and to investigate the strength of the arguments when considering that reasoning, whether the principles should be applied in the relevant scenario, etc." colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Why include the &quot;[common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iihxwN7WEHK0XRVoAKwqGuWm)&quot; importance category?" collapsed="true">
              <outline text="The reason that there is often a &quot;common&quot; category under importance is that if something is common, it is more likely to be relevant to your life in some way."/>
              <outline text="^ There are of course still many exceptions, but I thought it was worth including the category anyway."/>
            </outline>
          </outline>
          <outline text="Why aren&apos;t degrees of relevance/likelihood quantified?" collapsed="true">
            <outline text="It would take more effort to quantify them." colorLabel="1"/>
            <outline text="It would make the format even more alien/confusing to people just getting into it." colorLabel="1"/>
            <outline text="We believe that it&apos;s usually not very improtant to quantify the degree." colorLabel="1" collapsed="true">
              <outline text="We typically trust our unquantified estimates a decent amount and" colorLabel="4"/>
              <outline text="try to clarify the consequences of those estimates in the &quot;how to think of it&quot; sections." colorLabel="4"/>
            </outline>
            <outline text="Despite these reasons, we plan to consider quantifying relevance/likelihood in the future." colorLabel="4"/>
          </outline>
        </outline>
      </outline>
      <outline text="Reasoning" heading="1" colorLabel="2" collapsed="true">
        <outline text="Definition" _note="Fix up" heading="3" colorLabel="3" collapsed="true">
          <outline text="1. Forming inference(s) from premise(s)." collapsed="true">
            <outline text="The process of reasoning."/>
          </outline>
          <outline text="2. The general ability to find important truths and avoid important falsehoods." collapsed="true">
            <outline text="The ability of reasoning."/>
          </outline>
          <outline text="Distinctions" heading="3" colorLabel="3" collapsed="true">
            <outline text="Rationality vs emotions/intuitions" _note="Virtually entirely taken from:   https://www.readthesequences.com/Biases-An-Introduction" heading="3" collapsed="true">
              <outline text="Oftentimes (eg. in a Hollywood movie), being “rational” means that you’re a stern, by-the-book, hyperintellectual stoic." collapsed="true">
                <outline text="Eg. Spock from __Star Trek__, who “rationally” suppresses his emotions, “rationally” refuses to rely on intuitions or impulses, and is easily dumbfounded and outmaneuvered upon encountering an erratic or “irrational” opponent." colorLabel="6"/>
              </outline>
              <outline text="The &quot;rationality&quot; that this guide is concerned with (used synonymously with how the guide uses the term &quot;reasonableness&quot;) is completely different."/>
              <outline text="It is the version studied by mathematicians, psychologists, and social scientists. Roughly, it’s the idea of __doing the best you can with what you’ve got__. A rational person, no matter how out of their depth they are, forms the best beliefs they can with the evidence they’ve got. A rational person, no matter how terrible a situation they’re stuck in, makes the best choices they can to improve their odds of success. "/>
              <outline text="Real-world rationality isn’t about ignoring your emotions and intuitions. For a human, rationality often means becoming more self-aware about your feelings, so you can factor them into your decisions. "/>
              <outline text="Rationality can even be about knowing when __not__ to overthink things. There are some problems where conscious deliberation serves us better, and others where snap judgments serve us better." _note="Likely move some of the children here into system 1 thinking, and link it here." collapsed="true">
                <outline text="When selecting a poster to put on their wall, or predicting the outcome of a basketball game, experimental subjects have been found to perform __worse__ if they carefully analyzed their reasons."/>
                <outline text="^  Timothy D. Wilson et al., “Introspecting About Reasons Can Reduce Post-choice Satisfaction,” __Personality and Social Psychology Bulletin__ 19 (1993): 331–331." colorLabel="6"/>
                <outline text="^  Jamin Brett Halberstadt and Gary M. Levine, “Effects of Reasons Analysis on the Accuracy of Predicting Basketball Games,” __Journal of Applied Social Psychology__ 29, no. 3 (1999): 517–530." colorLabel="6"/>
              </outline>
              <outline text="Psychologists who work on dual process theories distinguish the brain’s “[System 1](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)” processes (fast, implicit, associative, automatic cognition) from its “System 2” processes (slow, explicit, intellectual, controlled cognition). The __stereotype__ is for rationalists to rely entirely on System 2, disregarding their feelings and impulses. Looking past the stereotype, someone who is actually being rational—actually achieving their goals, actually mitigating the harm from their cognitive biases—would rely heavily on System-1 habits and intuitions where they’re reliable. "/>
              <outline text="Unfortunately, System 1 on its own seems to be a __terrible__ guide to “when should I trust System 1?” Our untrained intuitions don’t tell us when we ought to stop relying on them." _note="Move to system 1" collapsed="true">
                <outline text="Being biased and being unbiased __feel__ the same."/>
                <outline text="^  Timothy D. Wilson, David B. Centerbar, and Nancy Brekke, “Mental Contamination and the Debiasing Problem,” in __Heuristics and Biases: The Psychology of Intuitive Judgment__, ed. Thomas Gilovich, Dale Griffin, and Daniel Kahneman (Cambridge University Press, 2002)." colorLabel="6"/>
              </outline>
            </outline>
            <outline text="[&quot;Winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDxHpzr99Ib8E5XfGJAHVTzK)" heading="3" colorLabel="2" collapsed="true">
              <outline text="In most important cases, your ability to &quot;win&quot; is not very indicative of your reasoning abilites." colorLabel="1" collapsed="true">
                <outline text="Most important debate &quot;winning&quot; is decided quite irrationally." colorLabel="4" collapsed="true">
                  <outline text="[Most people are bad at a large portion of important reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FQOqkxT7w7JVXNILiTfqfVSZ)" colorLabel="4"/>
                  <outline text="&quot;Winning&quot; is decided by things like what people generally think the conclusion was." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="[Persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)" heading="3" colorLabel="2" collapsed="true">
              <outline text="In most important cases, how well you can convince people of your points is not very indicative of your reasoning abilities." colorLabel="1" collapsed="true">
                <outline text="Most people are (in important matters) persuaded to a substantial degree by factors that don&apos;t have to do with reasoning." colorLabel="4" collapsed="true">
                  <outline text="Most people are bad at a large portion of important reasoning." colorLabel="4" collapsed="true">
                    <outline text="Most people are bad at &quot;soft&quot; reasoning" _note="Broken link"/>
                    <outline text="[&quot;Soft&quot; reasoning makes up a large portion of important reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9tq0nu1KebS2pKlxYbgP9dvS)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="[Articulation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eYwYVI-Ab8uN2sjZJEi6AKDx)" heading="3"/>
            </outline>
            <outline text="Debating abilities" heading="3" collapsed="true">
              <outline text="Ability to shut down opponents" collapsed="true">
                <outline text="In most important cases, how well you can shut down other(s) is not very indicative of your reasoning abilities." colorLabel="1" collapsed="true">
                  <outline text="In most kinds of important cases, people often aren&apos;t shut down by good reasoning and often are shut down by bad reasoning." colorLabel="4" collapsed="true">
                    <outline text="[Most people are bad at a large portion of important reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FQOqkxT7w7JVXNILiTfqfVSZ)" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Ability to leave opponents flustered" collapsed="true">
                <outline text="In most important cases, how well you can leave other(s) flustered is not very indicative of your reasoning abilities." colorLabel="1" collapsed="true">
                  <outline text="In most kinds of important cases, people often aren&apos;t shut down by good reasoning and often are shut down by bad reasoning." colorLabel="4" collapsed="true">
                    <outline text="[Most people are bad at a large portion of important reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FQOqkxT7w7JVXNILiTfqfVSZ)" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="[Persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7207XT-WQ4EQ-nDUBEsR1_hf)" heading="3" colorLabel="2"/>
              <outline text="[&quot;Winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDxHpzr99Ib8E5XfGJAHVTzK)" heading="3" colorLabel="2"/>
            </outline>
            <outline text="Articulation" heading="3" collapsed="true">
              <outline text="In most important cases, your ability to articulate your points is not very indicative of your reasoning abilities." colorLabel="1" collapsed="true">
                <outline text="In most kinds of important cases, articulation has to do more with practice, vocabulary, knowledge of the subject, etc." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Calculation speed" _note="Clarify what &quot;irreducible calculation speed&quot; means, and what calculation speed overall means." heading="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Calculation speed has a decent effect on reasoning." colorLabel="4"/>
              <outline text="Different people don&apos;t really have much of a difference between irreducible calculation speeds." colorLabel="1" collapsed="true">
                <outline text="The apparent differences are typically due to other things." colorLabel="4" collapsed="true">
                  <outline text="Ability to focus" heading="3" collapsed="true">
                    <outline text="Focus has a significant effect on apparent irreducible calculation speed." colorLabel="4" collapsed="true">
                      <outline text="More focus = more efficient usage of irreducible calculation speed." colorLabel="4"/>
                    </outline>
                    <outline text="Different people have different amounts of [mental stamina](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GcRDuicbl_3OrCk3NrMQs3Tz)" colorLabel="4"/>
                    <outline text="People have varying degrees of ability to focus." colorLabel="4" collapsed="true">
                      <outline text="ADHD is notorious for its tendency to make focusing much harder." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Memory" heading="3" collapsed="true">
                    <outline text="Short-term" heading="3" collapsed="true">
                      <outline text="Better short-term memory makes it significantly easier to reason about remotely complicated things." colorLabel="4" collapsed="true">
                        <outline text="Forgetting important things mid-discussion often forces a person to pause and try to recall those important things before they can continue, making it seem like their irreducible calculation speed is slower." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Long-term" heading="3" collapsed="true">
                      <outline text="Better long-term memory often makes it significantly easier to reason about things that you&apos;re familiar with, since you can utilize much more reasoning that you&apos;ve done in the past." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Well-trained [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) / Good [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="3" collapsed="true">
                    <outline text="When it is well-trained, it performs common reasoning processes very quickly and leaves our conscious reasoning to calculate higher-level things." colorLabel="3" collapsed="true">
                      <outline text="This is a kind of typical pattern-recognition." colorLabel="3" collapsed="true">
                        <outline text="So not the kind of calculation we typically imagine." colorLabel="4"/>
                        <outline text="It might still be regarded as calculation." colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="[Knowledge](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4RAjpCpCOo-xNe3znmmRs-YM)" heading="3" collapsed="true">
                    <outline text="General" heading="3" collapsed="true">
                      <outline text="General knowledge makes us much more able to have and use more information for calculation in many situations." colorLabel="4" collapsed="true">
                        <outline text="This often saves a lot of time that would otherwise be used researching things." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Specific" heading="3" collapsed="true">
                      <outline text="More specific knowledge relevant to the matter one is calculating saves time." colorLabel="4" collapsed="true">
                        <outline text="[This often saves a lot of time [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GTyHNpC8eI6kwetqFluNb9Z8)" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="[Debating abilities](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FLRdcIuNfUwnjM8vsQ0euzuo)" heading="3" collapsed="true">
                    <outline text="debating abilities have more to do with things that don&apos;t involve as much calculation." colorLabel="4" collapsed="true">
                      <outline text="The above link shows this. " colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="[Articulation]()https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eYwYVI-Ab8uN2sjZJEi6AKDx)" heading="3" collapsed="true">
                    <outline text="Vocabulary" heading="3" collapsed="true">
                      <outline text="A kind of [knowledge](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_KNIB7_5cS9BEuEIDsyEIIxm) so not really calculation." colorLabel="4"/>
                      <outline text="Allows for more accurate and easy expression, which makes articulation easier." colorLabel="4"/>
                    </outline>
                    <outline text="[System 1 thinking that&apos;s well-trained](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_xkyjTK9hy21ZgL6iASfk1ml) for articulation."/>
                  </outline>
                </outline>
              </outline>
              <outline text="In many important topics, the average amount of [close mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=z7LAOrlY0wVUk3aV25kvfWZe) makes virtually any realistic calculation speed insufficient to reason well." colorLabel="1"/>
            </outline>
            <outline text="Ability to focus" heading="3"/>
            <outline text="Knowledge" heading="3" collapsed="true">
              <outline text="General" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Knowledge in general / about important topics."/>
                </outline>
                <outline text="In most important cases, your knowledge is not very indicative of your reasoning abilities." colorLabel="1"/>
              </outline>
              <outline text="Specific" heading="3"/>
            </outline>
            <outline text="Memory" heading="3" collapsed="true">
              <outline text="Long-term" heading="3" collapsed="true">
                <outline text="[It&apos;s generally not much better than using notes [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mu2SI1H1yVZEl3TXSSNjJTHe)" colorLabel="1"/>
              </outline>
              <outline text="Short-term" heading="3" collapsed="true">
                <outline text="In most important cases, your memory is not very indicative of your reasoning abilities." colorLabel="1"/>
                <outline text="Even if it would often have a significant impact on reasoning abilities, it isn&apos;t nearly as important as reasoning abilities." colorLabel="1" collapsed="true">
                  <outline text="It&apos;s generally not much better than average quick-recollection abilities with [notes] and access to those notes, which one should virtually always have when reasoning about important things." _note="Link to notes section once it&apos;s available." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Being able to quickly recall a lot of relevant information."/>
              </outline>
            </outline>
            <outline text="Practice" heading="3"/>
            <outline text="IQ" heading="3" collapsed="true">
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="[Calculation speed](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HckyO_WwLL6dU5BLMkmlbOtT)" heading="3"/>
                <outline text="[Short-term memory](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kkI62VWIhD2gZtu0aH0hPSt3)" heading="3"/>
                <outline text="[Ability to focus](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LCFAG0tNkTDGO-PItGBsoiFN)" heading="3"/>
                <outline text="Motivation" heading="3"/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="Importance" heading="3" colorLabel="2">
          <outline text="Impactful" _note="Move out of impactful" heading="3" collapsed="true">
            <outline text="Deciding broad goals" heading="3" colorLabel="4" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="A form of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" heading="3"/>
            </outline>
            <outline text="[Cost of misunderstandings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1qtW0Q9lO1KZeMzP6UFlafQo)" heading="3" colorLabel="4" collapsed="true">
              <outline text="Irrationality (even to a degree that applies to the vast majority of people) tends to cause a ton of big misunderstandings." _note="Relevance" colorLabel="4"/>
            </outline>
            <outline text="[Decision-making about emotional well-being](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0fHpNJhj0qWSJZBZu6oJ79uV)" heading="3" colorLabel="4" collapsed="true">
              <outline text="Reasoning helps [decision making about emotional well-being](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0fHpNJhj0qWSJZBZu6oJ79uV) in a more effective manner." _note="Relevance" colorLabel="4"/>
              <outline text="Friend/partner decisions" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Decisions about what friend(s)/partner(s) to try to be with or separate from."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true"/>
                <outline text="People tend to be very irrational about it." _note="Relevance | Likely move to section for &quot;friend/partner decisions&quot; that isn&apos;t specific to &quot;decision-making about emotional well-being&quot;, so it can be reused for its sibling sections in other value metrics." colorLabel="4" collapsed="true">
                  <outline text="Evolutionarily designed irrationality" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A thing which we were naturally selected to be bad at reasoning about."/>
                    </outline>
                  </outline>
                  <outline text="A form of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" heading="3" collapsed="true">
                    <outline text="[People are bad at &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qarhXHvwcgUN1n5fnt5sFXck)"/>
                  </outline>
                  <outline text="Trained irrationality" heading="3" collapsed="true">
                    <outline text="Culturally encouraged irrationality" collapsed="true">
                      <outline text="Culturally-encouraged [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)"/>
                      <outline text="Culturally encouraged over-reliance on [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" collapsed="true">
                        <outline text="Culturally encouraged over-reliance on emotions " collapsed="true">
                          <outline text="&quot;Just follow your heart&quot;"/>
                        </outline>
                      </outline>
                      <outline text="[Evolutionarily designed irrationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4VmWGkXliQiks1LAALjryOpG)"/>
                    </outline>
                  </outline>
                  <outline text="We likely have bad resources about it" heading="3" collapsed="true">
                    <outline text="[Culturally encouraged irrationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Jt6KWZMZyq3ctUAaax8_Au2H)"/>
                    <outline text="[It&apos;s a form of &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=o4XX1ICWLTZc9o_M0ZMhElxV)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Education/career decisions" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                <outline text="Deciding on an education/career path is very impactful to your emotional well-being." _note="Relevance" colorLabel="4"/>
              </outline>
              <outline text="Financial decisions" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                <outline text="[Pleasure minus suffering] per money" _note="Relevance | Link or something probably. | Edit to make it make sense" heading="3" colorLabel="4"/>
                <outline text="Broad" heading="1"/>
                <outline text="Specific" heading="1"/>
              </outline>
              <outline text="Child decisions" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Decisions about your potential child(ren)."/>
                </outline>
                <outline text="Whether to have them" heading="1"/>
                <outline text="Whether to adopt" heading="1"/>
                <outline text="When to get them" heading="1"/>
                <outline text="How to raise" heading="1"/>
                <outline text="General" heading="1" colorLabel="6"/>
                <outline text="Decisions regarding children tend to involve a very large potential increase and decrease of emotional well-being." _note="Relevance" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Importance of reliable reasoning" heading="3" colorLabel="4" collapsed="true">
              <outline text="Unreliable reasoning is especially problematic in the context of large reasoning pyramids." _note="Likelihood" colorLabel="4" collapsed="true">
                <outline text="Large reasoning pyramids [are already unstable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PaYOtA9twsXFp_ky5_wJ02cH), so unreliable reasoning becomes even more unreliable in that context." _note="Likelihood" colorLabel="4"/>
                <outline text="It&apos;s common for us to heavily rely on large reasoning pyramids." _note="Relevance | Link to relevant reasoning pyramid importance section." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Hidden" heading="3" colorLabel="6" collapsed="true">
              <outline text="Moral/axiological reasoning" heading="3" collapsed="true">
                <outline text="A form of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" collapsed="true">
                  <outline text="[People are bad at &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7SsiX1YEVBoQ7nJN13LxPAbY)"/>
                </outline>
              </outline>
              <outline text="Deciding broad values" _note="Expand" heading="3" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="All value (subjective or objective) must emerge from intrinsically valuable things."/>
                </outline>
                <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                  <outline text="[Moral/axiological reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Hl4a_G2Jwbo_EnVZaaRg12lX)" heading="3"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Improvable" heading="3" colorLabel="4">
            <outline text="As behavioral economist Dan Ariely notes: we’re __predictably__ irrational. We screw up in the same ways, again and again, syste­ma­tically. If we can’t use our gut to figure out when we’re succumbing to a cognitive bias, we may still be able to use the sciences of mind." _note="Organize"/>
            <outline text="Currently bad" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
              <outline text="&lt;link to people being not great at soft reasoning&gt;" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                <outline text="The prior probability that you&apos;re more reasonable than the vast majority of people is quite low." _note="Relevance" colorLabel="4"/>
                <outline text="^ So the posterior probability is probably pretty low as well." _note="Relevance" colorLabel="4"/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
          <outline text="An extremely useful but deceptively difficult thing."/>
        </outline>
        <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
          <outline text="All reasoning can be reduced to [deduction (broad)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-n8BacOsj9yIbpLxsbz4df8M)" heading="3" colorLabel="4" collapsed="true">
            <outline text="Probabilistic/non-probabilistic dichotomy argument" heading="3" colorLabel="4" collapsed="true">
              <outline text="P1. All non-probabilistic reasoning is a form of deduction. | P → Q (p)" colorLabel="4" collapsed="true">
                <outline text="P1. All non-probabilistic reasoning can be reduced to [standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)" colorLabel="4"/>
                <outline text="P2. Standard deduction is a subset of deduction (broad)." colorLabel="4"/>
              </outline>
              <outline text="P2. All probabilistic reasoning [can be reduced to deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=shgVf32T8JinVWc0u-xf8ZtY) | R → Q (p)" colorLabel="4"/>
              <outline text="P3. All reasoning must be probabilistic or non-probabilistic. | P v R (p)" colorLabel="4" collapsed="true">
                <outline text="The [negation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Fn48qj62GIJ1QrISLDjPhqnc) of &quot;probabilistic&quot; is &quot;non-probabilistic&quot;." colorLabel="4"/>
                <outline text="[Excluded Middle](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=50yUI8YjZZnsIqPMR80s9hep)" colorLabel="4"/>
              </outline>
              <outline text="C. All reasoning must be a form of deduction. | Q (P1,P2,P3 [vE](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vXHh-RchhugkRBUD155IgO4F))" colorLabel="4"/>
            </outline>
            <outline text="Simplicity argument" heading="3" colorLabel="4" collapsed="true">
              <outline text="It&apos;s simpler to suppose that all reasoning derives from only a small subset of rules, which deduction seems to describe and allow for." colorLabel="4"/>
            </outline>
            <outline text="Via logic argument" heading="3" colorLabel="4" collapsed="true">
              <outline text="P1. All reasoning [can be reduced to logic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AbNaVbQdlvY2B3giwwf9Ej7N)" colorLabel="4"/>
              <outline text="P2. Deduction (broad) is entirely describable with logic." colorLabel="4"/>
              <outline text="C. Therefore all reasoning can be reduced to deduction (broad). (P1,P2)" colorLabel="4"/>
            </outline>
          </outline>
          <outline text="All reasoning can be reduced to logic" heading="3" colorLabel="4" collapsed="true">
            <outline text="&lt;Argument about how any reasoning not being reducible to logic would cause a contradiction given the recommended axioms.&gt;" colorLabel="4"/>
          </outline>
        </outline>
        <outline text="Axioms" heading="1" colorLabel="5" collapsed="true">
          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
            <outline text="Foundational beliefs which lack epistemic justification or are justified [circularly](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ll7iV-XLg_ynG7p4yWT34KAu)." collapsed="true">
              <outline text="**Foundational:**   Plays a significant role in the relevant epistemology(s)."/>
            </outline>
            <outline text="**Usually:**   Justifies a ton of other beliefs (often indirectly)."/>
            <outline text="**Usually:**   Commonly held."/>
            <outline text="**Examples:**   [Specific axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=DUl4hPw0aFpUvSp0yEx5SgPT)" colorLabel="6"/>
          </outline>
          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
            <outline text="Knowing axioms substantially helps with reasoning" heading="3" colorLabel="4" collapsed="true">
              <outline text="Understanding axioms allows one to shift to slower but **more reliable reasoning**." colorLabel="4" collapsed="true">
                <outline text="Understanding axioms and how they build up to higher levels of reasoning allows us to use a lower level of reasoning when a higher one is brought into question." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Lower/higher level definition" _note="Move all of this to definitions section." heading="3" colorLabel="3" collapsed="true">
                    <outline text="Lower/higher level of abstraction from pure logic."/>
                    <outline text="^ **Low-level reasoning** is reasoning done close to the level of pure logic." collapsed="true">
                      <outline text="**Example:**   Symbolic logic" _note="Create and link section" colorLabel="6"/>
                      <outline text="^ **Definition:**   Symbolic logic is a branch of formal logic that uses mathematical symbols, variables, and operators to represent logical expressions and relationships explicitly." colorLabel="3"/>
                    </outline>
                    <outline text="^ **High-level reasoning** is reasoning that&apos;s highly abstracted/emergent from the level of pure logic." collapsed="true">
                      <outline text="It&apos;s entirely reducible to pure logic." colorLabel="3"/>
                      <outline text="It has many short-cuts and functions that make it far easier to work with for everyday matters where precision is not super important." colorLabel="4"/>
                      <outline text="It tends to be far more ambiguous than low-level reasoning." colorLabel="1" collapsed="true">
                        <outline text="&lt;Consequences of misunderstandings&gt;" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="^ **Pure logic** is ..."/>
                  </outline>
                  <outline text="This allows for more resolutions of disagreements." colorLabel="4" collapsed="true">
                    <outline text="Cases where people agree (at least technically) about the relevant axioms" heading="3" collapsed="true">
                      <outline text="Understanding axioms and how they build up to higher levels of reasoning frequently allows for being able to systematically reason through a disagreement with someone when it would not otherwise be possible. So long as all the most impactful information can be shared." colorLabel="4" collapsed="true">
                        <outline text="[Information exchange limit](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uEaZcmGBfWucfZDX4My1zNhq)" _note="Likelihood" colorLabel="1" collapsed="true">
                          <outline text="We can&apos;t exchange information with other people efficiently enough to reason through a disagreement, even when understanding and agreeing on axioms." _note="Relevance" colorLabel="4"/>
                        </outline>
                        <outline text="The relevant axioms are generally not agreed upon." _note="Likelihood" colorLabel="1" collapsed="true">
                          <outline text="**Example:**   [Cases where people consciously disagree (at least technically) about the relevant axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=aRml1nvvK4ApEDb2GXoGMYIZ)" colorLabel="6"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Cases where people consciously disagree (at least technically) about the relevant axioms" heading="3" collapsed="true">
                      <outline text="Often when people consciously disagree about axioms, they still subconsciously disagree. So it is still theoretically possible to resolve the disagreement by showing them how they subconsciously rely on the same axioms." colorLabel="4" collapsed="true">
                        <outline text="This is usually infeasible due to how common a high level of [close-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr) is." colorLabel="1"/>
                      </outline>
                      <outline text="Being able to use a lower level of reasoning can often be very helpful even in cases where people even subconsciously disagree on the axioms." colorLabel="4" collapsed="true">
                        <outline text="Even if they don&apos;t agree on the specific axioms, they probably agree on most if not all of the relevant principles built not more then a few levels above those axioms, and those principles are part of how axioms build up to typical reasoning." colorLabel="4" collapsed="true">
                          <outline text="[This applies even when the lower level(s) of reasoning are not axiomatic.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ZMSRvi3uMATIOcUXniVzUp37)" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="This applies even when the lower level(s) of reasoning are above axioms." colorLabel="4" collapsed="true">
                    <outline text="Understanding axioms gives us a better intuition for how reasoning builds up in general, even at a high-level." _note="I&apos;m a little skeptical of this, unsure." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="This applies even when the supposed axioms in question are not the axioms one really accepts." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Even if these axioms are not accepted, the ones that are accepted will probably be de-facto accepted in such a way that they support all the main common reasoning principles in deduction and induction (and in turn virtually everything else)." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="We typically choose/modify our axioms with the intent of keeping our reasoning principles in-tact." _note="Likelihood" colorLabel="4"/>
                    <outline text="^ Our fundamental reasoning principles are almost always essentially equivalent or reducible to the fundamental reasoning principles in deduction and induction." _note="Likelihood | Link to a &quot;common sense&quot; section or something." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Axioms allow us to better avoid overly [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" colorLabel="4" collapsed="true">
                <outline text="Understanding axioms and how they build up to higher-level reasoning allows us to default to a deeper level of reasoning when there is sufficient evidence of our [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) being insufficiently reliable for the relevant case(s)." _note="Likelihood" colorLabel="4"/>
                <outline text="^ Unless we accept [circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_), axiom(s) must underlie all reasoning." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="[Gödel&apos;s incompleteness theorems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LUzSkKXZ4EfIFAKz5YFjBroE)" _note="Likelihood" heading="3" colorLabel="4"/>
                  <outline text="If axiom(s) must underlie all reasoning, then understanding them and how they build up to higher-level reasoning would necessarily give us a lower/deeper level to default to." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="**Common:**   With the rare exceptionof those who accept [non-axiomatic circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0DXdYOjFnNHS8xtYxVsGa0Ro), everyone holds some axiom(s)." colorLabel="4" collapsed="true">
              <outline text="[Unless we accept circular reasoning, axiom(s) must underlie all reasoning.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-jvgPdcXr3P7QdiziXf6BMOQ)" colorLabel="4"/>
            </outline>
            <outline text="**Knowing axioms ≠ reasonable:**   Even if you understand axioms very well, it is still very possible to be very unreasonable." colorLabel="1" collapsed="true">
              <outline text="For example via [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" _note="Likelihood" colorLabel="4" collapsed="true">
                <outline text="Eg. If one uses very simplistic heuristics to determine when they should stop using said heuristics, and the heuristics promote using heuristics in virtually all cases, it may be infeasible to get them to think at a lower level to properly check their reasoning." colorLabel="4"/>
              </outline>
              <outline text="For example via [close-minded close-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=g6oCGh3-jkvcVnp1kIMGHAZ7)" _note="Likelihood" colorLabel="4" collapsed="true">
                <outline text="If one is too overconfident, they may consider it a waste of time to check their reasoning at a lower level, resulting in it never (or very rarely) being checked, preventing them from improving even if they have a good understanding of axioms." colorLabel="4"/>
              </outline>
            </outline>
          </outline>
          <outline text="Specific axioms" heading="1" colorLabel="5" collapsed="true">
            <outline text="The laws of thought" heading="1" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The set of three laws: identity, contradiction and excluded middle."/>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Typically synonymous with the &quot;laws of logic&quot;."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Laws that are generally regarded as underlying all reasoning."/>
              </outline>
              <outline text="Identity" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="All [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) are equivalent to themselves."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Often considered to underlie everything except other axioms." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="All reasoning relies on propositions being equal to themselves, otherwise they could be different from themselves at any point."/>
                  <outline text="Anti-circularity specific" heading="3" collapsed="true">
                    <outline text="Any attempt to justify the law of identity must implicitly rely on its propositions being equal to themselves, thus dooming the attempts to be circular at best."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Contradiction" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="No [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) can be both true and untrue."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Often considered to underlie everything except other axioms." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="The principle of explosion" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The law according to which any statement can be proven from a contradiction."/>
                      <outline text="The implication is typically that accepting any contradiction is absurd."/>
                      <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Principle_of_explosion)"/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="This principle doesn&apos;t apply to [paraconsistent logic](https://en.wikipedia.org/wiki/Paraconsistent_logic)" colorLabel="1" collapsed="true">
                        <outline text="This guide is based on [classical logic](https://en.wikipedia.org/wiki/Classical_logic), not paraconsistent logic." colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Anti-circularity specific" heading="3" collapsed="true">
                    <outline text="Any attempt to justify the law of contradiction must implicitly rely on its propositions not entailing any contradictions, thus dooming the attempts to be circular at best."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Excluded middle" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="All [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) must either be true or false."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Often considered to underlie everything except other axioms." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Given the other laws of thought and modus ponens, it appears to be possible to derive the law of excluded middle and unnecessary to accept it as an axiom." _note="Link or move proof from elsewhere" colorLabel="1"/>
                  <outline text="However if we do not accept one of: [[identity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QNeZxWHbe7v-UYKBxTdg2LFx), [contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=f0OtGrGk9iM-Ry2mQ04gpGKG), [modus ponens works](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=k3emDCQzI6x381obzDk2UWqL)], then we can either accept it as an axiom, or reject it and potentially face some issues."/>
                  <outline text="^ Without the law of excluded middle, we need a method to separate which [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) can be neither true nor false, and which can&apos;t." collapsed="true">
                    <outline text="If we don&apos;t have this method, then:"/>
                    <outline text="For any well-defined proposition, we could say &quot;how do we know that this is true or false? It could be neither.&quot;"/>
                    <outline text="This would allow all well-defined propositions to escape the perview of reasoning, leaving us with no means to reason about anything."/>
                  </outline>
                  <outline text="However if we come up with a method, then it seems like we have other issues." collapsed="true">
                    <outline text="It seems unclear how to justify such a method without using itself (because of the aforementioned problem of any [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) possibly being neither true nor false, including the method), so it seems like we must use [circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_) to justify it."/>
                    <outline text="However circular reasoning tends to pose issues." _note="Read the circular reasoning (circularity) section for more details. Just click the &quot;circular reasoning&quot; link above to visit it."/>
                  </outline>
                </outline>
                <outline text="Alternative" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Negation as failure" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Synonym: NAF" heading="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Modus ponens works" _note="Likely replace this" heading="1" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="If [if x then y] and x, then y."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Often considered to underlie everything except other axioms." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Without accepting that modus ponens works (or something similar) as an axiom, it seems we are unable to engage in logical inference." colorLabel="4" collapsed="true">
                  <outline text="If only the other axioms listed here are presupposed, then it seems like we are unable to justify modus ponens without using modus ponens." colorLabel="4" collapsed="true">
                    <outline text="Using modus ponens to justify modus ponens would involve [circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_)." colorLabel="4" collapsed="true">
                      <outline text="If we accept a type of logic that allows for circular reasoning, it is [unclear](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Y3lxgSPd1iSGFrv4gcsKYHsK) why it should be allowed in this case but not in other cases that one would (ostensibly) not accept." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Isn&apos;t modus ponens an [inference rule](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MtLuLLSMtth4OOhFXZZJyyKb) rather than an axiom?" heading="3" colorLabel="5" collapsed="true">
                <outline text="Modus ponens is an inference rule, however the claim that it works is a proposition that can be treated largely like any other, including being considered an axiom."/>
              </outline>
            </outline>
            <outline text="Principle of induction" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The principle that a higher number of cases of association will increase the probability of a fresh association." _note="Clarify to what degree the probability increases and what exactly this means."/>
                <outline text="Examples" _note="Provide non-event based examples if applicable." heading="3" colorLabel="6" collapsed="true">
                  <outline text="We experience the sun rising many times, therefore we are more likely to experience the sun rising again then we would otherwise be."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Law_of_thought#The_Problems_of_Philosophy_(1912))" heading="3"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Supports [probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)" heading="3" colorLabel="4"/>
              <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Anti-circularity specific" heading="3" collapsed="true">
                  <outline text="The problem of induction" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The problem that there is no non-circular way to justify inductive [inferences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ua8jzU8x2DrWQ46H4Rz65bfj)"/>
                    </outline>
                    <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Problem_of_induction)" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Alternative" heading="3" colorLabel="2" collapsed="true">
                <outline text="Sometimes people presuppose the principle of uniformity and derive the principle of induction, rather than the other way around."/>
              </outline>
            </outline>
            <outline text="Semi-reliability of mental faculties" heading="1" colorLabel="6" collapsed="true">
              <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Your own conscious reasoning mental faculties are semi-reliable."/>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Different from the idea that everyone&apos;s conscious reasoning mental faculties are semi-reliable, this is just about your own conscious reasoning mental faculties."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="**Common:**   Often considered to underlie everything except other axioms." colorLabel="4"/>
                <outline text="**Reasoning specific:**   Non-reasoning mental faculties can still be less than semi-reliable." colorLabel="1" collapsed="true">
                  <outline text="**Example:**   [System 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" _note="Likelihood" colorLabel="4"/>
                </outline>
                <outline text="**Limited reliability:**   Reasoning mental faculties can still be unreliable to a substantial extent." colorLabel="1" collapsed="true">
                  <outline text="We can still often be wrong for reasons we never considered." _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Any attempt to justify the semi-reliability of our mental faculties must implicitly rely on our reasoning being semi-reliable, which implicitly relies on the semi-reliability of the mechanism(s) responsible for that reasoning, which are by definition our mental faculties. Thus dooming the attempts to be circular at best."/>
                <outline text="^ Thus we would have to use [circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_) to justify this, and circular reasoning tends to lead to issues." _note="See linked section for details."/>
                <outline text="Anti-circularity specific" heading="3"/>
              </outline>
            </outline>
            <outline text="Cogito" _note="Needs a lot more work." heading="1" colorLabel="2" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="There are multiple subtly different variations/interpretations of the cogito, but they&apos;re all roughly based on the idea of &quot;I think, therefore I am&quot;."/>
                <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Cogito, ergo sum"/>
                  <outline text="I think, therefore I am"/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="One of the most common beliefs considered to be at the foundation of one&apos;s epistemology." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="At least in [argument form](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=SzQXXOBPHpRDjzpcv7Lcl66B) (as it is often understood), [it appears to be misleading about how axioms work](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gQgtUg9J0XHH3ajcYY8h49vq)." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Full argument version" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The axiom that the argument: &quot;I think, therefore I am&quot; is sound."/>
                  <outline text="&quot;I think&quot; is a premise, &quot;I am&quot; is the conclusion."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Just-conclusion version of the cogito](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ZQ-Su6jH0Wl9HVLphQE3nZZQ)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Just-conclusion version" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The axiom that the argument: &quot;I think, therefore I am&quot; has a true conclusion."/>
                  <outline text="&quot;I think&quot; is a premise, &quot;I am&quot; is the conclusion."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="This seems to be misleading about how axioms work." colorLabel="1" collapsed="true">
                      <outline text="The argument really appears to be based on premises that are not normally deep down accepted as axioms." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Possible implied premises" heading="3" colorLabel="5" collapsed="true">
                  <outline text="If something thinks, then it must exist." heading="3" collapsed="true">
                    <outline text="Why?"/>
                    <outline text="^ It is self-evident." _note="Create a definition for &quot;self-evident&quot; and link it here." colorLabel="4" collapsed="true">
                      <outline text="As intuitive as it seems, it doesn&apos;t seem like it&apos;s truly self-evident."/>
                      <outline text="For example the statement below has the same structure:"/>
                      <outline text="&quot;If x does not exist, then x must exist.&quot;" colorLabel="6"/>
                      <outline text="And yet would not generally be considered true for obvious reasons."/>
                      <outline text="So why is &quot;if something thinks, then it must exist&quot; true, when the above example is not?"/>
                      <outline text="It seems like there must be __some__ kind of answer here, and that this answer would justify the &quot;if thinks then exists&quot; statement."/>
                      <outline text="If this is the case, it&apos;s difficult to see how it&apos;s **self**-evident, seeing as its evident-ness comes from something outside of itself."/>
                    </outline>
                  </outline>
                  <outline text="[Modus ponens works](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=k3emDCQzI6x381obzDk2UWqL)" heading="3"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Axiom systems" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Collections of axioms."/>
            </outline>
            <outline text="How to select an axiom system" heading="3" colorLabel="2" collapsed="true">
              <outline text="Typically, people select an axiom system based on the following principles:"/>
              <outline text="Minimal axioms" heading="3" collapsed="true">
                <outline text="No unnecessary axioms if it can be helped." colorLabel="3"/>
                <outline text="Why isn&apos;t this an axiom?" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Why don&apos;t we treat this essentially like an axiom?" colorLabel="3"/>
                    <outline text="Eg. &quot;If it can be justified, then it is not necessarily true&quot;." colorLabel="6"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Matches irreducible intuitions" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The axiomatic system appears to match our most fundamental reasoning intuitions."/>
                  <outline text="Fundamental reasoning intuitions (definition)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="What we would refuse to stop believing regardless of the evidence presented to us." _note="At least unless that evidence convinced us for non-evidential reasons, such as causing an emotional reaction that irrationally changes our mind. This doesn&apos;t account for that."/>
                  </outline>
                  <outline text="Example" heading="3" colorLabel="6"/>
                </outline>
                <outline text="Why accept this?" heading="3" colorLabel="1" collapsed="true">
                  <outline text="It doesn&apos;t seem justified to trust our intuitions (even our most irreducible ones)." colorLabel="1" collapsed="true">
                    <outline text="We should likely not trust our intuitive distrust of this principle." colorLabel="1"/>
                    <outline text="^ To be intuitively opposed to trusting our most irreducible intuitions is likely essentially equivalent to being intuitively opposed to a stronger intuition." colorLabel="4" collapsed="true">
                      <outline text="P1. These intuition of distrust must (to the extent that it is justified by any sort of reasoning) be based on some kind of reasoning that is ultimately justified by our axioms."/>
                      <outline text="P2. Our axioms are in turn likely partially derived from our irreducible intuitions."/>
                    </outline>
                  </outline>
                  <outline text="Essentially all reasoning necessarily relies on irreducible intuitions." _note="Justify" colorLabel="4"/>
                </outline>
                <outline text="Why isn&apos;t this an axiom?" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Why don&apos;t we treat this essentially like an axiom?" colorLabel="3"/>
                    <outline text="Eg. &quot;What matches our irreducible intuitions must necessarily be true&quot;." colorLabel="6"/>
                  </outline>
                  <outline text="Our temptation to make this an axiom appears to come from our subconscious desire to go &quot;my axioms must match my most irreducible intuitions, therefore axioms like the [law of contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=f0OtGrGk9iM-Ry2mQ04gpGKG) must necessarily be true.&quot;"/>
                  <outline text=""/>
                </outline>
              </outline>
            </outline>
            <outline text="&quot;Recommended&quot; system" _note="Likely unfinished and somewhat wrong." heading="1" colorLabel="4" collapsed="true">
              <outline text="[Law of identity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QNeZxWHbe7v-UYKBxTdg2LFx)" heading="2" colorLabel="5"/>
              <outline text="[Law of contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=f0OtGrGk9iM-Ry2mQ04gpGKG)" heading="2" colorLabel="5"/>
              <outline text="[Modus ponens works](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=k3emDCQzI6x381obzDk2UWqL)" heading="2" colorLabel="5"/>
              <outline text="[Principle of induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=u6QOAA3CMaWyvXF8U03DcNth)" heading="2" colorLabel="4"/>
              <outline text="Why doesn&apos;t this include the law of excluded middle?" heading="3" colorLabel="6" collapsed="true">
                <outline text="It can be derived from the other axioms here." _note="Link to argument or something."/>
              </outline>
            </outline>
            <outline text="Cogito only" heading="2" colorLabel="2" collapsed="true">
              <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gewP_QuUicD9TsEDCHYMTLn7" heading="3" colorLabel="2"/>
              <outline text="Immediate derivations" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="The causal source of accepting axioms" heading="3" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The causal reason for us accepting our axioms."/>
              <outline text="Distinction" heading="3" colorLabel="3"/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2"/>
            <outline text="Coincidentally accurate axioms" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The position that we coincidentally don&apos;t hold any wrong axioms."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Accuracy" heading="3" collapsed="true">
                  <outline text="In order to better survive and reproduce, evolution would have been best off selecting for the (at least deep down) acceptance of axioms that match reality." colorLabel="4" collapsed="true">
                    <outline text="This feels like circular reasoning." _note="Addressed" colorLabel="1" collapsed="true">
                      <outline text="It feels circular because of using axioms to investigate the causal source of axioms." colorLabel="3"/>
                      <outline text="To be a form of circular reasoning, it would have to be using axioms to justify axioms, or using axioms&apos; causal source to investigate their causal source. Neither is being done here." colorLabel="1"/>
                    </outline>
                    <outline text="There could be axioms that were not relevant to our survival/reproduction." _note="Addressed" colorLabel="1" collapsed="true">
                      <outline text="Simpler/broader axioms would likely apply everywhere in the universe in substantial way(s)." colorLabel="1" collapsed="true">
                        <outline text="Occam&apos;s razor supports the idea that all axioms are simple/broad." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Transcendental-esque access" heading="3" colorLabel="6" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Some sort of direct, implicit, perfect access to truth."/>
                <outline text="Not indirect/imperfect and probably not coincidental."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Accepting something like this in terms of trusting strong enough intuitions is pretty common." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="" colorLabel="1"/>
                </outline>
                <outline text="Accuracy" heading="3"/>
              </outline>
            </outline>
          </outline>
          <outline text="Accepting axioms with uncertainty" heading="3" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Accepting axioms in a manner that is uncertain."/>
              <outline text="Distinction" heading="3" collapsed="true">
                <outline text="This is different from considering __our conception__ of what axioms we hold to be uncertain."/>
                <outline text="^ It&apos;s possible to think that we could be wrong about what axioms form the foundation of our reasoning, while thinking that the axioms themselves cannot be wrong."/>
              </outline>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="**Common:**   For people to attempt to accept axioms in an uncertain way." colorLabel="4"/>
              <outline text="**Inconsistent**   It isn&apos;t possible for us to be consistent in believing that we hold axiom X while also believing that axiom X is uncertain." colorLabel="1" collapsed="true">
                <outline text="P1. Uncertainty about an axiom requires the possibility of affecting some currently present supporting evidence of that axiom." collapsed="true">
                  <outline text="P1. Uncertainty requires the possibility of being wrong." collapsed="true">
                    <outline text="In order to be uncertain about an axiom, we must consider it possible for that axiom to be wrong." colorLabel="3"/>
                    <outline text="**Example:**   If there&apos;s an 80% chance of being right, then there&apos;s necessarily a 20% chance of being wrong." _note="Link relevant induction section about probabilities adding up to 100%." colorLabel="6"/>
                  </outline>
                  <outline text="P2. The possibility of an axiom being wrong requires the possibility of affecting some currently present supporting evidence of that axiom." collapsed="true">
                    <outline text="P1. The possibility of an axiom being wrong requires the possibility of some evidence existing which indicates that the axiom is wrong." collapsed="true">
                      <outline text="**Distinction:**   This evidence/indication does not necessarily have to be practically or even theoretically accessible." colorLabel="3"/>
                      <outline text="In order for a well-defined proposition to be wrong, there must be some logic that makes it wrong." _note="Likelihood" colorLabel="4"/>
                    </outline>
                    <outline text="P2. In order for some evidence to indicate that an axiom is wrong, the evidence must influence some information we previously had that was supporting the axiom." collapsed="true">
                      <outline text="This is because counter-evidence always functions via deductive or inductive reasoning, which both always have this property." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Example" heading="3" colorLabel="6"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="P2. It isn&apos;t possible to affect some currently present supporting evidence of an axiom." collapsed="true">
                  <outline text="Axioms are (by this guide&apos;s definition) necessarily unsupported."/>
                </outline>
                <outline text="Accepting axioms with uncertainty frequently results in confusion and mistakes, especially in important areas." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="**Example:**   When feeling cornered with logic about religion or lackthereof, people will often resort to challenging their own implicitly accepted axioms with &quot;we can&apos;t be sure about that&quot;." colorLabel="6"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="The ways in which these can be axioms" heading="3" colorLabel="6" collapsed="true">
            <outline text="All of these can be assumed as applying in all cases or in at least most cases, or in at least most cases that have been observed, etc."/>
          </outline>
        </outline>
        <outline text="Standard deduction" heading="1" colorLabel="5" collapsed="true">
          <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
            <outline text="**Deductive reasoning** is the process of drawing valid [inferences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ua8jzU8x2DrWQ46H4Rz65bfj)" collapsed="true">
              <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                <outline text="The inference from the premises &quot;all men are mortal&quot; and &quot;Socrates is a man&quot; to the conclusion &quot;Socrates is mortal&quot; is deductively valid."/>
              </outline>
            </outline>
            <outline text="Alternative definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="One approach defines deduction in terms of the intentions of the author: they have to intend for the premises to offer deductive support to the conclusion." collapsed="true">
                <outline text="With the help of this modification, it is possible to distinguish [valid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa) from invalid deductive reasoning: it is invalid if the author&apos;s belief about the deductive support is false, but even invalid deductive reasoning is a form of deductive reasoning."/>
              </outline>
            </outline>
          </outline>
          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
            <outline text="Common" heading="3" colorLabel="4" collapsed="true">
              <outline text="Most non-trivial reasoning sessions involve some standard deduction." _note="Likelihood" colorLabel="4"/>
            </outline>
            <outline text="**Systematic reasoning:**   Makes it much easier to use more systematic reasoning." colorLabel="4" collapsed="true">
              <outline text="Better understanding the processes underlying deduction allows for more [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" _note="Likelihood" colorLabel="4" collapsed="true">
                <outline text="[It&apos;s easier](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=p9E_cUv003cdY4Ew8l0BE60q) to create very systematic deductive arguments than probabilistic ones." _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="It&apos;s easier to create very systematic deductive arguments than probabilistic ones." _note="Likelihood" colorLabel="4"/>
            </outline>
            <outline text="which allows for better decision-making during [big decisions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3IMrmLH-UeufI_a8aVlL492y)" colorLabel="4"/>
          </outline>
          <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
            <outline text="It&apos;s very easy to error in a very impactful way when using deductive reasoning." colorLabel="1" collapsed="true">
              <outline text="There are a lot of common and easy-to-make mistakes and fallacies surrounding standard deduction."/>
              <outline text="**Analogy:**   Just as it&apos;s easy for one small mistake in a mathematical solution to ruin the entire process." colorLabel="6" collapsed="true"/>
            </outline>
            <outline text="There are more specific limitations listed in other &quot;limitations&quot; items in this section."/>
          </outline>
          <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
            <outline text="Standard deductive reasoning (when applicable and properly used, which like most reasoning is often difficult) is extremely strong and reliable, so where available, it tends to be preferable to using just inductive reasoning."/>
            <outline text="However combining both inductive and standard deductive reasoning can be even better in many situations."/>
          </outline>
          <outline text="Structure of deduction" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The standard deduction topics that have to do with **logical structure**."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Understanding and following structured deductive reasoning helps reason in a more [systematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7) way." collapsed="true">
                <outline text="Unstructured reasoning typically leads to lots of/major blunders and mistakes." colorLabel="4" collapsed="true">
                  <outline text="Examples" heading="3" colorLabel="6"/>
                </outline>
              </outline>
            </outline>
            <outline text="Propositions" _note="Needs much more work." heading="2" colorLabel="5" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Propositions are typically characterized in terms of three interlocking roles:"/>
                <outline text="Meanings of [declarative sentences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NDUzShypnzTdPkkQ1BHxzg6y)" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The ideas or semantic contents expressed by declarative sentences."/>
                    <outline text="The information content of sentences and cross-linguistic sameness."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Propositions are not identical to individual sentences and do not belong to any particular language."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Contents or objects of propositional attitudes" heading="3" collapsed="true">
                  <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Propositions are not identical to individual beliefs or desires since the same proposition can underlie many individual mental states."/>
                  </outline>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Such as when someone believes that the sky is blue."/>
                    <outline text="If Leila believes that the train will be delayed, then she has a mental state, called a propositional attitude, directed at the proposition that the train will be delayed. "/>
                  </outline>
                  <outline text="Propositional attitudes" heading="1" collapsed="true">
                    <outline text="Types" heading="1" collapsed="true">
                      <outline text="Beliefs" heading="3"/>
                      <outline text="Desires" heading="3"/>
                      <outline text="Hopes" heading="3"/>
                      <outline text="Fears" heading="3"/>
                    </outline>
                    <outline text="Linking psychological attitudes" heading="3" collapsed="true">
                      <outline text="Propositional attitudes are typically expressed through that-clauses to link a psychological attitude to a proposition." collapsed="true">
                        <outline text="&quot;She believes that it will rain.&quot;" colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="The contents of propositional attitudes are shareable." collapsed="true">
                      <outline text="Different persons can have the same beliefs or fears." colorLabel="3"/>
                      <outline text="Both Leila and Diego fear that the train will be delayed." colorLabel="6"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Bearers of truth values" heading="3" collapsed="true">
                  <outline text="Each proposition is a function which takes a claim and returns either true or false."/>
                  <outline text="Primary truth-bearers" heading="3" collapsed="true">
                    <outline text="Non-proposition truth-bearers are true or false in a derivative sense by being about true or false propositions." colorLabel="3" collapsed="true">
                      <outline text="Declarative sentences" colorLabel="6"/>
                      <outline text="Beliefs" colorLabel="6"/>
                    </outline>
                    <outline text="Propositions are not the only entities that have truth values." collapsed="true">
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Declarative sentences"/>
                        <outline text="Beliefs"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Bearers of modal properties" heading="3" collapsed="true">
                    <outline text="A proposition can be possible, impossible, or necessary, depending on whether it is logically compatible with coherent scenarios, or in some sense conceivable or contradictory." colorLabel="3"/>
                    <outline text="[Modal types](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=c1IO0xgn3hhWQrXgqmoHrfRB)" heading="3"/>
                  </outline>
                  <outline text="[True vs false](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XMeFJ4S0hJUAe_TnOV3e7lG_)" heading="3"/>
                </outline>
                <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Statement" heading="3" collapsed="true">
                    <outline text="Sometimes used synonymously."/>
                    <outline text="However, the word &quot;statement&quot; is ambiguous since it can also refer to [declarative sentences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NDUzShypnzTdPkkQ1BHxzg6y) themselves rather than their meanings."/>
                  </outline>
                  <outline text="Judgement" heading="3" collapsed="true">
                    <outline text="The term proposition overlaps with the term judgment, with one difference being that judgments are more closely associated with mental processes that affirm or deny the truth of a content."/>
                  </outline>
                </outline>
                <outline text="Sub-definitions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Non-mental/abstract entities" heading="3"/>
                  <outline text="General mental entities" heading="3"/>
                </outline>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Unlike sentences, propositions are not linguistic expressions." collapsed="true">
                    <outline text="The English sentence &quot;Snow is white&quot; and the German &quot;Schnee ist weiß&quot; denote the same proposition." colorLabel="6"/>
                  </outline>
                </outline>
                <outline text="Formal definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Formal propositions are often modeled as functions which map a possible world to a truth value." collapsed="true">
                    <outline text="The proposition that the sky is blue can be modeled as a function which would return the truth value T if given the actual world as input, but would return F if given some alternate world where the sky is green." colorLabel="6"/>
                  </outline>
                  <outline text="Alternative definitions" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Structured propositions view" heading="3"/>
                  </outline>
                </outline>
                <outline text="Further clarification" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Propositions are the objects denoted by declarative sentences." collapsed="true">
                    <outline text="&quot;The sky is blue&quot; expresses the proposition that the sky is blue." colorLabel="6"/>
                  </outline>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Proposition)"/>
              </outline>
              <outline text="Types" heading="1" colorLabel="6" collapsed="true">
                <outline text="True vs false" heading="3" collapsed="true">
                  <outline text="The truth value of a proposition depends on its accuracy / correspondence with reality." colorLabel="3"/>
                  <outline text="True" heading="3" collapsed="true">
                    <outline text="A proposition which is in accordance with reality."/>
                  </outline>
                  <outline text="False" heading="3" collapsed="true">
                    <outline text="A proposition which is not in accordance with reality."/>
                  </outline>
                </outline>
                <outline text="Compound propositions" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="[Conditional propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5ScB8HIv-Th7cwN1Rh_C7pZh)" heading="3" collapsed="true">
                    <outline text="Conditional propositions are compound propositions since they have components that are themselves propositions."/>
                  </outline>
                  <outline text="Conjunctive propositions" heading="3" collapsed="true">
                    <outline text="Conjunctive propositions claim that all their component statements are true, typically expressed as an &quot;and&quot; sentence, such as &quot;the tree is green and the sky is blue&quot;."/>
                  </outline>
                  <outline text="Disjunctive propositions" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Propositions which assert that one of their component statements is true, typically expressed as an &quot;or&quot; sentence, as in &quot;it is windy or it is rainy&quot;."/>
                    </outline>
                    <outline text="Inclusive disjunctive propositions" heading="3" collapsed="true">
                      <outline text="At least one but possibly both component statements are true."/>
                    </outline>
                    <outline text="Exclusive disjunctive propositions" heading="3" collapsed="true">
                      <outline text="Exactly one component statement is true and the other is false."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Analytic vs synthetic" heading="3" collapsed="true">
                  <outline text="The difference depends on why they are true." colorLabel="3"/>
                  <outline text="Analytic" heading="3" collapsed="true">
                    <outline text="The truth of analytic propositions is determined only by the meanings of concepts, independent of the actual state of the world." colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="The proposition &quot;all bachelors are unmarried&quot; is analytically true because the concept &quot;bachelor&quot; already includes the meaning of &quot;unmarried&quot;."/>
                    </outline>
                  </outline>
                  <outline text="Synthetic" heading="3" collapsed="true">
                    <outline text="The truth of synthetic propositions, such as &quot;snow is white&quot;, depends on the state of the world." colorLabel="3"/>
                  </outline>
                </outline>
                <outline text="A priori vs a posteriori" heading="3" collapsed="true">
                  <outline text="The difference depends on the source of their knowledge." colorLabel="3"/>
                  <outline text="A priori" heading="3" collapsed="true">
                    <outline text="Propositions which can be known through pure reasoning alone." colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="&quot;2+2=4&quot;"/>
                    </outline>
                  </outline>
                  <outline text="A posteriori" heading="3" collapsed="true">
                    <outline text="Propositions which describe empirical facts knowable through sensory experience." colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="&quot;The sun is shining.&quot;"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Modal types" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Modal propositions express what is possible, necessary, or impossible."/>
                    <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                      <outline text="&quot;It is possible that I will win the lottery.&quot;"/>
                      <outline text="&quot;It is impossible to travel faster than light&quot;."/>
                    </outline>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Rather than asserting how the world is, they describe how it could or could not have been."/>
                    </outline>
                  </outline>
                  <outline text="A proposition is necessarily true if it is impossible that it is false. "/>
                  <outline text="Alethic modality" heading="3" collapsed="true">
                    <outline text="Concerns what is possible or necessary relative to the laws of nature, metaphysics, or logic." colorLabel="3"/>
                  </outline>
                  <outline text="Epistemic modality" heading="3" collapsed="true">
                    <outline text="Concerns what may or must be the case relative to someone&apos;s knowledge or evidence." colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="&quot;The butler cannot be the killer.&quot;"/>
                    </outline>
                  </outline>
                  <outline text="Normative propositions express what ought to be the case, like &quot;you should not drink and drive&quot;. They include permissions, requirements, and prohibitions. Moral propositions are normative propositions that assert moral principles or judgments, such as &quot;you should keep promises&quot;. Normative propositions contrast with descriptive propositions, which express what is rather than what ought to be. The schools of cognitivism and non-cognitivism debate the existence of normative propositions. Non-cognitivism argues that normative sentences are neither true nor false and do not express propositions, for example, because they convey emotions rather than propositions. A gappy proposition, also called an incomplete or unfilled proposition, is a statement whose subject matter is not properly specified, which results in an incomplete meaning. This can happen when the proposition involves an empty name, which does not refer to any real entity, such as the name Pegasus. Given the difficulties in assigning truth values to gappy propositions, philosophers debate whether they qualify as propositions in the strict sense. Alternative proposals suggest that they are another type of meaning content. Temporal propositions, another type, are statements that refer to specific times, such as &quot;the Berlin Wall fell in 1989&quot;. Propositions are also classified by the domain or field of inquiry to which they belong, such as mathematical, scientific, metaphysical, and theological propositions." collapsed="true">
                    <outline text=""/>
                  </outline>
                </outline>
                <outline text="Categorical vs conditional" heading="3" collapsed="true">
                  <outline text="Categorical propositions" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Categorical propositions assert how things are, independently of other statements or assumptions."/>
                    </outline>
                  </outline>
                  <outline text="Conditional propositions" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Conditional propositions link two simpler propositions, typically expressed as an &quot;if-then&quot; sentence."/>
                      <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Hypothetical proposition"/>
                      </outline>
                    </outline>
                    <outline text="They hold that if the if-statement is true, then the then-statement must be true." collapsed="true">
                      <outline text="If it rains, then the ground gets wet." colorLabel="6"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Typically linguistic" _note="Check if the other types belong here." heading="1" colorLabel="6" collapsed="true">
                  <outline text="General vs singular" heading="3" collapsed="true">
                    <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Usually a purely linguistic distinction."/>
                    </outline>
                    <outline text="General" heading="3" collapsed="true">
                      <outline text="General propositions are about a general set of entities." colorLabel="3"/>
                      <outline text="Universal vs existential" heading="3" collapsed="true">
                        <outline text="Universal" heading="3" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Propositions which assert that something is the case for all entities in a domain."/>
                            <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                              <outline text="&quot;All humans are mortal.&quot;"/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Existential" heading="3" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Propositions which state that something is the case for at least one entity in a domain."/>
                            <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                              <outline text="&quot;Some humans are left-handed.&quot;"/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Singular" heading="3" collapsed="true">
                      <outline text="Singular propositions are about one specific entity." colorLabel="3"/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="&quot;Socrates is wise.&quot;"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Affirmative vs negative" heading="3" collapsed="true">
                    <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Often a purely linguistic distinction." collapsed="true">
                        <outline text="Usually, the same information can be expressed with and without negations, as in &quot;he is not happy&quot; and &quot;he is sad&quot;."/>
                      </outline>
                    </outline>
                    <outline text="Affirmative" heading="3" collapsed="true">
                      <outline text="Affirmative propositions state that something is the case." colorLabel="3"/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="The tree is green."/>
                      </outline>
                    </outline>
                    <outline text="Negative" heading="3" collapsed="true">
                      <outline text="Negative propositions deny that something is the case." colorLabel="3"/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="The tree is not green."/>
                      </outline>
                    </outline>
                    <outline text="If an affirmative proposition is true, then the corresponding negative proposition is false, and vice versa."/>
                  </outline>
                </outline>
                <outline text="Misc" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Fictional" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Propositions about non-existing entities."/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="&quot;Santa Claus has a beard.&quot;"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Well-defined propositions" _note="Reconcile with [Well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Propositions that are defined in a perfectly unambiguous way." collapsed="true">
                    <outline text="Unambiguous" heading="3" colorLabel="3"/>
                    <outline text="Infeasibility" heading="3" colorLabel="2" collapsed="true">
                      <outline text="In reality this is typically infeasible to achieve, but we can get close enough by minimizing the probability of impactful ambiguities from arising." collapsed="true">
                        <outline text="[Clear semantics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=12AbgdKnf7gB2sw5V6F_Kh-6)" heading="3" colorLabel="3"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Antecedent and consequent" heading="2" colorLabel="5" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Antecedent" heading="3" collapsed="true">
                  <outline text="The first half of a [conditional proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5ScB8HIv-Th7cwN1Rh_C7pZh), whenever the if-clause precedes the then-clause."/>
                  <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Condition" heading="3" collapsed="true">
                      <outline text="When the antecedent is used for a [IF-THEN (material conditional)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw)"/>
                    </outline>
                    <outline text="Protasis" heading="3" collapsed="true">
                      <outline text="Used synonymously in some contexts."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Consequent" heading="3" collapsed="true">
                  <outline text="the second half of a [conditional proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5ScB8HIv-Th7cwN1Rh_C7pZh). In the standard form of such a proposition, it is the part that follows &quot;then&quot;."/>
                  <outline text="Synonyms" collapsed="true">
                    <outline text="Consequence"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[IF-THEN (material conditional)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw)" heading="1" colorLabel="5" collapsed="true">
                  <outline text="The only kind of [conditional proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5ScB8HIv-Th7cwN1Rh_C7pZh) where the sides cannot be swapped."/>
                </outline>
              </outline>
            </outline>
            <outline text="Premises and conclusions" heading="2" colorLabel="5" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Premise"/>
                <outline text="Conclusion"/>
              </outline>
            </outline>
            <outline text="Logical connectives" heading="1" colorLabel="5" collapsed="true">
              <outline text="Basic connectives" heading="3" colorLabel="5" collapsed="true">
                <outline text="NOT (negation)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Outputs the logical negation of the input."/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="I am human. -&gt; I am not Human."/>
                    </outline>
                    <outline text="Symbols" colorLabel="3" collapsed="true">
                      <outline text="¬"/>
                      <outline text="-"/>
                    </outline>
                  </outline>
                  <outline text="Double negation" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="&quot;The tree is not not green.&quot;" colorLabel="6"/>
                    </outline>
                    <outline text="A proposition with a double negation is logically equivalent to a proposition without either negation."/>
                  </outline>
                  <outline text="Understanding NOT in the context of contradictions." _note="What was this supposed to mean?"/>
                </outline>
                <outline text="AND (conjunction)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Symbols" colorLabel="3" collapsed="true">
                      <outline text="∧"/>
                      <outline text="^"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="OR (disjunction)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Symbols" colorLabel="3"/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="More specific than [the colloquial definition of or](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8JeXSZBuV_YRumG3FPV1y1id), in that it never means https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=n7OMAZ2eLgm2YIZTBh-L2db8"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Boolean_algebra#Basic_operations)"/>
              </outline>
              <outline text="Secondary connectives" heading="3" colorLabel="5" collapsed="true">
                <outline text="IF-THEN (material conditional)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Synonym:   conditional." colorLabel="3"/>
                    <outline text="[Antecedent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=A1OY9ItQTQcgXLrjT6B9w-kv)"/>
                    <outline text="[Consequent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Dr8LcqFWIIfqiyEAzLoy4d8P)"/>
                    <outline text="Symbols" colorLabel="3" collapsed="true">
                      <outline text="→"/>
                      <outline text="-&gt;"/>
                      <outline text="=&gt;"/>
                    </outline>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Different from [colloquial if-then](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2TuOKskT9XSu0CoJqiPtqE29), in that there is no requirement for a causal or epistemic correlation between the antecedent and consequent."/>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Unintuitive" heading="3" collapsed="true">
                        <outline text="[Non-colloquial](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tMrZGIpiDGQKx4L5feB1o2hl)"/>
                      </outline>
                      <outline text="Very useful in logic in general" heading="3"/>
                    </outline>
                    <outline text="Common" heading="3"/>
                  </outline>
                  <outline text="Vacuous truth" heading="1" colorLabel="5" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A true proposition that has the form &quot;if P then Q&quot; with a false antecedent." collapsed="true">
                        <outline text="The antecedent is P in this case."/>
                      </outline>
                      <outline text="https://en.wikipedia.org/wiki/Vacuous_truth"/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Unintuitive" heading="3" collapsed="true">
                          <outline text="https://en.wikipedia.org/wiki/Paradoxes_of_material_implication"/>
                        </outline>
                      </outline>
                      <outline text="Common" heading="3"/>
                    </outline>
                    <outline text="The only way a vacuous truth can be false is if the antecedent is true and the consequent is false." collapsed="true">
                      <outline text="But what if the consequent would be false if the antecedent was true, but the antecedent is false for now? It feels like the overall statement should be false, since colloquially &quot;if P then Q&quot; is false in this case."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="IF-AND-ONLY-IF (material biconditional)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="It can be understood as literally &quot;if and only if&quot;, or &quot;sufficient and necessary&quot;. But a more colloquial definition might simply treat it as synonymous with &quot;equals&quot;. If the [antecedent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=A1OY9ItQTQcgXLrjT6B9w-kv)&apos;s truth value is equal to the [consequent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Dr8LcqFWIIfqiyEAzLoy4d8P), then this connective &apos;returns&apos; true (i.e. the whole statement is true). Otherwise, if the antecedent and consequent have different truth values, then it returns false."/>
                    <outline text="**Why &quot;if and only if&quot;?**" collapsed="true">
                      <outline text="A nice intuitive way to think of this is to split a biconditional into &quot;if&quot; and &quot;only if&quot;."/>
                      <outline text="&quot;If&quot; (in this context) just describes an [ordinary conditional](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw), so you can think of this part as describing the right side of the double-headed arrow ↔."/>
                      <outline text="&quot;Only if&quot; (in this context) means that the only way for the consequent to be true is if the antecedent is true. This implies that if the consequent is true, the antecedent must be true, so you can think of this part as also describing an [ordinary conditional](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw), but in the other direction." _note="**Unimportant note:**   Technically it seems we could also derive &quot;if&quot; from &quot;only if&quot; as well, so the entire name only needs to be &quot;only if&quot;, the &quot;if and&quot; is kinda redundant. But I think describing &quot;if&quot; and &quot;only if&quot; this way is still a nice way to intuit and memorize what &quot;if and only if&quot; means."/>
                    </outline>
                    <outline text="Synonym:   biconditional." colorLabel="3"/>
                    <outline text="Symbols" colorLabel="3" collapsed="true">
                      <outline text="↔"/>
                      <outline text="&lt;-&gt;"/>
                      <outline text="&lt;=&gt;"/>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Informal representation of (bi)-conditionals](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2TuOKskT9XSu0CoJqiPtqE29)"/>
                  </outline>
                </outline>
                <outline text="XOR" heading="3" colorLabel="5"/>
                <outline text="https://en.wikipedia.org/wiki/Boolean_algebra#Secondary_operations"/>
              </outline>
            </outline>
            <outline text="Validity and soundness" heading="1" colorLabel="5" collapsed="true">
              <outline text="Validity" heading="2" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="**Validity** (in this context) describes whether or not it is possible for an argument&apos;s conclusion to be false while its premises are true. If an [argument](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=M3cViLMa_VnUyP-7Xp01TfFR) is valid and has only true premises, that means that the conclusion *must* be true, it is logically proven."/>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Horses and zebras " heading="3" collapsed="true">
                      <outline text="Argument" collapsed="true">
                        <outline text="Horses exist"/>
                        <outline text="Therefore zebras exist"/>
                      </outline>
                      <outline text="Why it&apos;s invalid" collapsed="true">
                        <outline text="It&apos;s true that horses exist (the premise is sound)."/>
                        <outline text="It&apos;s true that zebras exist (the conclusion is true)."/>
                        <outline text="But it isn&apos;t logically impossible for horses to exist without zebras existing (the conclusion doesn&apos;t logically follow from the premise, so the argument is still invalid)."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2">
                  <outline text="Very important for good reasoning" heading="3" colorLabel="4" collapsed="true">
                    <outline text="**Lacks deductive justification:**   An invalid argument cannot deductively justify its conclusion." colorLabel="4" collapsed="true">
                      <outline text="**Often relevant:**   Deductive arguments [are common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=t4q5dF-TXwNiSrdGj3N4glkf)" _note="Relevance" colorLabel="4"/>
                      <outline text="When relevant, very relevant." _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                        <outline text="Unlike in a probabilistic argument, in deduction, one tiny mistake about validity typically makes the difference between an argument that deductively proves the conclusion from the premises, and one that gives essentially no indication of the conclusion at all." _note="Likelihood" colorLabel="4"/>
                      </outline>
                      <outline text="**Often irrelevant:**   Often people present reasoning in a misleading way that should not be taken literally." _note="Relevance" colorLabel="1" collapsed="true">
                        <outline text="This is especially common in informal discussions." _note="Likelihood" colorLabel="4"/>
                        <outline text="Often people present reasoning in a deductive manner, when in reality they intend to give a probabilistic argument." _note="Likelihood &amp; Relevance" colorLabel="4" collapsed="true">
                          <outline text="A probabilistic argument does not need to be deductively valid to have a significant impact." _note="Relevance" colorLabel="4"/>
                        </outline>
                        <outline text="Often people present premises that don&apos;t technically represent what they meant to say." _note="Likelihood &amp; Relevance" colorLabel="4" collapsed="true">
                          <outline text="When one can sufficiently [reliably and quickly] determine that this is happening, it is typically better not to focus on invalidity." _note="Relevance" colorLabel="4" collapsed="true">
                            <outline text="In such cases, focusing on invalidity is likely to waste time." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="[It&apos;s very important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NYxdL99oO0wiJzLy4FF6TvXs) to save time." _note="Relevance" colorLabel="4"/>
                            </outline>
                            <outline text="^ There are better options for figuring out what they meant to say, to address their actual reasoning." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="You can [ask for clarification](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Hf0OMZKK9gpCvfma6I4h5Nwk)" _note="Likelihood" colorLabel="4"/>
                              <outline text="You can attempt to [anticipate their meaning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GiYDKlicnNc1dQVnntzf_w58)" _note="Likelihood" colorLabel="4"/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="**Unavoidable uncertainty:**   We cannot ever know for certain that an argument is valid." colorLabel="1" collapsed="true">
                      <outline text="[Limitations of mental faculties](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=C5Uyd9SYvh-0SPYyOkBCMDpA)" _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="**Invalid ≠ false:**   An invalid argument can still have a true conclusion." colorLabel="1" collapsed="true">
                    <outline text="Validity merely describes whether an argument&apos;s conclusion can be deductively derived from its premises (i.e. whether, given the premises, we can know* that the conclusion is true). It does not describe whether the conclusion is in fact true or false, since it does not tell us whether there are any other arguments that could work, or whether the conclusion could be unprovably true/false." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="* Technically we still [can&apos;t know for certain](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=p3smzzmZMepqF12QT_zfXcHm), but it should typically still give very good indication." colorLabel="3"/>
                    </outline>
                    <outline text="^ [Validity definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WxCDZRz_H2-cmIaiApjKzBGz)" _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="It&apos;s possible for a deductively invalid argument to work as a good inductive argument." colorLabel="1" collapsed="true">
                    <outline text="Examples" colorLabel="6" collapsed="true">
                      <outline text="Rising sun" collapsed="true">
                        <outline text="Argument" collapsed="true">
                          <outline text="The sun has risen every morning so far."/>
                          <outline text="Therefore the sun will likely rise in the next morning." collapsed="true">
                            <outline text="* As long as there isn&apos;t sufficient evidence to the contrary."/>
                          </outline>
                        </outline>
                        <outline text="Explanation" collapsed="true">
                          <outline text="This argument is invalid, the premise does not prove the conclusion, but it works fine as an inductive argument."/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="If term(s) are used in multiple different senses but the logic requires that the terms describe the same thing, this is called [conflation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2) and makes the logic invalid*." colorLabel="4" collapsed="true">
                    <outline text="This is because logic only applies to [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) and therefore only those can be valid." _note="Likelihood" colorLabel="4"/>
                    <outline text="* Technically it is possible for the logic to be valid if the two different usages are treated as distinct." colorLabel="3"/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Standard form](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WBGbs-oyLu2VHlBm5Vkh-KAb)" heading="3" colorLabel="5" collapsed="true">
                    <outline text="A form of argument that makes it relatively easy to check the validity of the argument."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Soundness" heading="2" colorLabel="5" collapsed="true">
                <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="**Soundness** (in this context) typically refers to whether or not an argument is both valid and containing no false premises. If it meets both of these conditions, then it is a sound argument."/>
                  <outline text="Main alternative definition" colorLabel="3" collapsed="true">
                    <outline text="Occasionally &quot;soundness&quot; will be defined to require *only* that the premises be true, and not that the argument is valid."/>
                    <outline text="This definition is often more useful than the main one if it doesn&apos;t cause confusion." colorLabel="2" collapsed="true">
                      <outline text="Because it&apos;s often useful to describe only the truthfulness of the premises, and it&apos;s easy to say &quot;valid and sound&quot; in place of using the more common definition."/>
                    </outline>
                  </outline>
                  <outline text="Which definition to use" colorLabel="2" collapsed="true">
                    <outline text="To avoid confusion, you can also use &quot;valid and sound&quot; in place of the former definition, and &quot;sound premise(s)&quot; in place of the latter definition."/>
                  </outline>
                </outline>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="An argument with unsound premises can still have a true conclusion." colorLabel="5" collapsed="true">
                    <outline text="It just cannot deductively prove the true conclusion."/>
                  </outline>
                  <outline text="A valid argument can still have unsound premises." colorLabel="5" collapsed="true">
                    <outline text="If the premises are not solidly established, then the conclusion cannot be solidly established via the argument either. The logic being valid doesn&apos;t mean that the premises are true, it can only tell us the logical consequences of the premises."/>
                    <outline text="The conclusion can still follow from the premise(s) while the premise(s) are false." collapsed="true">
                      <outline text="Example" colorLabel="6" collapsed="true">
                        <outline text="Premise 1:   2 + 2 = 5"/>
                        <outline text="Premise 2:   John and Mary both gave me two apples each."/>
                        <outline text="Conclusion:   I received 5 apples from John and Mary."/>
                      </outline>
                    </outline>
                    <outline text="The conclusion cannot be established from mere validity, the premises also have to be sound."/>
                  </outline>
                  <outline text="We cannot ever know for certain that an argument is sound." colorLabel="1" collapsed="true">
                    <outline text="[Limitations of mental faculties](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=C5Uyd9SYvh-0SPYyOkBCMDpA)" colorLabel="2"/>
                  </outline>
                  <outline text="Oftentimes what was technically stated is unsound but what was meant is sound." colorLabel="3" collapsed="true"/>
                </outline>
              </outline>
            </outline>
            <outline text="Formal deduction" heading="1" colorLabel="5" collapsed="true">
              <outline text="Formal true and false" heading="3" colorLabel="3" collapsed="true">
                <outline text="In and out of correspondence with reality, respectively."/>
                <outline text="**Synonyms:**  Truth simpliciter, absolute truth" colorLabel="3"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="A very important process to use for [formal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0At0cZGMuQERz1v4oedfKRza)." colorLabel="4" collapsed="true">
                  <outline text="[Importance of formal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MNUQZ7bu6j_LRJXAne92I7Ri)" _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Rules" heading="1" colorLabel="5" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Crucial for performing [formal deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zsOpjP92dDsI8MqzcQASsNlD)." colorLabel="4" collapsed="true">
                    <outline text="Importance of performing formal deduction." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Replacement rules" heading="1" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Rules that apply in both directions. Either side can be replaced with the other."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Some of these rules come in pairs, split with a &quot;|&quot;. These pairs cannot be swapped. Only expressions on either side of a ↔ may be swapped."/>
                    </outline>
                  </outline>
                  <outline text="Contraposition   (Contra)" _note="P → Q   ↔   -Q → -P" heading="3" colorLabel="1" collapsed="true">
                    <outline text="**Synonym:**   Transposition" colorLabel="3"/>
                  </outline>
                  <outline text="Double negation   (-E / DN / -- Elim)" _note="--P  ↔  P" heading="3" colorLabel="1" collapsed="true">
                    <outline text="**Synonyms:**   double negation elimination, negation elimination" colorLabel="3"/>
                    <outline text="Double negation introduction" _note="P   ∴   --P" heading="3"/>
                  </outline>
                  <outline text="Demorgan&apos;s laws   (DM / DeM)" _note="-(P ^ Q) ↔ -P v -Q    |    -(P v Q) ↔ -P ^ -Q" heading="2" colorLabel="2" collapsed="true">
                    <outline text="Negation of conjunction " _note="-(P ^ Q)  ↔  -P v -Q" heading="3" colorLabel="2"/>
                    <outline text="Negation of disjunction" _note="-(P v Q)  ↔  -P ^ -Q" heading="3" colorLabel="2"/>
                  </outline>
                  <outline text="Distribution   (Dist)" _note="(P v Q) ^ R   ↔   (P ^ R) v (Q ^ R)      |      (P ^ Q) v R    ↔   (P v R) ^ (Q v R)" heading="3" colorLabel="2"/>
                  <outline text="Conjunction introduction   (^I)" _note="P, Q  ↔  P ^ Q" heading="3" colorLabel="4"/>
                  <outline text="Exportation   (Exp)" _note="(P^Q) → R   ↔   P → (Q→R)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Reducible" heading="3" colorLabel="5"/>
                  </outline>
                  <outline text="Material equivalance   (Equiv)" _note="(P ↔ Q)   ↔   [(P → Q) ^ (Q → P)]      |      (P ↔ Q)   ↔   (P ^ Q) v (-P ^ -Q)" heading="3" colorLabel="5" collapsed="true">
                    <outline text="[Logical connectives](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4c53ztjrA-5-dTCfvBk6ryLz)" heading="1" colorLabel="5"/>
                  </outline>
                  <outline text="Material implication   (Impl)" _note="P → Q   ↔   -P v Q      |     -(P → Q)   ↔   P ^ -Q " heading="3" colorLabel="6" collapsed="true">
                    <outline text="**Reducible to:**   The definitions of [material conditional (→ )](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw), [disjunction (v)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TKmTc0y15-zDJqP-9eeA6L5Z) and [conjunction (^)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7L3dxYa84Fg0AT8HpDH4jekq)." _note="See [this entry&apos;s note](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=w5dUValYHC3XOad1KGCjAcyQ) for more details on how this might be wrong and an alternative way to look at it." colorLabel="5"/>
                  </outline>
                  <outline text="Commutative   (Com)" _note="P ^ Q   ↔   Q ^ P      |      P v Q   ↔   Q v P" heading="3" colorLabel="6" collapsed="true">
                    <outline text="**Reducible to:**   The definitions of [conjunction (^)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7L3dxYa84Fg0AT8HpDH4jekq) and [disjunction (v)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TKmTc0y15-zDJqP-9eeA6L5Z), respectively." _note="I think. But if not, then maybe the [principle of induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=JGRs9pW59a9Y_OB1lx7HkVL2) or similar. Like we&apos;ve done this operation without issue so many times, therefore likely reliable. Or it can be expressed in truth tables and truth tables have been shown to be reliable via induction, etc." colorLabel="5"/>
                  </outline>
                  <outline text="Associative   (Assoc)" _note="(P ^ Q) ^ R  ↔  P ^ (Q ^ R)      |      (P v Q) v R   ↔   P v (Q v R)" heading="3" colorLabel="6" collapsed="true">
                    <outline text="**Reducible to:**   [Commutative](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5CIJnWDSNGCLYi8MFent2pho)" colorLabel="5"/>
                  </outline>
                </outline>
                <outline text="Inference rules" _note="Add more from classically valid [...] section of https://en.wikipedia.org/wiki/Propositional_logic " heading="1" colorLabel="3">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Modus tollens   (MT)" _note="P→Q, -Q  ∴  -P" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Maybe reducible to doing"/>
                      <outline text="[Contraposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=C7HJTjN5oFYdYKKFdeGGg4Xv) to get -Q → -P" colorLabel="4"/>
                      <outline text="and then [modus ponens](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=haL1Nh2Q-JDklRNUGUdjSDwV) to get -P" colorLabel="2"/>
                    </outline>
                  </outline>
                  <outline text="Disjunction introduction   (vI / Add)" _note="P  ∴  P v Q" heading="3" colorLabel="3"/>
                  <outline text="Constructive dilemma" _note="P→Q, R→S, P v R  ∴  Q v S" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Modus ponens applied to both possibilities of the OR."/>
                  </outline>
                  <outline text="Destructive dilemma" _note="P→Q, R→S, -Q v -S  ∴  -P v -R" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Modus tollens applied to both possibilities of the OR." _note="There should probably just be a rule for being able to account for both possibilities of the OR, and then a reducible section can be created here and for the constructive dilemma."/>
                  </outline>
                  <outline text="Disjunctive syllogism   (DS / MTP)" _note="P v Q, -P  ∴  Q" heading="3" colorLabel="3" collapsed="true">
                    <outline text="**Synonym:**   modus tollendo ponens" colorLabel="3"/>
                  </outline>
                  <outline text="Disjunction elimination   (vE)" _note="P v R, P→Q, R→Q  ∴  Q" heading="3" colorLabel="3" collapsed="true">
                    <outline text="**Synonyms:**   or elimination, proof by cases, case analysis" colorLabel="3"/>
                  </outline>
                  <outline text="Conjunction elimination   (^E / Simp)" _note="P ^ Q  ∴  P" heading="3" colorLabel="4"/>
                  <outline text="Hypothetical syllogism" _note="P→Q, Q→R  ∴  P→R" heading="3" colorLabel="5" collapsed="true">
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Subproof?"/>
                    </outline>
                  </outline>
                  <outline text="Modus ponens   (→E / MP)" _note="P→Q, P  ∴  Q" heading="3" colorLabel="5" collapsed="true">
                    <outline text="**Synonym:**   Conditional elimination" colorLabel="3"/>
                  </outline>
                  <outline text="Absorption" _note="P→Q  ∴  P→(P ^ Q)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="**Reducible to:**   [Modus ponens](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=haL1Nh2Q-JDklRNUGUdjSDwV) and [conjunction introduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vpPbbla7pUAkVCE8iImkuKNN)" _note="Need to show that **conditional proof** is reducible too or use an alternative method." heading="3" colorLabel="5" collapsed="true">
                      <outline text="1. P→Q     (P)" _note="Absorption premise"/>
                      <outline text="2. | P     (Hyp)"/>
                      <outline text="3. | Q     (2,3 modus ponens)"/>
                      <outline text="4. | P ^ Q     (4 conjunction introduction)"/>
                      <outline text="5. P→(P ^ Q)     (2-4 [CP](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BEcqN1V3BBSW3Qpf_JVjoZQk))"/>
                    </outline>
                  </outline>
                  <outline text="Premise   (P / Supp)" _note="P" heading="3" colorLabel="6" collapsed="true">
                    <outline text="**Synonyms:**   supposition" colorLabel="3"/>
                  </outline>
                  <outline text="Assumption   (Hyp / Assump / ACP)" _note="P" heading="3" colorLabel="6" collapsed="true">
                    <outline text="A temporary premise used to begin a subproof." colorLabel="3"/>
                    <outline text="ACP as in &quot;assumption for conditional proof&quot;."/>
                  </outline>
                  <outline text="Reiteration   (R)" _note="P  ∴  P" heading="3" colorLabel="6" collapsed="true">
                    <outline text="**Reducible to:**   [Law of identity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QNeZxWHbe7v-UYKBxTdg2LFx)" colorLabel="5"/>
                  </outline>
                </outline>
                <outline text="Proof methods" heading="1" colorLabel="3" collapsed="true">
                  <outline text="Proof by contradiction" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The process of assuming that some proposition is false, then logically deducing that its falsehood leads to a contradiction, and thus deriving the assumption must be false, and thus that the proposition must be true."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Well founded" heading="3" colorLabel="4" collapsed="true">
                        <outline text="If an assumption leads to a contradiction, then we derive that the assumption must be false based on the [law of contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iRkaxeyoE5AgB17FzWOds2C7)." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="i.e. It&apos;s impossible for a contradiction to exist, therefore if some belief leads to a contradiction, it&apos;s impossible that the belief is true." _note="Likelihood" colorLabel="4"/>
                        </outline>
                        <outline text="If an assumption [about a proposition being false] is false, then we derive that the proposition must be true via [double negation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ifYR-YwY6DUytsHV25rMjYea)." _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Conditional proof   (→I / CP)" _note="Q is proven using [assumption](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qwicBgToMzZ4dsUMRSRdGN3I) P  ∴  P → Q" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The process whereby a sub-proof is provided, and a conditional is proven from it." colorLabel="3"/>
                    <outline text="**Synonym:**   Conditional introduction" colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="1. | (P → Q) ∧ P                 (hyp)"/>
                      <outline text="2. | P → Q                           (1 ^E)"/>
                      <outline text="3. | P                                     (1 ^E)"/>
                      <outline text="4. | Q                                    (2,3 MP)"/>
                      <outline text="C. ((P → Q) ∧ P) → Q     (1-4 CP)"/>
                    </outline>
                  </outline>
                  <outline text="Proof by contrapositive" heading="3"/>
                  <outline text="Indirect proof   (-I / IP)" _note="(Q ^ -Q) is proven using assumption P  ∴  -P" heading="3" colorLabel="1" collapsed="true">
                    <outline text="**Synonym:**   Negation introduction" colorLabel="3"/>
                    <outline text="**Reducible to:**   [Law of contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=f0OtGrGk9iM-Ry2mQ04gpGKG)" colorLabel="5"/>
                  </outline>
                </outline>
                <outline text="Meta" heading="3" colorLabel="6" collapsed="true">
                  <outline text="The colors for the grandchildren of [Rules](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-BroXwfgopzetJHC1qX8IWK4) (aside from definition, importance, meta and related sections) are just used for easier navigation/memorization, and not intended to be interpreted in the usual way. Their meanings are roughly as follows:"/>
                  <outline text="**Red:**   Introduces/eliminates a negation (-)." colorLabel="1"/>
                  <outline text="**Orange:**   Introduces/eliminates either a disjunction (v) or conjunction (^)." colorLabel="2"/>
                  <outline text="**Yellow:**   Introduces/eliminates a disjunction (v)." colorLabel="3"/>
                  <outline text="**Green:**   Introduces/eliminates a conjunction (^)." colorLabel="4"/>
                  <outline text="**Blue:**   Introduces/eliminates a conditional (→) or biconditional (↔)." colorLabel="5"/>
                  <outline text="**Purple:**   Non-traditional rules or simple tautologies." colorLabel="6"/>
                  <outline text="Within each color category, typically &quot;introduction&quot;-esque rules/equivalences/etc. will come first, then &quot;elimination&quot; ones."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Logical connectives](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4c53ztjrA-5-dTCfvBk6ryLz)" heading="1" colorLabel="5"/>
                </outline>
              </outline>
              <outline text="Proofs" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A deductive proof is a logical argument that establishes the truth of a conclusion based on the truth of one or more premises, using established rules of inference and previously accepted axioms or theorems."/>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="&quot;There are no married bachelors&quot;."/>
                    <outline text="^ This statement can be deductively proven given the definitions of &quot;married&quot; and &quot;bachelor&quot;. "/>
                  </outline>
                </outline>
                <outline text="[Proof methods](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ElPBHwauxQxXIJg4H7SMO-9E)" heading="1" colorLabel="3"/>
              </outline>
              <outline text="Formal contradictions" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="When multiple [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio) entail (directly or indirectly) that one proposition is both true and false." collapsed="true"/>
                  <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                    <outline text="This is different from a colloquial definition of &quot;contradiction&quot; which only requires that two things be very unlikely to both be true."/>
                    <outline text="This is different from a colloquial definition of &quot;contradiction&quot; which is synonymous with &quot;paradox&quot;."/>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Recognizing them can be hard sometimes because of [vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)"/>
                  <outline text="Recognizing them can often be hard because of how indirect they can be." collapsed="true">
                    <outline text="Examples" heading="3" colorLabel="6"/>
                    <outline text="Sat solver" _note="Link" heading="3" colorLabel="5"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Natural deduction" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="In logic and proof theory" heading="3"/>
                  <outline text="^ A kind of proof calculus in which logical reasoning is expressed by inference rules closely related to the &quot;natural&quot; way of reasoning."/>
                  <outline text="Specifically: A [syntactic proof system](https://en.wikipedia.org/wiki/Propositional_calculus#Syntactic_proof_systems) which assumes inference rules as primitives." _note="Link Inference rules, create a definition for primitive and maybe section/definition for syntactic proof system."/>
                  <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                    <outline text="This contrasts with [Hilbert-style systems](https://en.wikipedia.org/wiki/Hilbert_system), which instead use axioms as much as possible to express the logical laws of deductive reasoning."/>
                  </outline>
                </outline>
                <outline text="Undischarged assumptions" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="In natural deduction" heading="3"/>
                    <outline text="^ A premise or hypothesis in a proof that remains (at least at some relevant point(s)) active and unremoved."/>
                    <outline text="If a proof contains undischarged assumptions, it establishes that the conclusion follows from those assumptions, rather than being a standalone truth derived solely from axioms."/>
                    <outline text="Example" heading="3" colorLabel="6"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3" colorLabel="4"/>
                    <outline text="**Very relevant to final conclusion**" colorLabel="4" collapsed="true">
                      <outline text="If assumptions are not discharged (removed) by inference rules like Implication Introduction or Reductio Ad Absurdum, the conclusion is only true relative to those assumptions, not universally." _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Vacuous discharge" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The process of removing an assumption even if it was not used in the parent derivation."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3" collapsed="true">
                          <outline text="Permissible in classical logic. " colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Deductive consequence (⊢)" _note="I don&apos;t think this is specific to natural deduction, should probably be conbined with material implication or whatever?" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text=""/>
                    <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Syntactic consequence (⊢)"/>
                      <outline text="Material implication (-&gt;)"/>
                    </outline>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Semantic consequence (⊨)" _note="Create section and link"/>
                    </outline>
                  </outline>
                  <outline text="Inference bar" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A line separating a conclusion from premises in a proof."/>
                    <outline text="**Typically:**   Placed under premises and over a conclusion."/>
                    <outline text="Synonyms" heading="3" collapsed="true">
                      <outline text="Inference line"/>
                      <outline text="[Therefore (∴)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PrGbhUbVHDmySbRlLQFOymuL)"/>
                    </outline>
                  </outline>
                  <outline text="Therefore (∴)" _note="Maybe" heading="3" colorLabel="3"/>
                  <outline text="Comma (,)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="In a deductive consequence" heading="3"/>
                    <outline text="^ A separation between premises."/>
                  </outline>
                </outline>
                <outline text="Styles" heading="1" colorLabel="5" collapsed="true">
                  <outline text="Fitch-style" heading="2" colorLabel="5" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A style which uses vertical lines instead of numbers to keep track of undischarged assumptions."/>
                      <outline text="It is a style characterized by:"/>
                      <outline text="^ Its linear presentation of the proof, instead of presentation as a tree."/>
                      <outline text="^ Subordinate proofs, where assumptions could be opened within a subderivation and discharged later."/>
                    </outline>
                  </outline>
                  <outline text="Suppes-Lemmon-style" heading="2" colorLabel="5" collapsed="true">
                    <outline text="Standard form" _note="Standard form may be a subset, superset or alias to &quot;Lemmon-style&quot;." heading="3" colorLabel="5" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="1. An argument in standard form puts the premises first, and the conclusion last."/>
                        <outline text="2. The premises and conclusion are labelled, so they can be referred to easily."/>
                        <outline text="3. An [inference bar](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b_n_5bwCeuL3a3P8Dih3GYkW) is placed between the premises and the conclusion." _note="&quot;Therefore&quot; should get its own section probably." collapsed="true">
                          <outline text="The inference bar indicates that the conclusion is intended to follow from the premises above it."/>
                          <outline text="It&apos;s essentially synonymous with the &quot;therefore&quot; symbol (∴)."/>
                        </outline>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Informal:" heading="3"/>
                          <outline text="^ __There’s no need to stop using fossil fuels unless climate change is real. But climate change is fake. So there’s no need to stop using fossil fuels.__"/>
                          <outline text="Standard form:" heading="3"/>
                          <outline text="^ P1) There’s no need to stop using fossil fuels unless climate change is real."/>
                          <outline text="^ P2) Climate change is fake"/>
                          <outline text="^ \_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_"/>
                          <outline text="^ C) There’s no need to stop using fossil fuels."/>
                          <outline text=""/>
                          <outline text="Note that the ‘So’ that indicates the conclusion has been left out of the standard form. " collapsed="true">
                            <outline text="That’s because its role is to indicate where the conclusion is."/>
                            <outline text="It is not part of the content of the statement the arguer is trying to get you to believe. "/>
                          </outline>
                          <outline text="Because there are multiple premises, we number them." collapsed="true">
                            <outline text="It does not matter what order you put the premises in, in relation to one another."/>
                          </outline>
                          <outline text="In standard form, the premises must occur above the conclusion they are intended to support."/>
                        </outline>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="**Easier to assess validity:**   Standard form makes it easier to assess the [validity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa) of arguments." _note="Copy to formal deduction" colorLabel="4" collapsed="true">
                          <outline text="The standard form of an argument is the stripped-down version of the argument that has the pure reasoning involved, without any of the unnecessary rhetoric." colorLabel="4" collapsed="true">
                            <outline text="This allows for the argument to be assessed on its merits as an argument alone." colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="Slow" _note="Move to formal deduction" heading="3" colorLabel="1" collapsed="true">
                          <outline text="**Slow creation:**   Creating standard form arguments tends to take longer." colorLabel="4" collapsed="true">
                            <outline text="We tend to be much more accustomed to dealing with [informal arguments](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8GzHVvJUrHROzdmXaF07m4cE) than formal ones." _note="Likelihood" colorLabel="4"/>
                          </outline>
                          <outline text="**Slow translation:**   Translating informal arguments to standard arguments usually takes a bit." colorLabel="4" collapsed="true">
                            <outline text="[We tend to be much more accustomed to informal arguments than formal ones](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0tkEVCykyWK_o8Looww3IbS1)" _note="Likelihood" colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="[Importance of informal arguments](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PF8RPRZIZSNuaZyC6TP5UpKu)" _note="Move to formal deduction" heading="3" colorLabel="2" collapsed="true">
                          <outline text="The main alternative to formal deduction." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="Translating informal to standard form" heading="2" colorLabel="2" collapsed="true">
                        <outline text="The statements occurring in standard form are often rephrased so that they express their content in a straightforward way." heading="3" collapsed="true">
                          <outline text="In ordinary language, people sometimes use questions or commands to communicate statements. When we put the argument into standard form, we rephrase them as statements."/>
                          <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                            <outline text="Suppose someone says:"/>
                            <outline text="__University education was free for our parents’ generation. Shouldn’t it be free for us?__"/>
                            <outline text="This is an argument: the person is trying to persuade you of something, and they are giving a reason. The reason is “University education was free for our parents’ generation”. “Shouldn’t it free for us?” has the form of a question, but it’s being asked rhetorically. The person who gave the argument is not asking a sincere question: they are using the question to make a point. The statement the arguer intends is “University education should be free for us”. When we put the argument into standard form, each premise and conclusion is rephrased so that it is expressed as a statement."/>
                            <outline text="P1) University education was free for our parents’ generation."/>
                            <outline text="\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_"/>
                            <outline text="C) University education should be free for us."/>
                            <outline text="Rhetorical questions are one common way of making statements in ordinary language. Also common is expressing statements as commands. So, someone might say:"/>
                            <outline text="__University education was free for our parents’ generation. Make it free for us!__"/>
                            <outline text="Once again, a correct standard form rendition of the argument will rephrase the command as a statement, resulting in the same formal argument shown above."/>
                          </outline>
                        </outline>
                        <outline text="Each statement should be complete in itself." heading="3" collapsed="true">
                          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                            <outline text="Each statement is expected to be assessable on its own, so that both the [Validity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa) and [Soundness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3idCayhSSV8FPYu2R0U8ShgA) can be assessed in a systematic manner." colorLabel="4"/>
                          </outline>
                          <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                            <outline text="Consider the following argument:"/>
                            <outline text="__Barack Obama was a great president. He was always dignified and composed.__"/>
                            <outline text="The sentence “He was always dignified and composed” is incomplete, because we don’t know, when considering the sentence by itself, who is referred to by “he”. To make the statement complete, all we need to do is replace the “he” with the person it stands for. This is clear from the context. So, in standard form:"/>
                            <outline text="P1) Barack Obama was always dignified and composed."/>
                            <outline text="\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_"/>
                            <outline text="C) Barack Obama was a great president."/>
                          </outline>
                        </outline>
                        <outline text="Omitting rhetoric" heading="3" collapsed="true">
                          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                            <outline text="Common" heading="3" collapsed="true">
                              <outline text="It is often the case that putting an argument into standard form will require omitting a lot of what was said." colorLabel="4"/>
                            </outline>
                          </outline>
                          <outline text="Useful questions to ask during this process" heading="2" colorLabel="2" collapsed="true">
                            <outline text="What is the person trying to persuade me of?"/>
                            <outline text="What reasons do they give to support that?"/>
                          </outline>
                          <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                            <outline text="Informal:" heading="3"/>
                            <outline text="^ __Vegans are a bunch of puppy-kissing tree-huggers. They seem to think everybody should be vegan just because they are. Everyone is entitled to their own opinion. Besides, they give lousy reasons for being vegan: just as many animals are hurt through harvesting of plants as die in animal farming. __"/>
                            <outline text="The conclusion is not explicitly stated here, but the main reason is clear."/>
                            <outline text="Formal:" heading="3"/>
                            <outline text="^ P1) Just as many animals are hurt through harvesting of plants as die in animal farming."/>
                            <outline text="\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_"/>
                            <outline text="^ C) It is not the case that everyone should be vegan."/>
                            <outline text=""/>
                            <outline text="You may think something is missing from the above argument. You are right. In chapter 3 we will look at how to make such standard form reconstructions more complete. Before we do so, we need to look at one important aspect of what makes a good argument: [validity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa)." _note="Yoink more from https://oercollective.caul.edu.au/howtothinkcritically/front-matter/introduction/ to resolve this part."/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                        <outline text="https://oercollective.caul.edu.au/howtothinkcritically/chapter/standard-form/"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Gentzen-style" heading="2" colorLabel="5"/>
                </outline>
                <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Natural_deduction)"/>
                </outline>
              </outline>
              <outline text="Calculators" heading="1" colorLabel="2" collapsed="true">
                <outline text="[Proof tree generator](https://www.umsu.de/trees/)"/>
              </outline>
              <outline text="Truth tables" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Deductive inference](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MI_c1LeOvIF4S3rpndRAJvN7)" heading="1" colorLabel="5"/>
              <outline text="[Circularity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_)" heading="1" colorLabel="5"/>
              <outline text="[Input and output](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0lkGqtFKIOTHROwtUM-xYXtp)" heading="3" colorLabel="5"/>
            </outline>
          </outline>
          <outline text="Useful deductive tools" _note="Rename this" heading="1" colorLabel="2" collapsed="true">
            <outline text="[Specific proof methods](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ElPBHwauxQxXIJg4H7SMO-9E)" heading="3" colorLabel="6"/>
          </outline>
          <outline text="Theorems" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="A statement that can be proven with no [undischarged assumptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gQd6miuzU7YbR72h0S0y_wGb) (i.e., all assumptions are discharged)."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3"/>
              <outline text="Impactful" heading="3"/>
            </outline>
            <outline text="The law of excluded middle" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="All [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) must either be true or false."/>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="The definition of [well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk)." _note="This feels wrong, because it feels like &quot;well-defined proposition&quot; should be defined more in terms of lacking ambiguity than having a definitive true/false state. The latter seems more like a necessary consequence than a definition to me. But given the definition I put together based on similar terms, this seems right, so I&apos;ll leave it for now."/>
                <outline text="Assuming the above doesn&apos;t work, there is also this natural deduction proof:" colorLabel="6"/>
                <outline text="1. | -(P v -P) (assumption)"/>
                <outline text="2. | | P (assumption)"/>
                <outline text="3. | | (P v -P) (putting 2 in an &apos;or&apos;)"/>
                <outline text="4. | | False (contradiction with 1)"/>
                <outline text="5. | -P (proof by contradiction, 2-4)"/>
                <outline text="6. | (P v -P) (putting 5 in an &apos;or&apos;)"/>
                <outline text="7. | False (contradiction with 1)"/>
                <outline text="8. --(P v -P)     (proof by contradiction, 1-7)"/>
                <outline text="9. P v -P     (double negation, 8)"/>
              </outline>
            </outline>
          </outline>
          <outline text="Source" heading="3" colorLabel="6" collapsed="true">
            <outline text="[Logic 101 by William Spaniel](https://www.youtube.com/watch?v=JBjAyrX7wms&amp;list=PLKI1h_nAkaQq5MDWlKXu0jeZmLDt-51on)" heading="3" collapsed="true">
              <outline text="A good youtube series teaching formal deduction from the ground up."/>
            </outline>
          </outline>
          <outline text="Related" heading="3" colorLabel="6" collapsed="true">
            <outline text="[Practical techniques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yQVWivooam-CWEWkiSH8D5Gu)" heading="1" colorLabel="2" collapsed="true">
              <outline text="Standard deduction plays a major role in most of informal reasoning."/>
            </outline>
          </outline>
        </outline>
        <outline text="Probabilistic reasoning" heading="1" colorLabel="4" collapsed="true">
          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
            <outline text="A variety of methods of reasoning in which the conclusion of an argument is supported at best with some degree of probability*." collapsed="true">
              <outline text="Probability: Almost always [credence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Ms3v8Y2fFiAIyYnOmUc4oHN), but very occasionally [propensity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vMm_PqTAjUdjIqlIjPZWSXDO) depending on the context."/>
            </outline>
            <outline text="Distinct from [standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)" heading="3" colorLabel="3" collapsed="true">
              <outline text="In probabilistic reasoning, the conclusion does not [follow with certainty when the argument is valid and sound] like it does in deduction." collapsed="true">
                <outline text="This doesn&apos;t mean that there isn&apos;t any uncertainty involved when using standard deduction." colorLabel="3" collapsed="true">
                  <outline text="[We cannot ever know for certain that an argument is valid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=p3smzzmZMepqF12QT_zfXcHm)" colorLabel="1"/>
                  <outline text="[We cannot ever know for certain that an argument is sound](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TPYM2ig0UCPesToWq2uW4E_R)" colorLabel="1"/>
                </outline>
                <outline text="And the reasoning justifying the probabilistic inference rules can be reduced to standard deduction, so ultimately probabilistic reasoning is still reducible to deduction." colorLabel="3" collapsed="true">
                  <outline text="[Reducible](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yXZAWKV-nCFCPsJYuYLsJUX_)" heading="3" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Eg. [Mathematical induction](https://en.wikipedia.org/wiki/Mathematical_induction)" colorLabel="6" collapsed="true">
                <outline text="Kind of deceptively named, since it&apos;s actually a form of standard deduction and not induction as defined [here](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IySr180_V91UYqUgHnPhcp4n)."/>
              </outline>
            </outline>
          </outline>
          <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
            <outline text="Common" heading="3" collapsed="true">
              <outline text="A massive portion of reasoning is probabilistic." colorLabel="4"/>
            </outline>
            <outline text="Impactful" heading="3" collapsed="true">
              <outline text="Probabilistic reasoning can never justify literal absolute certainty." colorLabel="1"/>
              <outline text="Typically if all the main easily accounted for factors are taken into account, probabilistic reasoning cannot justify a very high or low probability." colorLabel="1"/>
            </outline>
            <outline text="Improvable" heading="3" collapsed="true">
              <outline text="There&apos;s a lot of very impactful and typically improperly or inadequately taught aspects of probabilistic reasoning that are taught better here." _note="Will be*, once the guide is much more complete." colorLabel="4"/>
            </outline>
            <outline text="Difficult" heading="3" collapsed="true">
              <outline text="[Probabilistic biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CGI6yCYSAdy8jsILM1rD8Wsw)" heading="3" colorLabel="4"/>
            </outline>
          </outline>
          <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
            <outline text="Probabilistic reasoning should typically be thought of as the weaker, less reliable but often more widely available sibling to [standard deductive reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)." collapsed="true">
              <outline text="While standard deductive reasoning is by no means rarely applicable, there are a vast amount of important situations in which exclusively standard deduction cannot take you all the way to a useful conclusion, but alongside probabilistic reasoning, can."/>
              <outline text="[Inductive reasoning typically can&apos;t justify a very low/high probability for much](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2zYOk8AVyLM5FCI87pKT-BdJ)"/>
            </outline>
            <outline text="[Probabilistic reasoning is reducible to deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yXZAWKV-nCFCPsJYuYLsJUX_), it just isn&apos;t regarded as a part of standard deduction."/>
          </outline>
          <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
            <outline text="It&apos;s just a useful higher level of abstraction, so we don&apos;t have to deal with so many deductive steps all the time."/>
            <outline text="All probabilistic reasoning is just the [deductive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-n8BacOsj9yIbpLxsbz4df8M) application of some axioms, with the uncertainty coming from the [principle of induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=u6QOAA3CMaWyvXF8U03DcNth) (or similar) and the [semi-reliability of mental faculties](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b_aWAORb1OU0XVl_fRpRpFsj)"/>
            <outline text="Known associations" heading="3" colorLabel="5" collapsed="true">
              <outline text="Using the uncertain definition of &quot;known&quot;." colorLabel="3" collapsed="true">
                <outline text="[Know (probability)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TnFde8i_liH0vcSg8sIc-HEA)"/>
              </outline>
            </outline>
          </outline>
          <outline text="Induction" _note="Add stuff from https://en.wikipedia.org/wiki/Inductive_reasoning" heading="1" colorLabel="4" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="the process of inferring some general principle from a body of knowledge, where the principle does not necessarily follow from the body of knowledge." collapsed="true">
                <outline text="The body of knowledge might give us very good reason to accept the principle, but never ensures it for certain."/>
              </outline>
              <outline text="Example: White/black swans" heading="3" colorLabel="6" collapsed="true">
                <outline text="If all swans that a person has observed so far are white, they may infer a universal categorical proposition of the form &quot;All swans are white&quot;. They have good reason to believe the conclusion from the premise because it is the best explanation for their observations, but the truth of the conclusion is not guaranteed. Indeed, it turns out that [some swans are black](https://en.wikipedia.org/wiki/Black_swan)."/>
              </outline>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3"/>
              <outline text="Impactful" heading="3"/>
              <outline text="Improvable" heading="3" collapsed="true">
                <outline text="Most people tend to apply a lot of specific and selective forms of induction, but tend discount many broad and abstract forms without good reason." colorLabel="4" collapsed="true">
                  <outline text="[Bias towards the specific/&quot;grounded&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" heading="3" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Fundamentals" heading="1" colorLabel="6" collapsed="true">
            <outline text="Important definitions: [credence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=udaRfJbExQFcuWIonQ7Ij8VV) and [plausibility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LGQrLMSvzhsoMTLjitCCpiK4)" heading="3" colorLabel="3"/>
            <outline text="Probabilistic axioms" heading="1" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Fundamental rules about probability."/>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Not necessarily unsupported like some definitions of &quot;axioms&quot;."/>
                </outline>
              </outline>
              <outline text="The probability of all events are non-negative real numbers" heading="3"/>
              <outline text="Assumption of unit measure" heading="3" collapsed="true">
                <outline text="The probability [that at least one of the elementary events in the entire sample space will occur] is 1."/>
              </outline>
              <outline text="σ-additivity" heading="3" collapsed="true">
                <outline text="https://en.wikipedia.org/wiki/Sigma-additive_set_function"/>
              </outline>
            </outline>
            <outline text="Evidence" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Here defined as information that epistemically supports a proposition." collapsed="true">
                  <outline text="This includes all information that epistemically opposes propositions, since for any proposition there is a negation." collapsed="true">
                    <outline text="If X opposes Y, then X supports the proposition &quot;Y is false&quot;."/>
                  </outline>
                </outline>
                <outline text="Often defined more narrowly, like information that epistemically supports a proposition by a quite substantial amount."/>
              </outline>
            </outline>
            <outline text="Principle of indifference" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The principle that in the absence of any relevant evidence, agents should distribute their credence (or &quot;degrees of belief&quot;) equally among all the possible outcomes under consideration."/>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Principle of insufficient reason"/>
                </outline>
              </outline>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="The principle of indifference tends to work well." colorLabel="4"/>
                  <outline text="A uniform distribution typically requires fewer assumptions than other distributions." colorLabel="4" collapsed="true">
                    <outline text="[Occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT)" _note="Relevance" heading="3" colorLabel="4"/>
                  </outline>
                  <outline text="Only works for cases where we have no information to favor any particular outcome." colorLabel="1" collapsed="true">
                    <outline text="Only works for cases where the possibility spaces of each of the considered possibilities are the same size." collapsed="true">
                      <outline text="[Occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT)" heading="3" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Reducible" _note="Ideally be more specific here." heading="3" colorLabel="5" collapsed="true">
                <outline text="A proof by contradiction using fundamental axioms of probability."/>
                <outline text="If we are to assign a greater probability than 1/possibilities without any evidence, it would seem to result in a contradiction with said axioms."/>
              </outline>
              <outline text="Advanced usage" heading="1" colorLabel="2" collapsed="true">
                <outline text="Breaking down [more complex cases where this principle cannot be applied] into multiple cases, in which some can have the principle applied."/>
              </outline>
            </outline>
            <outline text="50% default" _note="Intermediate" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The concept that every [well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) should be assigned 50% credence in the absence of any (other) information."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Can be very useful for systematically deriving probabilities, as it encourages accounting for every relevant factor explicitly." colorLabel="4"/>
                <outline text="If not all substantial intuitive factors are explicitly accounted for, the result of starting from the beginning may be worse than if we hadn&apos;t bothered." colorLabel="1" collapsed="true">
                  <outline text="It would typically still be more accurate, even in these cases." _note="Impact" colorLabel="1" collapsed="true">
                    <outline text="Our intuition is very unreliable." _note="Link" colorLabel="4"/>
                  </outline>
                  <outline text="It&apos;s usually not too difficult to account for all substantial intuitive factors." _note="Likelihood" colorLabel="1" collapsed="true">
                    <outline text="Our minds are typically (almost definitionally) quite ready to offer intuitive factors when we look for them." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Reducible" _note="This isn&apos;t quite complete, but probably close enough for a while." heading="3" colorLabel="5" collapsed="true">
                <outline text="**Premise 1:**   50% of [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) are true, and 50% are false." collapsed="true">
                  <outline text="**Premise 1:**   50% of [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) are the inverse of the other 50% of [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk)." collapsed="true">
                    <outline text="All [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) have exactly one inverse."/>
                    <outline text="[Premise 2: A well-defined proposition must either be true or false (i.e. the law of excluded middle)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WDTpuNbZvVZczhTDp2Hel6uT)"/>
                  </outline>
                  <outline text="**Premise 2:**   A [well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) must either be true or false. (i.e. https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=V99dOKyaHrazTWcoUt-ly_eC)"/>
                  <outline text="**Premise 3:**   The inverse of a true [well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) is a false [well-defined proposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oa2Z9ESPYZwu46VM4MvmxUAk) and vise versa. ([definition of inverse](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j3H0k5NrgqqJ2__9SgtP8ngy))"/>
                </outline>
                <outline text="**Premise 2:**   [Principle of indifference](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nwdnsuvq_ylA7Zc7YVfSoowC)"/>
                <outline text="**Conclusion:**   Well-defined propositions have (without accounting for any other information) a 50% chance of being true and a 50% chance of being false."/>
              </outline>
              <outline text="Objections" heading="3" colorLabel="1" collapsed="true">
                <outline text="What about cases where it&apos;s quite obvious that something has &lt;50% likelihood, even when we&apos;re running blind?" collapsed="true">
                  <outline text="**Example:**   we have no information about [Russell&apos;s teapot](https://en.wikipedia.org/wiki/Russell&apos;s_teapot), but we all obviously believe that there is no such teapot." colorLabel="6" collapsed="true">
                    <outline text="It seems like when considering the likelihood of Russell&apos;s teapot, our assignment of a low probability is based on evidence."/>
                    <outline text="For example it seems like the main reason is abductive. It would simply be much simpler to suppose that no such teapot existed, because supposing that it is there seems to require a greater number of assumptions." _note="Link to relevant abduction section(s) maybe?"/>
                    <outline text="Russell&apos;s Teapot is typically used to support the concept of a burden of proof, which is often a misleading heuristic, see &lt;section to be linked&gt; for more info on why."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="The law of complement" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="p(a) = 1 - p(not a)"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Calculating the inverse [is frequently useful] [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=85SVn5HckMK8xnoDd9V9eo0P)"/>
              </outline>
            </outline>
            <outline text="Zipf distribution of evidence weight" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The distribution of weight for different pieces of evidence for a given hypothesis tends to follow [Zipf&apos;s law](https://en.wikipedia.org/wiki/Zipf%27s_law)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="The authors of this guide have consistently observed this." _note="Likelihood" colorLabel="4"/>
                  <outline text="[Zipf&apos;s law]([Zipf&apos;s law](https://en.wikipedia.org/wiki/Zipf%27s_law)) supports this." _note="Likelihood" colorLabel="4"/>
                  <outline text="[Possible to resolve virtually any disagreement with reasonable people](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r1Q6C5LxLgbQ2nrTGTq2hC-G) thanks in part to this." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="It drastically limits the median amount of possible relevant irriducible disagreements that have to be explored to resolve the initial disagreement." _note="Likelihood | Maybe move elsewhere in &quot;zipf distribution of evidence weight&quot; importance and link here? | Link definition to &quot;irreducible disagreement&quot;." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Abduction" heading="1" colorLabel="4" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Abduction is a form of logical inference that seeks the simplest and most likely conclusion from a set of observations." _note="Look into whether &quot;simplest&quot; is defined specifically or broadly."/>
              <outline text="Compared to other forms of probabilistic reasoning" heading="3" collapsed="true">
                <outline text="While induction draws general conclusions that apply to many situations, abductive conclusions are confined to the particular observations in question." _note="Link induction"/>
              </outline>
              <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                <outline text="Abductive reasoning"/>
                <outline text="Abductive inference"/>
                <outline text="Retroduction"/>
              </outline>
              <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Abductive_reasoning)" heading="3" colorLabel="3"/>
              <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                <outline text="Two friends frequently go jogging together. They have a major argument, and therefore a falling out. However, the next week, you see them jogging together again, and assume they made up." collapsed="true">
                  <outline text="Source: https://rationalwiki.org/wiki/Reasoning"/>
                </outline>
                <outline text="Observing a billiard game and seeing the &apos;eight&apos; ball moving towards us, and abducing that the cue struck the ball." collapsed="true">
                  <outline text=""/>
                  <outline text="Source: https://rationalwiki.org/wiki/Reasoning"/>
                </outline>
              </outline>
            </outline>
            <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
              <outline text="An often helpful form of probabilistic reasoning."/>
            </outline>
            <outline text="Explanation / hypothesis" _note="Probably incorporate &quot;explanation&quot; terminology in other sections where reasonable?" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A claim (or set of claims) intended to explain/account for some data."/>
              </outline>
              <outline text="Comparing explanations" heading="3" colorLabel="4"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Falsification](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bL5yJhZQHw5Ii8SveWCStaDT)" heading="3" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Prior probability" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The credence that should be given to a hypothesis before considering the main evidence." heading="3" colorLabel="3" collapsed="true">
                  <outline text="Main evidence: The main evidence that would typically* be considered." colorLabel="3" collapsed="true">
                    <outline text="* Except when the evidence that would typically be considered is [prior evidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xGudJgQHlJyk5nLoeSUyyHmN)."/>
                  </outline>
                </outline>
                <outline text="**Context:**  Otherwise known as simply &quot;prior&quot; in the right kind of probabilistic context."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="**Impactful:**  Prior probabilies are typically one of the most impactful unknowns." colorLabel="4" collapsed="true">
                  <outline text="It&apos;s [important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK) to account for unknowns." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="**Improvable:**  Obtaining the prior probability of a claim just involves looking at the ratio of scenarios under which it could be true vs couldn&apos;t be true, which is usually pretty easy to estimate." colorLabel="4"/>
              </outline>
              <outline text="Typical prior evidence" heading="2" colorLabel="4" collapsed="true">
                <outline text="Usually priors use [occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT) and nothing else." _note="Check if this is right."/>
              </outline>
              <outline text="All prior evidence" heading="1" colorLabel="4" collapsed="true">
                <outline text="[Occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT)" heading="1" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Occam&apos;s Razor" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="The problem-solving principle that recommends searching for explanations constructed with the smallest possible set of assumptions."/>
                <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The principle of parsimony."/>
                  <outline text="The law of parsimony."/>
                </outline>
                <outline text="Other relevant definitions (for other terms)" _note="Move to definitions and link here" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Broadness/simplicity and specificity/complexity" _note="Probably move to definitions but retain a copy of the definitions here." colorLabel="3" collapsed="true">
                    <outline text="How few and many (respectively) logically irreducible suppositions have to be made."/>
                    <outline text="Logically irreducible supposition" colorLabel="3" collapsed="true">
                      <outline text="A supposition that is unable to be logically reduced any further."/>
                      <outline text="Logically irreducible" colorLabel="3" collapsed="true">
                        <outline text="&quot;Logically irreducible&quot; is here defined as something like &quot;cannot be reduced to multiple smaller elements of formal logic&quot;."/>
                        <outline text="This is because without this &quot;floor&quot; on complexity, it&apos;s very unclear how to properly count the number of assumptions. And this floor is grounded in the nature of the recommended [axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Supposition" colorLabel="3" collapsed="true">
                        <outline text="&quot;Supposition&quot; is here defined as &quot;proposition that is not epistemically justified by anything aside from simplicity.&quot;"/>
                      </outline>
                      <outline text="Note that this is a different concept from metaphysical irreducibility." colorLabel="2"/>
                    </outline>
                    <outline text="Usually the terminology used is &quot;complexity&quot; and &quot;simplicity&quot;, but the definitions used in the context of Occam&apos;s razor translate roughly to measures of specificity/broadness." colorLabel="2"/>
                  </outline>
                  <outline text="Possibility" collapsed="true">
                    <outline text="In this context: events or series&apos; of events that are subjectively possible." collapsed="true">
                      <outline text="&quot;subjectively possible&quot; being defined similarly to how &quot;subjective probability&quot; is defined." collapsed="true">
                        <outline text="[Credence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Ms3v8Y2fFiAIyYnOmUc4oHN)"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Possibility space" collapsed="true">
                    <outline text="[Possibility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IRjvgIigwzwP7Ki7mU3MS4m1)"/>
                  </outline>
                </outline>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Different from &quot;The simplest answer is the correct one.&quot;, since this is not always the case."/>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Russel&apos;s Teapot](https://en.wikipedia.org/wiki/Russell%27s_teapot)" heading="3"/>
                  <outline text="Horse vs zebra" heading="3" collapsed="true">
                    <outline text="You hear hoofbeats outside, is it a horse or a zebra? Unless you live in the African savannah, it&apos;s very unlikely to be a zebra. We&apos;d need more assumptions to get there - a zebra was imported to a local zoo, it escaped captivity, and now it&apos;s running amok. Whereas a horse would typically require fewer assumptions. That doesn&apos;t mean that it __cannot__ be a zebra, it just means that the prior probability for the horse hypothesis appears to be higher."/>
                  </outline>
                  <outline text="[Left out pickles](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=P5gRs0BLZT5qdBSotopaDGaw)" heading="3"/>
                </outline>
                <outline text="For more info, visit here: [Wikipedia](https://en.wikipedia.org/wiki/Occam&apos;s_razor)" colorLabel="6" collapsed="true"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Even when it&apos;s not directly mentioned by name, you&apos;ll see it frequently pop up in terms like &quot;what, you think things just __happened__ to end up that way?&quot;" colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Reliable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Reducible](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sfhS9SmyddKtN_s1h63EzJNw) to solid principles that can be applied systematically." _note="Likelihood" colorLabel="4"/>
                    <outline text="Feels unreliable" _note="Likelihood" heading="3" colorLabel="1" collapsed="true">
                      <outline text="This is likely in part caused by the [bias towards the specific/&quot;grounded&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" _note="Relevance" colorLabel="1" collapsed="true">
                        <outline text="Occam&apos;s razor typically doesn&apos;t feel specific/solid/grounded, it feels abstract and vague." _note="Likelihood" colorLabel="4"/>
                        <outline text="[Occam&apos;s razor can be specific/grounded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sfhS9SmyddKtN_s1h63EzJNw), it just isn&apos;t typically used in a proper systematic manner." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="This guide teaches how to use it in a proper systematic manner." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Useful if reliable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Generally powerful" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Specificity can often provide a very strong case against hypotheses that seem otherwise plausible." _note="Relevance" colorLabel="4"/>
                      <outline text="^ When you add properties to a hypothesis, the probabilities of the properties initially get multiplied together, quickly resulting in a much lower prior probability." _note="Likelihood" colorLabel="4"/>
                    </outline>
                    <outline text="Rejecting the absurd" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Occam&apos;s razor is one of the most common tools we use to reject absurd hypotheses." _note="Needs to be justified" colorLabel="3"/>
                      <outline text="[Examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GEc18a_OfPkwulsQ-VCBlSVl)" heading="3" colorLabel="6"/>
                    </outline>
                    <outline text="In the absence of other evidence" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Occam&apos;s razor provides us with epistemic justification to place a lower probability on even things that lack any evidence for/against it other than complexity." colorLabel="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Reducible" _note="Make this much more clear." heading="3" colorLabel="5" collapsed="true">
                <outline text="[50% default](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=va42B5s8gXVrfWzHBQVBMPKV)" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Via the principle of indifference, we can conclude that logically irreducible assumptions should by default be considered ~50% likely. Thus the more logically irreducible assumptions are involved in a hypothesis, the more unlikely it tends to be."/>
                </outline>
                <outline text="[Induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OJSQEWGwiRo2syWQyU9FbjoE)" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Occam&apos;s razor tends to work well, so via induction we can say that it will likely continue to work well."/>
                </outline>
                <outline text="&quot;Complexity&quot; translates to possibility space size" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                    <outline text="[Possibility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IRjvgIigwzwP7Ki7mU3MS4m1)"/>
                    <outline text="[Possiblity space](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CWsm9Z1X5Oi2O7vGouwzf91b)"/>
                  </outline>
                  <outline text="The set of possibilities where a given specific possibility occurs is typically smaller than the set of possibilities where a given broader possibility occurs." collapsed="true">
                    <outline text="Because specificity/broadness tends to refer to the amount of components required for something to be the case, i.e. the number of set divisions specified."/>
                  </outline>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="If there&apos;s a ball in a box and that ball could be any of the 7 colors of the rainbow and you have pretty much no reason to think that it&apos;s more likely to be any particular color, then you should place an equal probability on all colors, meaning they all have a 1/7 chance of being the color of the ball."/>
                    <outline text="The hypothesis &quot;the ball is not red&quot; is less specific than the hypothesis &quot;the ball is red&quot;. The latter is more specific, so the set of possibilities where the ball is red is smaller (1) than the set of possibilities where the ball is not red (6)."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Common razor heuristics" _note="Current WIP" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Common heuristics derived from Occam&apos;s Razor."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="[They are semi-unreliable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hegnfC1UpNvGubdE73TD6Nz_)" colorLabel="1"/>
                  </outline>
                  <outline text="Improvable" heading="3" collapsed="true">
                    <outline text="Your reasoning has likely been influenced at least a bit by bad ones." colorLabel="4" collapsed="true">
                      <outline text="They are commonly used and internalized in some form or another." _note="Likelihood" colorLabel="4"/>
                      <outline text="These heuristics are largely pretty unreliable." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="[reliability of &quot;first prioritize simplicity&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Rr2KTtxTD333wxnIG5iUuJS3)" _note="Likelihood" colorLabel="1"/>
                        <outline text="[Reliability of &quot;equally/similarly&quot; heuristic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Blzzv6-2lynscjLgGgbUxKt-)" _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Only applies to hypotheses that explain observations equally/similarly well" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Occam&apos;s Razor does not apply when one theory explains observations better."/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Quantum mechanics is more complicated than Newtonian mechanics, but it explains certain observations better, so Occam&apos;s razor doesn&apos;t apply." collapsed="true">
                        <outline text="It&apos;s not quite as obvious as one might expect that QM is more complex than Newtonian physics." colorLabel="1" collapsed="true">
                          <outline text="Most of the complexity of QM that we&apos;re familiar with is emergent from much simpler rules." _note="Likelihood" colorLabel="4"/>
                          <outline text="Much of QM is made much less comprehensible by the fact that it involves a kind of probabilistic process that&apos;s very unfamiliar to us." _note="Likelihood" colorLabel="4"/>
                        </outline>
                        <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rcyeuef9zWsNYMnUImsDLk7a" colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Occam&apos;s Razor should often apply at least somewhat in cases where relative explanatory power has more impact on the posterior probability than relative prior probability." _note="Link explanatory power and prior probability" colorLabel="1" collapsed="true">
                        <outline text="The prior probability often still has enough of an impact on the posterior that it&apos;s worth taking into account." _note="Likelihood" colorLabel="4"/>
                        <outline text="^ Even a difference of 1 assumption  means one side has at least twice the relative prior probability as it had before." _note="Likelihood | Not sure about this" colorLabel="4"/>
                      </outline>
                      <outline text="It&apos;s very rare that we reason about two hypotheses for more than a few moments and justifiably find that they explain the relevant observations exactly equally well." _note="Should likely support" colorLabel="1" collapsed="true">
                        <outline text="This doesn&apos;t address the &quot;similarly well&quot; interpretation of the heuristic." _note="Relevance" colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Rr2KTtxTD333wxnIG5iUuJS3" heading="1" colorLabel="2"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="3" colorLabel="5"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Theoretical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a__A4WdOE_LwKq1rrTZjz2Rm)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Occam&apos;s razor is a form of theoretical reasoning." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Bayesian inference" _note="~~Adept" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Bayesian inference is a specific method for calculating a probability of a hypothesis given prior evidence and new information."/>
                <outline text="The hypothesis is sometimes referred to as an unobserved variable." _note="I think"/>
                <outline text="**Inverse probability** is an old term for the probability distribution of an unobserved variable. " colorLabel="3"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Very generalizable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Bayesian inference can be generalized to many different kinds of problems, many of which involve unintuitive correct answers and intuitive incorrect answers, so it is a powerful way to overcome our intuitive limitations when it comes to probabilities." _note="Split" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="We make it easy to use" heading="3" colorLabel="4" collapsed="true">
                    <outline text="We provide calculators and teach how to use them." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Calculators" heading="1" colorLabel="5" collapsed="true">
                <outline text="You can use [this Bayesian calculator](https://www.desmos.com/calculator/k7ggs7wm2z) to more intuitively grasp how it works and more easily perform Bayesian reasoning." _note="There are likely better calculators out there so if anyone finds them, please let me know." collapsed="true">
                  <outline text="The way to use it is:"/>
                  <outline text="1. Assign the prior probability (the probability of a given hypothesis before accounting for whatever new information you want to account for) by dragging the black dot near the bottom to the appropriate place (eg. 0.1 = 10%)."/>
                  <outline text="2. Adjust the hypothesis&apos; probability given the new info (without accounting for the prior) by dragging the yellow dot on the left to the appropriate place."/>
                  <outline text="3. Adjust the probability of the hypothesis being false given the new information (without accounting for the prior) by dragging the blue dot on the right to the appropriate place."/>
                  <outline text="After this, the bar at the bottom will tell you how probable the outcome is. "/>
                  <outline text="You can drag the black circle to that spot and repeat the process if you have another piece of new info that you would like to calculate on top of all the other info as well."/>
                </outline>
              </outline>
              <outline text="Informal usage" heading="1" colorLabel="1"/>
              <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Bayesian_inference)"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6">
                <outline text="[Plausiblity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LGQrLMSvzhsoMTLjitCCpiK4)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The primary definition of &quot;probability&quot; used in bayesian inference."/>
                </outline>
                <outline text="[Propensity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FSrVYvon6XRX2Q4b71AMcYhc)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Another definition of &quot;probability&quot; that can be used in bayesian inference." _note="I think"/>
                </outline>
              </outline>
            </outline>
            <outline text="Useful abductive arguments" heading="1" colorLabel="2" collapsed="true">
              <outline text="The uniformity of nature" heading="3" colorLabel="4" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
              </outline>
            </outline>
            <outline text="The credence of typical coincidences" heading="2" colorLabel="2" collapsed="true">
              <outline text="[This video](https://www.youtube.com/watch?v=sHCHEykUxP4) does a decent job of giving a good intuition for how to think of coincidences and their probabilities."/>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Practical techniques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yQVWivooam-CWEWkiSH8D5Gu)" heading="1" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="General tips" _note="Fix this, move some into inductive biases" heading="1" colorLabel="2" collapsed="true">
            <outline text="**Calculating the inverse:**   Frequently when trying to find the probability of an event, it is most easy to calculate the probability of the event *not* occurring and then deriving the probability of it occurring using [the law of complement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YyCP6IBRSC05LETZJBFlZhDM)." _note="&quot;Inverse&quot; might cause some confusion here, due to [inverse probability](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8OQGdiSyGCTa9RInC0du0vng)." colorLabel="2"/>
            <outline text="Multiple events of a certain probability cannot simply have their probabilities added together unless the events are disjoint (mutually exclusive)." _note="Make sections for disjoint and conjoint(?) events, and how to calculate probabilities as a result. And create a section for the inductive bias involved in trying to add probabilities together when they are not mutually exclusive." collapsed="true">
              <outline text="Otherwise, rolling a 6 sided dice 6 times would guarantee a 100% chance of rolling a 6 once."/>
            </outline>
            <outline text="**Compounding uncertainty:**   In almost all cases, all else being equal, the more steps that are involved in any kind of reasoning, the more uncertainty carries into the conclusion." _note="Likely link this in many places." collapsed="true">
              <outline text="This is because all propositions (including most inference rules) aside from [axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd) rely on:" _note="Make a section for inference rules, probably under [Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)."/>
              <outline text="^ The [semi-reliability of mental faculties](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b_aWAORb1OU0XVl_fRpRpFsj) (which, due it to being &quot;**semi**-reliability&quot;, always has some uncertainty)." collapsed="true">
                <outline text="Example:" _note="Move or link this example in [Deduction (broad)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-n8BacOsj9yIbpLxsbz4df8M)." heading="3" colorLabel="6"/>
                <outline text="When making [deductive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-n8BacOsj9yIbpLxsbz4df8M) arguments, we often like to say &quot;so long as the premises are true and the argument is valid, the conclusion is certain!&quot;"/>
                <outline text="^ In itself, this is true. However the implication is often something more like &quot;so long as we have a high confidence in the premises and a high confidence in the validity of the argument, we can know for certain that the conclusion is true!&quot;, which is obviously quite questionable." collapsed="true">
                  <outline text="It is very possible (and common) for people to accidentally create invalid arguments or rely on premises that really seem true at first glance, but on closer inspection are plausibly false. Deduction provides &quot;certainty&quot; only in an idealistic sense, or often a &quot;high probability&quot; sense. Practically it only provides a stronger inductive argument (eg. &quot;you suppose that your mental faculties are semi-reliable and you can&apos;t see a problem with this deductive argument, so you would agree that it&apos;s probably true, right?&quot;)."/>
                </outline>
              </outline>
              <outline text="^ And/or the [principle of induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=u6QOAA3CMaWyvXF8U03DcNth) (or similar alternatives). Which also has some uncertainty, due to the fact that we (ostensibly) do not make infinite observations."/>
            </outline>
            <outline text="Common probabilistic errors" _note="Maybe just move the stuff in here into the parent category." heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Common probabilistic errors or areas where probabilistic errors often arise."/>
              </outline>
              <outline text="[False cause](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0W3UbrW6nEPQtBlFnsKqSbXT)" heading="1" colorLabel="2"/>
              <outline text="[Lacking evidence ≠ false](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PoAcoW2P9Q9L6hiLGzVECWql)" heading="3" colorLabel="4" collapsed="true">
                <outline text="The failure to consistently account for this."/>
              </outline>
            </outline>
            <outline text="Prioritize more likely hypotheses" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The strategy of prioritizing hypotheses that initially appear to be more likely."/>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Left out pickles" heading="3" collapsed="true">
                    <outline text="A man goes into his kitchen and sees a jar of pickles left out on the counter. He knows it wasn&apos;t him, which left two possibilities that their mind initially came up with:"/>
                    <outline text="1. A burglar broke in, stole several other items, and __also__ ate a pickle. He left the jar out to taunt the owner."/>
                    <outline text="2. The man&apos;s wife had a pickle and then forgot to put away the jar."/>
                    <outline text="The man could have totally checked their locks, made sure their valuables were still in the right place, etc. Instead he just yelled &quot;Hey, did you leave this pickle jar out?&quot; and got the simpler answer right away. Starting with the simpler solution (fewer assumptions than my burglar story) got them to the right answer efficiently."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="In general, this strategy saves time." colorLabel="4" collapsed="true">
                    <outline text="Once the correct hypothesis is found, it typically means that no more analysis is necessary. Thus prioritizing the more likely hypotheses typically results in more quickly finishing the analysis." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="First prioritize simplicity" heading="2" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="When trying to explain an observation, you should go with the [simplest](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OZPNRE7XVJaT-1kbq4eiWIsC) explanation first."/>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Forgetting Avengers" heading="3" collapsed="true">
                      <outline text="You notice that the name of an old film wasn&apos;t you remembered it being. Maybe you notice a poster for the first Avengers movie and see it&apos;s called &quot;Avengers Assemble&quot;. That can&apos;t be right, you think, you&apos;re sure it was just called The Avengers."/>
                      <outline text="Two explanations occur to you:"/>
                      <outline text="1. you misremembered it"/>
                      <outline text="2. you come from another universe where it was called The Avengers and you somehow jumped dimensions"/>
                      <outline text="The second one requires more assumptions, namely the assumptions inherent in other universes existing and the possibility of travelling between them. The first assumption doesn&apos;t require any new assumptions on top of how you already understand reality, so you go with that one."/>
                      <outline text="But then you gather new evidence--another poster where it was called The Avengers. So what now--your first theory now doesn&apos;t work, so what do you do? Immediately adopt the second theory?"/>
                      <outline text="No, because someone suggests a different theory. The film was released under different titles in different regions, and you saw a poster made for the UK. This isn&apos;t as simple as that first theory, but it&apos;s still simpler than the multiverse theory, so you change to that theory. And in this case that is the actual answer."/>
                      <outline text="So, it doesn&apos;t mean &quot;the simplest explanation is always true&quot;, just that it&apos;s usually an easier process of arriving at the truth if you start at the simplest answer and work up"/>
                      <outline text="The important part is that if you have two theories that explain observations similarly well then you should assume the simpler is true."/>
                      <outline text="**Source:**   [A Reddit comment](https://www.reddit.com/r/explainlikeimfive/comments/vyzqqs/comment/ig5b20x/?utm_source=share&amp;utm_medium=mweb3x&amp;utm_name=mweb3xcss&amp;utm_term=2&amp;utm_content=share_button)" colorLabel="6"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Complexity = difficulty to investigate" _note="Plausibly important enough to become its own section or something, and then become linked here?" heading="3" colorLabel="4" collapsed="true">
                      <outline text="The more different variables or assumptions have to add up to get to a solution (i.e. the more complex the hypothesis), the more difficult it is to investigate." colorLabel="3"/>
                    </outline>
                    <outline text="The more complex the hypothesis, the less likely it is to occur in general." colorLabel="4"/>
                    <outline text="Decently accurate" complete="true" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Usually, there is [an obvious enough difference in simplicity] to make it quick and easy enough to estimate prior probabilities well enough to make them worth thinking of first." _note="Very unsure about this, because you can switch back and forth between considerating simplicity and other factors at first, and the effect of starting on one vs the other would be so small in that case, that other factors likely play a bigger role in which should be started with." complete="true" colorLabel="4" collapsed="true">
                        <outline text="Still isn&apos;t always the case." _note="Relevance" colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="How to view it      (crucial to move stuff to importance / organize)" _note="Likely move some of this to Occam&apos;s razor how to view it section and link it here. | Organize this better | Move a bunch of this to importance." heading="3" colorLabel="2" collapsed="true">
                  <outline text="Simplicity and other factors both typically offer evidence."/>
                  <outline text="Neither are inherently stronger than the other." collapsed="true">
                    <outline text="In some cases simplicity is stronger, in some cases it isn&apos;t." _note="Likelihood | Link examples for both kinds of cases." colorLabel="4"/>
                  </outline>
                  <outline text="Getting the posterior is just a matter of combining these probabilities, which can ultimately be represented by numbers."/>
                  <outline text="The combination method should not care which number comes first. So it shouldn&apos;t intrinsically matter whether the number comes from the simplicity or other evidence."/>
                  <outline text="So prioritizing one kind of evidence can only be justified when it&apos;s typically stronger, typically easier to get a relatively decent estimate for quickly, or something similar. "/>
                  <outline text="And even then, it&apos;s questionable whether it&apos;s better to more quickly get into other considerations, or whether one should try to estimate both simplicity and other factors, and/or then more deeply consider both simplicity and other factors for each hypothesis."/>
                  <outline text="Considerations for simplicity should definitely not end at prioritization of which hypotheses to consider in what order, because it&apos;s often unclear when a hypothesis should be discarded (and we are often irrationally reluctant to discard a hypothesis), and there are often unobvious considerations to have about simplicity that have a substantial impact on the prior probability (and thus also the posterior probability)."/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Formal probabilistic reasoning" heading="3" colorLabel="4" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2"/>
            <outline text="Limitations" heading="3" colorLabel="2"/>
            <outline text="Probabilistic calculators" heading="1" colorLabel="5" collapsed="true">
              <outline text="https://www.calculator.net/probability-calculator.html"/>
            </outline>
            <outline text="Factorial stuff"/>
          </outline>
          <outline text="Experiments" heading="1" colorLabel="4" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2"/>
            <outline text="&quot;Blind&quot; techniques" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Double-blind" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Double blind techniques involve ..."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Helpful for protecting our reasoning from the errors involving confirmation bias." _note="Link"/>
              </outline>
              <outline text="Data collection" heading="1" collapsed="true">
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="The patients involved in the trial of a new drug don’t know whether they are getting the drug or a pacebo."/>
                </outline>
              </outline>
              <outline text="Data analysis" heading="1" collapsed="true">
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="The researchers also don’t know whether each particular patient they examine afterwards were in the test group who received the drug, or the control group."/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Complex probabilistic reasoning" _note="~~Advanced" heading="3" colorLabel="4" collapsed="true">
            <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
              <outline text="Probabilistic reasoning about topics with many complex interactions and factors."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3"/>
            </outline>
            <outline text="Emergent simplicity" heading="1" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The supposed phenomenon whereby for a simple question about a complex topic, the importance of the relevant components is rarely uniform, resulting in a decent guess being derivable from a much smaller set of  the factors/interactions than might be expected."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Probabilistic biases" _note="Probably move to cognitive biases and link here? Also update backlinks if so." heading="3" colorLabel="4" collapsed="true">
            <outline text="Statistical bias" heading="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A bias that occurs when one&apos;s sample is unrepresentative of a corresponding population one is intending to make an inference about."/>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="**Scenario:** An urn contains seventy white balls and thirty red ones (the population). You pick a number of balls out (a sample), and try to infer the number of white balls vs red balls (using induction)."/>
                  <outline text="**Bias:** In this case, the white balls happen to be heavier, meaning that your sample (the balls that you happen pick when using the process of reaching into the urn to fetch them) is likely to be biased (unrepresentative of the population)."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="When your method of learning about the world is biased, learning more may not help. Acquiring more data can even consistently __worsen__ a biased prediction. "/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Falsification" heading="3" colorLabel="4" collapsed="true">
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Explanation/hypothesis](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lelHmq5_RA_nj89mdbd500nr)" heading="3" colorLabel="4" collapsed="true">
                <outline text="The target of falsification."/>
              </outline>
              <outline text="[Experiments](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=l4ypO5YkR15Gt6nG4SYw6KKi)" heading="3" colorLabel="4" collapsed="true">
                <outline text="Typically done to try to falsify a hypothesis."/>
              </outline>
            </outline>
          </outline>
          <outline text="Misc" heading="1" colorLabel="6" collapsed="true">
            <outline text="Anecdotal evidence" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Evidence based on descriptions and reports of individual, personal experiences, or observations, collected in a non-systematic manner." collapsed="true">
                  <outline text="Distinction (systematic)" colorLabel="3"/>
                  <outline text="^ &quot;systematic&quot; is not used in the &quot;systematic reasoning&quot; sense, but a broader sense." _note="Link systematic reasoning"/>
                </outline>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Anecdata"/>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Personal experiences"/>
                  <outline text="Self-reported claims"/>
                  <outline text="Eyewitness accounts of others"/>
                </outline>
                <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Anecdotal_evidence)"/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Often pretty unreliable" heading="3" colorLabel="1"/>
                <outline text="^ Often non-representative" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Often justified with only a small number of anecdote(s)." _note="Likelihood" colorLabel="4"/>
                  <outline text="Often [cherry-picked](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VCYeE_G2-lkwQ6_S-w6A9idu)" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Psychologists have found that due to cognitive bias, people are more likely to remember notable or unusual examples." _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Thus, anecdotal evidence is often not representative of a typical experience even when accurate." _note="Relevance" colorLabel="4"/>
                      <outline text="**Source:**   Gibson, Rhonda; Zillman, Dolf (1994). &quot;Exaggerated Versus Representative Exemplification in News Reports: Perception of Issues and Personal Consequences&quot;. Communication Research. 21 (5): 603–624. doi:10.1177/009365094021005003. S2CID 145050644." colorLabel="6"/>
                    </outline>
                    <outline text="Often cherry-picked from an individual&apos;s experiences." _note="Likelihood" colorLabel="4"/>
                    <outline text="Often cherry-picked from a search through many individual anecdotes." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Common" heading="3" colorLabel="4"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Anecdotal fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BlL_bkib3oL-kwQR393H6fJS)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="An argument which relies on anecdotal evidence that does not provide enough support to justify the argument are called &quot;anecdotal fallacies&quot;." colorLabel="4"/>
                </outline>
                <outline text="[Link to / combine with] testimony section"/>
                <outline text="[Induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OJSQEWGwiRo2syWQyU9FbjoE)" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Anecdotal evidence is almost always used in some kind of inductive argument." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Analogical reasoning" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Reasoning involving a comparison of two systems in relation to their similarity. It starts from information about one system and infers information about another system based on the resemblance between the two systems." _note="Make this more colloquial."/>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Logical_reasoning#Analogical)"/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="People often use analogical reasoning." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Analogical reasoning tends to be relatively weak" heading="3" colorLabel="1" collapsed="true">
                    <outline text="The differences between the target idea and the allegedly analogous idea often hold important details that change whether or not the analogy works." colorLabel="4"/>
                    <outline text="Analogies are often used when there is a disagreement or potential disagreement. Propositions where there is relatively high (potential) disagreement tend to have more reasons for believing that particular details make them true/false." _note="Split" colorLabel="4"/>
                    <outline text="[Weak analogy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=aIaqFNRqVPOJak6jkLM6mLod)" heading="3" colorLabel="1"/>
                  </outline>
                  <outline text="[Analogical reasoning tends to be relatively weak](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sTV1i15MBelZwM1OZV54lcFB)" heading="3" colorLabel="4"/>
                  <outline text="[People often overestimate analogical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Qa9fASkuaXd072rMnTTM9TH9)" heading="3" colorLabel="4"/>
                </outline>
                <outline text="Difficult / Improvable" heading="3" collapsed="true">
                  <outline text="People often overestimate analogical reasoning" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Analogical reasoning tends to be relatively weak](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sTV1i15MBelZwM1OZV54lcFB)" heading="3" colorLabel="4"/>
                    <outline text="[Weak analogy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=aIaqFNRqVPOJak6jkLM6mLod)" heading="3" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Convergent futures" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Future events which many, most or all possible timelines between now and then will lead to." collapsed="true">
                  <outline text="Possible timelines defined in terms of subjective possibility: things that are possible according to our best guesses."/>
                </outline>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Ice cube melting" collapsed="true">
                    <outline text="It is incredibly difficult or near impossible to predict where exactly all the atoms of water will go during the ice cube&apos;s melting, but it is often easy to predict that the ice will completely melt despite that."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Instrumental convergence" heading="3"/>
            </outline>
            <outline text="Novel testable predictions" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
            </outline>
            <outline text="Avoiding double-counting" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Avoiding counting evidence&apos;s impact twice."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Difficulty" heading="3" collapsed="true">
                  <outline text="Double-counting is an easy mistake to make, due to how it can often be hard to tell when we&apos;re using two long lines of evidence that are incompatible with each other but both support a conclusion we&apos;re trying to defend." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Practical techniques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yQVWivooam-CWEWkiSH8D5Gu)" heading="1" colorLabel="2" collapsed="true">
                <outline text="Probabilistic reasoning plays a major role in a lot of practical techniques."/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="Psychology" heading="1" colorLabel="1" collapsed="true">
          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
            <outline text="Study of mental functions and behaviours."/>
          </outline>
          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
            <outline text="Impactful" heading="3" collapsed="true">
              <outline text="Many of the topics here are incredibly important for good reasoning." colorLabel="4"/>
              <outline text="[Induction biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CGI6yCYSAdy8jsILM1rD8Wsw)" colorLabel="4"/>
            </outline>
            <outline text="Difficult" heading="3" collapsed="true">
              <outline text="It&apos;s very easy to reason badly about psychology." colorLabel="4" collapsed="true">
                <outline text="It&apos;s very easy to fall into [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37) when learning about psychology, which usually makes our reasoning about psychology significantly worse." _note="Support"/>
              </outline>
            </outline>
          </outline>
          <outline text="Learning" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="**Quantity importance:**   There are a lot of really important things to learn about." colorLabel="4" collapsed="true">
                <outline text="So it&apos;s important to learn about a lot of things." _note="Relevance" colorLabel="4"/>
                <outline text="^ We can learn about a lot of things." _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="**Difficult:**   It&apos;s not straightforward to learn properly." colorLabel="4" collapsed="true">
                <outline text="There are substantial [common misconceptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8pU9ttpcR1n3re0U17Q4JkZ2) about learning." _note="Likelihood" colorLabel="4"/>
                <outline text="There&apos;s a lot of knowledge in this section to help." _note="Relevance" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="How to learn from this guide" heading="3" colorLabel="2" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Common misconceptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8pU9ttpcR1n3re0U17Q4JkZ2)"/>
              </outline>
              <outline text="[How to practice this guide](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zyl1TWJiM71PFuHXhvjpKQxD)" heading="3" colorLabel="2"/>
            </outline>
            <outline text="Feedback" heading="1" colorLabel="6" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="We typically need accurate, consistent feedback in other to form the right [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) and avoid forming the wrong ones."/>
              </outline>
              <outline text="Reasoning feedback" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Here: The feedback you get for how well you performed at reasoning and how you could improve."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Typically practicing reasoning on soft science topics does not help us reason much better because we either get no feedback or unclear/misleading feedback (such as our emotions, how right/wrong we feel). So we have no good system to reinforce good habits and prune bad ones."/>
                  <outline text="However if we treat what others say seriously, even when we really feel like it&apos;s wrong, there is a good way to use what they say as effective feedback. However we must be incredibly careful with this, because it&apos;s very easy to either take what they say too seriously or not seriously enough (usually the latter, at least in practice)."/>
                  <outline text="That is one of the reasons we place such importance on steelmanning (in the way it will be described). Without this, it&apos;s very difficult to get good feedback. Unfortunately this can become a self-perpetuating cycle, where you can&apos;t get good feedback to improve how to get good feedback. As such, we will develop a system for practicing and getting clear feedback without needing these techniques."/>
                </outline>
              </outline>
            </outline>
            <outline text="Psychology of learning" heading="1" colorLabel="1" collapsed="true">
              <outline text="[Practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7uTPFcFISeOZWgi6CC8b3Q50)" heading="1" colorLabel="2" collapsed="true">
                <outline text="Incredibly important for learning in general." colorLabel="2" collapsed="true">
                  <outline text="[Skills require practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=79KS_JjMDcI8g9agrwdEtRao)"/>
                </outline>
              </outline>
              <outline text="[Learning from others](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Qlio6RfNJC5UcTvCa9o-7SX)" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Fitting things together" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The process of mentally categorizing/connecting information."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="People fit different topics together all the time, so it&apos;s important to learn how to do it well." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[Importance of generalizable concepts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HyAnyIPx3VpR9Vs61Kj6CslU)" colorLabel="4"/>
                  <outline text="Helpful for [clear communication](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Yxl_WsBK8P0HiEmkAD6MWYWr)" colorLabel="4" collapsed="true">
                    <outline text="By having more mental connections (if they are largely accurate), we can often get a more precise grasp of what exactly things mean." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Primarily using broadly applicable concepts" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Helps with accurately understanding things" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Understanding how things work in a very general way helps avoid [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" colorLabel="4"/>
                  </outline>
                  <outline text="Helps with quickly learning things" heading="3" colorLabel="4" collapsed="true">
                    <outline text="By consistently understanding topics using concepts that apply to many different things, you&apos;ll have more very-generally-applicable-knowledge." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Practice" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Doing something in order to get better at doing it."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Skills require practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=79KS_JjMDcI8g9agrwdEtRao)" heading="2" colorLabel="2"/>
                <outline text="[Common misconceptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8pU9ttpcR1n3re0U17Q4JkZ2)"/>
              </outline>
              <outline text="How to practice this guide" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="How to practice the material in this guide."/>
                </outline>
                <outline text="Reasoning practice problems" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Testing" heading="3"/>
                    <outline text="Practicing" heading="3"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="There aren&apos;t practice problems for many important forms/facets of reasoning." collapsed="true">
                      <outline text="Cause: Many important forms/facets of reasoning are difficult to design practice problems for."/>
                      <outline text="Cause: People can use [reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7VkGKlZfqI3D-chGqzjjpwn) to improve their reasoning further."/>
                    </outline>
                  </outline>
                  <outline text="Problem types" heading="1" colorLabel="6" collapsed="true">
                    <outline text="Recognizing assumptions" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Tests involving checking if a supposed assumption is actually an assumption of a given statement." collapsed="true">
                          <outline text="Intentionally vague, I&apos;m not sure what interpretation of &quot;assumption&quot; would be best to use for the test."/>
                          <outline text="Obviously should be clarified if/when the test is made."/>
                        </outline>
                      </outline>
                      <outline text="Implementation note" heading="3" collapsed="true">
                        <outline text="We&apos;ll have to be very careful when making this test, as it would likely often be very easy to mistakenly assume that something is an assumption of something else when it isn&apos;t." collapsed="true">
                          <outline text="We might be best off using very abstract or toyish scenarios, or just writing assumptions which are definitely necessary for the statement."/>
                        </outline>
                      </outline>
                      <outline text="Types" heading="3" collapsed="true">
                        <outline text="Premises" heading="3" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Checking if something is necessarily a premise of something else."/>
                          </outline>
                          <outline text="I haven&apos;t thought about this much."/>
                        </outline>
                        <outline text="&lt;99% credence" heading="3"/>
                      </outline>
                    </outline>
                    <outline text="Recognizing (in)validity" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Tests involving checking if conclusions necessarily follow from sets of premises (the sets of premises may take the form of natural language statements)."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Practice sections on deduction seem like they could be quite beneficial for thinking of exceptions and nuances, which would be beneficial for criticalness and indirectly open mindedness."/>
                      </outline>
                      <outline text="Specific problems" heading="3" collapsed="true">
                        <outline text="Ferb&apos;s wager"/>
                      </outline>
                    </outline>
                    <outline text="Making good inferences" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Problems involving addressing degrees of likelihood/certainly for a conclusion given a statement, assuming that the statement is definitely true."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="This doesn&apos;t necessarily mean assuming that our interpretation of the statement is definitely true."/>
                        </outline>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="[5-step system](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KKPP9u9YS7VgWMdzSR8SYgDE)"/>
                        </outline>
                      </outline>
                      <outline text="Types" heading="3" collapsed="true">
                        <outline text="5-step system" heading="3" collapsed="true">
                          <outline text="Natural language interpretation" collapsed="true">
                            <outline text="True"/>
                            <outline text="Probably true"/>
                            <outline text="Not enough information"/>
                            <outline text="Probably false"/>
                            <outline text="False"/>
                          </outline>
                          <outline text="A credence interpretation" collapsed="true">
                            <outline text="c ≥ 19/20 (true)"/>
                            <outline text="3/5 &lt; c &lt; 19/20 (probably true)"/>
                            <outline text="2/5 ≤ c ≤ 3/5 (unsure)"/>
                            <outline text="1/20 &lt; c &lt; 2/5 (probably false) "/>
                            <outline text="c ≤ 1/20 (false)"/>
                            <outline text="Implementation note" heading="3" collapsed="true">
                              <outline text="5/95% might be better as 1/99% or even 0/100%, especially if we tell the test taker to select answers as if they&apos;re assuming that their interpretations are definitely (100% credence) correct."/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="[Common inductive errors](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=m9PFkYuw2EMpsMzGXrogqtdj)" heading="3" colorLabel="1" collapsed="true">
                        <outline text="We should abuse these in the problems."/>
                      </outline>
                    </outline>
                    <outline text="Judging arguments" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Judging how weak/strong arguments are." collapsed="true">
                          <outline text="This definition is vague and should be improved for the test if nothing else."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Judging interpretations" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="A test comprised of statements and interpretations of sections of those statements, where one must answer whether the interpretations correctly interpret that section of the statement (at least when taking into account the context of the other parts of the statement)."/>
                      </outline>
                    </outline>
                    <outline text="Translating formal to informal" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Implementation note" heading="3" collapsed="true">
                        <outline text="To make an automatic system to test for this, we can use multiple choice questions."/>
                      </outline>
                    </outline>
                    <outline text="Translating informal to formal" heading="3" colorLabel="2"/>
                  </outline>
                  <outline text="Implementation types" heading="1" colorLabel="6" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Ways in which problems can be implemented."/>
                    </outline>
                    <outline text="Types used" heading="1" colorLabel="5" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Which types are used during the test."/>
                      </outline>
                      <outline text="1-type" heading="3" collapsed="true">
                        <outline text="Only one type can appear, so you can practice just that type."/>
                      </outline>
                      <outline text="All-type" heading="3" collapsed="true">
                        <outline text="Any type can appear, so you have to pay attention to all the important details that you can."/>
                      </outline>
                    </outline>
                    <outline text="Memory (optional)" heading="1" colorLabel="4" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Problems are presented and you have to remember important details about them and answer later."/>
                      </outline>
                      <outline text="The way to view this" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Plausibly important for getting people to focus on important details about statements (especially like validity/invalidity)."/>
                      </outline>
                      <outline text="Pause-based" heading="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="X seconds to read the statement, Y seconds waiting, then Z seconds to read the proposed conclusion/interpretation/etc. of the statement and answer."/>
                        </outline>
                        <outline text="Times" heading="3" colorLabel="2" collapsed="true">
                          <outline text="60-5-60"/>
                        </outline>
                      </outline>
                      <outline text="Juggling" heading="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Back and forth between reading and answering, and you have to remember important details about the problems."/>
                          <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                            <outline text="A¹,?²,B¹,A²,C¹,B²,D¹,C²"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Emotions" heading="1" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Implementations that try to activate irrational emotions during the test."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Avoiding overly [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2"/>
                      </outline>
                      <outline text="Controversial topics" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Disclaimer" heading="3" colorLabel="1" collapsed="true">
                          <outline text="This test uses controversial and disturbing topics to try to illicit irrational, emotional intuitions, instincts and reactions, to make you rely on previously (and likely unreasonably) memorized patterns, rather than general reasoning."/>
                          <outline text="Your goal is to try to resist these things as much as possible and reason using the same kind of general reasoning you would normally apply to less controversial topics."/>
                        </outline>
                      </outline>
                      <outline text="Using [persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7) tactics" heading="3" colorLabel="2"/>
                      <outline text="Abusing [Hot biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4b2Z6i8P8doUYRe6rHWYtv5I)" heading="3" colorLabel="1"/>
                    </outline>
                    <outline text="Meta" heading="1" collapsed="true">
                      <outline text="Random gen" heading="3" collapsed="true">
                        <outline text="Structure" heading="3"/>
                        <outline text="Values" heading="3" collapsed="true">
                          <outline text="Topic network?" heading="3"/>
                          <outline text="Number" heading="3"/>
                          <outline text="TF" heading="3"/>
                        </outline>
                      </outline>
                      <outline text="User contributions" heading="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Users contribute the problems."/>
                        </outline>
                        <outline text="Process" heading="1" colorLabel="5" collapsed="true">
                          <outline text="User gets info." collapsed="true">
                            <outline text="User is given a template and instructions on roughly how to fill it out."/>
                          </outline>
                          <outline text="User gives problem." collapsed="true">
                            <outline text="They fill it out and send it to server."/>
                          </outline>
                          <outline text="Auto moderation?" collapsed="true">
                            <outline text="Check for correct values in correct places." collapsed="true">
                              <outline text="Correct length."/>
                              <outline text="Correct type."/>
                            </outline>
                            <outline text="Check for inappropriate language."/>
                          </outline>
                          <outline text="User moderation." collapsed="true">
                            <outline text="Make sure scorer isn&apos;t author."/>
                            <outline text="Check if user is trustworthy by giving random already-scored problem(s)." collapsed="true">
                              <outline text="Probably give 2 already-sufficiently-scored problems (1 that isn&apos;t good and 1 that is) and some not-yet-sufficiently-scored problems to get feedback on them." collapsed="true">
                                <outline text="Give these in a random order."/>
                              </outline>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Motivation" heading="3" colorLabel="1" collapsed="true">
                          <outline text="None" heading="3"/>
                          <outline text="To take test" heading="3" collapsed="true">
                            <outline text="Proportional" heading="3" collapsed="true">
                              <outline text="1-per-n problems" heading="3" collapsed="true">
                                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                                  <outline text="Give one problem to receive n problems."/>
                                </outline>
                              </outline>
                              <outline text="N problems free, very easy to get 10%, easy to get 25%, medium to get 50%, hard to get 75%, very hard to get 90%, impossible to get 100%." collapsed="true">
                                <outline text="Database has 200." heading="3" colorLabel="6" collapsed="true">
                                  <outline text="10 problems free."/>
                                  <outline text="Rate 4?/Create 1, +10 problems"/>
                                  <outline text="Rate 8?/Create 2, +30 problems"/>
                                  <outline text="Rate 16?/Create 4, +50 problems"/>
                                  <outline text="Rate 32?/Create 8, +50 problems"/>
                                  <outline text="Rate 64?/Create 16, +32 problems"/>
                                  <outline text="Rate 128?/Create 32, +16 problems"/>
                                  <outline text="Rate 256?/Create 64, +8 problems"/>
                                </outline>
                              </outline>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Rated problems" heading="3" collapsed="true">
                        <outline text="The problems could be rated like in lichess, that could potentially be very cool and useful for several reasons." collapsed="true">
                          <outline text="Maybe allows us to test people."/>
                          <outline text="Allows people to get problems of a more consistent difficulty."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Testing methodology" _note="Combine with implementation methods" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Consistency &gt; speed" heading="3" collapsed="true">
                        <outline text="Maybe test should tell takers to aim for 95% accuracy, and heavily penalize for &lt;90%?"/>
                        <outline text="Consistency should be considered significantly more important than speed, especially when considering open mindedness."/>
                      </outline>
                      <outline text="Auxiliary modifiers" heading="3" collapsed="true">
                        <outline text="Interest" heading="3" collapsed="true">
                          <outline text="People could be asked before or after the test how motivated they are/were."/>
                        </outline>
                        <outline text="Stamina /ability" heading="3" collapsed="true">
                          <outline text="People could be asked what their stamina / ability is/was like before/after the test."/>
                        </outline>
                        <outline text="There could be an option to show the results with and without these modifiers maybe."/>
                      </outline>
                    </outline>
                    <outline text="Having people write why they disagree with us if their answer is different maybe?" heading="3"/>
                    <outline text="Using [vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="3" colorLabel="3"/>
                  </outline>
                  <outline text="Ideas" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Testing for [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37) instead of open mindedness directly." collapsed="true">
                      <outline text="Easier because testing open-mindedness directly requires checking for changed beliefs, which is very cheatable and hard to do properly." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Practice problems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=X1LikFP17mEZqub9nd_2Uq2E)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Proactive practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9SVyks7moIibu2HXE-cK1qWi)" heading="3" colorLabel="2"/>
                  <outline text="[Reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7VkGKlZfqI3D-chGqzjjpwn)" heading="3" colorLabel="2" collapsed="true">
                    <outline text="If you don&apos;t get feedback, it&apos;s going to be very difficult to properly learn from this guide."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Skills require practice" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Complicated precise behaviors typically require habits to perform consistently."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="People typically don&apos;t properly internalize what they read about reasoning and implement it into their epistemic [habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mwz5Ve2BffIKD_YiMRN4SJOU), because they don&apos;t practice it enough to form those habits."/>
                  <outline text="Merely knowing how to reason well doesn&apos;t do much until you form the [habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mwz5Ve2BffIKD_YiMRN4SJOU) necessary to consistently apply that knowledge."/>
                  <outline text="[Common misconceptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8pU9ttpcR1n3re0U17Q4JkZ2)"/>
                  <outline text="Mastery" heading="3" collapsed="true">
                    <outline text="In virtually all areas* we can properly test, it seems that our [subconscious](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2u3zb8iZbtZCj5aZBVmU0ON) typically takes a lot of https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9SVyks7moIibu2HXE-cK1qWi to properly master topics." collapsed="true">
                      <outline text="* minus those that are (near-)trivially simple."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Reasoning" heading="1" colorLabel="5" collapsed="true">
                  <outline text="You can learn all the theory you want about how to play the piano, but if you don&apos;t practice it, you won&apos;t be able to perform all the precise movements, even for simpler songs (unless you&apos;ve practiced being able to do so)."/>
                  <outline text="Likewise this applies for mental activities that require lots of complicated precise actions."/>
                  <outline text="You can learn all the info you want about how to play chess well, but if you don&apos;t practice it, you won&apos;t be able to act it out consistently."/>
                </outline>
              </outline>
              <outline text="Proactive practice" _note="Maybe merge this with practice prioritization?" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Practice prioritization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YrmkLyC9ffiXfVcchrcxJ5wc)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Practice prioritization" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Prioritizing what to practice."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="We tend to default to practicing some things too much and some things not enough."/>
                </outline>
                <outline text="Important to practice" heading="2" colorLabel="4" collapsed="true">
                  <outline text="Things we are bad at" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3"/>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Assuming these things are sufficiently important, it&apos;s typically very important for us to improve at our weaknesses."/>
                    </outline>
                    <outline text="[Finding weaknesses](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=s5mEfV34YJ5ddQBNCzX2VshR)" heading="3" colorLabel="2" collapsed="true">
                      <outline text="We have to find the things we are bad at in order to practice them."/>
                    </outline>
                  </outline>
                  <outline text="Useful things" heading="3" collapsed="true">
                    <outline text="Fundamentals" heading="3"/>
                  </outline>
                </outline>
                <outline text="Unimportant to practice" _note="~~Intermediate" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Things that we are good at" _note="~~Expert" heading="3" collapsed="true">
                    <outline text="Risks" heading="3" colorLabel="1"/>
                  </outline>
                  <outline text="Useless things" _note="~~Intermediate" heading="3"/>
                </outline>
              </outline>
              <outline text="Practice problems" heading="1" colorLabel="2" collapsed="true">
                <outline text="Flashcards"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Reasoning practice problems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fuVtjkC3ZxxSXxc7TO0SgQDv)" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nJ3ltWAInP1X3K5j7Yf8aM99)" heading="3" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Learning narrow things" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Research."/>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Often not plausibly substantially helpful." collapsed="true">
                  <outline text="Cases where not many others have thought about it properly and many others have thought about it properly."/>
                </outline>
                <outline text="Often time-consuming to do properly."/>
                <outline text="Can allow for cherry-picking if done improperly." _note="Link"/>
              </outline>
              <outline text="Places to learn about many narrow things" heading="3" colorLabel="6" collapsed="true">
                <outline text="Colors" heading="3" collapsed="true">
                  <outline text="I used colors here in a different way than anywhere else, just to fit the theme of the sites mentioned. Sorry."/>
                </outline>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="These typically don&apos;t work great for learning about broad things."/>
                </outline>
                <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Important info about ideas is scattered" heading="3" collapsed="true">
                    <outline text="Unfortunately, there is currently often no one place to look for information regarding a single topic of debate that represents all sides of the issue and presents enough depth and research for the information provided."/>
                  </outline>
                </outline>
                <outline text="Wikipedia" heading="1" collapsed="true">
                  <outline text="https://en.wikipedia.org/wiki/Wikipedia" heading="3" colorLabel="3"/>
                  <outline text="How to view it" heading="3" colorLabel="2"/>
                  <outline text="Limitations" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Typically somewhat unstructured (compared to the ideal)."/>
                    <outline text="Typically has a lot of fluff (compared to the ideal)." collapsed="true">
                      <outline text="Talking about the history/major figures a lot, in places where it&apos;s unlikely you would need the info."/>
                    </outline>
                    <outline text="Some important topics are often buried in the pages of related but different topics."/>
                    <outline text="Usually lacking a lot of depth, particularly for controversial issues."/>
                    <outline text="Typically using the broadest common definitions, which can often be confusing."/>
                  </outline>
                  <outline text="Benefits" heading="1" colorLabel="4" collapsed="true">
                    <outline text="Usually a relatively decent and quick way to grasp the rough outlines of ideas."/>
                  </outline>
                </outline>
                <outline text="Stanford Encyclopedia of Philosophy" heading="1" colorLabel="1" collapsed="true">
                  <outline text="https://plato.stanford.edu/" heading="3" colorLabel="3"/>
                  <outline text="How to view it" heading="3" colorLabel="2"/>
                  <outline text="Limitations" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Typically somewhat unstructured (compared to the ideal)."/>
                    <outline text="Many important topics do not have dedicated pages, which at best makes it difficult to find them and at worst neglects to cover them."/>
                    <outline text="Usually lacking some depth, particularly for controversial issues."/>
                    <outline text="Typically has a lot of fluff (compared to the ideal)." collapsed="true">
                      <outline text="Talking about the history/major figures a lot, in places where it&apos;s unlikely you would need the info."/>
                    </outline>
                  </outline>
                  <outline text="Benefits" heading="1" colorLabel="4" collapsed="true">
                    <outline text="Usually relatively thorough."/>
                    <outline text="Usually pretty clear if you&apos;re semi-familiar with the relevant concepts."/>
                  </outline>
                </outline>
                <outline text="[Kialo](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=g2OYys1jFKu_KGU-Najcj_rh)" heading="1" colorLabel="5" collapsed="true">
                  <outline text="All of the following sections are talking specifically about using Kialo as a place to learn about many narrow things."/>
                  <outline text="How to view it" heading="3" colorLabel="2"/>
                  <outline text="Benefits" heading="1" colorLabel="4" collapsed="true">
                    <outline text="Relatively organized."/>
                  </outline>
                  <outline text="Detriments" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Lots of the topics are badly organized and/or badly moderated."/>
                  </outline>
                </outline>
                <outline text="AI" heading="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Artificial intelligence"/>
                  </outline>
                  <outline text="How to view it" heading="3" colorLabel="2"/>
                  <outline text="Detriments" heading="1" colorLabel="1" collapsed="true">
                    <outline text="For now, often pretty inaccurate." heading="3"/>
                  </outline>
                  <outline text="Benefits" heading="1" colorLabel="4" collapsed="true">
                    <outline text="The ability to ask the AI for more info about a particular part, or to explain a particular thing in different words, etc." collapsed="true">
                      <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                        <outline text="[For now, often pretty inaccurate](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=c3WAPxK0YlXg38aaH-h_wLfM)" heading="3"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Research methodology" heading="3" colorLabel="2" collapsed="true">
                <outline text="Primary sources" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Immediate, first-hand accounts of a topic, from people who had a direct connection with it."/>
                    <outline text="Example" _note="Give an example based on reasoning/experiment rather than direct experience, to clarify that potential ambiguity." heading="3" colorLabel="6"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2"/>
                </outline>
                <outline text="Credibility" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Conflicts of interest" heading="3" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Proactive learning" heading="1" colorLabel="2" collapsed="true">
              <outline text="[Post-failure review](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vt5kpj9CiWd1H217AZA8HD94)" heading="3" colorLabel="2"/>
            </outline>
            <outline text="Post-failure review" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Reviewing the causes and trying to come up with solutions to prevent future repeats, after a failure."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Generally an incredibly underrated technique to apply to many problems that are often deemed (consciously or subconsciously) unsolvable."/>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Freak accidents" _note="~~Intermediate" heading="3" collapsed="true">
                  <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Freak accidents that are very unlikely to ever happen again."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="This is different from freak accidents that are likely to happen again. Eg. A very unlikely event that causes a plane crash should likely be accounted for even if it&apos;s very unlikely, because there are so many planes flying constantly that the chances of a repeat are usually decently high."/>
                    </outline>
                  </outline>
                  <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="While the specific accident might be so unlikely, it may be part of a category of possible failures which has a small set of solutions required to prevent most of the possible failures. In this case, while the specific failure may not be worth focusing on for its own sake, it may be worth focusing on to better understand the category and how to prevent similar failures from occurring."/>
                  </outline>
                  <outline text="These are sometimes so unlikely to happen again that it&apos;s probably not worth trying to prevent repeats."/>
                </outline>
                <outline text="Unimpactful failures" heading="3" collapsed="true">
                  <outline text="Definition (specific) " heading="3" colorLabel="3" collapsed="true">
                    <outline text="Failures that are so unimpactful compared to the cost to solve them, that they aren&apos;t worth solving for their own sake."/>
                  </outline>
                  <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="While the specific accident might be so unimpactful, it may be part of a category of possible failures which has a small set of solutions required to prevent most of the possible failures. In this case, while the specific failure may not be worth focusing on for its own sake, it may be worth focusing on to better understand the category and how to prevent similar failures from occurring."/>
                  </outline>
                  <outline text="These are sometimes so unimpactful that it&apos;s probably not worth trying to prevent repeats."/>
                </outline>
              </outline>
              <outline text="Finding the causes " heading="1" colorLabel="2" collapsed="true">
                <outline text="Impact" heading="3" collapsed="true">
                  <outline text="Definition (specific) " heading="3" colorLabel="3" collapsed="true">
                    <outline text="Causes that have the greatest impact on the potential for similar future failures."/>
                  </outline>
                  <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Cost](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Cb8A2O3Dkr5lF2XUj99-rQWa)" heading="3" collapsed="true">
                      <outline text="High impact causes may not be worth considering if the cost is too high."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Cost" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Causes that have a low cost to prevent."/>
                  </outline>
                  <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Impact](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hmvcXgFtyABw9AdmcfZUXrBO)" heading="3" collapsed="true">
                      <outline text="Uncostly-to-prevent causes may not be worth considering if they have low impact."/>
                    </outline>
                  </outline>
                  <outline text="Direct" heading="1" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The upfront obvious cost(s)."/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="The financial cost."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Indirect" heading="1" collapsed="true">
                    <outline text="Risks" heading="3"/>
                    <outline text="Other negative consequences" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Finding solution(s)" heading="1" colorLabel="2" collapsed="true">
                <outline text="Solution(s) to the specific problem" heading="3"/>
                <outline text="Solution(s) to similar problem(s)" heading="3"/>
                <outline text="[Contingencies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HGsYQS9G0jsA4vN6p0eGkk4G)" heading="3"/>
              </outline>
            </outline>
            <outline text="Measuring learning" heading="3" colorLabel="2" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Measuring learning allows you to generate [feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nJ3ltWAInP1X3K5j7Yf8aM99)" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Explaining what you&apos;re learning" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3"/>
                  <outline text="^ A good way to measure how well you&apos;ve learned something (and to better internalize it) is to try to explain it." colorLabel="4"/>
                  <outline text="^ ^ One&apos;s ability to explain something tends to be highly correlated with their intuitive understanding of the topic." colorLabel="4"/>
                  <outline text="^ ^ ^ A good intuitive understanding tends to be preceded by understanding that something in terms of more familiar things. And more familiar things tend to be understood by more people." colorLabel="4"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Intuitive understanding](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Lyj37DqUcGeYIrDH-6UuXTxI)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
            </outline>
            <outline text="Intuitive understanding" heading="3" colorLabel="2"/>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rbfReKt_odNwwwIDWESiYqq-)" heading="2" colorLabel="1"/>
              <outline text="[Learning from others](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Qlio6RfNJC5UcTvCa9o-7SX)" heading="2" colorLabel="2"/>
              <outline text="[Reasoning self-improvement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mcey5J-t6AUuWU92iqr8Nkqe)" heading="3" colorLabel="6"/>
              <outline text="Common misconceptions" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Common misconceptions about learning."/>
                </outline>
                <outline text="We are sponges" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The feeling/idea that we are information sponges who merely need to hear things (often only once) in order to fully incorporate them into our behavior."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Even when we are consciously aware that this is wrong, we often still feel as though it is right." collapsed="true">
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="When we listen/read a ton more material than we can possibly internalize at once, because it makes us feel like we&apos;re making more progress than we would otherwise feel like we&apos;re making."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Skills require practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=79KS_JjMDcI8g9agrwdEtRao)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Little practice = mastery" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The feeling/idea that we only need to practice a little bit in order to become masters."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2"/>
                  <outline text="Common causes" heading="3" colorLabel="1" collapsed="true">
                    <outline text="The feeling/belief that [proactive practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9SVyks7moIibu2HXE-cK1qWi) can speed up mastery by more than it can."/>
                    <outline text="The feeling/belief that [we are sponges](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mh31JVikXkHTrnsNloomB98p) (at least largely)."/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Skills require practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=79KS_JjMDcI8g9agrwdEtRao)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Mastery is unattainable" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The feeling/idea that we could never be really fantastic at something(s)."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Usually we underestimate how much we can improve with the right approach."/>
                  </outline>
                  <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Sometimes this is (at least practically) true."/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Skills require practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=79KS_JjMDcI8g9agrwdEtRao)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Habits" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Routines of [behavior](https://en.wikipedia.org/wiki/Behavior) that are repeated regularly and tend to occur [subconsciously](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2u3zb8iZbtZCj5aZBVmU0ON)"/>
              <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                <outline text="Wont (formal term)"/>
              </outline>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="Learning is not enough" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Learning about a good/bad practice is typically not enough to adopt/avoid it."/>
                  </outline>
                  <outline text="broken link (replace with something relevant here)"/>
                </outline>
              </outline>
              <outline text="Common" heading="3" collapsed="true">
                <outline text="We&apos;re almost always operating on habits" collapsed="true">
                  <outline text="There&apos;s little we can do to change this."/>
                </outline>
              </outline>
              <outline text="[Importance of practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=y9rQ9gCcN0WYM7R_0bgRUsHv)"/>
            </outline>
            <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="[Practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7uTPFcFISeOZWgi6CC8b3Q50) required" heading="3"/>
              <outline text="[Feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nJ3ltWAInP1X3K5j7Yf8aM99) required" heading="3"/>
            </outline>
            <outline text="[Changing habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=737-9b9UIs5aAHrA10DDEWlC)" heading="1" colorLabel="2"/>
            <outline text="Bad habits" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Habits that you would rather not have."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="The vast majority of our bigger mistakes are typically partially caused by bad habits."/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Bad habits influence a massive amount of behavior for virtually everyone."/>
                </outline>
              </outline>
              <outline text="Finding bad habits" heading="1" colorLabel="2" collapsed="true">
                <outline text="Find source of bad behaviors" heading="3"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)" heading="1" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Removing bad habits" _note="Possibly somewhat combine/replace with changing habits section" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="[Requires finding them](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XpT2iNVGc7je2c3fLuyQcKV8)" heading="3" colorLabel="1"/>
                    <outline text="Requires training" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Something we should virtually always be trying to do."/>
                </outline>
                <outline text="0. Prepare to remove the bad habit" heading="3" collapsed="true">
                  <outline text="These are optional practices in no particular order:"/>
                  <outline text="Find a habit to replace it" heading="3" collapsed="true">
                    <outline text="Importance: This often makes it feel more natural and easier, since you can focus on doing the alternative thing(s) rather than the thing you would have otherwise done." colorLabel="2"/>
                  </outline>
                  <outline text="Change motivators" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Motivator (in this context): Factor that motivates us to perform an act [we have a bad habit or want to have a good habit] to perform."/>
                    </outline>
                    <outline text="Bad motivator changes" heading="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Good/bad (in this context): Things we think would lead to better or worse habits, respectively." collapsed="true">
                          <outline text="Distinction: Different from ethically/axiologically good/bad." collapsed="true">
                            <outline text="It&apos;s possible for it to be best (especially temporarily) to keep a bad habit or remove a good habit for various reasons."/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Remove bad motivators" heading="3"/>
                      <outline text="Don&apos;t add bad motivators" heading="3" collapsed="true">
                        <outline text="Example: You identify a bad habit to eat unhealthy food, and to make it easier to avoid, you stop buying unhealthy food." colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Good motivator changes" heading="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3"/>
                      <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Typically [reduces intrinsic motivation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=SxW_3R0188AszzqLS04sbpt3) for the good behavior"/>
                      </outline>
                      <outline text="Add good motivators" heading="3" collapsed="true">
                        <outline text="Example: Get someone to hold you accountable." colorLabel="6" collapsed="true">
                          <outline text="Importance: Can often be very effective." colorLabel="2"/>
                          <outline text="Limitation: Such people often pressure us in a way that can cause bigger issues." colorLabel="2"/>
                          <outline text="Limitation: Such people often assume that certain things will help you, when they won&apos;t. This can cause issues." colorLabel="2"/>
                        </outline>
                      </outline>
                      <outline text="Don&apos;t remove good motivators" heading="3"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="1. Learn to recognize when you&apos;re doing it" heading="3" collapsed="true">
                  <outline text="1.1 Learn to recognize when you&apos;re in situations where you will likely do it."/>
                  <outline text="1.2 Learn to ask yourself questions to check if you are doing it."/>
                </outline>
                <outline text="2. When you realize that you&apos;re doing it, avoid following the bad habit" heading="3" collapsed="true">
                  <outline text="2.1 And instead do what you want to learn to form a different habit to do, if there is one."/>
                </outline>
                <outline text="3. Regularly practice the habits that you want to replace the bad ones with" heading="3" collapsed="true">
                  <outline text="3.1 Find good replacement habits."/>
                  <outline text="3.2 Form a plan to make yourself practice the good replacement habits well and consistently." collapsed="true">
                    <outline text="3.2.1 Principles for practicing habits well."/>
                    <outline text="3.2.2 Principles for practicing habits consistently."/>
                  </outline>
                </outline>
                <outline text="**Source:**   https://en.wikipedia.org/wiki/Undoing_(psychology)" colorLabel="6"/>
              </outline>
              <outline text="The habits of improving habits" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Developing habits which help with improving your habits."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This is crucial for self-improvement in general."/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="1" colorLabel="2"/>
              <outline text="[Practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7uTPFcFISeOZWgi6CC8b3Q50)" heading="1" colorLabel="2"/>
              <outline text="[Learning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XwNwxOcZRgH_hY46vX9t5UTb)" heading="1" colorLabel="1" collapsed="true">
                <outline text="Habits are a crucial part of learning, and always arise as a sort of learned behavior."/>
              </outline>
            </outline>
          </outline>
          <outline text="Intellectual humility" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="General ability to avoid being overconfident."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="Extremely important for avoiding close-minded tendencies." colorLabel="4"/>
                <outline text="^ Close-minded tendencies are one of the largest contributors to irrationality ever." _note="Support" colorLabel="4"/>
              </outline>
              <outline text="[The importance of learning about close-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3JYkrvEjUHYENVJaDqFSq3Cd)" colorLabel="4"/>
            </outline>
            <outline text="Open-mindedness (broad)" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition (broad)" heading="3" colorLabel="3">
                <outline text="Skill to change your mind when it is most reasonable to."/>
                <outline text="Distinction" heading="3" colorLabel="3">
                  <outline text="Distinct from one&apos;s [agreeableness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zlCs-xFdA9UKoVTDSukgddfI)">
                    <outline text="Although this is typically correlated."/>
                  </outline>
                  <outline text="Distinct from the degree to which one is willing/able to tolerate others or other viewpoints.">
                    <outline text="Although this is still plausibly correlated."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Close mindedness is very common." colorLabel="4" collapsed="true">
                    <outline text="If it weren&apos;t, people wouldn&apos;t disagree so much on topics with a lot of [&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" colorLabel="4"/>
                    <outline text="Examples of close mindedness being very common" colorLabel="6" collapsed="true"/>
                  </outline>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="For those who use the right strategies, it&apos;s typically much more impactful than criticalness because of [critical piggybacking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2J5emCtKut8DRA6avr2C4r87)" colorLabel="4"/>
                  <outline text="For those who use the wrong strategies, it&apos;s very bad." colorLabel="4" collapsed="true">
                    <outline text="Examples of lacking epistemic humility being extremely bad for reasoning" _note="Move this to broader section about how people tend to be irrational." colorLabel="6" collapsed="true">
                      <outline text="[Three out of three Verizon employees believe that $0.002 = ¢0.002](https://youtu.be/nUpZg-Ua5ao?si=ysSxbuts4S6LLFTD)"/>
                    </outline>
                  </outline>
                  <outline text="The usefulness of open-mindedness is very dependent on knowledge and criticalness." colorLabel="1" collapsed="true">
                    <outline text="Criticalness" heading="3" collapsed="true">
                      <outline text="With insufficient criticalness (and/or insufficient [Open-mindedness (broad)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr)), it&apos;s going to be very difficult to properly filter the information you recieve and determine what makes the most sense."/>
                    </outline>
                    <outline text="Knowledge" heading="3" collapsed="true">
                      <outline text="If you don&apos;t have the important info in the first place, the ability to change your mind in accordance with it won&apos;t do much good."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="Open mindedness is determined by mental [habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mwz5Ve2BffIKD_YiMRN4SJOU), and mental habits can almost always be changed." colorLabel="4"/>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="[Difficulty of measuring](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rA2h7QNAIULbrA_CxFB34k2K)" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                <outline text="Reasoning abilities are mostly determined by open mindedness, so it is one of the most important things to get right." collapsed="true">
                  <outline text="[&quot;Soft&quot; reasoning makes up a large portion of important reasoning.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9tq0nu1KebS2pKlxYbgP9dvS)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Causes of close-mindedness" heading="1" colorLabel="1" collapsed="true">
                <outline text="Emotions from open/close mindedness" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Confidence" heading="3" colorLabel="1" collapsed="true">
                    <outline text="High confidence" heading="3" collapsed="true">
                      <outline text="It almost always feels cool and satisfying to be confident, so long as it doesn&apos;t feel misguided."/>
                      <outline text="It feels like you&apos;re the strong, powerful, capable one who firmly knows the truth."/>
                    </outline>
                    <outline text="Low confidence" heading="3" collapsed="true">
                      <outline text="Less respect" heading="3" collapsed="true">
                        <outline text="Being less confident typically makes you appear weaker, less reliable, less cool and less attractive."/>
                      </outline>
                      <outline text="Less trust" heading="3" collapsed="true">
                        <outline text="People trust confidence way too much, so having less confidence means way less trust, even when the opposite makes the most sense." _note="Link to cognitive bias on this in future."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Being &quot;right&quot;/&quot;wrong&quot;" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Being &quot;right&quot;" heading="3" collapsed="true">
                      <outline text="It feels cool and satisfying to feel right and like you have the truth."/>
                      <outline text="You&apos;re the capable one who&apos;s correct, who&apos;s aligned with reality, who knows best."/>
                    </outline>
                    <outline text="Being &quot;wrong&quot;" heading="3" collapsed="true">
                      <outline text="Embarrassment" heading="3" collapsed="true">
                        <outline text="Often, accepting that you were wrong means embarrassment, especially if it was because of a pretty obvious error. "/>
                      </outline>
                      <outline text="Lack of recognition" heading="3" collapsed="true">
                        <outline text="Unfortunately people don&apos;t typically appreciate or compliment people for recognizing their own errors, despite how important and rare it is to do."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Close-minded close-mindedness" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Being close-minded about how close-minded they themselves are or could be."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3"/>
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="It makes it much more difficult to become more open-minded." collapsed="true">
                        <outline text="If one can&apos;t recognize their own close mindedness (or the plausibility of it), they have much less reason and motivation to proactively improve."/>
                      </outline>
                      <outline text="At the very least, it is important to seriously consider the possibility that you are slightly close-minded in the particular area you are discussing in the vast majority of cases." collapsed="true">
                        <outline text="Even if there&apos;s only a 0.1% chance that you&apos;re somewhat close-minded about the topic, that&apos;s still enough to justify taking it seriously because the cost of taking it seriously is so low and the reward of fixing it is potentially very high."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                    <outline text="One of the most important areas to be open-minded about is the possibility of your own close-mindedness."/>
                  </outline>
                  <outline text="Defensiveness about cm cm" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Getting defensive about the idea that we could be close-minded."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Common" heading="3" collapsed="true">
                        <outline text="Often when someone points out our close-mindedness, they do so in a way that is or seems accusatory, causing us to feel defensive."/>
                      </outline>
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="When defensive about it, it&apos;s often very hard to properly reflect on the possibility that we could be close-minded on the topic when others point it out, despite how important it is."/>
                      </outline>
                    </outline>
                    <outline text="Countermeasures" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Taking a [break](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=T8lQobqEPaFFypMihwloQHLZ) before considering it."/>
                      <outline text="[Analyzing your own discussions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O32isZwT45SUSXPvCW0M_zr5)"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Unsystematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="5" collapsed="true">
                    <outline text="[Unsystematic reasoning makes it much harder to realize when we&apos;re wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G6re_Z7HFY4TY1H6os1Spa16)"/>
                  </outline>
                  <outline text="Lacking [self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)" heading="1" colorLabel="1" collapsed="true"/>
                  <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="1" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Strategies for open-mindedness" heading="1" colorLabel="2" collapsed="true">
                <outline text="[Acknowledging mistakes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=u9DK4UQhAdQKZIwwKFHicH00)" heading="1" colorLabel="2" collapsed="true">
                  <outline text="[Intellectual humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gh0FW_-AcyLbpnuFvEWm45Ke)" heading="1" colorLabel="1"/>
                </outline>
                <outline text="[Other-shoe review](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)" heading="1" colorLabel="2"/>
              </outline>
              <outline text="Measuring [open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=C2NJmspsNQQbItGTwTU9d299)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Knowing yourself" heading="3"/>
                    <outline text="Creating reasonable people" _note="~~Advanced" heading="3" collapsed="true">
                      <outline text="It&apos;s very difficult to improve open mindedness, so finding open minded people to start with is very useful for creating very reasonable people."/>
                    </outline>
                  </outline>
                  <outline text="Difficult" heading="3" collapsed="true">
                    <outline text="It&apos;s typically very difficult to accurately determine how open-minded people (including yourself) are."/>
                  </outline>
                </outline>
                <outline text="How to view" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Something that typically shouldn&apos;t be attempted on your own."/>
                </outline>
              </outline>
            </outline>
            <outline text="Epistemic self-confidence" _note="Maybe change to intellectual self-confidence?" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Confidence in your reasoning abilities, judgement, etc."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Generally you can avoid most of the detriments of low [criticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CDQTVmFBdUrFvIU4T3JfvdWZ) by having a relatively low epistemic confidence." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Epistemic self-overconfidence" _note="A lot of links to this are actually supposed to be links to short-term close-mindedness. Create a temporary overconfidence section and use the dynalist feature to view links to this item in order to fix that." heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition (overconfidence for short)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="(A propensity towards) overconfidence in one&apos;s own reasoning abilities." collapsed="true">
                    <outline text="Overconfidence: an irrationally high credence." colorLabel="3"/>
                  </outline>
                  <outline text="&quot;Overconfidence&quot; is in this section used as a shorthand for this specific kind of overconfidence."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="**Common:**   A massive portion of people are overconfident in this way about many topics." colorLabel="4" collapsed="true">
                    <outline text="Often even when they appear on the surface to have a lot of epistemic humility, they have just formed surface-level agreeable habits." colorLabel="4"/>
                  </outline>
                  <outline text="**Irrationality:**   Overconfidence makes one __far__ less [rational](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZcLNKNmVyYYwMjNA5z_NhQs)." heading="3" colorLabel="1" collapsed="true">
                    <outline text="Overconfidence usually makes one far more [close-minded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr)." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Overconfidence usually greatly reduces the effort that one would put into considering how they could be wrong." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="This is typically an intuitive response." _note="Likelihood + Relevance | Has more than you&apos;d think." colorLabel="4" collapsed="true">
                          <outline text="We hardly ever consciously decide how much effort to spend on checking whether we&apos;re wrong about something." _note="Likelihood" colorLabel="4"/>
                          <outline text="Therefore our reduced effort doesn&apos;t only apply to the depth/breadth of counterarguments we&apos;re willing to consider, but to the effort we put into considering __each counterargument individually__." _note="Relevance" colorLabel="4" collapsed="true">
                            <outline text="That it&apos;s an intuitive response means that it isn&apos;t only a mathematical division of effort, but also an emotional inclination to dismiss the possibility of being wrong entirely." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="The emotional inclination to [dismiss the possibility] heavily compels us to get the consideration over with as quickly as possible. " _note="Relevance" colorLabel="4"/>
                              <outline text="^ Because in this situation we generally subconsciously accept that we&apos;re definitely right, and so feel that checking for the possibility that we&apos;re wrong is a waste of time." _note="Likelihood" colorLabel="4" collapsed="true">
                                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ebci0135HVGMAuvAYUa_w1LW" _note="Likelihood" colorLabel="4"/>
                              </outline>
                              <outline text="Related:   [Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="6"/>
                            </outline>
                            <outline text="This causes the accuracy of the checks to plummet more than proportional to the effort reduction." _note="Relevance" colorLabel="4" collapsed="true">
                              <outline text="Our reduced effort tends to result in us trying to do only the bare minimum to satisfy the scrutiny that other people [are putting/will put] our position under." _note="Likelihood" colorLabel="4" collapsed="true">
                                <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" _note="Relevance" colorLabel="4"/>
                                <outline text="&lt;Link to how irrational people are about soft reasoning or similar&gt;" _note="Relevance" colorLabel="4" collapsed="true">
                                  <outline text="Therefore only very flawed reasoning is typically &quot;necessary&quot;." _note="Relevance" colorLabel="4"/>
                                  <outline text="^ And so we tend to have evolved and subconsciously developed strategies of using [rationalizations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NaE-8bpB1ZDuRzcl_T3nNErK) to defend our positions." _note="Relevance" colorLabel="4" collapsed="true">
                                    <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" _note="Likelihood" colorLabel="4"/>
                                    <outline text="And so we&apos;re likely to rely on rationalizations while checking to see if our reasoning is flawed." _note="Relevance" colorLabel="4"/>
                                    <outline text="^ And so our check is less likely to be successful in the event that our reasoning is flawed." _note="Relevance" colorLabel="4"/>
                                  </outline>
                                </outline>
                              </outline>
                              <outline text="The main point of checking [to see if we&apos;re wrong] is to make sure that [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) (intuition) isn&apos;t leading us astray." _note="Relevance" colorLabel="4" collapsed="true">
                                <outline text="So relying so heavily on system 1 during the check makes it even less likely for us to find the flaw(s), if there are some." _note="Relevance" colorLabel="4"/>
                                <outline text="^ It means that we will perform practically no system 2 reasoning on the matter." _note="Likelihood" colorLabel="4" collapsed="true">
                                  <outline text="[Combining system 1 and 2 is more accurate than only 1](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ta-FclRlNYMDkSM7zGdWY9ZM)" _note="Relevance" colorLabel="4"/>
                                </outline>
                              </outline>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="When one considers themselves so likely to be correct, they tend not to spend nearly as much effort checking to make sure." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="Given such a high likelihood of being correct, spending more than a tiny amount of effort checking for the contrary seems like a waste of time." _note="Likelihood" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="[Importance of open mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3JYkrvEjUHYENVJaDqFSq3Cd)" _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="[Irrationality is very costly](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=06mMgDCwf1zEQOy-EBOIangh)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Learning about distinguishing between overconfidence and confidence is impactful." colorLabel="4" collapsed="true">
                    <outline text="People typically can&apos;t distinguish between overconfidence and confidence very well." _note="Likelihood" colorLabel="4"/>
                    <outline text="It would likely make it much easier to see when you are being overconfident." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="With sufficient [self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc), it can help you recognize the signs in yourself." _note="Likelihood" colorLabel="4"/>
                      <outline text="Becoming less overconfident is very important." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="[Overconfidence makes one far less rational](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YKxHmgAjiY1nQQCjSvq_lIZZ)" _note="Likelihood" colorLabel="4"/>
                        <outline text="^ [Importance of rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iDTLYnvT3mQLwAaXj65fNdY3)" _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="This section can help you learn about it." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="[How overconfidence seems like positive confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ityU4yMPEryFxasgaEMZk6tu)" _note="Likelihood" colorLabel="4"/>
                      <outline text="[How epistemic humility seems like a bad lack of confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fbZ_0EpA2GNrjG5Uu_td05-r)" _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Overconfidence tends to increase how much one acts on their ideas." colorLabel="4" collapsed="true">
                    <outline text="It makes people feel more motivated." _note="Likelihood" colorLabel="4"/>
                    <outline text="This helps put their ideas to the test." _note="Relevance" colorLabel="4"/>
                    <outline text="There are usually much less costly ways to achieve a similar increase in how much one will act on their ideas." _note="Relevance" colorLabel="1" collapsed="true">
                      <outline text="[Overconfidence makes one __far__ less rational](https://dynalist.io/d/axyUc8EpOb4NEwUA5hpTKBU1#z=eOF242H0lJpbc2jU8tObt2jd)" _note="Relevance | Make sure this link still works after the move." colorLabel="4"/>
                    </outline>
                    <outline text="The efficiency reduction from irrationality resulting from overconfidence is very high." _note="Relevance" colorLabel="1" collapsed="true">
                      <outline text="So the value of the effort is far less, even if the amount of effort is more." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Overconfidence can lead to rationalized procrastination." _note="Relevance" colorLabel="1" collapsed="true">
                      <outline text="So the degree of increased action would likely be less than it otherwise would be." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Overconfidence has a mixed effect on charisma." _note="Link charisma, and link persuasion to and from charisma." colorLabel="1" collapsed="true">
                    <outline text="Among people who recognize it as overconfidence, it will generally be seen as very cringey." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="There are some exceptions in the form of people who think it&apos;s cute, inspiring, helpful, etc." _note="Relevance" colorLabel="1"/>
                      <outline text="^ These people generally fail to see how much of a negative effect overconfidence has on reasoning." _note="Relevance" colorLabel="1" collapsed="true">
                        <outline text="So the people who like you most will be people who fail to properly understand one of the most crucial aspects of reasoning." _note="Relevance" colorLabel="1"/>
                        <outline text="^ So the people who like you most are likely to be more irrational and overconfident themselves." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Among people who mistake it for competence, it&apos;s generally very charismatic." _note="Relevance" colorLabel="1" collapsed="true">
                      <outline text="https://dynalist.io/d/axyUc8EpOb4NEwUA5hpTKBU1#z=CZmSIG1xt_tN4899_oU3eVuS" _note="Relevance" colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="Overconfidence increases how much counterarguing you&apos;ll get from other people." colorLabel="4" collapsed="true">
                    <outline text="This could help find flaws in your reasoning." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Generally, overconfidence makes it much harder to recognize flaws in your reasoning." _note="Likelihood" colorLabel="1" collapsed="true">
                        <outline text="[Overconfidence makes one far more close-minded.](https://dynalist.io/d/axyUc8EpOb4NEwUA5hpTKBU1#z=HSLkskvXW7D6a6r_R18S7OE7)" _note="Likelihood" colorLabel="4"/>
                        <outline text="Even when the flaws are pointed out explicitly." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="There are easy and effective alternative methods to achieve this." _note="Relevance" colorLabel="1" collapsed="true">
                        <outline text="Eg. Acting overconfident when you actually aren&apos;t." _note="Likelihood" colorLabel="4"/>
                        <outline text="Eg. Surrounding yourself with critical people." _note="Likelihood | Link criticalness and surrounding yourself with reasonable people" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="**Difficult:**   It&apos;s very difficult to avoid overconfidence." colorLabel="4"/>
                </outline>
                <outline text="The ways in which overconfidence seems like positive confidence" _note="Maybe reorganize this" heading="3" colorLabel="1" collapsed="true">
                  <outline text="It often feels like better reasoning" heading="3" colorLabel="1" collapsed="true">
                    <outline text="It often feels like one must have good evidence/reasoning to be so confident."/>
                  </outline>
                  <outline text="It often feels like higher capability" heading="3" colorLabel="1" collapsed="true">
                    <outline text="It often feels like one must have good evidence/reasoning to be so confident, and therefore that they are very capable."/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="The ways in which epistemic humility seems like a bad kind of lack of confidence" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Lack of intelligence" heading="3" collapsed="true">
                    <outline text="Indication that you didn&apos;t calculate properly." _note="(Especially if you had far too much confidence before changing your mind.)"/>
                    <outline text="^ This often comes from people thinking that it&apos;s much easier to reason in general than it really is." collapsed="true">
                      <outline text="Everyone is very often wrong all the time." _note="Move and link here, and connect with [people are bad at &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qarhXHvwcgUN1n5fnt5sFXck)"/>
                    </outline>
                  </outline>
                  <outline text="Lack of backbone" heading="3" collapsed="true">
                    <outline text="It often feels like changing your mind is a sign of weakness/gullibility, even when it isn&apos;t."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[System 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Usually one of the primary causes of overconfidence is over-reliance on system 1 reasoning." colorLabel="4"/>
                  </outline>
                  <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Usually one of the primary causes of overconfidence is overly heavy heuristic usage." colorLabel="4"/>
                  </outline>
                  <outline text="[Pride](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GdWZXDTEkI9DW_5ydfmnRxce)" heading="2" colorLabel="1"/>
                  <outline text="https://en.wikipedia.org/wiki/Hubris"/>
                </outline>
              </outline>
            </outline>
            <outline text="The knife&apos;s edge of humility" _note="Link/combine with emotional/epistemic self-confidence." heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The issues that epistemic humility can cause."/>
              </outline>
              <outline text="Doubting yourself" heading="3" colorLabel="1" collapsed="true">
                <outline text="Doubting yourself epistemically is crucial for good reasoning."/>
                <outline text="Doubting yourself emotionally often leads to insecurity, anxiety, self-hate, and lots of other unhealthy things."/>
              </outline>
              <outline text="Believing in yourself" heading="3" colorLabel="1" collapsed="true">
                <outline text="Epistemically believing in yourself tends to lead to frequently assuming you&apos;re right and failing to consistently give the possibility that you&apos;re wrong adequate consideration."/>
                <outline text="Emotionally believing in yourself is extremely useful for pushing past hard obstacles and bouncing back from bad feelings."/>
              </outline>
              <outline text="The correlation between epistemic and emotional habits" heading="3" colorLabel="1" collapsed="true">
                <outline text="Long-term, the habits we form for how to emotionally view things tends to heavily skew how we epistemically view things in a similar way. " collapsed="true">
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="If one is emotionally optimistic then they&apos;ll likely be epistemically optimistic."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Measuring epistemic humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IBGJau5KaVc-QdSibLKAw_4g)" heading="1" colorLabel="5"/>
              <outline text="[Goals of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDRmT592xGeslYb-hvYp2ujH)" heading="2" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Cognitive biases" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Systematic pattern of deviation from rational judgement."/>
              <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                <outline text="When calling people biased, we are often using &quot;biased&quot; in a different way:"/>
                <outline text="Unfair" heading="3" collapsed="true">
                  <outline text="One does not have to be &quot;unfair&quot; in any traditional sense to have some kind of systematic pattern of deviation from rational judgement."/>
                  <outline text="^ Eg. We have evolved to simplify our sensory data in a way that is more efficient to us given our cognitive limitations, resulting in us being consistently trickable with [optical illusions](https://en.wikipedia.org/wiki/Optical_illusion)." colorLabel="6"/>
                </outline>
                <outline text="Preferenced" heading="3" collapsed="true">
                  <outline text="One can have an emotional preference for something (that is specific to themselves) without any irrational judgement involved."/>
                </outline>
                <outline text="__Particularly__ biased relative to what we&apos;re accustomed to." heading="3" collapsed="true">
                  <outline text="One can be just as biased (or even far less) than what we are used to, while still having __some__ deviation from rational judgement."/>
                  <outline text="^ [Optical illusions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9Q0DI4-UOJ2wDg2RWheNrLTF)" colorLabel="6"/>
                </outline>
              </outline>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="Cognitive biases are incredibly common." _note="Support" colorLabel="4"/>
              </outline>
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="**Cause big reasoning obstacles:**   Cognitive biases of various sorts are involved in all the biggest obstacles to good reasoning." colorLabel="4"/>
                <outline text="**Stacking effects:**   The effects of multiple cognitive biases can stack on each other, creating exponentially more irrational judgements." colorLabel="4"/>
                <outline text="**Can&apos;t substitute systematic reasoning:**   Learning to avoid specific cognitive biases can&apos;t be a complete substitute for [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" colorLabel="1" collapsed="true">
                  <outline text="If it&apos;s treated as a complete substitute, there is a significant risk of substantial [Uncriticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HFlajn-7ApUXftkQMGXZHVWq) due to still relying on [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)"/>
                </outline>
              </outline>
              <outline text="Improvable" heading="3" collapsed="true">
                <outline text="**Bias variety indicates solution variety:**   People vary in how strongly they exhibit different biases, so there should be a host of ways to influence how biased we are." colorLabel="4"/>
                <outline text="**Learning helps avoid:**   Learning about specific cognitive biases helps develop methods for recognizing and combating many specific cognitive biases." colorLabel="4"/>
                <outline text="**Bias blind spot:**   Due to the [bias blind spot](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qYKn9LjoeqFhKAwabwW925I7), studying biases can in fact make you __more__ vulnerable to [overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB) and [confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)." colorLabel="1" collapsed="true">
                  <outline text="Because it can help you see the influence of cognitive biases all around you—without seeing the influence in yourself." colorLabel="4" collapsed="true">
                    <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0Twe0jxOkPS7EBmXHOxaQnBm" colorLabel="6"/>
                  </outline>
                  <outline text="Richard F. West, Russell J. Meserve, and Keith E. Stanovich, “Cognitive Sophistication Does Not Attenuate the Bias Blind Spot,” __Journal of Personality and Social Psychology__ 103, no. 3 (2012): 506." colorLabel="6"/>
                </outline>
              </outline>
            </outline>
            <outline text="Common cause" heading="1" colorLabel="5" collapsed="true">
              <outline text="Cognitive biases arise when the corners cut with [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) result in a relatively consistent and discrete mistake. "/>
            </outline>
            <outline text="Bias blind spot" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A special blind spot towards our own biases, which applies even when we can correctly identify the biases of others."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="In a survey of 76 people waiting in airports, individuals rated themselves much less susceptible to cognitive biases on average than a typical person in the airport. In particular, people think of themselves as unusually unbiased when the bias is socially undesirable or has difficult-to-notice consequences." colorLabel="4" collapsed="true">
                    <outline text="Emily Pronin, Daniel Y. Lin, and Lee Ross, “The Bias Blind Spot: Perceptions of Bias in Self versus Others,” __Personality and Social Psychology Bulletin__ 28, no. 3 (2002): 369–381." colorLabel="6"/>
                  </outline>
                  <outline text="Other studies find that people with personal ties to an issue see those ties as enhancing their insight and objectivity; but when they see __other people__ exhibiting the same ties, they infer that those people are overly attached and biased." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="The bias blind spot, unlike many biases, is __especially severe__ among people who are __especially intelligent, thoughtful, and open-minded__." colorLabel="4" collapsed="true">
                    <outline text="Not to be confused with people who think they’re unusually intelligent, thoughtful, etc. because of the illusory [superiority bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cjbQO8yswEZPcz1DSN_OENAs)."/>
                    <outline text="Richard F. West, Russell J. Meserve, and Keith E. Stanovich, “Cognitive Sophistication Does Not Attenuate the Bias Blind Spot,” __Journal of Personality and Social Psychology__ 103, no. 3 (2012): 506." colorLabel="6"/>
                  </outline>
                  <outline text="Studying biases can make you more overconfident and susceptible to confirmation bias." colorLabel="4"/>
                  <outline text="[Learning about biases can make us more overconfident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tnS7Qx3CE7MMeNj2iCv-gShl)" colorLabel="4" collapsed="true">
                    <outline text="Therefore learning how this works, how to recognize it, etc. is incredibly important." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="[Learning about biases can make us more overconfident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tnS7Qx3CE7MMeNj2iCv-gShl)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Bias blind spot would ostensibly apply to itself, so we must be very careful with how we go about learning to avoid it." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                <outline text="We’re especially loath to think of our views as inaccurate compared to the views of others."/>
                <outline text="We fail to detect any “biased-feeling thoughts” when we [introspect](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=aqX299sRiWRL4uS29eOaKCGW), and so draw the conclusion that we must just be more objective than everyone else." collapsed="true">
                  <outline text="Joyce Ehrlinger, Thomas Gilovich, and Lee Ross, “Peering Into the Bias Blind Spot: People’s Assessments of Bias in Themselves and Others,” __Personality and Social Psychology Bulletin__ 31, no. 5 (2005): 680–692." colorLabel="6"/>
                </outline>
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc"/>
              </outline>
              <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                <outline text="https://www.readthesequences.com/Biases-An-Introduction"/>
              </outline>
            </outline>
            <outline text="Base rate neglect" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The fallacy where we ground our judgements in how intuitively &quot;normal&quot; a combinatino of attributes is, neglecting how common each attribute is in the population at large."/>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Is it more likely that Steve is a shy librarian, or that he’s a shy salesperson? Most people answer this kind of question by thinking about whether “shy” matches their stereotypes of those professions. They fail to take into consideration how much more common salespeople are than librarians—seventy-five times as common, in the United States."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Base_rate_fallacy)"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="There are effective [countermeasures](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=beXBS7l0arptnCenIIQfz8aa)" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="[Representativeness heuristic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HFS-yoqzJcX2UK10bI3AB6p4)"/>
              </outline>
              <outline text="Countermeasures" heading="3" colorLabel="2" collapsed="true">
                <outline text="Thinking of probabilities as frequencies of objects or events." collapsed="true">
                  <outline text="[https://www.youtube.com/watch?v=HZGCoVF3YvM](This video) shows a visual technique that can help with this."/>
                </outline>
              </outline>
            </outline>
            <outline text="Confirmation bias" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Giving more weight to evidence for confirming what we already believe (in itself)."/>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The &quot;in itself&quot; is very important here. without that, we might be tempted to object: &quot;We ought to give more weight to evidence that confirms what we believe, as it fits in better with our model of reality in that case, doesn&apos;t it?&quot;"/>
                  <outline text="^ Confirmation bias occurs when it is [the **mere fact** that it confirms are beliefs] that makes us give it more weight, and not any indirect factors such as the abductive weight provided by [it fitting into our model of reality well]."/>
                </outline>
                <outline text="[Example and source](https://youtu.be/SoCqftOYHX4)" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="[Wason selection task](https://en.wikipedia.org/wiki/Wason_selection_task)" colorLabel="4" collapsed="true">
                    <outline text="A very small number of people (~4-10%) are able to complete the task successfully, when it is presented ordinarily." colorLabel="4" collapsed="true">
                      <outline text="**&quot;ordinarily&quot;:**  (i.e. Without prior knowledge about its difficulty, and with abstract elements.)" colorLabel="3"/>
                    </outline>
                    <outline text="[We tend to be able to perform well at the task when it is presented in a social context.](https://en.wikipedia.org/wiki/Wason_selection_task#Policing_social_rules)" colorLabel="1" collapsed="true">
                      <outline text="Whether this is the result of instinctual or learned processes, either way it seems obviously dependent on [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) which are not ordinarily active in more abstract variations." colorLabel="1"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="It easily tricks people into denying important logical consequences of new information." colorLabel="4"/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="We can effectively practice systematic methods of reasoning that account for and largely avoid most forms of biased thinking." _note="Needs support." colorLabel="4"/>
                  <outline text="We can learn much more consistent means of accounting for [past reasoning that may have been forgotten]." colorLabel="4"/>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="Merely knowing about a bias is rarely enough to protect you from it." heading="3" colorLabel="4" collapsed="true">
                    <outline text="In a study of __bias blindness__, experimental subjects predicted that if they learned a painting was the work of a famous artist, they’d have a harder time neutrally assessing the quality of the painting. And, indeed, subjects who were told a painting’s author and were asked to evaluate its quality exhibited the very bias they had predicted, relative to a control group. When asked __afterward__, however, the very same subjects claimed that their assessments of the paintings had been objective and unaffected by the bias—in all groups!"/>
                    <outline text="^ Katherine Hansen et al., “People Claim Objectivity After Knowingly Using Biased Strategies,” __Personality and Social Psychology Bulletin__ 40, no. 6 (2014): 691–699." colorLabel="6"/>
                    <outline text="^ Similarly, Pronin writes of gender bias blindness. " colorLabel="6" collapsed="true">
                      <outline text="In one study, participants considered a male and a female candidate for a police-chief job and then assessed whether being “streetwise” or “formally educated” was more important for the job. The result was that participants favored whichever background they were told the male candidate possessed (e.g., if told he was “streetwise,” they viewed that as more important). Participants were completely blind to this gender bias; indeed, the more objective they believed they had been, the more bias they actually showed."/>
                      <outline text="^ Eric Luis Uhlmann and Geoffrey L. Cohen, “‘I think it, therefore it’s true’: Effects of Self-perceived Objectivity on Hiring Discrimination,” __Organizational Behavior and Human Decision Processes__ 104, no. 2 (2007): 207–223. " colorLabel="6"/>
                    </outline>
                    <outline text="Source for this section" heading="3" colorLabel="6" collapsed="true">
                      <outline text="https://www.readthesequences.com/Biases-An-Introduction#footnote3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true"/>
              <outline text="Indicators" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Indications that you may be under the influence of cognitive bias(es)."/>
                </outline>
                <outline text="Someone is claiming that you are being close-minded or failing to take into account an obvious fact."/>
                <outline text="Rejecting a proposition that you likely do not fully understand."/>
              </outline>
              <outline text="Suggested countermeasures" heading="1" colorLabel="2" collapsed="true">
                <outline text="Systematic reasoning" heading="3" collapsed="true">
                  <outline text="Learning (and practicing) to [reason systematically](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7) (at least for important decisions)." colorLabel="3"/>
                  <outline text="This minimizes the room for all biases (confirmation bias included) to creep in." colorLabel="4"/>
                </outline>
                <outline text="[Reduce over-reliance on intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OUAhqDVNYRgxVu2oBtqGswCr)" _note="Only visit this now if you&apos;re heavily focusing on learning countermeasures." heading="3"/>
                <outline text="Recognition" heading="3" collapsed="true">
                  <outline text="Practice recognizing when confirmation bias is likely occurring." colorLabel="3"/>
                  <outline text="We are typically very bad (and overconfident) at recognizing when a bias is affecting us." colorLabel="1" collapsed="true">
                    <outline text="So this method should likely not be relied on, at least on its own." colorLabel="2"/>
                    <outline text="[Bias blind spot](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qYKn9LjoeqFhKAwabwW925I7)" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Considering alternatives" heading="3" collapsed="true">
                  <outline text="Practice considering alternative possibilities that feel wrong in situations where you lack very solid conscious reasoning to justify your feelings." colorLabel="3"/>
                </outline>
                <outline text="Disproving" heading="3" collapsed="true">
                  <outline text="Create the habit of (for non-trivial problems) considering whether it would be easier to solve the problem via trying to disprove what you&apos;re ultimately trying to prove." colorLabel="3"/>
                  <outline text="Software debugging" heading="3" colorLabel="2" collapsed="true">
                    <outline text="To think of your ideas and beliefs as software you&apos;re actively trying to find problems with, rather than things to be defended." colorLabel="3"/>
                    <outline text="If they should be defended given the information you&apos;ll have, you should naturally realize this without needing emotionally assume that they are true." colorLabel="4"/>
                    <outline text="It&apos;s easy to get into habits that make you __feel__ like you&apos;re doing this, without actually properly doing it." colorLabel="1" collapsed="true">
                      <outline text="So there should be some feedback mechanism to practice this, if you intend to use this method." colorLabel="2"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="[&quot;Blind&quot; techniques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CLmXQEO4-lPT5O56n2jbZsSC" _note="Only visit this now if you&apos;re heavily focusing on learning countermeasures." heading="3"/>
                <outline text="Related" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Potential evolutionary explanations" heading="2" colorLabel="1" collapsed="true">
                <outline text="It tended to be more efficient for multiple people with competing perspectives to focus on reasoning for their own perspective rather than for multiple perspectives, and then to use that reasoning to competitively try to influence the overall tribe. In the absence of biases specific to the topic in question, the crowd would tend to overall come to an agreement on the better justified position this way, with the &quot;researchers&quot; often only needing to do enough work to represent the best reasons they could give for their own perspective."/>
                <outline text="The past importance of making rapid decisions in uncertain situations."/>
                <outline text="Confirmation bias implicitly accounts for (in some sense) past reasoning that may have been forgotten, since we ostensibly arrived at our initial belief through reasoning that we may or may not remember."/>
                <outline text="We evolved to __act__ reasonable more than __be__ reasonable." _note="Create/link"/>
              </outline>
              <outline text="Myside bias" _note="Synonym of confirmation bias? I recall it being different" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A bias toward searching and interpreting evidence in a manner that tends to favor the hypothesis we want to be true."/>
                </outline>
              </outline>
            </outline>
            <outline text="Groupthink" _note="PC ~Beginner, link in framing/etc., deal with duplicate in &quot;environment&quot; or sociology category." heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The bias to let the social dynamics of a group situation override the most reasonable choice."/>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Informational social influence"/>
                </outline>
                <outline text="[Example and source](https://www.youtube.com/watch?v=n1A9vrsw6Hw)" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s common" heading="3" collapsed="true">
                  <outline text="It&apos;s often used in advertising."/>
                </outline>
                <outline text="It can lead us to deny important logical consequences of the available information in favor of the socially accepted answer." collapsed="true">
                  <outline text="This is a cognitive bias that plagues many people" heading="3" collapsed="true">
                    <outline text="Dissent can be uncomfortable and dangerous to one&apos;s social standing, and so often the most confident or first voice will determine group decisions."/>
                    <outline text="" heading="3" colorLabel="6"/>
                  </outline>
                </outline>
                <outline text="We can learn much more consistent means of accounting for the reasoning that others have performed, such as gaining an in-depth understanding of why they hold different opinions."/>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="Partially reducible to [anchoring/framing effects](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gqfxRHs-DUYtXdVA2pFuNEji)." collapsed="true">
                  <outline text="Social norms are a heavy anchor/frame." colorLabel="4" collapsed="true">
                    <outline text="[Overton Window](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uN0SA7RJNS9CHXfwu6uBCV9g)" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Indicators" heading="1" colorLabel="1" collapsed="true">
                <outline text="Your belief initially differs from the relevant social group and the subject of the beliefs is heavily reliant on [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)." _note="Fix link"/>
                <outline text="The reasoning that other(s) provide(s) seems flawed."/>
              </outline>
              <outline text="In-group favoritism" _note="PC Link stuff from importance in in-group vs out-group or something." heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The propensity for people, under certain conditions, to prefer and have affinity for one&apos;s in-group over the out-group, or anyone viewed as outside the in-group."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common and impactful" heading="3" collapsed="true">
                    <outline text="How we perceive the actions of others is frequemtly and substantially affected by in-group favoritism." collapsed="true">
                      <outline text="People may perceive the same action very differently depending on whether the action was executed by a member of the same group or a member of a different group."/>
                      <outline text="People tend to evaluate actions of their own group or team members much more favorably than those of outgroup members."/>
                      <outline text="This phenomenon was demonstrated in an empirical study conducted by Molenberghs and colleagues in 2013." collapsed="true">
                        <outline text="In the study, participants were arbitrarily divided into two teams where they watched videos of individuals of competing teams and individuals from their own team perform hand actions. Participants were then asked to judge the speed of the hand movements."/>
                        <outline text="On average participants judged members of their own teams to be faster, although the hand movements were the exact same speed across the board."/>
                      </outline>
                      <outline text="Similarly, Hastorf and Cantril conducted a pioneering study in 1954, where students of both Princeton and Dartmouth viewed a contentious football game between their two teams." collapsed="true">
                        <outline text="Although they had watched the same motion picture of the game, their versions of what transpired were so starkly different it appeared as though they had watched two totally different games."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="This can be expressed in one&apos;s evaluation of others, linking, allocation of resources, and many other ways."/>
                  </outline>
                  <outline text="Improvable" heading="3" collapsed="true">
                    <outline text="Elements of favoritism are flexible in that they can be erased by changes in social categorization." collapsed="true">
                      <outline text="This change is known as [recategorization](https://en.wikipedia.org/wiki/Recategorization)." _note="Probably make a separate section for this and link or something."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Potential evolutionary explanation" heading="3" colorLabel="1" collapsed="true">
                  <outline text="In-group favoritism was likely selected for the advantages of [coalition](https://en.wikipedia.org/wiki/Coalition) affiliation."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Information bubbles](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mb-QFAcGf_sctWRPSrJ6Ubpp)" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Suggested countermeasures" _note="In roughly descending order of effectiveness." heading="1" colorLabel="2" collapsed="true">
                <outline text="Learning (and practicing) to reason in a systematic way (at least for important decisions)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This minimizes the room for all biases (confirmation bias included) to creep in." colorLabel="2"/>
                </outline>
                <outline text="[Reduce over-reliance on vague intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OUAhqDVNYRgxVu2oBtqGswCr)" heading="3" colorLabel="2"/>
                <outline text="Learn about (and practice recognizing) cognitive biases and other common flaws in reasoning to be able to better recognize when it seems that others are using flawed reasoning to arrive at their conclusions." colorLabel="2" collapsed="true">
                  <outline text="" heading="3" colorLabel="2"/>
                  <outline text="Other flaws (fallacies?)"/>
                </outline>
                <outline text="[Facilitate group critical thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eFQRxyWWj9LJQipxpfkDcZbr)" heading="3" colorLabel="2"/>
                <outline text="Getting better at measuring how much [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) is involved in a topic." heading="3" colorLabel="2"/>
                <outline text="Practice recognizing when groupthink is likely occurring." heading="3" colorLabel="2" collapsed="true">
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="This likely won&apos;t be very effective because it&apos;s difficult to practice this in a reliable way."/>
                  </outline>
                  <outline text="" heading="1" colorLabel="1"/>
                </outline>
                <outline text="Common links" heading="3" colorLabel="6" collapsed="true">
                  <outline text="" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Potential evolutionary explanations" heading="2" colorLabel="1" collapsed="true">
                <outline text="The importance of social cohesion for our ancestors."/>
                <outline text="The tendency for flaws in reasoning to sort of &quot;even out&quot; for most hypotheses, making the majority&apos;s opinion more reliable usually."/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Overton Window](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uN0SA7RJNS9CHXfwu6uBCV9g)" heading="3"/>
                <outline text="[Isolating yourself from unreasonable people](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=pqLJHM1DMjTBOlRsyi6vQORW)" collapsed="true">
                  <outline text="Reasonable people are much less likely to apply many of the kinds of social pressures that encourage groupthink." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Therefore complete isolation would likely not be necessary to be able to greatly reduce groupthink via isolating from unreasonble people." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Anchoring/framing effects" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The bias to consider values in the context of other presented values."/>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Today only, you can get a new Toyota for 20% off the sticker price! So act now and drive your new car away today!"/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Especially impactful when it biases us to consider an overly-limited range of potential values." colorLabel="4" collapsed="true"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Incredibly commonly abused by marketers and salespeople." colorLabel="4"/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="We can learn to consider unpresented values to compare something with." colorLabel="4" collapsed="true">
                    <outline text="Many of the most common and important unpresented values are fundamentally pretty easy to account for." colorLabel="4" collapsed="true">
                      <outline text="Example: [prior probability](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=p27oF333OJQDubxwMG2_gtog)" colorLabel="6"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Failure to (sufficiently) account for unknowns" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="**Unknowns:**  Unknown factors relevant to the claim(s) you&apos;re considering." colorLabel="3"/>
                </outline>
                <outline text="[Importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NQqQgRCBkQi_8NvWlOhzlMob)" heading="3" colorLabel="2"/>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="[Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49)" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Typically we simply do not have the time to account for all the biggest potential unknowns. We instead heavily rely on unreliable reasoning short-cuts and engage in [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37), which tends not to be the best way to consistently account for the biggest potential unknowns."/>
                  </outline>
                  <outline text="[Unsystematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="3" colorLabel="5" collapsed="true">
                    <outline text="We typically lack the time to investigate arguments in a systematic fashion, which would typically involve (or at least help with) accounting for all the biggest potential unknowns."/>
                  </outline>
                  <outline text="" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Often when considering other peoples&apos; claims (particularly those from those we are close with), we will be less [critical](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HFlajn-7ApUXftkQMGXZHVWq) and more agreeable."/>
                  </outline>
                </outline>
                <outline text="Solutions" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Many specific strategies to account for unknowns are in [accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK)" heading="3" colorLabel="6"/>
                  <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="3" colorLabel="5"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK)" heading="3" colorLabel="6"/>
                </outline>
              </outline>
              <outline text="Less-is-better effect" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The cognitive bias to favor a lesser option when it is presented separately, but to prefer the better option when both are presented together."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="A person giving a $45 scarf (from scarves ranging from $5-$50) as a gift was perceived to be more generous than one giving a $55 coat (from coats ranging from $50-$500);"/>
                    <outline text="An overfilled ice cream serving with 7 oz of ice cream was valued more than an underfilled serving with 8 oz of ice cream;"/>
                    <outline text="A dinnerware set with 24 intact pieces was judged more favourably than one with 31 intact pieces (including the same 24) plus a few broken ones."/>
                  </outline>
                  <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Less-is-better_effect)"/>
                </outline>
              </outline>
              <outline text="The availability heuristic" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The bias to assume that the likelihood of something is more heavily correlated with how readily it comes to mind (its “salience”) than it actually is, or with more confidence than is justified."/>
                </outline>
                <outline text="Bias towards how well we can initially imagine something" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Causes" heading="3" colorLabel="1" collapsed="true">
                    <outline text="When we can better initially imagine something, it typically feels more real, which makes it feel more likely to be true."/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Bias towards the specific/&quot;grounded&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Bias towards the stated" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[False dilemma](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HgqsuPlUw6Vw0iQlDlryh4oB)" heading="1" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Often an over-reliance on our [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) to provide good and relevant evidence, when it merely provides what we&apos;ve formed the strongest relevant associations about." _note="PC copy/move to subconscious and link here"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="3" colorLabel="5"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Assuming that others feel the same as us](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uOOadpgv2pwwmCpjInvAhEFN)" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Likely often caused by an anchoring/framing effect." colorLabel="4"/>
                </outline>
                <outline text="[False dilemma](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HgqsuPlUw6Vw0iQlDlryh4oB)" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Wishful thinking" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Bias towards emotionally appealing people/ideas/etc. and bias against emotionally unappealing people/ideas/etc."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="" colorLabel="4"/>
                </outline>
                <outline text="[Importance of &quot;defending sub/un-conscious&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Po037OookU67GxF_ILSnIc90)" colorLabel="4"/>
              </outline>
              <outline text="Forms" heading="1" colorLabel="1" collapsed="true">
                <outline text="Defending sub/un-conscious" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Bias towards believing (and especially defending) what we unconsciously or subconsciously did."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3" collapsed="true">
                      <outline text="Virtually everyone does it." colorLabel="4"/>
                      <outline text="^ " colorLabel="4"/>
                    </outline>
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="How to abuse this" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Make one feel like the belief you want them to have is their own idea (i.e. embed it in their un/sub-conscious). Once they feel this way, they will be much more likely to adopt/defend it themselves, possibly even if it goes against their previous belief(s)."/>
                  </outline>
                </outline>
                <outline text="Projecting desires" _note="This seems very similar to the parent." heading="1" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The bias to project our own desires onto reality and fool ourselves into thinking that reality conforms to how we would like it to be."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Potential evolutionary explanation" heading="2" colorLabel="1" collapsed="true">
                <outline text="The conscious as our &quot;PR team&quot;" heading="3" collapsed="true">
                  <outline text="Humanity was (and still is) an irrational species, in a way that gradient decent promoted." collapsed="true">
                    <outline text="A more rational species would require very specific moral/axiological axioms in order to consistently act in advantageous ways, and due to the way that our brains evolved, there&apos;s no easy way to evolve such axioms, only emotional instincts towards simplistic patterns roughly representing those axioms."/>
                  </outline>
                  <outline text="In order to motivate humans towards certain ideal actions (eg. mating more capable people), they developed metrics for judging features like capability."/>
                  <outline text="However since humans were so irrational, their judgement was highly susceptible to trickery."/>
                  <outline text="So natural selection supported the evolution of a mechanism that convinces people to view us in a better light than they otherwise would."/>
                  <outline text="Our bias to defend our actions, even when they were our un/sub-conscious actions and there&apos;s no justifiable defense, is plausibly a result of this."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="" heading="3" colorLabel="1"/>
                <outline text="" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Bias towards the specific/&quot;grounded&quot;" _note="~~Amateur" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="We feel like things presented in a more specific/&quot;grounded&quot; way are more likely to be accurate."/>
                <outline text="i.e." heading="3" colorLabel="3" collapsed="true">
                  <outline text="We are biased against vague/&quot;ungrounded&quot; things."/>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="One presents us with a realistic hypothetical and all the necessary reasoning to support it, but we still treat it like it is &quot;just a hypothetical/conceptual thing&quot; and consider it substantially less likely to be truthful."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[Theoretical reasoning importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ES3dSwo0NpH94kCkD6KVMiQi)" colorLabel="4"/>
                </outline>
                <outline text="Common" heading="3"/>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="We often develop the heuristic that more vague/abstract evidence is less reliable."/>
                  <outline text="^ Partially because they are more prone to being interpreted in a biased manner." collapsed="true">
                    <outline text="And this is generally accurate, vague/abstract things allow for more possibilities, thus allowing us to fill those gaps with our biases." colorLabel="4"/>
                    <outline text="However there are major exceptions to this heuristic, such that relying on it to give more than a minor indication of how to treat vague/abstract evidence is sure to lead to major mistakes." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="[Bias towards how well we can initially imagine something](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hnFpbjCcECkbgFcHNQupthnG)" heading="3" colorLabel="1" collapsed="true">
                  <outline text="When we have an explicit example (especially when it is tied to an emotion that compels us to accept the fact), we can typically imagine it more clearly." _note="Relevance" colorLabel="4"/>
                  <outline text="Our imagination often has an easier time with more explicit/detailed descriptions." colorLabel="4"/>
                </outline>
                <outline text="Over-reliance on [System 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" heading="3" colorLabel="1" collapsed="true">
                  <outline text="The bias towards the specific/&quot;grounded&quot; would not be very influential, except that we tend to trust our [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) (especially our initial intuition) far too much." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="How to abuse this" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Characterization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-RfRZ7650bJF8cl3dEY8_zE_)" heading="3"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Theoretical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a__A4WdOE_LwKq1rrTZjz2Rm)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Attribution errors" _note="Fix terms of sections under this and refine" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definitions" _note="Fix" heading="3" colorLabel="3" collapsed="true">
                <outline text="1. The underemphasis of situational and environmental factors and overemphasis on dispositional or personality factors for the behavior of other(s)."/>
                <outline text="2. The overemphasis of dispositional or personality factors for the behavior of one&apos;s self."/>
                <outline text="i.e." heading="1" collapsed="true">
                  <outline text="An error where one tends to overattribute the behaviors of others to their personality (e.g., he is late because he&apos;s selfish) and underattribute them to the situation or context (e.g., he is late because he got stuck in traffic)."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3"/>
                <outline text="Common?" heading="3" collapsed="true">
                  <outline text="It is (at least according to my Wikipedia skim) seemingly substantially contested how common these errors are."/>
                </outline>
              </outline>
              <outline text="Failures" heading="1" colorLabel="6" collapsed="true">
                <outline text="Other-personality overemphasis" heading="3" colorLabel="1"/>
                <outline text="Self-environment overemphasis" heading="3" colorLabel="1"/>
              </outline>
              <outline text="Successes" heading="1" colorLabel="6" collapsed="true">
                <outline text="Other-environment overemphasis" heading="3" colorLabel="1"/>
                <outline text="Self-personality overemphasis" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Sunk cost fallacy" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" _note="Improve this definition a bit." heading="3" colorLabel="3" collapsed="true">
                <outline text="Feeling committed to things you’ve spent resources on in the past, when you should be cutting your losses and moving on."/>
              </outline>
            </outline>
            <outline text="Duration neglect" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A bias that occurs when we evaluate an experience without regard for how long it lasts."/>
              </outline>
              <outline text="Countermeasures" heading="3" colorLabel="2" collapsed="true">
                <outline text="Depicting duration graphically." collapsed="true">
                  <outline text="Michael J. Liersch and Craig R. M. McKenzie, “Duration Neglect by Numbers and Its Elimination by Graphs,” __Organizational Behavior and Human Decision Processes__ 108, no. 2 (2009): 303–314." colorLabel="6"/>
                </outline>
                <outline text="Directing more attention to duration."/>
              </outline>
            </outline>
            <outline text="Superiority bias" heading="3" colorLabel="1"/>
            <outline text="Assuming that others feel the same as us" _note="~Amateur" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3"/>
                <outline text="Common" heading="3"/>
              </outline>
              <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                <outline text="[Anchoring/framing effects](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gqfxRHs-DUYtXdVA2pFuNEji)" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Likely often caused by these." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Indicators" heading="1" colorLabel="1"/>
              <outline text="Suggested countermeasures" _note="In roughly descending order of importance." heading="1" colorLabel="2"/>
              <outline text="Potential evolutionary explanation" heading="2" colorLabel="1"/>
            </outline>
            <outline text="Mere exposure effect" _note="~~Adept" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The phenomenon whereby individuals develop a preference for things merely due to repeated exposure."/>
              </outline>
              <outline text="Resource" heading="3" colorLabel="6" collapsed="true">
                <outline text="https://www.ebsco.com/research-starters/psychology/mere-exposure-effect"/>
              </outline>
            </outline>
            <outline text="Distinction bias" _note="~~Intermediate" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The tendency to view two options as more distinctive when evaluating them simultaneously than when evaluating them separately."/>
                <outline text="Examples" heading="3" colorLabel="6"/>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Distinction_bias)"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
              </outline>
              <outline text="Countermeasures" heading="3" colorLabel="2" collapsed="true">
                <outline text="Independent evaluation" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An evaluation which avoids comparing two options directly and instead considers each option individually and makes an overall assessment of each one on its own, and then compares the assessments."/>
                  </outline>
                  <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Can easily involve us accidentally imagining differences that don&apos;t actually exist." collapsed="true">
                      <outline text="For example by thinking of a new way to utilize a common factor present in both options only while considering the second option. We may fail to account for how this factor would also improve the experience of the first option, if we do not keep the first option in mind." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="By being systematic, we can largely avoid relying on heuristics from which distinction bias emerges."/>
                </outline>
              </outline>
            </outline>
            <outline text="Gambler&apos;s fallacy" _note="~Intermediate" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The belief that, if an event (whose occurrences are independent and identically distributed) has occurred less frequently than expected, it is more likely to happen again in the future (or vice versa)."/>
                <outline text="Synonyms" colorLabel="3" collapsed="true">
                  <outline text="Monte Carlo fallacy"/>
                  <outline text="Fallacy of the maturity of chances"/>
                </outline>
                <outline text="Distinctions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Events whose probabilities are explicitly not independent." collapsed="true">
                    <outline text="The gambler&apos;s fallacy does not apply when the probability of different events is not independent. "/>
                    <outline text="In such cases, the probability of future events can change based on the outcome of past events, such as the statistical permutation of events."/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="When cards are drawn from a deck without replacement. If an ace is drawn from a deck and not reinserted, the next card drawn is less likely to be an ace and more likely to be of another rank. The probability of drawing another ace, assuming that it was the first card drawn and that there are no jokers, has decreased from ⁠4/52 (7.69%) to 3/51⁠ (5.88%), while the probability for each other rank has increased from 4/52 (7.69%) to 4/51⁠ (7.84%)."/>
                    </outline>
                  </outline>
                  <outline text="Events whose probabilities are not independent due to hidden factors." collapsed="true">
                    <outline text="For example, if a coin is flipped 21 times, the probability of 21 heads with a fair coin is 1 in 2,097,152. Since this probability is so small, if it happens, it may well be that the coin is somehow biased towards landing on heads, or that it is being controlled by hidden magnets, or similar. In this case, the smart bet is &quot;heads&quot; because Bayesian inference from the empirical evidence — 21 heads in a row — suggests that the coin is likely to be biased toward heads. Bayesian inference can be used to show that when the long-run proportion of different outcomes is unknown but exchangeable (meaning that the random process from which the outcomes are generated may be biased but is equally likely to be biased in any direction) and that previous observations demonstrate the likely direction of the bias, the outcome which has occurred the most in the observed data is the most likely to occur again." colorLabel="6"/>
                  </outline>
                  <outline text="Events whose probabilities change" collapsed="true">
                    <outline text="If external factors are allowed to change the probability of the events, the gambler&apos;s fallacy may not hold. For example, a change in the game rules might favour one player over the other, improving their win percentage. Similarly, an inexperienced player&apos;s success may decrease after opposing teams learn about and play against their weaknesses. This is another example of bias."/>
                  </outline>
                </outline>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="The belief that the next dice roll is more likely to be six than is usually the case because there have recently been fewer than the expected number of sixes."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Gambler%27s_fallacy)" _note="Pull more from this starting with origins"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="It is a major contributing factor to the amount of people who gamble."/>
                </outline>
              </outline>
              <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                <outline text="In most illustrations of the gambler&apos;s fallacy and the reverse gambler&apos;s fallacy, the trial (e.g. flipping a coin) is assumed to be fair. In practice, this assumption may not hold."/>
              </outline>
              <outline text="Reverse position" heading="3" colorLabel="1" collapsed="true">
                <outline text="After a consistent tendency towards tails, a gambler may also decide that tails has become a more likely outcome. This is a rational and Bayesian conclusion, bearing in mind the possibility that the coin may not be fair; it is not a fallacy. Believing the odds to favor tails, the gambler sees no reason to change to heads. However, it is a fallacy that a sequence of trials carries a memory of past results which tend to favor or disfavor future outcomes."/>
                <outline text="Inverse gambler&apos;s fallacy" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="A situation where a gambler entering a room and seeing a person rolling a double six on a pair of dice may erroneously conclude that the person must have been rolling the dice for quite a while, as they would be unlikely to get a double six on their first attempt."/>
                    <outline text="A game of roulette at the Monte Carlo Casino on August 18, 1913, when the ball fell in black 26 times in a row. This was an extremely unlikely occurrence: for any given sequence of 26 spins, the probability of either red or black occurring 26 times in a row on a single zero roulette wheel is around 1 in 68.4 million, assuming the mechanism is unbiased. Gamblers lost millions of francs betting against black, reasoning incorrectly that the streak was causing an imbalance in the randomness of the wheel, and that it had to be followed by a long streak of red."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Retrospective gambler&apos;s fallacy" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A similar bias for inferences about unknown past events based upon known subsequent events."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="To observe multiple successive &quot;heads&quot; on a coin toss and conclude from this that the previously unknown flip was &quot;tails&quot;."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                <outline text="[Hasty generalization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ecu_HuUAoK7nIZBDmynRINzl)" heading="3" colorLabel="2"/>
                <outline text="[Representativeness heuristic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HFS-yoqzJcX2UK10bI3AB6p4)" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Low-ball technique" _note="~Advanced" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A two-stage compliance technique in which the influencer secures agreement with a request but then increases the size of that request by revealing hidden costs."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s a common technique" heading="3"/>
                <outline text="It can allow people to manipulate you or people you are about." heading="3"/>
                <outline text="You can learn to be harder to manipulate this way." heading="3"/>
                <outline text="It can be used to manipulate other people for your benefit." heading="3"/>
              </outline>
              <outline text="Indicators" heading="1" colorLabel="1"/>
              <outline text="Suggested countermeasures" _note="In roughly descending order of importance." heading="1" colorLabel="2"/>
              <outline text="Potential evolutionary explanation" heading="2" colorLabel="1"/>
            </outline>
            <outline text="Foot-in-the-door technique" _note="~Expert" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A two-stage compliance technique in which the influencer sets the stage for the real request by first getting the person to comply with a much smaller request."/>
                <outline text="[Example and source](https://www.youtube.com/watch?v=1x19z5Jb_pg)" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="It can allow people to manipulate you." heading="3" collapsed="true">
                  <outline text="This is a technique that works on a lot of people." heading="3" collapsed="true"/>
                </outline>
                <outline text="You can learn to be harder to manipulate this way." heading="3" collapsed="true">
                  <outline text="Learning patterns to watch out for and calculating important decisions consciously." _note="Adept" collapsed="true"/>
                </outline>
                <outline text="It can be used to manipulate other people for your benefit." heading="3" collapsed="true">
                  <outline text="" heading="3"/>
                </outline>
              </outline>
              <outline text="Indicators" heading="1" colorLabel="1" collapsed="true">
                <outline text="A small request is quickly followed up by a much larger one."/>
              </outline>
              <outline text="Suggested countermeasures" _note="In roughly descending order of importance." heading="1" colorLabel="2" collapsed="true">
                <outline text="Learning (and practicing) to reason in a systematic way (at least for important decisions)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This minimizes the room for all biases (confirmation bias included) to creep in." colorLabel="2"/>
                  <outline text="" heading="3" colorLabel="2"/>
                </outline>
                <outline text="" heading="3" colorLabel="2"/>
                <outline text="Practice recognizing when this technique is likely being used." heading="3" colorLabel="2" collapsed="true"/>
              </outline>
              <outline text="Potential evolutionary explanation" heading="2" colorLabel="1"/>
            </outline>
            <outline text="Minor biases" _note="~Advanced" heading="3" colorLabel="1" collapsed="true">
              <outline text="Ending positivity" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The bias to be positive about how an event went at the end of the event."/>
                </outline>
              </outline>
            </outline>
            <outline text="[Hot/cold biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=e6Z-xzc6uDwhxxlrgZhYFwN7)" heading="3" colorLabel="3"/>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Fallacies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=jDHc0-8PYgwn0kzMSnE6ZSbF)" heading="3" colorLabel="5"/>
            </outline>
          </outline>
          <outline text="System 1 thinking" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
              <outline text="Subconscious"/>
              <outline text="Synonyms" colorLabel="3" collapsed="true">
                <outline text="Intuition"/>
                <outline text="Vibes"/>
                <outline text="Emotions (in some cases)"/>
                <outline text="System 1 thinking"/>
              </outline>
              <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                <outline text="Not conscious reasoning." collapsed="true">
                  <outline text="Can still be rational or have rational components."/>
                </outline>
              </outline>
              <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Subconscious)"/>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="It tends to heavily contribute to bad reasoning" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Peoples&apos; [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) habits tend to rely too heavily on system 1 thinking." _note="Likelihood &amp; relevance" colorLabel="1" collapsed="true">
                    <outline text="Peoples&apos; common [&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) habits tend to focus on vibes over the reasoning itself." _note="Likelihood" colorLabel="4"/>
                    <outline text="Peoples&apos; common [&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) habits often apply even to formal reasoning, albeit to a lesser extent." _note="Likelihood" colorLabel="4"/>
                    <outline text="[Importance of &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=jPysip7brKTtf9PYUPBWVJ1I)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Relying on vibes/intuition too much tends to make us much worse at reasoning." _note="Likelihood &amp; relevance" colorLabel="1" collapsed="true">
                    <outline text="Frequently ignoring relevant reasoning is bound to lead to a whole host of fallacies, but one of the most straightforward and common ones is [Strawmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j7YUoP-36fiXLnITfI6f1Tl5)" _note="Add non-strawmanning stuff here, very important!" colorLabel="4" collapsed="true">
                      <outline text="If you focus on vibes over content, you&apos;re going to strawman people because focusing on vibes over content entails a lack of focusing on the content of what they&apos;re actually saying."/>
                    </outline>
                    <outline text="The subconscious begins with in-built fundamental processes that are very epistemically unideal." colorLabel="4" collapsed="true">
                      <outline text="Overcoming these is not easy." colorLabel="4"/>
                      <outline text="[Our brains evolved to reason badly](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mkjCEhDKSSE1q2KpLj9SH4Oj)" colorLabel="4"/>
                    </outline>
                    <outline text="A plausibly correct intuition is typically a plausibly incorrect one as well, and the cost of checking is typically pretty small and good for building up better reasoning habits for more important decisions." colorLabel="4"/>
                  </outline>
                  <outline text="During many important decisions, we often become impulsive, in significant part due to trusting intuition too much." _note="Likelihood &amp; relevance" colorLabel="1" collapsed="true">
                    <outline text="If we did not trust intuition so much, we would usually internalize that our emotions not very trustworthy in those areas, and thus usually not be as impulsive." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Reasoning habits often rely on vibes/intuition a lot." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qSM0l5Zj-kIBKAbPujHYYidX" _note="Likelihood" colorLabel="4"/>
                    <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zG_I7j1EH7y2eLtxTBpqml6a" _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="[Our intuition can be trained to reason pretty well.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LNNPBQDfQgBSVNFinWhv4mbG)" colorLabel="4"/>
              </outline>
              <outline text="Improvable" heading="3" collapsed="true">
                <outline text="A combination of system 2 and system 1 reasoning is almost always __far__ more accurate than just system 1 reasoning." colorLabel="4" collapsed="true">
                  <outline text="People almost always have a set of habits that relies much more on system 1 and much less on system 2 than would be ideal." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Our intuition can be trained to reason pretty well" colorLabel="4" collapsed="true">
                  <outline text="Teaching your intuition to reason well is typically much harder than it seems." _note="Relevance" colorLabel="1" collapsed="true">
                    <outline text="By default it is subject to a massive host of [cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9)" _note="Likelihood" colorLabel="4"/>
                    <outline text="The subconscious cannot &quot;think&quot; in a general sense*, so it will usually handle situations it doesn&apos;t have any specific training for badly." _note="Likelihood" colorLabel="1" collapsed="true">
                      <outline text="* This may be technically untrue." colorLabel="3"/>
                      <outline text="^ Our subconscious/unconscious may be able to learn to think in a very consistent and general sense if we trained it in an extremely specific way. However this is likely not realistic, as it would be incredibly easy for the subconscious/unconscious to learn the wrong things even if you were incredibly epistemically knowledgeable. Because the in-built evolutionary instincts are very broad, epistemically unideal and difficult to overwrite or sidestep." colorLabel="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
              <outline text="Fast if-then tree" heading="3" colorLabel="5" collapsed="true">
                <outline text="The subconscious comes from a part of the brain that&apos;s far faster than other parts. It recognizes patterns (typically simple ones), and immediately spits out the associated result. In other words, it is essentially a network of [heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) that is applied immediately, without inherent questioning."/>
                <outline text="With adequate training, it can basically act as a big if-then tree that runs super fast and pretty consistently. That means if you do the same process a lot, in the absence of other factors, your subconscious can often learn how to do more and more of that process until your conscious isn&apos;t needed at all for even a pretty high level of performance. This is so effective that the vast majority of our behavior is governed by subconscious processes."/>
              </outline>
              <outline text="Minor indication" heading="3" colorLabel="4" collapsed="true">
                <outline text="In general: a minor indicator that should not be blindly trusted for remotely important decisions, but should likely be investigated."/>
              </outline>
              <outline text="[A helpful video on intuition](https://youtu.be/1f6N2UrCK6o)" collapsed="true">
                <outline text="Note that this is mostly focused on the benefits of intuition, so it may give a positively skewed impression of it."/>
              </outline>
            </outline>
            <outline text="Causes of over-reliance on system 1" heading="3" colorLabel="1" collapsed="true">
              <outline text="Rationalization" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The process of constructing seemingly logical, socially acceptable excuses to justify behaviors, decisions, or feelings that are actually driven by unrecognized, irrational or unacceptable motives."/>
                  <outline text="**Often:**   Unknowingly."/>
                  <outline text="Distinction (from good reasoning)" heading="3" collapsed="true">
                    <outline text="While good reasoning typically applies logic to find a conclusion, rationalization starts with a predetermined conclusion (usually an emotional impulse) and works backward to invent justifications in an irrational manner."/>
                    <outline text="[Assuming that other(s) are wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=525oYS_TiO4rZW4aUGvWXESU)"/>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3"/>
                  <outline text="Impactful" heading="3"/>
                </outline>
                <outline text="Instinctual rationalization" heading="1" colorLabel="1" collapsed="true">
                  <outline text="We tend to have very strong instincts to consciously defend our intuitive/subconscious reasoning/decisions to the death, even when we consciously believe otherwise." _note="Create/link to section(s) on why this is the case."/>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="It acts as a cognitive mechanism to protect self-esteem and alleviate guilt." collapsed="true">
                    <outline text="Helps the ego defend against anxiety and discomfort. It allows individuals to protect their self-image after making a poor decision or experiencing a setback"/>
                  </outline>
                </outline>
                <outline text="Anti-rationalization strategies" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Learning to recognize rationalization" heading="1" colorLabel="2" collapsed="true">
                    <outline text="[Learning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XwNwxOcZRgH_hY46vX9t5UTb)" heading="3" colorLabel="1"/>
                    <outline text="[Self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)" heading="3" colorLabel="1"/>
                    <outline text="[Bias blind spot](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qYKn9LjoeqFhKAwabwW925I7)" heading="3" colorLabel="1"/>
                  </outline>
                  <outline text="&quot;If this reason were enough, what else would have to be true?&quot;" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The process of checking a suspected rationalization by asking &quot;if this were true, what else would have to be true?&quot;"/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="&quot;I can&apos;t respect a girl if she goes home with me on the first date.&quot;" collapsed="true">
                          <outline text="The rationalization: &quot;It&apos;s risky, given how little she knows about him.&quot;"/>
                          <outline text="What else would have to be true: &quot;Let&apos;s say a friend of yours goes out at night in a dangerous part of town. That&apos;s risky, would you then lose respect for them?&quot;"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="&quot;If the emotional aspect wasn&apos;t there, would I think differently?&quot;" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The process of checking a suspected rationalization by asking &quot;If the emotional aspect weren&apos;t present, would I think differently?&quot;"/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Asking someone out" heading="3" collapsed="true">
                          <outline text="You&apos;re thinking of asking an attractive stranger out. But you&apos;re nervous and afraid of being rejected, and then think to yourself &quot;I don&apos;t have time for dating anyway, I should just focus on my schoolwork.&quot;"/>
                          <outline text="Considering if the emotion wasn&apos;t present: &quot;If I knew for sure that they&apos;re interested in me too, would I still think it isn&apos;t worth approaching them because I don&apos;t have time for it?&quot;"/>
                        </outline>
                      </outline>
                      <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                        <outline text="This doesn&apos;t mean that the emotional aspect should never be given any weight." collapsed="true">
                          <outline text="Typically, there&apos;s a reason (even if a bad one) why our emotions are leaning in some direction."/>
                          <outline text="The reason may be good, even if we can&apos;t immediately think of why." collapsed="true">
                            <outline text="Eg. In the [asking someone out example](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QVjtZjfd0iDCadnYEoVrK6Pc), rejection may make you feel significantly worse for a few days or even weeks in a way that isn&apos;t worth it." colorLabel="6" collapsed="true">
                              <outline text="Perhaps the coming days/weeks are quite important to feel good in, or perhaps you&apos;re sufficiently confident you can find a partner of similar quality with less costly strategies later on."/>
                            </outline>
                          </outline>
                          <outline text="However it should still likely typically be scrutinized, to avoid getting into the habit of relying so heavily on [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) as to trust reasons that are likely rationalizations." collapsed="true">
                            <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Bl3wKaMf5c2daJkgAQEcPkOp"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Helpful for investigating the actual weight of the emotion(s) on your decision-making, when compared with the reason(s) your brain conjures up." colorLabel="4" collapsed="true">
                        <outline text="If the weight of the emotion is far greater than the reason, the reason is very likely a rationalization." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Typically reduces the degree to which we would be compelled by our emotions towards a certain kind of reasoning, by removing the emotional element." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Checking for emotional convenience" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Checking to see if the reason is emotionally convenient, especially if it protects us from some emotional threat."/>
                      <outline text="[Example: Asking someone out](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-XDUDPbKjlM3FEDEJLIa7GG0)" heading="3" colorLabel="6" collapsed="true">
                        <outline text="&quot;I don&apos;t have time for dating anyway, I should just focus on my schoolwork.&quot; is an emotionally convenient excuse in this scenario, it protects you from the possibility of being rejected." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Emotional convenience is correlated with likelihood of a reason being a rationalization." colorLabel="4"/>
                      <outline text="^ Rationalization tends to occur as a result of our emotions driving us towards a conclusion." _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="&quot;If this reason were not true, would I think differently?&quot;" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The process of checking a suspected rationalization by asking &quot;If this were not true, would I think differently?&quot;"/>
                      <outline text="[Example: Asking someone out](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QVjtZjfd0iDCadnYEoVrK6Pc)" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Same example, except instead of checking what you would think if the emotional aspect wasn&apos;t there, you check what you would think if the reason wasn&apos;t present."/>
                        <outline text="Specifically: &quot;If I did have time and didn&apos;t have to worry about schoolwork, would I still think it isn&apos;t worth asking them out?&quot;"/>
                      </outline>
                    </outline>
                    <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="It&apos;s typically better to [check for the lack of the emotional aspect](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Py1-2VklYhuNpH_hl4f0YxM5) instead." colorLabel="4" collapsed="true">
                          <outline text="[Typically reduces emotional influence more](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ghExX9EFB-aIOp3J0HBSzhzZ)" colorLabel="4"/>
                        </outline>
                        <outline text="It&apos;s easy for another rationalization to slip in with this strategy." colorLabel="1" collapsed="true">
                          <outline text="&quot;but I have this other reason!&quot;" colorLabel="4" collapsed="true">
                            <outline text="Our brain can come up with a practically infinite amount of rationalizations if it subconsciously feels necessary to. So being able to come up with more reasons that appear (on the surface) to support your position is not in itself very good reason to trust the position." colorLabel="4"/>
                          </outline>
                          <outline text="&quot;I&apos;m sure it would be different!&quot;" colorLabel="4" collapsed="true">
                            <outline text="Instinctually self-assuring yourself with the thought/proclaimation that it would be different (and thus, you can feel like you aren&apos;t just rationalizing), without actually properly thinking through whether it would be different or not." colorLabel="3"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[How to spot a rationalizaton (4 min video)](https://www.youtube.com/watch?v=tfp34-ruvGE)" collapsed="true">
                      <outline text="Heavy inspiration, practically plagerizing."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="1" colorLabel="1"/>
                  <outline text="[Explaining system 1](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Srymy9g8BcuTG-UVoOZfLZwY)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Trusting emotions" heading="1" colorLabel="1" collapsed="true">
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Our emotions are unreliable" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="We can almost never trust our initial emotions to pick a reliable confidence value for claims in areas we are inexperienced in, or topics involving a lot of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)."/>
                      </outline>
                      <outline text="Link to section(s) about subconscious/intuition being unreliable."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Instinctual trust" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Our tendency to automatically react and place higher/lower confidence on things that emotionally feel more/less trustworthy."/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Hard to resist because of intensity" heading="3" collapsed="true">
                        <outline text="We often feel like certain ideas are obviously certain, absurd, unacceptable, etc. when really we have nowhere near enough evidence to justify that feeling."/>
                      </outline>
                      <outline text="Hard to resist because of some common habits" heading="3" collapsed="true">
                        <outline text="Emotional incentives" heading="3" collapsed="true">
                          <outline text="There are significant emotional incentives to form such habits." colorLabel="3"/>
                          <outline text="" heading="3"/>
                          <outline text="[Being &quot;right&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=SEY-nxGd5c0jjzwT_16t4yWc)" heading="3" collapsed="true">
                            <outline text="When one blindly trusts in their emotions in areas where they feel like they can&apos;t solidly be shown to be wrong, they can enjoy the feeling of being &quot;right&quot; and evade the feeling of being &quot;wrong&quot;." collapsed="true">
                              <outline text="A countermeasure to this is to become decent enough at automatically recognizing when you&apos;re shown to be wrong, even when it wouldn&apos;t feel solid to the vast majority of people."/>
                              <outline text="This is __much__ harder than it seems and it&apos;s incredibly easy to think you&apos;re much better at this than you really are."/>
                            </outline>
                            <outline text="This incentive likely often effects trust in emotions subconsciously." collapsed="true">
                              <outline text="It seems likely that the short-term feelings of discomfort with proper truth seeking and comfort in the following of emotions would (over time) subconsciously influence many people to start trusting their emotions more."/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Instructed" heading="3" collapsed="true">
                          <outline text="We&apos;re often told to, and thus implicitly guided to form habits around doing it." colorLabel="3"/>
                          <outline text="&quot;Don&apos;t think about it&quot;" colorLabel="6"/>
                          <outline text="&quot;You&apos;ll know what to do&quot;" colorLabel="6"/>
                          <outline text="&quot;Trust your gut&quot;" colorLabel="6"/>
                          <outline text="&quot;Follow your heart&quot;" colorLabel="6"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NaE-8bpB1ZDuRzcl_T3nNErK" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Often we trust emotions because we feel like we can adequately rationalize them."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Generally how to reduce over-reliance" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="How to reduce over-reliance on subconscious/intuition."/>
              </outline>
              <outline text="Changing [habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rbfReKt_odNwwwIDWESiYqq-)" heading="1" colorLabel="2" collapsed="true">
                <outline text="Step 1: Recognition" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Learning to recognize when you&apos;re making important decisions based on vibes/subconscious reasoning without adequately consciously checking that reasoning."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impact" heading="3"/>
                    <outline text="Difficulty" heading="3" collapsed="true">
                      <outline text="Learning to recognize it consistently is very hard." colorLabel="4" collapsed="true">
                        <outline text="If It was easy, lots more people would do it and there would be far less disagreement on subjects requiring good general reasoning." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Learning roughly what it looks like" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Learning roughly what over-reliance on subconscious/intuition looks like."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Most people don&apos;t have a great handle on even roughly what it looks like." collapsed="true"/>
                    </outline>
                    <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Making intuitive relationship decisions" collapsed="true">
                        <outline text="Choosing to not befriend/partner with an otherwise promising person who has bad vibes." collapsed="true">
                          <outline text="The vibes could be bad even if they would immediately be a great friend/partner." collapsed="true">
                            <outline text="Our subconscious/intuition is very rarely especially accurate at determining what partner(s)/friend(s) would be good for us." collapsed="true">
                              <outline text="It often overestimates the value of many things." collapsed="true">
                                <outline text="Immediate ability to guess how you feel." collapsed="true">
                                  <outline text="You can usually (and probably usually should) communicate how you feel to them, so they can understand you in individual cases even without being able to guess how you feel. "/>
                                  <outline text="You can usually communicate how you feel to them enough over the course of a while for them to learn the patterns required to guess how you feel, especially if you explicitly ask them to and explain why it&apos;s important. So them not being able to guess how you feel short-term isn&apos;t great evidence that they can&apos;t guess it long-term."/>
                                </outline>
                                <outline text="Social status"/>
                                <outline text="Wealth/job"/>
                                <outline text="Physical characteristics" collapsed="true">
                                  <outline text="Appearance" collapsed="true">
                                    <outline text="The appearance may be adjustable in accordance with your preferences."/>
                                  </outline>
                                  <outline text="Voice"/>
                                  <outline text="Smell" collapsed="true">
                                    <outline text="BO" collapsed="true">
                                      <outline text="Connotations" collapsed="true">
                                        <outline text="&quot;They are not very well put together in life.&quot;" collapsed="true">
                                          <outline text="If it only happened once, it may have just been a bad day or something."/>
                                          <outline text="This should not necessarily  be a deal-breaker depending on how solvable it is and what other advantages they have."/>
                                        </outline>
                                      </outline>
                                      <outline text="Direct" collapsed="true">
                                        <outline text="Often easy to fix by asking them to use deodorant or something."/>
                                      </outline>
                                    </outline>
                                    <outline text="Smoker"/>
                                    <outline text="Unpleasant deodorant/shampoo/etc."/>
                                  </outline>
                                </outline>
                              </outline>
                              <outline text="It often underestimates the value of many things." collapsed="true">
                                <outline text="It often underestimates the value of good reasoning abilities."/>
                              </outline>
                            </outline>
                          </outline>
                          <outline text="If the vibes are based on something substantially bad..." collapsed="true">
                            <outline text="The issue(s) might be sufficiently solvable for it to still be worthwhile."/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Making intuitive financial decision" collapsed="true">
                        <outline text="Paying a lot for things that only make a very short-term impact."/>
                        <outline text="Paying for things to support the developer." collapsed="true">
                          <outline text="Out of all the possible selfless ways you could spend your money, given any semi-reasonable ethical/axiological framework, it&apos;s usually implausible that paying to support the developer is the best."/>
                        </outline>
                      </outline>
                      <outline text="Making intuitive philosophical decisions " collapsed="true">
                        <outline text="Ethics/axiology"/>
                        <outline text="Epistemology "/>
                        <outline text="General reasoning"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Learning [common errors](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=93xKBOKZAl0tsr5P7wY-ZV3Y)" heading="1" colorLabel="2"/>
                  <outline text="[Self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Very relevant for virtually all forms of recognizing over-reliance on intuition."/>
                  </outline>
                </outline>
                <outline text="Step 2: Avoid following bad habits" heading="3" colorLabel="2" collapsed="true">
                  <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="5"/>
                  <outline text="[The habit of changing habits](https://dynalist.io/d/KFA9G9pcSJq3Iu6wBJH7WSZh#z=SircCB0nBHQWxMV3_RwXfVYQ)" _note="Not sure if this should be here, and/or something else should likely also be here." heading="3" colorLabel="2"/>
                </outline>
                <outline text="Step 2/3 Form good habits" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Good replacement habits" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Doubting the feelings/intuition" heading="3" colorLabel="2"/>
                    <outline text="Questioning the feelings/intuition" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Importance / limitations" _note="Very important to add limitations here." heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3"/>
                      </outline>
                      <outline text="How to learn" heading="1" colorLabel="2" collapsed="true">
                        <outline text="Practicing questioning the feelings/intuition in general" heading="1" colorLabel="2" collapsed="true">
                          <outline text="We typically don&apos;t make enough important decisions to learn to consistently do this for important decisions only, and there don&apos;t appear to be good broader categories that contain virtually all important decisions but far less important ones, and learning to do it for decisions in generally usually isn&apos;t very bad if it&apos;s not good, so learning to do it for decisions in general is typically best and/or necessary."/>
                        </outline>
                      </outline>
                      <outline text="Questions" heading="1" colorLabel="6" collapsed="true">
                        <outline text="Is it worth acting on the vibes/intuition immediately, or should you give it more thought/research first?" collapsed="true">
                          <outline text="How important is it to make sure you make the right decision?"/>
                          <outline text="How likely is it for a reasonable amount of (extra) thought to reveal important details you didn&apos;t consider?"/>
                          <outline text="How likely is it for a reasonable amount of (extra) research to reveal important details you didn&apos;t consider?"/>
                        </outline>
                        <outline text="Is there substantial issue(s) with choosing the unintuitive/bad vibes option(s)?"/>
                        <outline text="What is/are the issue(s)?"/>
                        <outline text="What reasons do you have for/against those issues?"/>
                      </outline>
                    </outline>
                    <outline text="More systematic thinking" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Combing through the content more systematically, trying to understand how it fits into the relevant tree of arguments and counterarguments." collapsed="true">
                          <outline text="[Trees of knowledge](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sjf_YfQC68xvLqyavOZ3COo-)" heading="3" colorLabel="6"/>
                        </outline>
                      </outline>
                      <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="2"/>
                    </outline>
                    <outline text="Researching the issue" heading="3" colorLabel="2" collapsed="true">
                      <outline text="[Learning narrow things](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=66aqrbR1LxW2iMTjDg-scZ6l)" heading="1" colorLabel="2"/>
                    </outline>
                    <outline text="Consciously investigating the matter to see if your feelings/intuition are justified" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Consciously considering possibilities that feel wrong." heading="3" colorLabel="2"/>
                      <outline text="Seeing if you can consciously justify the vibes/intuitions." _note="~~Expert level. Doing this below would often cause confirmation bias." heading="3" colorLabel="2"/>
                    </outline>
                  </outline>
                  <outline text="Form a plan to make yourself practice the good replacement habits well" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Waiting to let system 2 catch up with system 1" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="System 1 thinking tends to come to a conclusion far too quickly based on far too little data, whereas system 2 is more careful and reliable." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Changing habits to be less impulsive about semi-important decisions" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="System 2 disagreeing with system 1" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Consciously disagreeing with your subconscious/intuition (which is typically seen via how you feel about things)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Facing it directly" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="You consciously disagreeing with your subconscious."/>
                    </outline>
                    <outline text="Recognizing conscious-subconscious disagreement" heading="3" colorLabel="2"/>
                    <outline text="Changing subconscious" heading="3" colorLabel="2" collapsed="true">
                      <outline text="[Training your subconscious](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lv3OxhygLPFJul4TD3C-5ZJb)" heading="3" colorLabel="2"/>
                      <outline text="[Convincing your subconscious](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AFqSS9YtLBDH1Qu463LR3QhX)" heading="3" colorLabel="2"/>
                    </outline>
                    <outline text="Investigating the disagreement" heading="3" colorLabel="2" collapsed="true">
                      <outline text="[Using intuition in conscious reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_4zysecum-4nQppMkIAl6ogn)" heading="3" colorLabel="2"/>
                    </outline>
                  </outline>
                  <outline text="Accounting for its implications when interacting with others" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Avoiding assuming that others&apos; feelings reflect their thoughts.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=h2PA8YfJOBPVBzcIXaDqNbtI)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Ignorance" heading="3" collapsed="true">
                    <outline text="Frequently when we don&apos;t understand all the relevant important details, our subconscious/intuition often reaches inaccurate conclusions."/>
                  </outline>
                  <outline text="Subconscious bias" heading="3" collapsed="true">
                    <outline text="Abuse" heading="3" collapsed="true">
                      <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Includes verbal abuse."/>
                      </outline>
                      <outline text="Frequently when we are abused, our subconscious is heavily imprinted with the lessons that we learned from it. And these lessons are often not reflective of reality." collapsed="true">
                        <outline text="Imprintability" heading="3"/>
                        <outline text="At odds with reality" heading="3"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Recognizing the disagreement" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="[Common reasons for disagreement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oUX4Y0c60qNBFL_gSik65iQK)" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Convincing the subconscious" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Counterarguing the subconscious beliefs" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="" _note="It&apos;s easy to accidentally assume that subconscious beliefs align with conscious beliefs when arguing against the subconscious beliefs, especially when arguing against other peoples&apos; subconscious beliefs." heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Spending time with those who agree with your conscious beliefs" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Effective partially due to the &lt;broken link&gt; cognitive bias." colorLabel="4"/>
                      <outline text="Effective partially due to [In-group favoritism](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BO3hgdXGDMPCMKm_AFmDlaEk)" colorLabel="4"/>
                      <outline text="Effective partially due to the &lt;broken link&gt;" colorLabel="4"/>
                      <outline text="Effective partially due to &lt;broken link&gt;" colorLabel="4"/>
                      <outline text="Often feeds &lt;broken link&gt;" colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                    <outline text="A technique ideal to use almost only when you&apos;re virtually certain that an idea is true." collapsed="true">
                      <outline text="[Often feeds confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ZRTyxFncWw3BhQQpQ72dhVC9)"/>
                    </outline>
                  </outline>
                  <outline text="Talking with them about it" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text=" Tends to further utilize [these biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KAenLgo0gxik53Pk7Roqilcg)."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Using [intuition pulls](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="1" colorLabel="2"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="2"/>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Switching to system 2" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="When to switch to system 2 reasoning" heading="1" colorLabel="2" collapsed="true">
                <outline text="For general reasoning and situations where system 1 is not trained well, system 1 reasoning (especially [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)) should likely be used instead to avoid many of the [cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9) and errors that system 1 would likely contribute."/>
              </outline>
              <outline text="Strategies" heading="1" colorLabel="2" collapsed="true">
                <outline text="[Checklists](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UIOFokR-YXIMhKjWiMDs4NlZ)" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="It&apos;s very helpful to create and use checklists for situations where your default course of action would otherwise likely be over-reliance on subconscious/intuition." colorLabel="4" collapsed="true">
                        <outline text="It can often help form conscious reasoning habits." colorLabel="4"/>
                        <outline text="It can often help reduce subconscious reasoning habits." colorLabel="4"/>
                        <outline text="It can often help force yourself to use conscious reasoning for many more important decisions." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Effective utilization" heading="1" colorLabel="2" collapsed="true">
              <outline text="Training the subconscious" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Since most of our behavior is driven by our subconscious, this is incredibly impactful on our behavior." _note="Create/link to section on most of our behavior being subconscious-driven." colorLabel="4"/>
                    <outline text="We can have habits to switch to our conscious reasoning for more important decisions." colorLabel="1" collapsed="true">
                      <outline text="These habits tend to be quite unreliable unless very carefully trained." colorLabel="1" collapsed="true">
                        <outline text="Almost no one has undergone sufficient training for this." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Using intuition in conscious reasoning" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition (broad)" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Intuition is usually not very reliable for any kind of general reasoning."/>
                </outline>
                <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Intuition tends to be relatively good at finding promising ideas."/>
                </outline>
                <outline text="Intuitive reasoning" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition (specific)" heading="3" colorLabel="3"/>
                  <outline text="Deconstructing intuitive reasoning into solid reasoning" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="It can be tested and consciously investigated, and testing and consciously investigating things is typically more reliable."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="[Intuitive brainstorming](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KAbxasduRM_rhk_QTFB7OcCP)" heading="1" colorLabel="2"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Important consequences" heading="1" colorLabel="1" collapsed="true">
              <outline text="Conscious beliefs differing from subconscious beliefs" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Conscious beliefs often substantially differing from subconscious beliefs."/>
                  <outline text="Conscious belief" heading="3" colorLabel="3"/>
                  <outline text="Subconscious belief" heading="3" colorLabel="3"/>
                </outline>
                <outline text="Avoiding assuming that subconscious and conscious beliefs always align" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Assuming that subconscious and conscious beliefs always align is likely to lead you to impactful inaccurate conclusions" colorLabel="4" collapsed="true">
                        <outline text="Broad" heading="3" collapsed="true">
                          <outline text="Subconscious (only) beliefs that are uncontrollably &quot;bad&quot; are common" colorLabel="4" collapsed="true">
                            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                              <outline text="Situation where subconscious beliefs are uncontrollably* &quot;bad&quot;, but in which conscious beliefs are not." _note="* Or at least very difficult to control."/>
                            </outline>
                            <outline text="Examples" heading="3" colorLabel="6"/>
                          </outline>
                          <outline text="Subconscious (only) beliefs explain a lot of important behaviors/situations." colorLabel="4" collapsed="true">
                            <outline text="So missing this would likely be pretty impactful." colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="Specific" heading="3" collapsed="true">
                          <outline text="Likely to make the person feel bad" colorLabel="4" collapsed="true">
                            <outline text="&lt;broken link&gt;"/>
                            <outline text="&lt;broken link&gt;"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Example assumptions" heading="3" colorLabel="6" collapsed="true">
                    <outline text="&quot;You dislike that your father is perfectionistic, but you are being hypocritical because you are also perfectionistic.&quot;" collapsed="true">
                      <outline text="This likely makes two dubious assumptions:"/>
                      <outline text="1. Having the subconscious desires/habits that lead the subject to be perfectionistic means they must consciously believe that being perfectionistic themselves is good for themselves to do."/>
                      <outline text="2. The &quot;dislike&quot; involves a conscious belief rather than just an emotional reaction."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="How it works" heading="1" colorLabel="1" collapsed="true">
              <outline text="Analogy" heading="3" colorLabel="6" collapsed="true">
                <outline text="We are made up of two kinds of cognition. A rider (controlled processes, conscious reasoning) and an elephant (automatic processes, including emotion and intuition)."/>
                <outline text="Automatic processes run the human mind, just as they have been running animal minds for 500 million years, so they’re very good at what they do (instinctual, quick decision-making based on survival and reproduction), like software that has been improved through thousands of product cycles."/>
                <outline text="The rider evolved to do several useful things. It can see further into the future (because we can examine alternative scenarios in our heads) and therefore it can override the elephant&apos;s propensity to aim for short-term/intuitive benefits, to make better decisions when better but unintuitive ones are available." collapsed="true">
                  <outline text="The rider can guide the elephant to learn new skills and master new technologies, when the elephant would by itself rarely have the discipline for that."/>
                </outline>
                <outline text="The rider acts as the spokesman for the elephant, even though the rider doesn’t necessarily know what the elephant is thinking. The rider is skilled at fabricating post hoc explanations for whatever the elephant has just done, and it&apos;s good at finding reasons to justify whatever the elephant wants to do next. This was incredibly socially advantageous, it allowed us to defend lots of our socially unacceptable actions and mistakes much more effectively, by essentially turning us into fantastic unconscious liars."/>
                <outline text="This analogy becomes a little misleading in that we might be tempted to think of the rider and the elephant as having different desires, but this is not exactly correct in the intuitive sense." collapsed="true">
                  <outline text="Typical emotions and desires are all [controlled by the elephant](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yP6X4DaMABkdUQV3tpI7NRpZ), our conscious reasoning does not have emotional desires of its own."/>
                  <outline text="However it can have its own distinct __goals__ separate from the &quot;goals&quot; of the elephant, albeit likely ultimately based on the desires of the elephant." _note="Link to psychological hedonism."/>
                  <outline text="The &quot;goals&quot; of the elephant are really just collections of behaviors that (typically) were generally evolutionarily beneficial in the past."/>
                </outline>
                <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Taken from &quot;The Righteous Mind&quot; by Jonathan Haidt."/>
                </outline>
              </outline>
              <outline text="The subconscious/intuition works by learning and using patterns and associations." collapsed="true">
                <outline text="We especially tend to associate things with positive or negative emotions and use these associations to decide what to do." collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Our feelings are largely controlled by our subconscious/intuition."/>
              <outline text="The subconscious seems to learn to mimic what you do, albeit in a simplistic and flawed way." collapsed="true">
                <outline text="&lt;broken link&gt;"/>
              </outline>
              <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
            </outline>
            <outline text="General pattern recognition" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="There are a lot of useful patterns that you can recognize." colorLabel="4"/>
                </outline>
                <outline text="[Limitations of subconscious/intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eb4tL-JqeLtd7Ja63cgnb__b)" colorLabel="1"/>
              </outline>
              <outline text="How to practice this" heading="3" colorLabel="2" collapsed="true">
                <outline text="Finding useful patterns" heading="3" collapsed="true">
                  <outline text="Useful patterns are often in useful subjects and involving at least one useful idea."/>
                  <outline text="Useful patterns are often very general, involving many things you know about. It&apos;s often not so important to find links that are immediately important as it is to constantly build up the web of links to recognize large patterns."/>
                </outline>
                <outline text="Frequently look for similar/connected things/concepts and try to find plausibly useful patterns."/>
              </outline>
            </outline>
            <outline text="Explaining system 1 reasoning" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Trying to explain/justify your system 1 intuition."/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Difficulty explaining indicates bad reasoning" heading="3" colorLabel="1" collapsed="true">
                    <outline text="If you feel like you can&apos;t explain the reasoning behind system 1 thinking even after a substantial amount of trying, then that&apos;s a strong sign that the intuition is unjustified, and __barely__ a sign that you&apos;re only unable to articulate your thoughts well." colorLabel="4" collapsed="true">
                      <outline text="If it was just an articulation problem, you should generally still be able to justify the intuition well, albeit in an inefficient, inarticulate manner." colorLabel="4"/>
                      <outline text="^ Providing sufficient justification for something almost never requires good articulation." colorLabel="4" collapsed="true">
                        <outline text="If your intuition is well-founded, you should be able to identify the reasoning why." colorLabel="4"/>
                        <outline text="^ Because in the time it takes to adequately train your intuition about the topic, you should be able to learn the vast majority of the reasoning that your intuition relies on." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Rationalization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NaE-8bpB1ZDuRzcl_T3nNErK)" heading="2" colorLabel="1" collapsed="true">
                  <outline text="The most common cause of trying to explain system 1 thinking." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="1" colorLabel="5"/>
              <outline text="[Intuitive understanding](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Lyj37DqUcGeYIrDH-6UuXTxI)" heading="3" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Emotions" _note="Very unfinished" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Physical and mental states brought on by neurophysiological changes, variously associated with thoughts, feelings, behavioral responses, and a degree of pleasure or displeasure."/>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Extremely common" heading="3" colorLabel="4"/>
              <outline text="**Hidden &amp; significant impact:**   Emotions tend to have a very significant impact on our reasoning even when we don&apos;t realize it." colorLabel="4" collapsed="true">
                <outline text="Because it has such an effect on our thoughts and behaviors, which play a significant role in our reasoning." _note="Likelihood" colorLabel="4"/>
                <outline text="**Unreliable:**   Very unreliable to trust for decision-making." _note="Relevance" colorLabel="1" collapsed="true">
                  <outline text="Emotions are ultimately caused by our [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) processes." _note="Likelihood | Move or replace with link to section under system 1 thinking." colorLabel="4"/>
                  <outline text="^ [System 1 thinking tends to heavily contribute to bad reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YZZwZnIdDPVZYqhdrYSUr1pg)" _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Even when you attempt to teach it to reason well." _note="Relevance" colorLabel="4"/>
                    <outline text="^ [Difficult to teach system 1](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Od48-jxKICdgo2zNi9PABeGD)" _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="**Resisting:**   One&apos;s ability to resist the influence of their emotions is incredibly crucial for their reasoning." colorLabel="4" collapsed="true">
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=D8c4D-d-eL0Z65s11qB264CH" _note="Likelihood" colorLabel="4"/>
                <outline text="This guide teaches how to resist the influence of emotions." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="[Changing outlook](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hr9qrTLa1XZ4OT4FMJxYJ3eo)" _note="Likelihood" colorLabel="4"/>
                  <outline text="[Using outlet](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=jvPpkrErIZaLrotZb16iaY0a)" _note="Likelihood" colorLabel="4"/>
                  <outline text="[Avoiding cause](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j3lG3AEozd127qU6GtNPal82)" _note="Likelihood" colorLabel="4"/>
                  <outline text="[Repressing emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NOPn06eFCiAI1WnxcQwKHLMl)" _note="Likelihood" colorLabel="4"/>
                  <outline text="Therefore this can likely be improved by reading the guide." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="**Directing:**   One&apos;s ability to direct their emotions is very important for their reasoning. " colorLabel="4" collapsed="true">
                <outline text="This guide teaches how to direct one&apos;s emotions." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="[Changing outlook](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hr9qrTLa1XZ4OT4FMJxYJ3eo)" _note="Likelihood" colorLabel="4"/>
                  <outline text="[Using outlet](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=jvPpkrErIZaLrotZb16iaY0a)" _note="Likelihood" colorLabel="4"/>
                  <outline text="Therefore this can likely be improved by reading the guide." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                <outline text="A lot of therapy techniques successfully reduce the influence of emotions when they would cause irrational thinking or actions." colorLabel="4"/>
                <outline text="The strategies provided [here](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j3lG3AEozd127qU6GtNPal82) can help." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
              <outline text="Emotions occur in steps that involve a rough, simplified appraisal of whether something that just happened advanced or hindered your goals or evolutionary goals."/>
              <outline text="Small flashes of positive or negative feeling that prepare us to approach or avoid something. Every emotion (such as happiness or disgust) includes an affective reaction, but most of our affective reactions are too fleeting to be called emotions."/>
              <outline text="Affective reactions are so tightly integrated with perception that we find ourselves liking or disliking something the instant we notice it, sometimes even before we know what it is."/>
            </outline>
            <outline text="Social Emotions" _note="altin didnt read yet" heading="1" colorLabel="6" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Emotions that depend upon the thoughts, feelings or actions of other people, &quot;as experienced, recalled, anticipated, or imagined at first hand&quot;."/>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="Admiration/coolness?"/>
                  <outline text="[Elevation](https://en.wikipedia.org/wiki/Elevation_(emotion))"/>
                </outline>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Basic emotions such as happiness and sadness don&apos;t depend upon the thoughts, feelings or actions of other people."/>
                </outline>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Social emotions are sometimes called moral emotions, because they are often considered to play an important role in morality and moral decision making."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Social_emotions)"/>
              </outline>
              <outline text="Development" heading="3" colorLabel="1" collapsed="true">
                <outline text="The development of social emotions is tightly linked with the development of social cognition, the ability to imagine other people&apos;s mental states, which generally develops in adolescence."/>
                <outline text="Children as young as 2 to 3 years of age can express emotions resembling guilt and remorse."/>
                <outline text="Five-year-old children are able to imagine situations in which basic emotions would be felt."/>
                <outline text="Seven year old children can describe situations in which social emotions might be experienced."/>
                <outline text="Studies using fMRI have found that different brain regions are involved in different age groups when performing social-cognitive and social-emotional tasks. While brain areas such as medial prefrontal cortex (MPFC), superior temporal sulcus (STS), temporal poles (TP) and precuneus bordering with posterior cingulate cortex are activated in both adults and adolescents when they reason about intentionality of others, the medial PFC is more activated in adolescents and the right STS more in adults. Similar age effects were found with younger participants, such that, when participants perform tasks that involve theory of mind, increase in age is correlated with an increase in activation in the dorsal part of the MPFC and a decrease in the activity in the ventral part of the MPFC were observed. Studies that compare adults with adolescents in their processings of basic and social emotions also suggest developmental shifts in brain areas being involved. Comparing with adolescents, the left temporal pole has a stronger activity in adults when they read stories that elicit social emotions. The temporal poles are thought to store abstract social knowledge. This suggests that adult might use social semantic knowledge more often when thinking about social-emotional situations than adolescents."/>
              </outline>
              <outline text="Self-conscious emotions" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A variety of &lt;broken link&gt; that relate to our sense of self and/or our consciousness of others&apos; reactions to us."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true"/>
                  <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                    <outline text="They have five distinct features that differentiate them from other emotions:"/>
                    <outline text="^ Require self-awareness and self representation"/>
                    <outline text="^ Emerge later than basic emotions"/>
                    <outline text="^ Facilitate attainment of complex social goals"/>
                    <outline text="^ Do not have distinct universally recognized facial expressions"/>
                    <outline text="^ Cognitively complex"/>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Social benefits" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Social harmony" heading="3" collapsed="true">
                        <outline text="Self-conscious emotions are seen to promote social harmony in different ways. The first is its ability to reinforce social norms. It does this in a very similar way to that of [operant conditioning](https://en.wikipedia.org/wiki/Operant_Conditioning). Performing well in situations while keeping to social norms can elicit pride. This feels good so therefore encourages the behaviour to be repeated. Equally performing in a situation while not sticking to the social norms can leave individuals feeling [embarrassed](https://en.wikipedia.org/wiki/Embarrassment). This feels bad and is generally avoided in the future. An example of this is a study (Brown, 1970) where participants were shown to choose avoiding feelings of embarrassment over financial gains."/>
                        <outline text="&lt;broken link&gt;"/>
                      </outline>
                      <outline text="Social healing" heading="3" collapsed="true">
                        <outline text="Self-conscious emotions enable social healing. When an individual makes a social error, feelings of guilt or embarrassment changes not just the person’s mood but their body language. In this situation the individual gives out non-verbal signs of submission and this is generally more likely to be greeted with forgiveness. This has been shown in a study where actors knocked over a supermarket shelve (Semin &amp; Manstead, 1982). Those that acted embarrassed were received more favorably than those who reacted in a neutral fashion."/>
                        <outline text="Levels of embarrassment have found to be easier to see in females and African-Americans, than compared to male and Caucasian targets (Keltner, 1995). This is due to social learnings from previous generations."/>
                      </outline>
                      <outline text="Behavior regulation" heading="3" collapsed="true">
                        <outline text="There is a strong link between the ability of an individual to regulate their behaviour in an appropriate manner and problems with their self-conscious emotions. A school was able to list a set of boys who were classified as ‘prone to aggression and delinquent behaviour’. When these boys sat an interactive IQ test, they scored higher on scores of anger compared with the normal boys at the school. They also scored lower in feelings of embarrassment (Keltner, 1995)."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Development" heading="3" colorLabel="1" collapsed="true">
                  <outline text="During the second year of life, new emotions begin to emerge when children gain the understanding that they themselves are entities distinct from other people and begin to develop a sense of self." collapsed="true">
                    <outline text="These emotions include:"/>
                    <outline text="&lt;broken links&gt;"/>
                  </outline>
                  <outline text="Self-conscious emotions are among the latter of emotions to develop." collapsed="true">
                    <outline text="Two reasons are at the cause of this:"/>
                    <outline text="^ Body language" heading="3" collapsed="true">
                      <outline text="Emotions such as joy, fear and sadness can all be gathered reliantly on just a person’s face."/>
                      <outline text="However self-conscious emotions heavily involve the body in addition to the face." collapsed="true">
                        <outline text="(Darwin, 1965)"/>
                      </outline>
                      <outline text="This means that when humans are attempting to learn self-conscious emotions, they have more to tend to, making the emotions harder to grasp."/>
                    </outline>
                    <outline text="^ Self-awareness" heading="3" collapsed="true">
                      <outline text="Due to the nature of these emotions, they can only begin to form once an individual has the capacity to self-evaluate their own actions. If the individual decides that they have caused a situation to occur, they then must decide if the situation was a success or a failure based on the social norms they have accrued, then attach the appropriate self-conscious feeling (Weiner, 1986). This is a complex cognitive skill, one that takes time to master."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Pride" _note="Expand" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An emotion characterized by a sense of security with one&apos;s identity, performance, or accomplishments."/>
                    <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Self-respect."/>
                    </outline>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Pride is also often defined as: [Arrogant](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lWWMHYx_Y9FUx5dmOwFNKjmb) or disdainful conduct or treatment; haughtiness."/>
                    </outline>
                    <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Pride)"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3"/>
                    <outline text="Common" heading="3"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Very often causes &lt;broken link&gt;"/>
                  </outline>
                  <outline text="Common causes" heading="3" colorLabel="1" collapsed="true">
                    <outline text="&lt;broken link&gt;" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Especially &lt;broken link&gt;" heading="3" colorLabel="1"/>
                    </outline>
                    <outline text="A fulfilled feeling of belonging" heading="3" colorLabel="1"/>
                    <outline text="Independent self-reflection" heading="3" colorLabel="1"/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                    <outline text="[Humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9qhDnRw_o9q14H23ZjxsSopI)" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Often considered the opposite of pride."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Shame" _note="Refine" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An emotion often associated with negative self-evaluation; motivation to quit; and feelings of pain, exposure, distrust, powerlessness, and worthlessness."/>
                    <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Shame)"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Often drives people to hide or deny their perceived failures or faults."/>
                    </outline>
                  </outline>
                  <outline text="Common causes" heading="3" colorLabel="1"/>
                  <outline text="It can bring about profound feelings of deficiency, defeat, inferiority, unworthiness, or self-loathing. Our attention turns inward; we isolate from our surroundings and withdraw into closed-off self-absorption. Not only do we feel alienated from others but also from the healthy parts of ourselves. This inward focus can intensify self-criticism and contribute to further emotional distress.[3] The alienation from the world leads to painful emotions and self-deprecating thoughts and inner anguish.[4] Empirical research demonstrates that it is dysfunctional for the individual and group level.[5] Shame can also be described as an unpleasant self-conscious emotion that involves negative evaluation of the self.[6] Shame can be a painful emotion that is seen as a &quot;...comparison of the self&apos;s action with the self&apos;s standards...&quot; but may equally stem from comparison of the self&apos;s state of being with the ideal social context&apos;s standard. In Western, individualistic contexts, shame is often conceptualized as an internal failure of the self, whereas collectivist cultures may interpret shame as a relational emotion tied to maintaining social harmony or fulfilling obligations to family and community.[7][8] In some East Asian settings, shame can be experienced vicariously, felt on behalf of one’s social group or family.[9] According to Neda Sedighimornani,[10] shame is relevant in several psychological disorders such as depression, phobia of social interactions, and even some eating disorders. Some scales of shame measure it to assess emotional states, whereas other shame scales are used to assess emotional traits or dispositions- shame proneness.[11] &quot;To shame&quot; generally means to actively assign or communicate a state of shame to another person. Behaviors designed to &quot;uncover&quot; or &quot;expose&quot; others are sometimes used to place shame on the other person. Whereas, having shame means to maintain a sense of restraint against offending others (as with modesty, humility, and deference). In contrast to having shame is to have no shame; behaving without restraint, offending others, similar to other emotions like pride or hubris. This distinction between “having shame” and “being shamed” also function both as a social regulator and as a punitive tool within communities."/>
                  <outline text="blushing, confusion of mind, downward cast eyes, slack posture, and lowered head"/>
                  <outline text="Shame is a self-punishing acknowledgment of something gone wrong.[13] It is associated with &quot;mental undoing&quot;. Studies of shame showed that when ashamed people feel that their entire self is worthless, powerless, and small, they also feel exposed to an audience—real or imagined—that exists purely for the purpose of confirming that the self is worthless. Shame and the sense of self is stigmatized, or treated unfairly, like being overtly rejected by parents in favor of siblings&apos; needs, and is assigned externally by others regardless of one&apos;s own experience or awareness. An individual who is in a state of shame will assign the shame internally from being a victim of the environment, and the same is assigned externally, or assigned by others regardless of one&apos;s own experience or awareness."/>
                  <outline text="The person experiencing shame might not be able to, or perhaps simply will not, identify their emotional state as shame, and there is an intrinsic connection between shame and the mechanism of denial.[14] &quot; The key emotion in all forms of shame is contempt (Miller, 1984; Tomkins, 1967). Two realms in which shame is expressed are the consciousness of self as bad and self as inadequate.[15] People employ negative coping responses to counter deep rooted, associated sense of &quot;shameworthiness&quot;.[16] The shame cognition may occur as a result of the experience of shame affect or, more generally, in any situation of embarrassment, dishonor, disgrace, inadequacy, humiliation, or chagrin.[17]The dynamics of shame and devaluation appear to be consistent across cultures. This has led some researchers to propose the existence of a universal human psychology related to how we assign value and worth. This applies both to us and to others."/>
                  <outline text="Behavioral expression" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Physiological symptoms caused by the autonomic nervous system include blushing, perspiration, dizziness, or nausea. A feeling of paralysis, numbness, or loss of muscle tone might set in making it difficult to think, act, or talk. Children often visibly slump and hang their head. In an effort to hide this reaction, adults are more likely to laugh, stare, avoid eye contact, freeze their face, tighten their jaw, or show a look of contempt. In another&apos;s presence, there&apos;s a feeling of being strange, naked, transparent, or exposed, as if wanting to disappear or hide.[19][20] The Shame Code was developed to capture behavior as it unfolds in real time during the socially stressful and potentially shaming spontaneous speech task and was coded into the following categories: (1) Body Tension, (2) Facial Tension, (3) Stillness, (4) Fidgeting, (5) Nervous Positive Affect, (6) Hiding and Avoiding, (7) Verbal Flow and Uncertainty, and (8) Silence.[21] Shame tendencies were associated with more fidgeting and less freezing, but both stillness and fidgeting were social cues that convey distress to the observer and may elicit less harsh responses. Thus, both may be an attempt to diminish further shaming experiences. Shame involves global, self-focused negative attributions based on the anticipated, imagined, or real negative evaluations of others and is accompanied by a powerful urge to hide, withdraw, or escape from the source of these evaluations. These negative evaluations arise from transgressions of standards, rules, or goals and cause the individual to feel separate from the group for which these standards, rules, or goals exist, resulting in one of the most powerful, painful, and potentially destructive experiences known to humans."/>
                  </outline>
                  <outline text="Types of shame" heading="1" colorLabel="1" collapsed="true">
                    <outline text="Existential" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Occurs when we become self-aware of an objective, unpleasant truth about ourselves or our situation."/>
                    </outline>
                    <outline text="Situational" heading="3" colorLabel="1" collapsed="true">
                      <outline text="The feeling we have when violating an ethical principle, interpersonal boundary, or cultural norm."/>
                    </outline>
                    <outline text="Class" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Relates to social power and pertains to skin color, social class, ethnic background, and gender and occurs in societies that have rigid caste stratifications or disparate classes."/>
                    </outline>
                    <outline text="Narcissistic" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Occurs when our self-image and pride are wounded, affecting how we feel and think about ourselves as an individual, in contrast as a member of a group"/>
                    </outline>
                    <outline text="..."/>
                    <outline text="Unwanted exposure" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Something personal that we would like to keep private is unexpectedly revealed, or when we make a mistake in [a] public [setting]."/>
                        <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                          <outline text="You are called out in front of a whole class for doing something wrong."/>
                          <outline text="Someone sees you doing something you did not want them to see."/>
                        </outline>
                        <outline text="This is what you would normally think of when you hear the word &quot;shame&quot;."/>
                      </outline>
                    </outline>
                    <outline text="Unrequited love" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Unreciprocated love that causes yearning for more complete love." colorLabel="3"/>
                      <outline text="Common causes" heading="3" colorLabel="1" collapsed="true">
                        <outline text="When you love someone but your partner does not reciprocate, or one is rejected by somebody that they like; this can be mortifying and shaming."/>
                      </outline>
                      <outline text="An experiment called &quot;The Still Face Experiment&quot; was done where a mother showed her baby love and talked to the baby for a set period of time. She then went a few minutes without talking to the baby. This resulted with the baby making different expressions to get the mother&apos;s attention. When the mother stopped giving the baby attention, the baby felt shame. "/>
                      <outline text="According to research on unrequited love, people tend to date others who are similar in attractiveness, leaving those less attractive to feel an initial disappointment that creates a type of unrequited love in the person."/>
                    </outline>
                    <outline text="Disappointed expectation" heading="3" colorLabel="1" collapsed="true">
                      <outline text="The feeling of dissatisfaction that follows the failure of expectations or hopes to manifest." colorLabel="3"/>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Not passing a class"/>
                        <outline text="Having a friendship go wrong"/>
                        <outline text="Not getting a big promotion in a job that you thought you would get."/>
                      </outline>
                    </outline>
                    <outline text="Exclusion" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Being left out of connection or involvement with others or groups that we would like to belong to." colorLabel="3"/>
                      <outline text="also means being left out. Many people will do anything to just fit in or want to belong in society, e.g., at school, work, friendships, relationships, everywhere."/>
                    </outline>
                    <outline text="..."/>
                    <outline text="Internalized shame" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Internalized shame reflects deep-seated beliefs of inadequacy that feel permanent and irreversible and are accompanied by words, voices, and images."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Different from an acute short-lived experience of shame."/>
                        </outline>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3" collapsed="true">
                          <outline text="Once internalized, the original shaming event(s) and beliefs need not be recalled nor be conscious."/>
                          <outline text="Later experiences of shame are intensified and last longer. "/>
                          <outline text="They do not require an external event or another person to trigger associated feelings and thoughts and can cause depression and feelings of hopelessness and despair."/>
                          <outline text="It also causes &quot;shame anxiety,&quot; which makes people apprehensive about experiencing shame."/>
                        </outline>
                      </outline>
                      <outline text="Causes" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Internalized shame stems from chronic or less frequent severe experiences of shame occurring with prior trauma or in childhood. It can take over a child&apos;s emotions and identity and continue into adulthood or may gradually increase over time."/>
                      </outline>
                    </outline>
                    <outline text="Vicarious shame" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The experience of shame on behalf of other person(s). "/>
                      </outline>
                      <outline text="Individuals vary in their tendency to experience vicarious shame, which is related to neuroticism and to the tendency to experience personal shame."/>
                    </outline>
                  </outline>
                  <outline text="Collectivist shame" _note="Link in sociology or something, and maybe move under types of shame." heading="3" colorLabel="1" collapsed="true">
                    <outline text="In collectivist cultures, shame is tied with social harmony, family honor, and group reputation. Chinese cultures are influenced by Confucian values and experience shame as a tool to regulate moral conduct and social cohesion.[7] Japanese individuals, similiarily, encounter both personal shame and shame felt for the actions of others within their social groups, highlighting the communal aspect of shame in collectivist contexts.[8] Differences still exist among collectivist cultures. Analyses of language corpora from multiple cultures demonstrate cross-cultural variation in how shame, guilt, and embarrassment are conceptualized and expressed. Even within East Asia, semantic and philosophical interpretations of shame diverge. Korean shame is very closely associated moral failure and the protection of family honor, with an individual&apos;s shame reflecting throughout their household.[9] In Japan, shame is tied to maintaining social harmony and fufilling expected social roles, and resulting in feelings of embarrassment or proxy shame when group norms are disrupted.[9] While shame may be a universal self-conscious emotion, it can operate as a social function depending on the cultural norm."/>
                  </outline>
                  <outline text="Distinguishing shame from similar emotions" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Distinguishing between shame, guilt, and embarrassment can be challenging."/>
                    </outline>
                    <outline text="Distinguishing guilt" heading="3" colorLabel="1" collapsed="true">
                      <outline text="According to cultural anthropologist Ruth Benedict, shame arises from a violation of cultural or social values while guilt feelings arise from violations of one&apos;s internal values.[24] Thus shame arises when one&apos;s &apos;defects&apos; are exposed to others, and results from the negative evaluation (whether real or imagined) of others; guilt, on the other hand, comes from one&apos;s own negative evaluation of oneself, for instance, when one acts contrary to one&apos;s values or idea of one&apos;s self.[25] Shame is more attributed to internal characteristics and guilt is more attributed to behavioral characteristics.[26] Thus, it might be possible to feel ashamed of thought or behavior that no one actually knows about (because one is afraid of what they find), and conversely, feeling guilty about the act of gaining approval from others.Psychoanalyst Helen B. Lewis argued that, &quot;The experience of shame is directly about the self, which is the focus of evaluation. In guilt, the self is not the central object of negative evaluation, but rather the thing done is the focus.&quot;[27] Similarly, Fossum and Mason say in their book Facing Shame that &quot;While guilt is a painful feeling of regret and responsibility for one&apos;s actions, shame is a painful feeling about oneself as a person.&quot;[28]Following this line of reasoning, Psychiatrist Judith Lewis Herman concludes that &quot;Shame is an acutely self-conscious state in which the self is &apos;split,&apos; imagining the self in the eyes of the other; by contrast, in guilt the self is unified.&quot;[29]Clinical psychologist Gershen Kaufman&apos;s view of shame is derived from that of affect theory, namely that shame is one of a set of instinctual, short-duration physiological reactions to stimulation.[30][31] In this view, guilt is seen as a learned behavior consisting primarily of self-directed blame or contempt, and the shame that results from this behavior, making up a part of the overall experience of guilt. Here, self-blame and self-contempt mean the application, towards (a part of) one&apos;s self, of exactly the same dynamic that blaming of, and contempt for, others represents when it is applied interpersonally.Kaufman saw that mechanisms such as blame or contempt may be used as a defending strategy against the experience of shame and that someone who has a pattern of applying them to himself may well attempt to defend against a shame experience by applying self-blame or self-contempt. This, however, can lead to an internalized, self-reinforcing sequence of shame events for which Kaufman coined the term &quot;shame spiral&quot;.[30] Shame can also be used as a strategy when feeling guilty, especially when the hope is to avoid punishment by inspiring compassion."/>
                    </outline>
                    <outline text="Distinguishing embarrassment" heading="3" colorLabel="1" collapsed="true">
                      <outline text="One view of difference between shame and embarrassment says that shame does not necessarily involve public humiliation while embarrassment does; that is, one can feel shame for an act known only to oneself but to be embarrassed one&apos;s actions must be revealed to others. In the field of ethics (moral psychology, in particular), however, there is debate as to whether or not shame is a heteronomous emotion, i.e., whether or not shame does involve recognition on the part of the ashamed that they have been judged negatively by others.Another view of the dividing line between shame and embarrassment holds that the difference is one of intensity.[33] In this view embarrassment is simply a less intense experience of shame. It is adaptive and functional. Extreme or toxic shame is a much more intense experience and one that is not functional. In fact, according to this view, toxic shame can be debilitating. The dividing line then is between functional and dysfunctional shame. This includes the idea that shame has a function or benefit for the organism.[34]Immanuel Kant and his followers held that shame is heteronomous (comes from others); Bernard Williams and others have argued that shame can be autonomous (comes from oneself).[35][36] Shame may carry the connotation of a response to something that is morally wrong whereas embarrassment is the response to something that is morally neutral but socially unacceptable. Another view of shame and guilt is that shame is a focus on self, while guilt is a focus on behavior. Simply put: A person who feels guilt is saying &quot;I did something bad.&quot;, while someone who feels shame is saying &quot;I am bad&quot;.[37]Embarrassment has occasionally been viewed as a less severe or intense form of shame, which usually varies on different aspects such as intensity, the physical reaction of the person, or the size of the present social audience, but it is distinct from shame in that it involves a focus on the self-presented to an audience rather than the entire self.[26] It is experienced as a sense of fluster and slight mortification resulting from a social awkwardness that leads to a loss of esteem in the eyes of others. Embarrassment has been characterized as a sudden-onset sense of fluster and mortification that results when the self is evaluated negatively because one has committed, or anticipates committing, a gaffe or awkward performance before an audience. So, because shame is focused on the entire self, those who become embarrassed apologize for their mistake, and then begin to repair things and this repair involves redressing harm done to the presented self.[13]One view of difference between shame and embarrassment says that shame does not necessarily involve public humiliation while embarrassment does; that is, one can feel shame for an act known only to oneself but to be embarrassed one&apos;s actions must be revealed to others. Therefore shame can only be experienced in private and embarrassment can never be experienced in private.[13] In the field of ethics (moral psychology, in particular), however, there is debate as to whether or not shame is a heteronomous emotion, i.e. whether or not shame does involve recognition on the part of the ashamed that they have been judged negatively by others. This is a mature heteronomous type of shame where the agent does not judge herself negatively, but, due to the negative judgments of others, suspects that she may deserve negative judgment, and feel shame on this basis.[38] Therefore, shame may carry the connotation of a response to something that is morally wrong whereas embarrassment is the response to something that is morally neutral but socially unacceptable."/>
                    </outline>
                  </outline>
                  <outline text="https://en.wikipedia.org/wiki/Self-deprecation"/>
                  <outline text="https://en.wikipedia.org/wiki/Self-hatred"/>
                  <outline text="https://en.wikipedia.org/wiki/Social_alienation" _note="Maybe make a section for this or add it to sociology? Shouldn&apos;t be here probably but should be linked or something."/>
                  <outline text=""/>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Narcissism" _note="Create and link section, maybe move some of this under narcissism or link this there?" heading="3" colorLabel="1" collapsed="true">
                      <outline text="It has been suggested that narcissism in adults is related to defenses against shame and that narcissistic personality disorder is connected to shame as well."/>
                      <outline text="NPD can perhaps be broken down into two subtypes:"/>
                      <outline text="^ Oblivious" collapsed="true">
                        <outline text="A grandiose, arrogant, thick-skinned &quot;oblivious&quot; subtype"/>
                        <outline text="Presents for admiration, envy, and appreciation a grandiose self that is the antithesis of a weak internalized self which hides in shame."/>
                      </outline>
                      <outline text="^ Hypervigilant " collapsed="true">
                        <outline text="An easily hurt, oversensitive, ashamed &quot;hypervigilant&quot; subtype."/>
                        <outline text="Neutralizes devaluation by seeing others as unjust abusers."/>
                      </outline>
                    </outline>
                    <outline text="Sociology" _note="Probably move most or all of this to sociology and link it here." heading="3" colorLabel="1" collapsed="true">
                      <outline text="According to the anthropologist Ruth Benedict, cultures may be classified by their emphasis on the use of either shame (a [shame society](https://en.wikipedia.org/wiki/Guilt%E2%80%93shame%E2%80%93fear_spectrum_of_cultures)) or guilt to regulate the social activities of individuals. Shame may be used by those people who commit [relational aggression](https://en.wikipedia.org/wiki/Relational_aggression) and may occur in the workplace as a form of overt social control or aggression. Shaming is used in some societies as a type of punishment, shunning, or ostracism. In this sense, &quot;the real purpose of shaming is not to punish crimes but to create the kind of people who don&apos;t commit them&quot;."/>
                    </outline>
                    <outline text="A &quot;sense of shame&quot; is the feeling known as &lt;broken link&gt;"/>
                  </outline>
                </outline>
                <outline text="Guilt" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Guilt_(emotion))"/>
                  </outline>
                </outline>
                <outline text="Embarrassment" heading="3" colorLabel="1"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Frontotemporal lobar degeneration" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Frontotemporal lobar degeneration (FTLD) is a [neurodegenerative disease](https://en.wikipedia.org/wiki/Neurodegenerative_disease) that attacks the brain selectively in the frontal lobe, temporal lobe and [amygdala](https://en.wikipedia.org/wiki/Amygdala). Patients suffering from FTLD offer information on the biological complexity involved in generating self-conscious emotions. With the use of a startle experiment (where patients and control participants are exposed to an unexpected and loud sound) it has been shown that sufferers of FTLD show and experience the basic negative emotions expected to be attached to the startling sounds. However they show significantly less signs of experiencing self-conscious emotions compared to control groups. This is due to an inhibition of [embarrassment](https://en.wikipedia.org/wiki/Embarrassment) caused by the damaged brain (Sturm &amp; Rosen, 2006)."/>
                    <outline text="The ability to show basic emotions while lacking the ability to perform the more complex self-conscious emotions demonstrates that self-conscious emotions are biologically harder to perform than average emotions. FTLD patients tend to struggle in social situations (Sturm &amp; Rosen, 2006). This is again linked with their inability to perform self-conscious emotions adequately."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Defensiveness" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Psychological self-protection used in an attempt to ward off perceived threats, criticism or shame. "/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text=""/>
                  </outline>
                </outline>
                <outline text="Causes" heading="3" colorLabel="1" collapsed="true">
                  <outline text="When one feels unjustly accused, it&apos;s common for them to fish for excuses so that the person who they feel unjustly accused by will back off." collapsed="true">
                    <outline text="More accurately, it&apos;s likely that one subconsciously follows the &quot;advice&quot; of a previously commonly learned habit which tells them to fish for excuses. And the habit is typically learned because it tends to have helped with getting people to back off in previous cases. "/>
                  </outline>
                  <outline text="When one feels accused (especially unjustly), it&apos;s common to feel misunderstood, attacked, stressed, etc." collapsed="true">
                    <outline text="Which can often cause anger, which can often cause [impulsivity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ghD22JG6DO01dRavfcanfIYs)."/>
                    <outline text="Which can often cause [social withdrawal](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eifa30Mr_JzDmKtBSW1swo5B)."/>
                  </outline>
                </outline>
                <outline text="Recognizing defensive feelings" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Frequently practicing thinking about how you feel during and after your discussions." _note="I think this is easier in text, because there&apos;s less pressure to respond immediately and more natural time for reflection, and you can look back over the messages you sent."/>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Crucial for [preventing defensiveness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d5aMFPJNTagqE-3KO89FGDh-)." colorLabel="4" collapsed="true">
                        <outline text="[Preventing defensive feelings is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HsdSacyuDhDM9n41_Xn7jK2b)." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Crucial for [addressing defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cLEzyxQ79Cg_ihyVlzluxgpi)." colorLabel="4" collapsed="true">
                        <outline text="[Addressing defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K3-_A86nX8A3yr4j-YsoLIxv) is important." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Difficult" heading="3" collapsed="true">
                      <outline text="[People don&apos;t tend to be very good with self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ocsBqG0JTPgES1WfMoMGb7Gk)." colorLabel="4"/>
                      <outline text="Ironically, the more emotional we get, the harder it becomes to reflect like this." colorLabel="4" collapsed="true">
                        <outline text="This kind of reflection is the kind of auxillary process that our brain is wired to (by default) shut down in favor of more efficiently attacking/defending (whether emotionally or otherwise)." _note="Link this to evolutionary section." colorLabel="4"/>
                        <outline text="It typically takes a lot of practice to overcome that instinct to be able to recognize it consistently in real-time." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Strategies" heading="1" colorLabel="2" collapsed="true">
                    <outline text="During the discussion ask yourself questions about yourself." collapsed="true">
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="How tense am I? If I&apos;m tense, why?"/>
                        <outline text="How long am I spending thinking about this? How much time should I be spending?"/>
                      </outline>
                    </outline>
                    <outline text="After a discussion, look back over it and ask yourself questions about yourself." collapsed="true">
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="It makes it easier to recognize and deal with your emotions." colorLabel="2" collapsed="true">
                          <outline text="This builds up habits for thinking about how you&apos;re feeling and gives you a better understanding of how your emotions work, which makes it easier to recognize and deal with them."/>
                        </outline>
                        <outline text="It&apos;s typically easier to do retroactive self-analysis than real-time self-analysis." colorLabel="2" collapsed="true">
                          <outline text="You&apos;re usually less defensive in the future looking back."/>
                        </outline>
                      </outline>
                      <outline text="Examples" heading="1" colorLabel="6" collapsed="true">
                        <outline text="How was I feeling when I said that?"/>
                        <outline text="If negative, why was I feeling that way?"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Preventing defensive feelings" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Preventing defensive feelings from arising or sustaining (as strongly) in at least some cases."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Not the same as [ignoring](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qcuSSeqHqOV-skymlWBLrXhf) or [repressing](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NOPn06eFCiAI1WnxcQwKHLMl) defensive feelings or making yourself suffer."/>
                      <outline text="Not the same as [addressing defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cLEzyxQ79Cg_ihyVlzluxgpi), which is less about resolving the emotions and more about working around them."/>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3"/>
                  </outline>
                  <outline text="Strategy" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Typically the main strategy is understanding the primary [causes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qenn0boc4gHKBedikLWTyyaq) to learn to [recognize defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=U22yH5CUuOIMUy0MIBGdwSXj) and [avoid causes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=w2gZVkev0-poImf01hYsbbkc) where worthwhile."/>
                  </outline>
                </outline>
                <outline text="Addressing defensive feelings" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Not the same as [preventing defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d5aMFPJNTagqE-3KO89FGDh-), which is less about working around the emotions and more about resolving them."/>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="**Common:**   It&apos;s often very important to ensure we can address defensive feelings effectively." colorLabel="4"/>
                    <outline text="**Ignoring emotions:**   If this is done __instead__ of [preventing defensive feelings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d5aMFPJNTagqE-3KO89FGDh-) rather than alongside it, then it&apos;s typically a form of [ignoring emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qcuSSeqHqOV-skymlWBLrXhf)." colorLabel="1" collapsed="true">
                      <outline text="Ignoring emotions [tends to cause a lot of issues](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4CGQCYFNDW5VpkRTZAnuo6e0)." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Strategies" heading="3" colorLabel="2" collapsed="true">
                    <outline text="The below strategies rely on being able to [recognize when you&apos;re feeling defensive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=U22yH5CUuOIMUy0MIBGdwSXj)"/>
                    <outline text="Reduce impact on reasoning" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Reduce the impact that defensive feelings have on reasoning."/>
                      </outline>
                      <outline text="Practice habits for [self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc) about how defensiveness might be impacting your reasoning." heading="3" colorLabel="2" collapsed="true">
                        <outline text="Whenever you&apos;re feeling even a little defensive, practice thinking about:"/>
                        <outline text="1. How your points might be influenced by your emotions."/>
                        <outline text="2. How some crucial epistemic steps might have been skipped because your emotions are compelling you to be more reactionary." collapsed="true">
                          <outline text="**Related:**   [Thoroughness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ)" colorLabel="6"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Social withdrawal" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text=""/>
                  </outline>
                </outline>
                <outline text="Innocent victimhood" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Often used to reverse the blame, since attacking victims is often seen as bad."/>
                </outline>
              </outline>
              <outline text="Empathy" _note="Expand this a lot" heading="1" colorLabel="1" collapsed="true">
                <outline text="**Definition:** The ability or propensity to feel others&apos; emotions." colorLabel="3"/>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Almost everyone feels empathy, usually a substantial amount of it." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Tends to be based on a lot of irrational subconscious beliefs/associations." colorLabel="4" collapsed="true">
                      <outline text="This makes it very dangerous to rely on." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="It makes it so our empathy can be leveraged for irrational ends." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="It is usually the case that many of our irrational subconscious beliefs/associations can be leveraged for virtually any end. So if our empathy is based on that, our empathy too can likely be leveraged for virtually any end." _note="Likelihood" colorLabel="4"/>
                        </outline>
                        <outline text="If it is very dangerous to rely on, then it is very important to learn how to avoid relying on it in important cases." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Heavy reliance tends to result in [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)." colorLabel="4" collapsed="true">
                      <outline text="Our empathy is largely dependent on our https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2u3zb8iZbtZCj5aZBVmU0ON , therefore relying on empathy tends to mean relying on our subconscious/intuition. And [our subconscious/intuition is based on heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yXhXm2F6GcWOS8hNsMQfe-xS), therefore heavy reliance on empathy tends to result in heavy heuristic usage." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="[Most emotions are largely dependent on our vibes/intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yP6X4DaMABkdUQV3tpI7NRpZ) , therefore empathy likely is too." _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Tends to have a very strong effect on peoples&apos; behavior." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Managing &lt;broken link&gt;" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Reducing in-group empathy" heading="3" collapsed="true">
                    <outline text="Often very helpful for reducing many biases and epistemic issues related to in-groups." colorLabel="4"/>
                    <outline text="Can make it more difficult to intuitively understand others." colorLabel="1"/>
                  </outline>
                  <outline text="Increasing out-group empathy" heading="3" collapsed="true">
                    <outline text="Can counteract the bias from in-group empathy." colorLabel="4"/>
                    <outline text="Can help with intuitively understanding others." colorLabel="4"/>
                    <outline text="Can create new biases in favor of out-groups." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Sociopathy / psychopathy" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The state of lacking empathy, either partially or completely."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="For reasoning" colorLabel="4" collapsed="true">
                        <outline text="[Psychopaths (at least tend to) have less self-esteem issues](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LvMTuKAycZcnCro8RyROiIPr)" colorLabel="4" collapsed="true">
                          <outline text="This can be helpful for reasoning because of &lt;broken link&gt;" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="For better moods during certain tasks" colorLabel="4" collapsed="true">
                        <outline text="[Psychopaths (at least tend to) have less self-esteem issues](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LvMTuKAycZcnCro8RyROiIPr)" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Evolution" _note="Link and expand" heading="3" colorLabel="1"/>
                  <outline text="Experience" heading="3" collapsed="true">
                    <outline text="We tend to empathize more with things that have a high capacity to experience things like emotions (especially pain/suffering)." colorLabel="3"/>
                  </outline>
                  <outline text="Low agency" heading="3" collapsed="true">
                    <outline text="We tend to empathize more with things that have low agency (especially low ability to prevent themselves from going through pain/suffering, i.e. helplessness)." colorLabel="3"/>
                  </outline>
                  <outline text="Unpredictable" heading="3" collapsed="true">
                    <outline text="We tend to empathize more with things that we can&apos;t predict." colorLabel="3"/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="If a shape merely moves in a circle, we feel like it&apos;s programmed, mechanical, **experienceless**."/>
                      <outline text="If a shape moves in a way that feels very unpredictable, then we tend to feel like it&apos;s alive, experiencing and choosing to make these movements." collapsed="true">
                        <outline text="Especially if even its form(s) of unpredictability feels unpredictable."/>
                      </outline>
                    </outline>
                    <outline text="This could also be due to feeling like if something can&apos;t be predicted, it must have an experiential element guiding its processes because systems lacking such an experiential element tend to be more predictable." colorLabel="1"/>
                  </outline>
                  <outline text="Clear work -&gt; value trade" heading="3" collapsed="true">
                    <outline text="We tend to empathize more with things which allow us to trade work for value." colorLabel="3"/>
                    <outline text="Maybe because it feels more like a relationship." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Anthropomorphism" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Causes" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Empathy"/>
                    <outline text="We tend to anthropomorphize more when we desire positive social connection or control over our environment." collapsed="true">
                      <outline text="The idea is that one attempts to escape social loneliness by trying to make one&apos;s own social connections. As such (the idea goes), we tend to anthropomorphize objects in a positive way."/>
                      <outline text="Anthropomorphization often brings a kind of fictional clarity that sometimes feels comforting to us."/>
                    </outline>
                    <outline text="This is perhaps a process of inductive inference where we subconciously guess at the experiential nature of an object using the model we&apos;re most familiar with, our own."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Contempt" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A feeling of angry superiority over someone else."/>
                </outline>
                <outline text="Common consequences" _note="Edit" heading="3" colorLabel="2" collapsed="true">
                  <outline text="When we communicate in this state, we are truly mean—we treat others with disrespect, mock them with sarcasm, ridicule, call them names, and mimic or use body language such as eye-rolling or scoffing. The target of contempt is made to feel despised and worthless."/>
                  <outline text="Stonewalling" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The act of withdrawing from an interaction, shutting down and avoiding responding."/>
                    </outline>
                    <outline text="Rather than confronting the issues, people who stonewall can make evasive maneuvers such as tuning out, turning away, acting busy, or engaging in obsessive or distracting behaviors."/>
                    <outline text="Common causes" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Desire to avoid conflict."/>
                      <outline text="Desire to convey disapproval, distance and/or separation."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Indignation" _note="Refine a lot" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A feeling involving anger mingled with &lt;broken link&gt; or &lt;broken link&gt;"/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Politics" heading="3" collapsed="true">
                    <outline text="Indignation plays a significant role in politics. This is because politicians hold the power to offend many people based the decisions that they make. The decisions that politicians make impact hundreds, thousands, or millions of people. Certain decisions they make may cause many constituents to feel indignant because they feel like those decisions go against what they stand for or believe in, especially if the constituents belong to the same party as the politician. Politicians themselves also feel indignant because if people are not in favor of their policies or are competing against them, they will attack their self-construct. For example, this can be seen when politicians are debating. The other politician typically questions their policies and procedures in hopes to make their competition feel indignant. By doing this, the hope would be that the debate would be stifled.It has been stated that indignation provides the capacity to think through certain situations.[8][9]: 290  The person feeling indignant wants to think about why they are feeling indignant so that they can figure out an appropriate response and pin-point whatever caused them to feel indignant. It has been stated that &quot;when indignation does not express itself immediately as violence, it becomes an investigation of (and what he believes is a more appropriate response to) whatever has caused it&quot;"/>
                  </outline>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="The feeling of indignation can occur when one is mistreated by another or negative feelings are sparked when a situation is out of the normal realm of society. When situations or actions that are considered to be unjust behavior occur, the feeling of indignation is experienced. With unjust actions and behaviors comes to blame. Blame also helps to make up the emotion of indignation. When blameworthy actions take place, the emotion of indignation occurs and negative feelings are projected onto the person who is to blame. Which can be brought on by disturbances that go against social normative. According to Claude Miller, &quot;indignation is defined as a non-primary, discrete, social emotion, specifying disapproval of someone else&apos;s blameworthy action, as that action is explicitly viewed to be in violation of the objective order, and implicitly perceived as injurious to the perceiver&apos;s self-concept&quot;. Indignation is experienced when violations are made to our daily lives. Indignation is an emotion that is considered to be an adaptive behavior. Social environment and social emotions being a stimuli for indignation. Our emotions and behaviors adapt depending on certain situations. Internal and external social norms play a part in experiencing the emotion of indignation. It is expected that everyone coexists and follows the social normative behaviors society has put in place. When something disrupts what is considered to be a social norm, a violation occurs, both internally and externally. A range of feelings are experienced internally, as well as a desire to be removed from the situation externally. When norms are disrupted, offense is taken and the emotion of indignation is ignited.The attribution process is integral in the development of indignation. It is the split-second assessments a person makes (attributions) about their own behavior or in the behavior of others in order to figure out the reason or cause behind it. Behaviors can be classified as situational (external) or dispositional (internal). Fritz Heider wrote that people tend to view behavior in one of two ways; the cause of situational factors or of dispositional factors. From this, an individual is either an Entity theorist or an Incremental theorist when considering event or categorization but is not exclusive to either group. According to one scholar, &quot;People&apos;s implicit theories create a framework for processing information, forming inferences, determining attributions, shaping predictions, understanding others&apos; behaviors, and construction representations of social events&quot;. Taking this into account and based on a person&apos;s classification of entity or incremental theorist (which delineates how a person views behavior in relation to its driving factors), research demonstrates that said person is inclined to experience indignation with more or less frequency and severity respectively."/>
                </outline>
                <outline text="Entity theory" _note="Probably move and link here" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Entity theorists believe that judgements of moral character can be made from merely a few or even a single observation(s). They are most often found making stereotypes about people or events, and believe that disposition based attributions are innate, and rarely ever change. &apos;You can&apos;t teach an old dog new tricks&apos; explains how entity theorists might explain a situation. Behavior, to them, is caused by the unchanging, internal (character) attributes.[5] Hypothetically, if the two different types of people were sitting on a parole board for a jailed criminal, those who exemplify traits of entity theorists might say &apos;once a criminal always a criminal&apos; and reason that the criminal behavior was driven by the immoral nature of the person and they would do it again, no matter the circumstance, when given the opportunity.Dispositional traits are used within the entity theory as a basic unit of analysis. Either positive or negative attributes are experienced and possibly expressed. With indignation, the attributes experienced are going to be negative. These tendencies are most likely going to remain the same and be predictable with little to no room for change. An assumption is made and judgments are carried out. Entity theory creates and holds judgements based on a single behavioral observation. Once something is believed to be true, it is almost permanently labeled, and objective situational evidence is neglected to be taken into consideration. Disposition-relevant information is the main focus due to the fact that it feeds the reinforcement of negative information."/>
                </outline>
                <outline text="Incremental theory" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Incremental theorists believe just the opposite position of some entity theorists. They can make judgements of moral character more based on changing external factors (situational) and factors such as effort, desire such as goals.[4]: 18  When formulating judgements, incremental theorists take recent evidence into account and avoid broad character attributions. For example, those of those who are considered to be incremental theorists might argue that, the aforementioned criminal&apos;s behavior, was possibly the subsequent result of a poor upbringing or was drug induced, and while, in prison, the incarcerated changed his/her lifestyle through exemplary behavior and service to others. Thus they would not be a threat to the public anymore, in theory."/>
                </outline>
                <outline text="Righteous indignation" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Righteous indignation is typically a reactive emotion of anger over perceived mistreatment, insult, or malice. It is akin to a sense of injustice. In some Christian doctrines, righteous indignation is considered the only form of anger which is not sinful, e.g., when Jesus drove the money lenders out of the temple in the Gospel of Matthew.[10]The Forerunner Commentary on Psalms 137:2–6 argues that these psalms are about the &quot;bitterness of exile into which God forced Judah&quot;, purportedly with the goal of turning grief into zeal, so that the &quot;anger can be used to scour away sin&quot; by becoming &quot;righteously indignant&quot;.[11] In John W. Ritenbaugh&apos;s comments on Proverbs 15:18 in How to Survive Exile, he argues that it &quot;is alright for us to be righteously indignant as long as we do not sin.&quot;[11]Daniel Whitby argues that &quot;anger is not always sinful&quot;, in that it is found among non-sinners. For example, Jesus was &quot;angry with the Pharisees for the hardness of their hearts; yet He had no desire to revenge this sin upon them, but had a great compassion for them&quot;"/>
                </outline>
              </outline>
              <outline text="Jealousy" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Desire for the possessions or qualities of another."/>
                </outline>
                <outline text="Envy" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A feeling of discontent and resentment aroused by and in conjunction with jealousy."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Organize this" heading="1" collapsed="true">
                <outline text="People may not only share emotions with others, but may also experience similar physiological arousal to others if they feel a sense of social connectedness to the other person." collapsed="true">
                  <outline text="A laboratory-based study by Cwir, Car, Walton, and Spencer showed that, when a participant felt a sense of social connectedness to a stranger (research confederate), the participant experienced similar emotional states and physiological responses to that of the stranger while observing the stranger perform a stressful task."/>
                </outline>
                <outline text="To investigate the function of social emotions in economic behaviors, researchers are interested in the differences in brain regions involved when participants are playing with, or think that they are playing with, another person as opposed to a computer. A study with fMRI found that, for participants who tend to cooperate on two-person “trust and reciprocity” games, believing that they are playing with another participant activated the prefrontal cortex, while believing that they are playing with a computer did not.[19] This difference was not seen with players who tend not to cooperate.[19] The authors interpret this difference as theory of minds that cooperators employ to anticipate the opponents&apos; strategies. This is an example of the way social decision making differs from other forms of decision making."/>
                <outline text="in the ultimatum game, two players are asked to divide a certain amount of money, say x. One player, called the proposer, decides ratio by which the money gets divided. The other player, called the responder, decides whether or not to accept this offer. If the responder accepts the offer, say, y amount of money, then the proposer gets x-y amount and the responder gets y. But if the responder refuses to accept the offer, both players get nothing. This game is widely studied in behavioral economics. According to the rational agent model, the most rational way for the proposer to act is to make y as small as possible, and the most rational way for the responder to act is to accept the offer, since little amount of money is better than no money. However, what these experiments tend to find is that the proposers tend to offer 40% of x, and offers below 20% would get rejected by the responders.[23] Using fMRI scans, researchers found that social emotions elicited by the offers may play a role in explaining the result. When offers are unfair as opposed to fair, three regions of the brain are active: the dorsolateral prefrontal cortex (DLPFC), the anterior cingulate cortex (ACC), and the insula. The insula is an area active in registering body discomfort. It is activated when people feel, among other things, social exclusion.[24] The authors interpret activity in the insula as the aversive reaction one feels when faced with unfairness, activity in the DLPFC as processing the future reward from keeping the money, and the ACC is an arbiter that weighs these two conflicting inputs to make a decision. Whether or not the offer gets rejected can be predicted (with a correlation of 0.45) by the level of the responder&apos;s insula activity."/>
                <outline text="Research using PET scan has found that, when players punish other players, activity in the nucleus accumbens (part of the striatum), a region known for processing rewards derived from actions[25] gets activated.[26] It shows that we not only feel hurtful when we become victims of unfairness, but we also find it psychologically rewarding to punish the wrongdoer, even at a cost to our own utility."/>
                <outline text="Some social emotions are also referred to as moral emotions because of the fundamental role they play in morality.[10] For example, guilt is the discomfort and regret one feels over one&apos;s wrongdoing.[27] It is a social emotion, because it requires the perception that another person is being hurt by this act; and it also has implication in morality, such that the guilty actor, in virtue of feeling distressed and guilty, accepts responsibility for the wrongdoing, which might cause desire to make amends or punish the self.[28]Not all social emotions are moral emotions. Pride, for instance, is a social emotion which involves the perceived admiration of other people, but research on the role it plays in moral behaviors yields problematic results.[10]Empathic responseeditEmpathy is defined by Eisenberg and colleagues as an affective response that stems from the apprehension or comprehension of another&apos;s emotional state or condition and is similar to what the other person is feeling or would be expected to feel.[29] Guilt, which is a social emotion with strong moral implication, is also strongly correlated with empathic responsiveness; whereas shame, an emotion with less moral flavor, is negatively correlated with empathic responsiveness, when controlling for guilt.[28]Perceived controllability also plays an important role modulating people&apos;s socio-emotional reactions and empathic responses.[30] For example, participants who are asked to evaluate other people&apos;s academic performances are more likely to assign punishments when the low performance is interpreted as low-effort, as opposed to low-ability.[31] Stigmas also elicit more empathic response when they are perceived as uncontrollable (i.e., having a biological origin, such as having certain disease), as opposed to controllable (i.e. having a behavioral origin, such as obesity)."/>
              </outline>
            </outline>
            <outline text="Mood" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Background, somewhat long term emotions that affect how we react to/feel about things that happen while we have them."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="We can react to the same thing very differently based on our mood."/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="The vast majority of people experience moods, and their emotions from "/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="It can be changed chemically to be less harmful, and therapy techniques can change their amount or significance in behavior. Practicing reasoning well even in unideal moods would also make it easier to not fall into acting based on the mood."/>
                </outline>
              </outline>
              <outline text="How moods affect reasoning" heading="1" colorLabel="1" collapsed="true">
                <outline text="Even when we become just a little emotional (especially angry/defensive/adrenaline/etc.), our brain places much more emphasis on defending ourselves/attacking the &quot;threat&quot; than we like to think, and this tends to be extremely bad for reasoning." collapsed="true">
                  <outline text="It usually makes it something like 5-25x more difficult to maintain many crucial epistemic habits." collapsed="true">
                    <outline text="Examples of crucial epistemic habits it makes it harder to maintain" colorLabel="6" collapsed="true">
                      <outline text="Consistently considering ways in which your opponent could be right or at least mean something right (via semantics, implications or logic)."/>
                      <outline text="Consistently finding/accounting for nuances in the topic/arguments and thoroughly accounting for how you could be wrong."/>
                      <outline text="Keeping your claims conservative (which tends to cause one to get more defensive which makes the other stuff even more difficult)."/>
                      <outline text="Changing your mind when you&apos;re shown to be wrong."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6"/>
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
              <outline text="Common factors that affect moods" heading="1" colorLabel="1" collapsed="true">
                <outline text="Hunger" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Hunger tends to put us in a worse mood."/>
                  <outline text="Countermeasure" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Don&apos;t make important decisions on an empty stomach."/>
                  </outline>
                </outline>
                <outline text="Stressful Events" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Stress often causes us to be more impatient and get angry easier."/>
                  <outline text="Countermeasure" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Be aware of it, try to reduce it and look at the topic from a broader view if you&apos;re very emotionally affected by a small part of it."/>
                  </outline>
                </outline>
                <outline text="Hormones and Nutritional Deficincies" heading="3" colorLabel="1" collapsed="true">
                  <outline text="People often experience getting into different moods than they otherwise would during period or pregnancy."/>
                  <outline text="Nutritional deficiencies can affect mood and thinking ability."/>
                  <outline text="Countermeasure" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Recognize when a thought comes from irrational feelings."/>
                  </outline>
                </outline>
                <outline text="Mental Health Problems" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Sometimes they cause or are caused by hormone changes."/>
                  <outline text="They can affect mood in incredible amounts."/>
                  <outline text="Countermeasure" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Take it into account and recognize when a thought comes from irrational feelings."/>
                    <outline text="Work on it and reduce its effect."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Mood swings" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Experiencing different moods over a short span of time."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="It is common to have various mood swings, including ones that only last a few seconds, dozen seconds or minutes."/>
                  </outline>
                  <outline text="Impactful" _note="add more maybe" heading="3" collapsed="true">
                    <outline text="It can make it hard to make decisions if you feel differently about the options very quickly."/>
                  </outline>
                </outline>
                <outline text="Causes of mood swings" heading="1" colorLabel="1" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="People not feeling how they &quot;should&quot;" heading="3" colorLabel="1" collapsed="true">
                <outline text="It&apos;s important to recognize that this is not necessarily indicative of how they feel about something long-term, nor indicative of what they think." collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                </outline>
                <outline text="Examples" _note="more examples?" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Laughing at a joke at a funeral"/>
                </outline>
              </outline>
              <outline text="Some Moods" _note="Should we add more to each of them? And change this title?" heading="1" colorLabel="1" collapsed="true">
                <outline text="Happiness" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A sense of well-being, joy or contentment."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Increases &lt;broken link&gt;"/>
                      <outline text="It can cause [optimism](https://dynalist.io/d/E6JAP9Lxs3aSTwRVt4EFKOGS#z=Pmv9cElzghzD7ZVNJPhK1_zR)"/>
                    </outline>
                  </outline>
                  <outline text="Calculating happiness" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Calculatable happiness" heading="2" colorLabel="3" collapsed="true">
                      <outline text="p-s" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Short for pleasure minus suffering, which is here used to mean total pleasant feelings minus unpleasant feelings."/>
                      </outline>
                    </outline>
                    <outline text="Direct" _note="I don&apos;t think there&apos;s anything direct that&apos;s not the indirect ones" heading="3"/>
                    <outline text="Indirect" heading="3" collapsed="true">
                      <outline text="Excitement"/>
                      <outline text="Contentment"/>
                      <outline text="Potential lack of some default emotions" collapsed="true">
                        <outline text="It&apos;s plausible that the activity would replace some default emotions at least partially."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Optimism" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An inclination to put the most favorable construction upon actions and events or to anticipate the best possible outcome"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Increases &lt;broken link&gt;"/>
                      <outline text="It can cause faster decision making and less criticalness."/>
                      <outline text="It could include close mindedness about the probabilities of the bad outcomes."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Urgency" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Decision-making under pressure](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OlKQC8Exx5M6Tn-FOycliz_7)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Depression" heading="2" colorLabel="1" collapsed="true">
                  <outline text="https://en.wikipedia.org/wiki/Depression_(mood)"/>
                </outline>
                <outline text="Disinterest" _note="Need to research this." heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Includes boredom and can come from feeling like it&apos;s not necessary or relevant to one&apos;s life."/>
                  </outline>
                </outline>
                <outline text="Disgust" _note="did you mean to make this not about people since this is not in social emotions?" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A feeling of revulsion or strong disapproval caused by percieving something that feels unpleasant or offensive."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="It often causes close mindedness when it&apos;s about a person or an opinion."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Approaches to deal with emotions" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Approaches one can take to deal with emotions."/>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Not the same as solving the issue or resolving the emotions, some of these approaches are not productive in one or both respects."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Using the wrong approach can have significant consequences on your reasoning." colorLabel="4" collapsed="true">
                    <outline text="&lt;Emotions influence reasoning a lot.&gt;"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Avoiding cause" heading="3" collapsed="true">
                <outline text="[Breaks](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yBxfkWJ99xb9ez9591A-FFWM)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="[Importance of using breaks to deal with emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=DaeivaCfRbFKkg_LhihP7J-0)" _note="Relevance" colorLabel="2"/>
                </outline>
                <outline text="Abandoning the task" heading="3" colorLabel="2" collapsed="true">
                  <outline text="We often consider it best to complete tasks that we abandon." colorLabel="1"/>
                  <outline text="Abandoning finishing reasoning." colorLabel="1" collapsed="true">
                    <outline text="Abandoning finishing reasoning isn&apos;t being thorough." _note="Relevance" colorLabel="4"/>
                    <outline text="^ [It&apos;s very important to be thorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=v06MMtLk-l69FN8yrpApO2BV)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Changing outlook" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Using outlet" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Using an emotional outlet can often allow you to direct your emotions in a more productive / less damaging way." colorLabel="4"/>
                  <outline text="Avoids [repressing](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NOPn06eFCiAI1WnxcQwKHLMl) / [Ignoring](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qcuSSeqHqOV-skymlWBLrXhf) emotions." colorLabel="4" collapsed="true">
                    <outline text="[Importance of repressing emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sd2ctp_zjDxrxRsr8oOB3jLa)" _note="Relevance" colorLabel="4"/>
                    <outline text="[Importance of ignoring emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4CGQCYFNDW5VpkRTZAnuo6e0)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="This can be used as an excuse to do things that end up making things worse." colorLabel="1" collapsed="true">
                    <outline text="Eg. Abusing someone." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="^ If this person could be useful to you in other ways without abuse, that usefulness would likely be reduced." _note="Relevance" colorLabel="4"/>
                      <outline text="Most people are useful in other ways." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Eg. [Gambling emotional well-being](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6c77ObVFS_VibyBoqv9RJRWD)" _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Eg. [Competitive gaming](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=blyfekwSrk9b9iAfnenPq6SG)" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Repressing emotions" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="The emotions tend to come back at inopportune times." colorLabel="1" collapsed="true">
                    <outline text="The emotions tend to come back when a sufficiently similar situation to the one that originally caused them arises." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Because we tend to repress almost only negative emotions, and negative emotions are usually caused by somehow-distressing situations." _note="Likelihood" colorLabel="4"/>
                      <outline text="Negative emotions can often make distressing situations much worse, thus &quot;inopportune times&quot;." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Ignoring emotions" heading="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Often leads to [repressing emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NOPn06eFCiAI1WnxcQwKHLMl)." colorLabel="1"/>
                  <outline text="^ Repressing emotions [leads to a lot of problems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sd2ctp_zjDxrxRsr8oOB3jLa)." _note="Relevance" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Emotional well-being decision-making" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance / Limitations" _note="Consider moving stuff from &quot;gambling emotional well-being&quot; into this." heading="3" colorLabel="2"/>
              <outline text="Hedonic calculus" heading="2" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance / Limitations" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Gambling emotional well-being" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition (distinction)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The process of taking significant risks regarding one&apos;s emotional well-being."/>
                  <outline text="Distinction (important)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="While the negative term &quot;gambling&quot; is purposefully used to encourage being careful, this process is not inherently negative."/>
                    <outline text="Infact, oftentimes it is worthwhile, similar to how &quot;gambling&quot; in the stock market (in a responsible way) can be likely worthwhile in some cases." _note="This is not financial advice."/>
                  </outline>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="A competitive person feeling bad and deciding to play a competitive videogame, in the hopes of winning to feel better." _note="Likely negative example" collapsed="true">
                      <outline text="If they win then they might feel better, but it&apos;s likely that if they lose, they would feel much worse."/>
                      <outline text="It might still be worthwhile if the likelihood of winning is extremely high, the well-being reward is very high, the cost of losing is unintuitively low, etc."/>
                    </outline>
                    <outline text="Asking someone out." collapsed="true">
                      <outline text="If the person accepts, it could increase well-being a lot short-term, and you could end up with a partner that could greatly increase your well-being."/>
                      <outline text="If the person rejects, it could greatly decrease your well-being, particularly if it comes shortly after/before other negative events." _note="Maybe create a section for how emotions &quot;stack&quot; and what to look out for regarding that."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s often worthwhile." colorLabel="4"/>
                  <outline text="It&apos;s often unworthwhile." colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="&lt;broken links&gt;"/>
            </outline>
          </outline>
          <outline text="Environment" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The emotional, cognitive, and social atmosphere within a given setting, particularly how it influences individuals&apos; thoughts, feelings, and behaviors."/>
            </outline>
            <outline text="Overton Window" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The range of subjects and arguments politically acceptable to the mainstream population at a given time."/>
                <outline text="Synonym: Window of discourse"/>
              </outline>
              <outline text="The window can shift, grow or shrink" heading="3"/>
              <outline text="Acceptable vs true, unacceptable vs false" heading="3" collapsed="true">
                <outline text="What is more or less acceptable may be more or less likely to be true for various reasons. What is acceptable is never necessarily true, and what is unacceptable is never necessarily false."/>
              </outline>
            </outline>
            <outline text="In-groups vs out-groups" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="**In-group**: A social group to which a person [psychologically identifies](https://en.wikipedia.org/wiki/Self-categorization_theory) as being a member." collapsed="true">
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Religion"/>
                    <outline text="Political party"/>
                    <outline text="Nation"/>
                    <outline text="Family"/>
                    <outline text="Peer group"/>
                    <outline text="Community"/>
                    <outline text="Gender"/>
                    <outline text="Sexual orientation"/>
                    <outline text="Sports team"/>
                  </outline>
                </outline>
                <outline text="**Out-group**: A social group with which an individual does not identify."/>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/In-group_and_out-group)"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common and impactful" heading="3" collapsed="true">
                  <outline text="People can form [self-preferencing in-groups](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Om1MkJmG6cRVjw3-V29ukcOK) within a matter of minutes." collapsed="true">
                    <outline text="[Can form arbitrarily](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=x5PmnNWs3WONdr25NvwCwSyh)"/>
                  </outline>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[Self-preferencing in-groups](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Om1MkJmG6cRVjw3-V29ukcOK) can form even on the basis of completely arbitrary and invented discriminatory characteristics." collapsed="true">
                    <outline text="Example: preferences for certain paintings." colorLabel="6"/>
                    <outline text="Example: Sports teams" colorLabel="6"/>
                  </outline>
                  <outline text="The intensity of &quot;us vs them&quot; thinking exists along a spectrum from mild to complete dehumanization of the &quot;othered&quot; group." collapsed="true">
                    <outline text="Example: pseudospeciation" colorLabel="6"/>
                  </outline>
                  <outline text="The exact membership of the in-group and out-group are socially contingent (hence vulnerable to the instruments of propaganda)."/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="There is an innate propensity of the human brain to divide the world into us and them valence categories."/>
                </outline>
              </outline>
              <outline text="Groupthink" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A phenomenon where a group of people desire harmony/conformity, which then results in irrational decision-making."/>
                  <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Groupthink)"/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="This can lead the group to minimize conflict and reach a consensus decision without sufficiently critical evaluation."/>
                  </outline>
                  <outline text="Common" heading="3"/>
                </outline>
              </outline>
              <outline text="Group homogeneity" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The concept that categorization of people into social groups increases the perception that group members are similar to one another."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="It can heavily dictate how one thinks." collapsed="true">
                      <outline text="People filter reality through lenses that may interpret the same threats as opposite based on the group, because of this."/>
                      <outline text="It contributes to &lt;broken link&gt;"/>
                    </outline>
                    <outline text="It can be based on very arbitrary things." collapsed="true">
                      <outline text="In-group and out-group may be differentiated very minimally, such as choosing groups by coin flip."/>
                    </outline>
                    <outline text="It may rewrite threat detection to out-group members."/>
                  </outline>
                  <outline text="Common" _note="Look for similar section and link or something probably." heading="3" collapsed="true">
                    <outline text="Religions"/>
                    <outline text="Politics"/>
                    <outline text="Families"/>
                    <outline text="Wars"/>
                  </outline>
                </outline>
                <outline text="Out-group homogeneity" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The perception of members of an out-group as being homogenous, while members of one&apos;s in-group are perceived as being diverse."/>
                    <outline text="Example: &quot;they are alike; we are diverse&quot;." colorLabel="6"/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful " heading="3" collapsed="true">
                      <outline text="This is especially likely to occur in regard to negative characteristics, contributing to &lt;broken link&gt;"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="In-group homogeneity" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The concept of in-group members being perceived as similar to one another in regard to positive characteristics."/>
                  </outline>
                </outline>
                <outline text="Causes" heading="3" colorLabel="1" collapsed="true">
                  <outline text="This was superior for evolution." _note="Support"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="You are who you&apos;re with" _note="Support" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The idea that people tend to subconsciously mimic the beliefs, attitudes and behaviors of those around them to a significant extent."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="This effect means that your reasoning abilities will tend to reflect those of the people around you." colorLabel="4" collapsed="true">
                    <outline text="Since your reasoning behaviors would tend to reflect those around you." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                <outline text="It was evolutionarily advantageous for members of tribes to become more like each other." collapsed="true">
                  <outline text="To become emotionally closer."/>
                  <outline text="To better achieve unified goals."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Surrounding yourself with good people](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O2iKsShjtUBDRY5QCc-9lI4b)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Information bubbles" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="A state of intellectual isolation that can result from [personalized searches](https://en.wikipedia.org/wiki/Personalized_search), recommendation systems, and [algorithmic curation](https://en.wikipedia.org/wiki/Algorithmic_curation)." collapsed="true">
                  <outline text="The search results are based on information about the user, such as their location, past click-behavior, and search history."/>
                  <outline text="Consequently, users become separated from information that disagrees with their viewpoints, effectively isolating them in their own cultural or ideological bubbles, resulting in a limited and customized view of the world."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Filter_bubble)"/>
                <outline text="Synonyms" colorLabel="3" collapsed="true">
                  <outline text="Filter bubble"/>
                  <outline text="Social media bubble"/>
                  <outline text="Ideological frame"/>
                </outline>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="There are conflicting reports about whether such activity is beneficial or harmful." colorLabel="3"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="There are conflicting reports about the extent to which personalized filtering happens." colorLabel="3"/>
                </outline>
              </outline>
              <outline text="How to recognize when you&apos;re in one" heading="3" colorLabel="1"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Ideological frame wikipedia](https://en.wikipedia.org/wiki/Framing_(social_sciences)#Ideological_frame)"/>
              </outline>
            </outline>
            <outline text="Limiting environmental influence on reasoning" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Limiting the extent to which the environment influences our reasoning in ways that it shouldn&apos;t."/>
              </outline>
              <outline text="Methods" heading="1" colorLabel="2" collapsed="true">
                <outline text="Understanding &lt;broken link&gt; better" heading="3" colorLabel="2" collapsed="true">
                  <outline text="The more we understand about how we are influenced by our environment, the more we can do to counteract it."/>
                </outline>
                <outline text="[Managing empathy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=45AmsO2UZbqs8QXcm0eaq8eQ)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
          </outline>
          <outline text="Sociology" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The scientific study of human society, focusing on social life, social change, and the social causes and consequences of human behavior."/>
            </outline>
            <outline text="Vast majority&apos;s reasoning abilities" heading="1" colorLabel="1" collapsed="true">
              <outline text="[Definition of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PN-ghKTcl4UlzOcT7GoE4CIs)" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) abilities or lack thereof are very [impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=srdvqoFzlDXmMdtsZoZfaqcg)" heading="3" colorLabel="4"/>
                  <outline text="[General importance of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iDTLYnvT3mQLwAaXj65fNdY3)" heading="3" colorLabel="4"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="4"/>
                  <outline text="[Most people frequently have bad goals when reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QecR8ehYMs7oFAVLyxLw4EwB)" heading="3" colorLabel="4"/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="Almost everyone can (if they thoroughly follow this guide) realistically get way better at reasoning." heading="3" colorLabel="4" collapsed="true">
                    <outline text="The primary reasons for peoples&apos; irrationality have to do with ignorance of fundamental epistemic ideas and/or bad habits / lack of good habits around applying them." colorLabel="4"/>
                    <outline text="This guide contains the knowledge about fundamental epistemic ideas and teaches how to escape bad habits and learn good ones." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="The vast majority of people are very bad at [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ), including many important types" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The vast majority of people are very bad at &quot;soft&quot; reasoning, including on many important topics."/>
                </outline>
                <outline text="Examples" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Disagree" heading="3" collapsed="true">
                      <outline text="A vast number of people heavily disagree with __you__."/>
                    </outline>
                    <outline text="Not primarily ignorance" heading="3" collapsed="true">
                      <outline text="The vast majority of people would not change their mind about this upon hearing your evidence." collapsed="true">
                        <outline text="Unless they understood **all** your evidence completely (including like tens of thousands of beliefs in other areas that indirectly contribute), but that would be unrealistic."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="How to view this" heading="3" colorLabel="2" collapsed="true">
                    <outline text="The point of this list of examples is to give at least a couple that you agree the vast majority of people are unreasonable about such that the [parent claim](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7SsiX1YEVBoQ7nJN13LxPAbY) is justified." collapsed="true">
                      <outline text="As such, the examples don&apos;t need to be important, they just need to show common disagreements that are often based on irrationality."/>
                    </outline>
                    <outline text="You can disagree with the majority of examples and the claim can still be justified if enough people are shown to be unreasonable in the examples you do agree with."/>
                  </outline>
                  <outline text="Religion / spirituality" heading="3" collapsed="true">
                    <outline text="Disagreement" heading="3" collapsed="true">
                      <outline text="Number of atheists, agnostics, physicalists, etc."/>
                      <outline text="Number of people who are religious/spiritual."/>
                      <outline text="Number of people who have very different perspectives on religion/spirituality from each other."/>
                    </outline>
                    <outline text="Not primarily ignorance" heading="3" collapsed="true">
                      <outline text="Attempts to directly convert/de-convert people to/from a religious positions/denominations based purely on reasoning have a very low success rate."/>
                      <outline text="Techniques which incorporate a kind of emotional manipulation (such as [street epistemology](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=o_wrmnn0YC6kAm7mfGlDdsdR)) are far more effective, indicating that people are often irrational in this area." collapsed="true">
                        <outline text="Some examples of this and its efficacy can be found on [Anthony Magnabosco&apos;s YouTube channel](https://www.youtube.com/channel/UCocP40a_UvRkUAPLD5ezLIQ)." _note="Though keep in mind that he is an atheist physicalist and typically uses SE from that angle."/>
                      </outline>
                    </outline>
                    <outline text="Important" heading="3" collapsed="true">
                      <outline text="One&apos;s religious/spiritual opinions often heavily impact their perspectives on things like the nature/capabilities/dangers of [AI](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=AC2FVOtDwykxzJwtFeWeyidz), the correct positions (or lack of correct positions) on [ethics/axiology](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=WUj1j0Ov-aaX2CZbDxQXrAKy) and specific ethical issues, [psychological beliefs](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=plEkklK0SEl9IlD-DPibunn4) related to ideal parental/educational attitudes (eg. epistemically valuing/rejecting faith due to examples given in holy book(s), or due to a rejection of such holy books), what [political](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=snGJLodh9Kcd0Y4K7s8uV0p_) issues are believed to be more/less important and what positions on those political issues are more reasonable, etc."/>
                    </outline>
                  </outline>
                  <outline text="Politics" heading="3" collapsed="true">
                    <outline text="Disagree" heading="3" collapsed="true">
                      <outline text="Conservatives vs progressives"/>
                      <outline text="Economic left vs right"/>
                      <outline text="Authoritarianism vs libertarianism"/>
                      <outline text="Party disagreements"/>
                      <outline text="&lt;broken link&gt;"/>
                      <outline text="&lt;broken link&gt;"/>
                    </outline>
                    <outline text="Not primarily ignorance" heading="3" collapsed="true">
                      <outline text="Attempts to directly change peoples&apos; political opinions based purely on reasoning have a very low success rate."/>
                    </outline>
                  </outline>
                  <outline text="Philosophy" heading="3" collapsed="true">
                    <outline text="Ethics/axiology" heading="3" collapsed="true">
                      <outline text="Realism vs anti-realism" heading="3" collapsed="true">
                        <outline text="Important (given consequentialism or similar): Whether or not moral/axiological realism or anti-realism is accurate influences how it is best to try to convince people of one&apos;s moral/axiological beliefs. Getting this right is important for most efficiently expanding one&apos;s group of believers, which is important for more effectively accomplishing those moral/axiological ends."/>
                      </outline>
                      <outline text="Consequentialism vs deontology vs virtue ethics, etc." heading="3" collapsed="true">
                        <outline text="Disagree: It&apos;s very common for people to believe in deontology and consequentialism to various extents and in various different domains."/>
                        <outline text="Important (given moral/axiological realism): Which broad moral/axiological framework is correct (if one is correct) has a massive bearing on a ton of important goals/decisions in areas such as [abortion](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=dXAcb_5RVmG1qtZT674whrLt) and [animal rights](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=aTfZw0oQ1jM62EfKQdw6t19m)"/>
                      </outline>
                      <outline text="Ethical/axiological framework variations." heading="3" collapsed="true">
                        <outline text="Disagree: It&apos;s very common for people to have disagreements about the particular variation ."/>
                        <outline text="Important (given moral/axiological realism): Which broad moral/axiological variation is correct (if one is correct) generally has a massive bearing on a lot of  important goals/decisions in areas such as [abortion](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=dXAcb_5RVmG1qtZT674whrLt) and [animal rights](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=aTfZw0oQ1jM62EfKQdw6t19m)"/>
                      </outline>
                      <outline text="Abortion" heading="3" collapsed="true">
                        <outline text="Disagree: Both pro-life and pro-choice positions have a significant number of supporters."/>
                        <outline text="Important: Depending on one&apos;s ethical framework, it can be seen (especially from a deontological perspective) as a kind of crazy mass genocide of completely innocent people which is often considered acceptable and even good. And it can also be viewed (especially from a consequentialist perspective) as a very important feature of freedom/health/happiness, because eg. parents who don&apos;t want the child(ren) would likely not treat the child(ren) as well and would likely go through a significant amount of suffering and restriction, and there are eg. situations where the mother will likely not survive the birth and the child may not either."/>
                      </outline>
                      <outline text="Animal rights" heading="3" collapsed="true">
                        <outline text="Disagree: There are a significant amount of people who are eg. vegetarian/vegan for ethical reasons, and a much more significant amount of people who are not."/>
                        <outline text="Important: Depending on one&apos;s ethical and psychology perspectives, the mass killing of animals can be viewed as a kind of crazy torturous genocide of innocent creatures. Or it can be viewed as something akin to chopping trees, just the efficient harvesting of resources which has no consciousness/free will/important feelings. Or it can be viewed as something in-between, like treatment that&apos;s somewhat too horrible but not of great importance due to eg. some psychological difference between other animals and humans."/>
                      </outline>
                    </outline>
                    <outline text="Free will" heading="3" collapsed="true">
                      <outline text="Disagree" heading="3" collapsed="true">
                        <outline text="Number of people who believe/disbelieve in free will."/>
                        <outline text="Number of people who believe in compatibilism vs incompatibilism."/>
                        <outline text="Number of people who believe/disbelieve in genuine randomness."/>
                      </outline>
                      <outline text="Important" heading="3" collapsed="true">
                        <outline text="Punitive vs rehabilitative parenting, prison system, etc., because free will is often considered to create moral responsibility."/>
                        <outline text="Can impact peoples&apos; perspectives on [consciousness](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=dckKGIczk90mYQxxh4PIV7Wp)"/>
                        <outline text="Can impact peoples&apos; perspectives on [psychology](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=plEkklK0SEl9IlD-DPibunn4) - Eg. If we have free will, one could conclude that a substantial amount of our important decision-making cannot be understood, meaning some aspects of psychology, neurology, decision theory, etc. would be much less important than they otherwise would be."/>
                      </outline>
                    </outline>
                    <outline text="Consciousness" heading="3" collapsed="true">
                      <outline text="Disagree" heading="3" collapsed="true">
                        <outline text="Number of people who believe that consciousness is entirely emergent vs something fundamental."/>
                      </outline>
                      <outline text="Important" heading="3" collapsed="true">
                        <outline text="Impacts peoples&apos; perspectives on things like:"/>
                        <outline text="[Religion/spirituality](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=1pCSj98PbE-S3TR4myUGW40g) - Eg. If it seems that consciousness can/cannot be explained within a physicalist framework, one may consider spirituality/religion to be less/more likely."/>
                        <outline text="[AI](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=AC2FVOtDwykxzJwtFeWeyidz) - Eg. If consciousness is necessarily non-physical and it would be necessary for AGI, then AGI could be considered impossible."/>
                        <outline text="[Free will](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=sXLnfVWldTRqCaP5AG8GRWQJ) - Eg. If consciousness is physical, one could conclude that we likely don&apos;t have free will."/>
                        <outline text="[Abortion](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=dXAcb_5RVmG1qtZT674whrLt) - Eg. If fetuses (at least prior to some point in development) are not conscious, then it could be considered that abortion is not problematic in that case but would be problematic in other cases."/>
                        <outline text="[Animal rights](https://dynalist.io/d/IXRq6OrW0nJs9OGU9TMI5_41#z=aTfZw0oQ1jM62EfKQdw6t19m) - Eg. If other animals are not considered conscious, we could consider virtually any behavior towards them to be completely fine. If they are conscious, that could cause us to think it&apos;s more important to reduce harm to them."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Psychology" heading="3" collapsed="true">
                    <outline text="The cognitive abilities of children / the importance of life experience" heading="3" collapsed="true">
                      <outline text="Important" heading="3" collapsed="true">
                        <outline text="Placing less or greater weight on life experience than is accurate likely means overestimating or underestimating abilities based on the amount of life experience, leading to inaccurate decisions about how seriously one should treat peoples&apos; opinions based on their life experience, and how people should ideally be educated."/>
                        <outline text="Placing less or greater weight on the feasible abilities/knowledge of children means potentially substantially overestimating or underestimating their abilities, which would likely lead to many important mistakes in many different areas (such as again how seriously to take their opinions and how to ideally educate them)."/>
                      </outline>
                      <outline text="Disagree - There are a significant amount of people who believe that life experience is extremely important, and a good amount of people who believe otherwise."/>
                    </outline>
                    <outline text="The efficacy/side effects of punishments and/or rewards" heading="3" collapsed="true">
                      <outline text="Disagree - There are many people who believe that eg. being even a little soft with kids will cause them to become somewhat spoiled. And there are a decent number of others who believe that it&apos;s important to be quite soft with kids. Likewise there is different on whether extrinsic motivation reduces intrinsic motivation or not."/>
                      <outline text="Important - Eg. The extent to which extrinsic motivation lowers  intrinsic motivation has a massive bearing on the ideal design for tons of important institutions and systems. For example it may make more sense to treat children more like animals to be trained much more with rewards and punishments, or it might make sense to use rewards and punishments much less and instead let the children be much more free."/>
                    </outline>
                    <outline text="Sexes/races/genes having significant differences in cognitive features/abilities" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Important - Eg. If the stereotype of females being caretakers and males being providers has a significant foundation in genetics, it may make more sense to organize society more in terms of that. Likewise if that stereotype is largely cultural, it may make more sense to organize society less in terms of that."/>
                    </outline>
                    <outline text="Ultimate motivation" heading="3" collapsed="true">
                      <outline text="Disagree - Eg. There are a good number of people who believe and disbelieve in psychological egoism, the position that everyone is ultimately motivated by objectives pertaining to the betterment of one&apos;s own situation/feelings/etc. without any intrinsic motivation coming from eg. helping others."/>
                      <outline text="Important - Our ultimate motivation(s) has a significant bearing on what to believe about how to better improve people, prevent corruption, understand how people work, etc."/>
                    </outline>
                    <outline text="LGBTQ+" heading="3" collapsed="true">
                      <outline text="Disagree - There are a large number of people who believe/disbelieve that lgbtq+ is (almost) always caused by other psychological issues."/>
                      <outline text="Important - The nature of LGBTQ+ and causes of it has a significant bearing on the ideal course of action/perspective towards it. Eg. If it causes significant issues (like going against what God intended), it may be best to take action to prevent such cases or try to get people to accept their intended state of being. But if it&apos;s often the healthier option, it may be best to instead encourage and support it to a significant extent."/>
                    </outline>
                  </outline>
                  <outline text="Misc social issues" heading="3" collapsed="true">
                    <outline text="AI" heading="3" collapsed="true">
                      <outline text="The consequences of AI content" heading="3"/>
                      <outline text="When will AGI/ASI arrive?" heading="3" collapsed="true">
                        <outline text="Disagree" heading="3" collapsed="true">
                          <outline text="Large groups of people have very significant disagreements on how long it will be. Many think it will never come because we are near the limit of feasible reasoning abilities, or that technology cannot replicate free will/consciousness. Many others think that it will be very soon, maybe even in just a few years due to the potential for exponential growth once it becomes intelligent enough to increase its own intelligence by significant margins."/>
                        </outline>
                        <outline text="Important" heading="3" collapsed="true">
                          <outline text="This can have a significant impact on what it makes sense to focus on:"/>
                          <outline text="Quicker timelines mean much greater importance for addressing AI safety concerns sooner."/>
                          <outline text="Quicker timelines mean less likely for the bubble to pop and more likely for it to make sense to eg. invest in AI."/>
                        </outline>
                      </outline>
                      <outline text="How likely is AGI/ASI to lead to doom?" heading="3" collapsed="true">
                        <outline text="How intrinsically hard is AI alignment?" heading="3" collapsed="true">
                          <outline text="Disagree - A lot of people believe that the set of goals compatible with eg. Human flourishing is very small compared to the number of goals that would lead the AI to &quot;want&quot; to wipe us out. A lot of others believe that as intelligence increases, things like empathy and moral accuracy will also increase."/>
                        </outline>
                        <outline text="Will we get another chance if we build a bad one the first time?" heading="3" collapsed="true">
                          <outline text="Disagree - People often believe that we will not get another chance if we make a mistake, because we could go extinct or similar.  Many others believe that we would be able to overpower the AI and try again."/>
                        </outline>
                        <outline text="What are international race dynamics likely to look like?" heading="3" collapsed="true">
                          <outline text="When leaders recognize just how powerful AI is likely to become in a short timespan, how much are they going to race vs work together to prevent it from developing too fast?"/>
                          <outline text="Disagree - A lot of people believe that a race is likely to emerge in which the world will not be able to properly regulate AI progress, leading to a kind of prisoner&apos;s dilemma where everyone develops AI unsafely in order to develop it in a way that is more likely to benefit themselves if they&apos;re lucky enough to develop it safely enough. Others believe that we will handle AI in a similar way to how we handled nuclear weapons, which is to say not perfectly but well enough that progress won&apos;t go too quickly such that it gets out of control."/>
                        </outline>
                        <outline text="What are the chances that an attempt is made to align one or more of the smarter AIs with bad goals?" heading="3" collapsed="true">
                          <outline text="Disagree - Many people believe that the people who will ultimately decide how these AIs are trained/set up will try to get these AIs to accept goals that most people would consider bad, but which align with their own personal interests. For example maximizing profits, maximizing safety of a country (to the point where annihiliating other countries is a likely outcome), etc. Others believe that this is unrealistic, either because alignment (even with bad goals) would not be plausible, or because of other reasons."/>
                        </outline>
                        <outline text="Important" heading="3" collapsed="true">
                          <outline text="These factors heavily influence how much we as a society should focus on AI safety. Delaying AI development could mean sentencing billions of humans to a significant amount of unnecessary harm, but speeding it up could mean doom and losing the opportunity to try again permanently."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Climate change" heading="3" collapsed="true">
                      <outline text="Disagree - People frequently disagree on the importance of dealing with climate change, and the ideal approach to it."/>
                      <outline text="Importance - If climate change is more significant, we likely want to spend significantly more resources on fighting it. If it is less significant, we likely want to spend less resources on it. If a certain approach is more effective, we likely want policies that are likely to support that approach."/>
                    </outline>
                  </outline>
                  <outline text="^ Not primarily ignorance" heading="3" collapsed="true">
                    <outline text="It is difficult to provide reasoning for this, but I urge you to find people who disagree on one or multiple of these topics (particularly the more controversial ones), and try to change their minds by giving them the knowledge that you believe they are lacking."/>
                    <outline text="If it is primarily a matter of ignorance, you should be able to convince the majority of people you try to convince. If the majority remain unconvinced and can&apos;t seem to give good counteraguments (especially if they start giving fallacious counterarguments or repeating points that you already addressed), that should be a good indication to you that it isn&apos;t primarily a matter of ignorance, but of cognitive biases and lacking reasoning abilities."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Using the wrong short-cuts can often be disasterous for one&apos;s reasoning on a topic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GDRPLIXI8Ge7vkMWNwlu6rzA)" heading="3"/>
                    <outline text="[It&apos;s common to use the wrong short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zWVET9lI3lrkE-bnS83VGFAo)" heading="3"/>
                  </outline>
                  <outline text="[We are bad at informal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hUZD_olPKQWAyhG7iNc0esm1)" heading="3" colorLabel="4"/>
                  <outline text="[Common high close mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KOanWToGIO130HiP_e_UnNTX)" heading="3" colorLabel="4"/>
                  <outline text="[Common high uncriticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=JHbdNsXrIosokMWp2eR7Tqtp)" heading="3" colorLabel="4"/>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Reasoning vs similar things](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IaJGr2lc0A403q27gdXVdcVO)" colorLabel="2"/>
                  </outline>
                </outline>
              </outline>
              <outline text="The vast majority of people are very bad at reasoning about topics which they have strong convictions about." heading="3" colorLabel="1" collapsed="true">
                <outline text="Conviction" colorLabel="3" collapsed="true">
                  <outline text="Convictions—unlike more typical beliefs—are accompanied by emotional commitment and ego preoccupation."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Attitudes rooted in moral mandates tend to become convictions. ([Source](https://scholar.google.com/scholar_lookup?journal=Journal%20of%20Personality%20and%20Social%20Psychology&amp;title=Moral%20conviction:%20Another%20contributor%20to%20attitude%20strength%20or%20something%20more?&amp;author=Linda%20J.%20Skitka&amp;author=Christopher%20W.%20Bauman&amp;author=Edward%20G.%20Sargis&amp;volume=88&amp;publication_year=2005&amp;pages=895-917&amp;pmid=15982112&amp;doi=10.1037/0022-3514.88.6.895&amp;#d=gs_qabs&amp;t=1773413447650&amp;u=%23p%3DhDL4X1UwzXQJ))"/>
                    <outline text="Tedtable vs distal beliefs" heading="3" collapsed="true">
                      <outline text="In further writings on the idea that some beliefs can become convictions, [Abelson](https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#B1-jintelligence-11-00027) ([1986](https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#B1-jintelligence-11-00027); [Abelson and Prentice 1989](https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#B3-jintelligence-11-00027)) makes the distinction between what he calls testable beliefs and distal beliefs. Testable beliefs are closely tied to the real world and the words we use to describe that world (e.g., roses are red). They can be verified by observations—sometimes easily made personal observations but other times requiring reliance on the expertise of others and the more sophisticated methods of science. In contrast, distal beliefs cannot be directly verified by experience, nor can they be easily confirmed by turning to experts or scientific consensus. For example, you may think that pharmaceutical companies make excessive profits, or that your state should spend more on mental health and less on green initiatives. Certainly, economic statistics and public policy facts might condition distal beliefs such as these (either strengthening or weakening our attachment to them) but they cannot verify our distal beliefs in the same manner that they can verify testable ones. Many distal beliefs embody our values. When they do, they are apt to become convictions, because they will lead to emotional commitment and ego preoccupation, as argued by [Abelson](https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#B2-jintelligence-11-00027) ([1988](https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#B2-jintelligence-11-00027)). Distal beliefs often derive from a person’s general worldview or, in politics, from their ideology."/>
                    </outline>
                    <outline text="Intuitive example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Imagine you were on another planet (Zircan), otherwise exactly like Earth, and heard from someone that on planet Zircan roses were never red and were always brown. You would have no trouble acquiring that belief. You would feel no urge to argue with anyone that roses can be red. On planet Zircan, they simply are not, and you would have no trouble giving up your belief that roses can be red. On the other hand, if you were to hear that on planet Zircan it was believed that left-handed people were morally inferior to right-handed people, you likely would not accept that belief and in fact would try to argue against it. You would instead defend your belief that the moral worth of human beings does not depend on whether they are left-handed or right-handed. That belief is a conviction for you in a way that the belief that roses can be red is not."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="The closer beliefs are to convictions, the more poorly calibrated people are—almost always believing that they can provide good arguments for their convictions when in fact they can not. ([Source](https://pmc.ncbi.nlm.nih.gov/articles/PMC3735824/))" _note="Organize"/>
                <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                  <outline text="This section was essentially entirely taken from https://pmc.ncbi.nlm.nih.gov/articles/PMC9966223/#sec7-jintelligence-11-00027"/>
                </outline>
              </outline>
            </outline>
            <outline text="Gender/Sex" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Gender" heading="3"/>
                <outline text="Sex" heading="3"/>
              </outline>
              <outline text="Epistemic gender convergence" _note="~~Expert" heading="3" colorLabel="1" collapsed="true">
                <outline text="In general when people become sufficiently reasonable (though it is rare), their habits tend to converge towards an epistemic ideal that involves most of the positive characteristics of all genders and few of the negative characteristics, which tends to make people less like their gender (assuming they have one)."/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Societal counterfactual thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bWk8PNvCQfAbrIjBHU47Pza5)" colorLabel="1"/>
              <outline text="&lt;broken links&gt;"/>
            </outline>
          </outline>
          <outline text="Self-awareness" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="(Amount of) awareness of one&apos;s own self."/>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="Most people struggle with being epistemically self-aware." colorLabel="4" collapsed="true">
                  <outline text="We often like to think of ourselves as epistemically immutable in the face of emotional turmoil, but this is often very much not the case even when we feel confident about it." collapsed="true">
                    <outline text="Sometimes because we assume that our reasoning habits/processes aren&apos;t substantially influenced by emotions." collapsed="true">
                      <outline text="Eg. Sometimes it&apos;s believed that unless our emotions are really significantly and obviously effecting us, they aren&apos;t substantially effecting our reasoning." colorLabel="6"/>
                      <outline text="&lt;broken link&gt;" colorLabel="1"/>
                    </outline>
                    <outline text="Sometimes because we&apos;re not really aware of our own emotional state most of the time."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="With insufficient self-awareness, it becomes significantly harder to realize when we are making mistakes, what kind of mistakes we are making, and subsequently how to improve." colorLabel="4"/>
              </outline>
              <outline text="Difficult" heading="3" collapsed="true">
                <outline text="People tend not to be very good at self-awareness." colorLabel="4"/>
                <outline text="[Bias blind spot](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qYKn9LjoeqFhKAwabwW925I7)" heading="3" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
              <outline text="A set of spectrums" heading="3" collapsed="true">
                <outline text="One can be largely self-aware about emotions but largely not self-aware about reasoning."/>
                <outline text="One can be largely self-aware about some aspects of their reasoning but largely not self-aware about others."/>
              </outline>
            </outline>
            <outline text="Strategies for improving self-awareness" heading="3" colorLabel="2">
              <outline text="Removing shame" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Shame tends to make us close up/shut down, which makes it much more difficult to engage in useful introspection."/>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Defensive/reactionary tendencies are very hard to completely avoid, so pretty much everyone has at least some."/>
                  </outline>
                </outline>
                <outline text="Strategies" heading="1" colorLabel="2"/>
              </outline>
              <outline text="Meta-awareness" heading="3" colorLabel="1">
                <outline text="Definition" heading="3" colorLabel="3">
                  <outline text="The [ability to probe]/[act of probing] yourself to become more aware of the things you&apos;re doing and why."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This allows you to become more conscious of yourself, which is useful for:"/>
                  <outline text="^ Better refining your &lt;broken link&gt;"/>
                  <outline text="^ Recognizing (and thus having a better chance of counteracting) your &lt;broken link&gt; and how it is affecting your reasoning."/>
                  <outline text="^ Acting more intentionally and overriding automatic behaviors in the moment when it seems best to."/>
                </outline>
                <outline text="Defensiveness" heading="3" colorLabel="2">
                  <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GngLFJktj5LSrbeQNe0s1YoN"/>
                </outline>
                <outline text="Related   (read)" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Introspection](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=aqX299sRiWRL4uS29eOaKCGW)" heading="1" colorLabel="1" collapsed="true">
                    <outline text="The primary tool to use to improve meta-awareness." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Introspection" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Questions to ask" heading="3" colorLabel="2" collapsed="true">
                  <outline text="[Epistemic questions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W17mij9t81Sv6LWJqdqjiejH)" heading="3"/>
                  <outline text="[Emotional questions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MjFRIxEgOyepp8XQAUt1d7sO)" heading="3"/>
                  <outline text="[Conscious questions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MfB8W5T3g7oPQgrmIX1NzJ-Z)" heading="3"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="Learning &lt;broken link&gt;" heading="3" colorLabel="1" collapsed="true">
                  <outline text="This includes learning about others, as this can help you get a better grasp of human psychology in general which can help you understand yourself better."/>
                </outline>
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
                <outline text="[Presumptuous reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N4Vxzc2HQu1bOoAN_oiOn0sm)" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Different types of self-awareness" heading="3" colorLabel="1" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="It&apos;s useful to be able to distinguish between different types of self-awareness." colorLabel="4" collapsed="true">
                    <outline text="Otherwise it&apos;s easy mistakenly assume that self-awareness (or a lack of self-awareness) in some area(s) substantially indicates (a lack of) self-awareness in other(s) when it doesn&apos;t." colorLabel="4"/>
                    <outline text="They do different things." colorLabel="4" collapsed="true">
                      <outline text="&lt;broken link&gt;"/>
                    </outline>
                  </outline>
                  <outline text="It&apos;s useful to recognize what different types of self-awareness do." colorLabel="4"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Different types of self-awareness exist for everyone." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Epistemic self-awareness" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Self-awareness of one&apos;s own epistemic processes."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Difficult" heading="3" collapsed="true">
                    <outline text="It&apos;s easy to be self-aware" heading="3" colorLabel="1" collapsed="true">
                      <outline text="One can be self-aware about some of their epistemic processes while not being self-aware about others." colorLabel="1"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Questions to ask" heading="1" colorLabel="2"/>
                <outline text="Conscious self-awareness" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Self-awareness about conscious thoughts."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Epistemic processes typically involve conscious reasoning."/>
                  </outline>
                  <outline text="Questions to ask" heading="1" colorLabel="2" collapsed="true">
                    <outline text="What&apos;s a way I could be mistaken that I haven&apos;t considered yet?"/>
                    <outline text="Am I using a fundamentally flawed technique/approach?"/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Epistemic processes are typically influenced by emotions." _note="Link(s)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Emotional self-awareness" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Self-awareness of one&apos;s own emotions and their immediate psychological effects."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="&lt;broken link&gt;" colorLabel="4"/>
                </outline>
                <outline text="Questions to ask" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Valuing" heading="3" collapsed="true">
                    <outline text="Why do I emotionally value this?"/>
                  </outline>
                  <outline text="Action" heading="3" collapsed="true">
                    <outline text="Why do I emotionally want to do this?"/>
                  </outline>
                  <outline text="Misc" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Why do I feel this way?"/>
                    <outline text="Do I have good reason to trust/distrust my emotions in this scenario?"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Recognizing your redundant arguments" _note="Might be better under informal reasoning or smth" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Recognizing when you&apos;re making an argument that someone has already addressed."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="It&apos;s very commonf or people to make such repeititous arguments."/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="If you can consistently recognize this, then you can better improve your [habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mwz5Ve2BffIKD_YiMRN4SJOU) for recognizing when other people have addressed your arguments and be more [systematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7) in your responses."/>
                  <outline text="^ This makes your reasoning more efficient and increases the probability that you will change your mind when it is reasonable to."/>
                </outline>
                <outline text="Difficulty" heading="3" collapsed="true">
                  <outline text="Most people are bad at recognizing this."/>
                </outline>
              </outline>
              <outline text="Strategies" heading="3" colorLabel="2" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="2" colorLabel="2"/>
                <outline text="[Other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Coping with low self-awareness" colorLabel="2" collapsed="true">
              <outline text="[Cooperative reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tIkQysDqkCY4YvrwV_mIfQ_d)" heading="3" colorLabel="2" collapsed="true">
                <outline text="If you can become sufficiently [Open-mindeded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=z7LAOrlY0wVUk3aV25kvfWZe) then you can [piggyback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=F6oszHuNAfhf9o8bwqy0goGm) on the criticalness of others."/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)" heading="3" colorLabel="2"/>
              <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Misc" _note="Create new categories to replace this" heading="1" colorLabel="6" collapsed="true">
            <outline text="Impulsivity" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                <outline text="Our intuition tends to not place nearly enough weight on logic and systematic reasoning."/>
                <outline text="We tend to trust intuition far too much in areas where it has not been adequately trained."/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[System 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Criticalness" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="&lt;broken link&gt; is extremely important to understand."/>
                  <outline text="Uncriticalness of a substantially detrimental degree is very common."/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="&lt;broken link&gt;"/>
                </outline>
              </outline>
              <outline text="Critical piggybacking" _note="Very likely move to practical techniques" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Using the criticalness of others to catch the mistakes you make that are primarily caused by your lack of criticalness."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Due to [how](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hrEJMvz4-YIh1F6g7q3K1fPP) open mindedness is more important than criticalness for critical piggybacking, this typically makes open mindedness more important overall."/>
                  </outline>
                </outline>
                <outline text="Requirements" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Pretty open minded" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="You must be sufficiently open minded to give the critical thoughts of others enough serious consideration for this process to be very effective. " collapsed="true">
                        <outline text="Serious consideration" _note="Probably move elsewhere and link here." heading="3" colorLabel="3" collapsed="true">
                          <outline text="Consideration about how the idea could be correct."/>
                          <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Not consideration about how the idea &quot;is&quot; incorrect." collapsed="true">
                              <outline text="Very important to avoid [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)"/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="This is much more rare and more important than having &lt;broken link&gt;" _note="Provide reasoning here or link something"/>
                    </outline>
                  </outline>
                  <outline text="Decent criticalness" heading="3" collapsed="true">
                    <outline text="You typically need to be decently critical to properly understand the critical thoughts of others and properly piggyback off of them consistently."/>
                  </outline>
                  <outline text="A sufficiently critical community" heading="3" collapsed="true">
                    <outline text="A community where your ideas will (ideally) be challenged by lots of people with lots of different views, and some people are very consistently able to find whatever problems there might be in your reasoning."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Criticalness helps open-mindedness" heading="3" colorLabel="2" collapsed="true">
                <outline text="The degree to which one can change their mind when their current beliefs have been challenged is mostly dependent on their ability to consistently understand when their beliefs have been adequately challenged. So becoming more critical can make one more open-minded."/>
              </outline>
              <outline text="Agreeableness" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3"/>
                  <outline text="Improvable" heading="3"/>
                </outline>
                <outline text="Conflict avoidance" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3"/>
                    <outline text="Improvable" heading="3"/>
                  </outline>
                  <outline text="Pros / Cons" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Avoiding conflicts often makes others less defensive and more open minded." colorLabel="4"/>
                    <outline text="Avoiding conflict often entails leaving dubious claims uncontested and unquestioned." colorLabel="1" collapsed="true">
                      <outline text="This prevents you from learning their reasoning."/>
                      <outline text="This makes it easier to blindly accept dubious claims."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                <outline text="[How to measure](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IBGJau5KaVc-QdSibLKAw_4g)" heading="3"/>
              </outline>
            </outline>
            <outline text="Evolved reasoning" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition (broad)" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="The human brain evolved to reason badly" heading="1" colorLabel="1" collapsed="true">
                <outline text="Evolution is typically a very slow process, often taking millions of years to make significant changes to a species. As such, the human brain evolved for human life hundreds of thousands of years in the past, which is extremely different from the modern life. "/>
                <outline text="The ideal intellectual process is actually not very complex. It really just involves a consistent and efficient application of inductive and deductive reasoning using the axioms* listed before, with decent memory and compute. However for our hunter-gather ancestors, this was not ideal. It requires more energy to calculate deeply with ideal nuance, so evolution supported a route that involves a lot of short-cuts." collapsed="true">
                  <outline text="* [Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)"/>
                </outline>
                <outline text="Evolutionarily-advantageous but epistemically-unideal reasoning short cuts" heading="3" collapsed="true">
                  <outline text="Evolved subconscious/unconscious" collapsed="true">
                    <outline text="One such intellectual short-cut mechanism is our subconscious/unconscious (hereafter simply referred to as &quot;subconscious&quot;) processes." collapsed="true">
                      <outline text="&lt;broken link&gt;" heading="3" colorLabel="2"/>
                    </outline>
                  </outline>
                  <outline text="Evolved overconfidence" collapsed="true">
                    <outline text="Evolutionarily, our brain was wired such that confidence is very effective at giving us self-esteem and motivation (good for survival) and seeming capable (good for attracting mates). As such, we are in general somewhat overconfident about most things."/>
                  </outline>
                </outline>
              </outline>
              <outline text="&lt;broken link&gt;" heading="1" colorLabel="1" collapsed="true">
                <outline text="Inside each one shoudl be an evolutionary explanation."/>
              </outline>
              <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
            </outline>
            <outline text="Confidence" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition (colloquial)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Can refer to either something like [self-esteem](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5mmCXq5NdWjuCdTW4wQgRgGE) or [epistemic self-confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Y9tqRoYVuJ-Fx4nqtdo3klx9) depending on the context."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Importance of self-esteem](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=38ZfXtPNz6byb0jZrs8fXKLs)" heading="3" colorLabel="2"/>
                <outline text="[Importance of epistemic confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fVrH6jUvQXVp345JG-AHLchD)" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Self-esteem" _note="Likely move to emotions and just link here or something." heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A person&apos;s overall emotional evaluation of their own worth."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Increases &lt;broken link&gt;" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Higher self-esteem can substantially increase our motivation to do things." collapsed="true">
                        <outline text="Things including learning to reason better."/>
                      </outline>
                    </outline>
                    <outline text="&lt;broken link&gt;" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Higher/lower self-esteem implies lower/higher insecurity."/>
                    </outline>
                    <outline text="Increases &lt;broken link&gt;" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Insecurity encourages people to be more fake to be more accepted and protect themselves."/>
                    </outline>
                    <outline text="Increases &lt;broken link&gt;" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Higher emotional estimation of one&apos;s own worth tends to lead to more trust in their own judgement, which (on its own) tends to result in a net negative to reasoning abilties due to how great our default overconfidence is."/>
                    </outline>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Has a substantial effect on virtually everyone." colorLabel="4"/>
                    <outline text="The primary mechanisms underlying this for most people seem to often (or always) be absent from [psychopaths](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=D7Ey-XN074IGrKd4ydeqHorH)." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Insecure irrationality" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Insecurity-caused irrationality or irrational behaviors."/>
                  </outline>
                  <outline text="Overcompensation" heading="2" colorLabel="1" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A defense mechanism where individuals unconsciously exaggerate certain traits or behaviors to cover perceived weaknesses, inadequacies, or insecurities to protect their self-esteem."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Because &lt;broken link&gt; often substantially contributes to irrationality." colorLabel="4" collapsed="true">
                          <outline text="Acting overly confident often involves genuinely taking a lot of &lt;broken link&gt;" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Forms / features" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Broad" heading="3" collapsed="true">
                        <outline text="Acting overly confident"/>
                        <outline text="Boasting about achievements"/>
                        <outline text="Seeking constant external validation"/>
                      </outline>
                      <outline text="Specific" heading="3" collapsed="true">
                        <outline text="Dominating discussions through volume/duration of speaking rather than substance"/>
                        <outline text="Engaging in petty competitiveness"/>
                        <outline text="Apologizing excessively"/>
                        <outline text="Avoiding emotional intimacy"/>
                      </outline>
                    </outline>
                    <outline text="Reducible?" _note="I forget why I added this." heading="3" colorLabel="5"/>
                  </outline>
                  <outline text="Self-hate" heading="3" colorLabel="1"/>
                </outline>
                <outline text="Evolutionary purpose" heading="3" colorLabel="1" collapsed="true">
                  <outline text="A nonconscious and preattentative internal gauge (a kind of &quot;sociometer&quot;) that continuously measures your relational value (and recent changes to it). Whenever the sociometer needle drops, it triggers an alarm and changes our behavior."/>
                  <outline text="Why do people frequently deny this (both to themselves and others)?" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Because appearing concerned about other people&apos;s opinions makes us look weak, and we do a terrifick job of unknowingly tricking ourselves in order to better trick others." _note="Link/create a section on tricking ourselves to better trick others and/or similar concept(s)."/>
                  </outline>
                  <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Leary&apos;s sociometer theory and experiment on self-proclaimed mavericks (people supposedly unaffected by the opinions of others)."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6">
                <outline text="[Acting confident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=JpYALVtKecAzCAMA6D5-FMiZ)" heading="3" colorLabel="1"/>
                <outline text="[Credence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=udaRfJbExQFcuWIonQ7Ij8VV)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="People often call credence &quot;confidence&quot;. This is the sort of confidence that describes &quot;confidence in&quot; a particular proposition being true or a particular event occurring, rather than propositions/events in general like in [epistemic self-confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Y9tqRoYVuJ-Fx4nqtdo3klx9)."/>
                </outline>
                <outline text="[Epistemic self-confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Y9tqRoYVuJ-Fx4nqtdo3klx9)" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Humility" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="https://en.wikipedia.org/wiki/Humility"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Intellectual humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gh0FW_-AcyLbpnuFvEWm45Ke)" heading="3" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Motivation" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Motivation has a substantial effect on the amount of effort one can put into things." collapsed="true">
                    <outline text="More effort towards being reasonable allows us to be much more reasonable." collapsed="true">
                      <outline text="[Time usage in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ix4g1EoGh3HsteZTJwCBMY8E)" colorLabel="4"/>
                    </outline>
                    <outline text="More effort towards things in general is very generally useful."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Intrinsic vs extrinsic motivation" heading="2" colorLabel="1" collapsed="true">
                <outline text="Intrinsic motivation" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Typically reduced by https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AkQY7wIZu6cEgqpKfnI80rKX ([main section](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uhfcF8yRc8rHq14-ED5y_ORx))" heading="3" colorLabel="1"/>
                </outline>
                <outline text="Extrinsic motivation" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Tends to reduce intrinsic motivation." collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="When there are extrinsic motivators pushing us to do something, we typically become less intrinsically motivated to do that thing."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="&lt;broken link&gt;" heading="2" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Motivation ≠ ability" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Motivation doesn&apos;t equal or necessarily substantially imply ability."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s possible (and common) for one to be very motivated to do something but completely incapable of doing it (at least in the short-term)." collapsed="true">
                    <outline text="This is especially pertinent for reasoning, where people are often very motivated to reason well or perform practices that are very important for reasoning well, but have absolutely no idea how to do them or that they&apos;re not doing them well."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Ultimate motivation" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Psychological hedonism" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                <outline text="[Goals of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDRmT592xGeslYb-hvYp2ujH)" heading="3" colorLabel="2"/>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                <outline text="[Decision-making under pressure](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OlKQC8Exx5M6Tn-FOycliz_7)" heading="3" colorLabel="1"/>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Scrutiny-driven reasonableness" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The idea that when we will have to explain our decisions to people later on, we become more [critical](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HFlajn-7ApUXftkQMGXZHVWq) and/or [open-minded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=z7LAOrlY0wVUk3aV25kvfWZe)."/>
              </outline>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="When all &lt;broken link&gt; are met, such need for explanation can increase reasoning by a lot, by making people more [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7) and thorough." colorLabel="4"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="In almost all cases (because the &lt;broken link&gt; are not met), this mostly only increases [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Common requirements" heading="3" colorLabel="1" collapsed="true">
                <outline text="Decision makers learn before forming any opinion that they will be accountable to an audience."/>
                <outline text="The audience&apos;s views are unknown."/>
                <outline text="They believe the audience is well informed and interested in accuracy."/>
                <outline text="Why?" colorLabel="1" collapsed="true">
                  <outline text="We evolved to act in ways that can be persuasively justified or excused to others, not to expend so much energy reasoning well unless absolutely necessary. We do this subconsciously, also trying to persuade ourselves." _note="Create/link to section in &lt;broken link&gt;"/>
                </outline>
              </outline>
              <outline text="Exploratory thought" heading="3" colorLabel="1" collapsed="true">
                <outline text="An evenhanded consideration of alternative points of view." colorLabel="3"/>
              </outline>
              <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                <outline text="&quot;The Righteous Mind&quot; by Jonathan Haidt - Chapter: We are all intuitive politicians."/>
              </outline>
            </outline>
            <outline text="Mental stamina" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The general energy we have for cognitive tasks." collapsed="true">
                  <outline text="Energy: The typical length/intensity we are able to think* for (per session) before getting exhausted." collapsed="true">
                    <outline text="Why &quot;session&quot;: We can sometimes &quot;recharge&quot; and return (at least mostly) to normal before the day is over."/>
                    <outline text="Getting exhausted: Our cognitive abilities becoming significantly diminished."/>
                    <outline text="* Energy can be lost in ways other than thinking, like sleep deprivation."/>
                  </outline>
                </outline>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="3"/>
              </outline>
              <outline text="How mental stamina effects executive functions" heading="1" colorLabel="2"/>
              <outline text="Exhaustion" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="We become significantly exhausted quicker than you might expect during intensive mental activities."/>
                  </outline>
                  <outline text="Common" heading="3"/>
                </outline>
                <outline text="Recognizing it" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Signs" heading="1" colorLabel="1"/>
                </outline>
                <outline text="Taking [breaks](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=T8lQobqEPaFFypMihwloQHLZ)" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Conserving mental stamina" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="&quot;Conserving&quot; is here used to mean something like &quot;preventing from being lost&quot;."/>
                </outline>
                <outline text="Getting overwhelmed" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition (emotional)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Feeling emotionally overwhelmed."/>
                  </outline>
                  <outline text="How getting overwhelmed reduces mental stamina" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Getting overwhelmed often greatly reduces our mental stamina. This is likely caused by the instinct that dedicating a lot of mental energy to the process is pointless, because we feel like we cannot possibly surmount the obstacle."/>
                  </outline>
                  <outline text="How to avoid getting overwhelmed" heading="3" colorLabel="2" collapsed="true">
                    <outline text="1. Recognize when things feel too difficult" heading="3" colorLabel="2"/>
                    <outline text="2.a  Take a [break](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=T8lQobqEPaFFypMihwloQHLZ)" heading="3" colorLabel="2"/>
                    <outline text="2.b  Decomposition" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Breaking a task up into smaller parts."/>
                      </outline>
                      <outline text="This allows us to focus on smaller and more managable problems, which tend to feel less overwhelming."/>
                    </outline>
                    <outline text="2.c  Ask for help" heading="3" colorLabel="2"/>
                    <outline text="2.d  Abandon the task" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Typically our emotional instinct is to abandon tasks when they start to feel overwhelming, and typically that instinct is not justified. However just because something is not justified does not mean that we necessarily have good reason to contest it. If it seems most reasonable to abandon the task and you believe you&apos;ve given sufficient consideration towards doing so and not doing so, then this should certainly be considered a viable option."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Taking [breaks](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=T8lQobqEPaFFypMihwloQHLZ)" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Helpful for conserving mental stamina by:"/>
                  <outline text="1. Often replenishing some mental stamina."/>
                  <outline text="2. Often allowing for a fresh perspective after the break."/>
                </outline>
              </outline>
              <outline text="Increasing mental stamina" heading="1" colorLabel="2"/>
              <outline text="Causes of stamina peaks/valleys" _note="The main sections for this should probably be &quot;causes of executive function peaks/valleys&quot; or something? " heading="1" colorLabel="1" collapsed="true">
                <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The causes for your stamina increasing/decreasing substantially compared to what you would expect."/>
                </outline>
                <outline text="Times of the day / Sleepiness" heading="3" colorLabel="1" collapsed="true">
                  <outline text="It&apos;s common for peoples&apos; executive functions to perform relatively badly during the circadian low, or when they are tired." collapsed="true">
                    <outline text="[Circadian low](https://skybrary.aero/articles/window-circadian-low-wocl)" heading="3" colorLabel="3"/>
                  </outline>
                </outline>
                <outline text="Hunger / Diet" heading="3" colorLabel="1"/>
                <outline text="Being overwhelmed" heading="1" colorLabel="1"/>
                <outline text="Depression" heading="1" colorLabel="1"/>
              </outline>
              <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
            </outline>
            <outline text="Attention span" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The typical amount of time you can concentrate on one thing before getting distracted."/>
                <outline text="Distinction (attention span vs mental stamina)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Attention span refers to how long we tend to be able to concentrate on individual things, whereas mental stamina is about the energy we tend to have before our cognitive abilities are significantly diminished." collapsed="true">
                    <outline text="Energy: How much time and/or effort in a day we tend to have before our cognitive abilities are significantly diminished."/>
                  </outline>
                  <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Competitiveness" heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="[&quot;Winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDxHpzr99Ib8E5XfGJAHVTzK)" heading="1" colorLabel="2"/>
              <outline text="[Immediate correctness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KUPpriNFmUD5Q_kShoJSEf1k)" heading="1" colorLabel="2"/>
              <outline text="[Refutation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vGnU05OJtfhN092NcMo2TQ36)" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Disinterest" _note="I probably need to research this." heading="1" colorLabel="1" collapsed="true">
              <outline text="[Disinterest mood](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kDlMr_akHEdxxIzQR8MhNE1T)" heading="3" colorLabel="1"/>
            </outline>
            <outline text="Rewards/punishments" heading="1" colorLabel="1" collapsed="true">
              <outline text="Rewards" heading="1" colorLabel="1" collapsed="true">
                <outline text="Praise" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Punishments" heading="1" colorLabel="1" collapsed="true">
                <outline text="Blame" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3"/>
                    <outline text="Common" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Moral desert r/p" heading="3" colorLabel="6" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Reward/punishment for the sake of giving what is deserved."/>
                </outline>
              </outline>
              <outline text="Pragmatic r/p" heading="3" colorLabel="6" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Reward/punishment for the sake of motivating people to change/repeat behaviors."/>
                </outline>
                <outline text="Rehabilitative r/p" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Reward/punishment for the sake of motivating people to change behaviors."/>
                  <outline text="Typically punishment."/>
                </outline>
              </outline>
            </outline>
            <outline text="Life experience" _note="Link to subconscious/intuition and to (importance of) knowledge" heading="1" colorLabel="1" collapsed="true">
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="It&apos;s incredibly useful for testing and learning about unknown variables that are hard to account for without experience." colorLabel="4"/>
                  <outline text="Life experience tends not to help much in [&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" colorLabel="1" collapsed="true">
                    <outline text="Learned and widespread biased and unsystematic thinking tends to prevent us from translating our experience in those areas into useful knowledge." colorLabel="4" collapsed="true">
                      <outline text="It tends to prevent us from learning from our mistakes in those areas."/>
                      <outline text="It might be necessary to distinguish between experience and expertise, with expertise meaning “the development of a schematic principle that involves conceptual understanding of the problem,” which in turn enables the decision maker to recognize particular biases. However, using expertise as countermeasure requires more than just being familiar with the situational content or being an expert in a particular domain. It requires that one fully understand the underlying rationale of the respective bias, is able to spot it in the particular setting, and also has the appropriate tools at hand to counteract the bias." collapsed="true">
                        <outline text="Sebastian Serfas, __Cognitive Biases in the Capital Investment Context: Theoretical Considerations and Empirical Experiments on Violations of Normative Rationality__ (Springer, 2010). " colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Soft reasoning tends to be about abstract topics which we don&apos;t directly experience in a very straightforward or informative way." colorLabel="4"/>
                    <outline text="[People are bad at &quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qarhXHvwcgUN1n5fnt5sFXck)" colorLabel="4"/>
                  </outline>
                  <outline text="Most of the biggest things learnable through life experience are typically learnable in other ways." colorLabel="1" collapsed="true">
                    <outline text="Abstract reasoning."/>
                    <outline text="Learning from others."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Thinking speed" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="How fast one can think, in general or in a particular area."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Higher thinking speed multiplies the amount of thoughts that you can perform in a given amount of time."/>
                  <outline text="Higher thinking speed often means a larger amount of thoughts that can be had before short-term memory fades away."/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="The general idea is to reduce less useful thoughts and increase more useful thoughts."/>
                </outline>
              </outline>
            </outline>
            <outline text="Charisma" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance / Limitations" heading="3" colorLabel="2"/>
              <outline text="Humor" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Reductio ad absurdum](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6LOKFZ350qqORVV4R48gcQ2O)" heading="3" colorLabel="5"/>
              </outline>
              <outline text="Friendliness / respect" heading="3" colorLabel="2" collapsed="true">
                <outline text="Convey warmth" heading="3" collapsed="true">
                  <outline text="Smile"/>
                </outline>
                <outline text="Begin your interactions in a friendly way" heading="3" collapsed="true">
                  <outline text="First impressions are quite important." _note="Create and link a section on first impressions."/>
                </outline>
                <outline text="Be a good listener" heading="3" collapsed="true">
                  <outline text="People love to talk about themselves and their interests, by letting them, you make them feel good and get them more open to your ideas."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Avoid direct confrontation" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Avoid direct confrontation those you want to appear charismatic to."/>
                  <outline text="Distinction" colorLabel="3" collapsed="true">
                    <outline text="This is distinct from avoiding confrontation in general, as it can sometimes be charismatic to engage in some specific kinds of confrontations."/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Honesty" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Resolving conflicts properly" heading="3" collapsed="true">
                  <outline text="Important for good relationships" collapsed="true">
                    <outline text="Important for &lt;broken link&gt;"/>
                  </outline>
                  <outline text="Important for improving in general" collapsed="true">
                    <outline text="Important for improving reasoning" _note="Expand and link this a lot" collapsed="true">
                      <outline text="You likely won&apos;t become completely aware of many of your epistemic flaws without going through a process like this."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="[Importance of genuineness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-2XoOnKGt_cpe65ZzBc3SL2L)" colorLabel="2"/>
              </outline>
              <outline text="Genuineness" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Long-term honesty."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Increases &lt;broken link&gt;" heading="3"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Expectations" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
                <outline text="The level of performance that is expected to be met and which, if not met, someone (could be ourselves) will be disappointed."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Setting your expectations too high" heading="1" colorLabel="1" collapsed="true">
                <outline text="This tends to be very easy to do, because:"/>
                <outline text="1. We often fail to anticipate many challenges."/>
                <outline text="2. We focus on the things that we can explicitly account for and usually don&apos;t propelry account for many of the unknown challenges."/>
                <outline text="3. We generally tend to be too confident in ourselves."/>
                <outline text="[For complex problems](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zRXP26n914iccTGdJXRxB69C)" heading="3" colorLabel="1"/>
                <outline text="Examples" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Setting your expectations too low" heading="1" colorLabel="1"/>
            </outline>
            <outline text="Neuroscience" heading="3" colorLabel="1" collapsed="true">
              <outline text="The two hemispheres" heading="3" colorLabel="1" collapsed="true">
                <outline text="Cut corpus callosum" heading="3" colorLabel="1" collapsed="true">
                  <outline text="[You Are Two - CGP Grey](https://www.youtube.com/watch?v=wfYbgdo8e-8&amp;pp=ygUTY3V0IGNvcnB1cyBjYWxsb3N1bQ%3D%3D)"/>
                </outline>
                <outline text="[Why evolution split your brain](https://youtu.be/ybuhqtDVO_A)"/>
              </outline>
            </outline>
            <outline text="Responsibility" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Taking responsibility" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" _note="Look this up and change if necessary." heading="3" colorLabel="3" collapsed="true">
                  <outline text="Admitting (both to yourself (consciously) and to those involved) that you are the thing that should change to avoid some specific future negative effect(s)."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Modesty" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="https://en.wikipedia.org/wiki/Modesty"/>
              </outline>
            </outline>
            <outline text="Deference" heading="3" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="https://en.wikipedia.org/wiki/Deference"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Reasoning mindsets](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDRmT592xGeslYb-hvYp2ujH)" heading="1" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Related" heading="3" colorLabel="6" collapsed="true">
            <outline text="[Memory](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XTxjpYFXjK4lV4I5PTPsRulR)" heading="1" colorLabel="1"/>
          </outline>
        </outline>
        <outline text="In practice" _note="Create categories for many of the items here" heading="1" colorLabel="2" collapsed="true">
          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
            <outline text="Reasoning in practice; Practical reasoning."/>
            <outline text="This category is full of practical problems, techniques, strategies and misc info about the nature of reasoning in practice."/>
          </outline>
          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
            <outline text="**Informal:**   Practical reasoning is very useful for informal reasoning." _note="Link informal reasoning" colorLabel="4" collapsed="true">
              <outline text="Importance of systematic reasoning" _note="Likelihood | Link" heading="3" colorLabel="4"/>
              <outline text="Importance of heuristics" _note="Likelihood | Link" heading="3" colorLabel="4"/>
            </outline>
            <outline text="**Formal:**   Practical reasoning can help even in very formal contexts." colorLabel="4" collapsed="true">
              <outline text="We cannot (at least ordinarily) be literally certain that an argument is valid." _note="Likelihood | Exchange for link" colorLabel="4" collapsed="true">
                <outline text="We could always be making a mistake while calculating whether it is valid." _note="Likelihood | Move" colorLabel="4"/>
                <outline text="So lots of practical reasoning can substantially increase our chances of being correct." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="Eg. &lt;Time usage in reasoning&gt;" _note="Likelihood" colorLabel="4"/>
                  <outline text="^ By learning to solve formal problems using an amount of time proportional to the given problem&apos;s difficulty and importance, we can substantially increase our consistency on important formal problems." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Practical reasoning plays a big role in translating [thoughts / informal arguments] into formal arguments." _note="Likelihood | Maybe link somewhere in formal reasoning or something" colorLabel="4" collapsed="true">
                <outline text="Translating [thoughts / informal arguments] into formal arguments is important." _note="Relevance | Get link from somewhere for sure." colorLabel="4" collapsed="true">
                  <outline text="The process of translation is essentially necessarily an informal one." _note="Likelihood | Move" colorLabel="4"/>
                  <outline text="^ [Practical helps informal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MtVsy73dMPwCpEQ2Xc-qZHIz)" _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
            <outline text="Standard deduction" _note="Link" heading="1" colorLabel="5"/>
            <outline text="Probabilistic reasoning" _note="Link" heading="1" colorLabel="4"/>
            <outline text="All reasoning can be reduced to logic, and logic can fit in these things." _note="Likelihood" colorLabel="4" collapsed="true">
              <outline text="1. All reasoning [can be reduced to logic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AbNaVbQdlvY2B3giwwf9Ej7N)" colorLabel="4"/>
              <outline text="2. Logic can entirely fit in standard deduction and probabilistic reasoning." colorLabel="4" collapsed="true">
                <outline text="1. Standard deduction allows one to express and perform any expressable/performable logic that isn&apos;t mainly probabilistic." colorLabel="4"/>
                <outline text="2. Probabilistic reasoning covers all logic that&apos;s mainly probabilistic. " colorLabel="4"/>
                <outline text="3. Via the &lt;law of excluded middle&gt; and the first two premises, we can conclude that logic can entirely fit in standard deduction and probabilistic reasoning." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="See specific items under &quot;in practice&quot; for more details on how they can ultimately be reduced to these things. " _note="Likelihood" colorLabel="4"/>
          </outline>
          <outline text="Systematic reasoning" _note="Amateur | Move/link lots of importance stuff" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Thorough, precise reasoning, similar to formal reasoning."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2">
              <outline text="Systematic reasoning (done right) tends to be pretty reliable." colorLabel="4">
                <outline text="It&apos;s much more falsifiable." _note="Likelihood" colorLabel="4">
                  <outline text="Typically helps us more quickly find and solve the mistakes we make." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Often before we even present the argument." colorLabel="4"/>
                    <outline text="Often in a way that we aren&apos;t even conscious of." colorLabel="4"/>
                  </outline>
                  <outline text="Allows others to much more consistently point out our errors." _note="Relevance" colorLabel="4">
                    <outline text="Significantly helps with [cooperative reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tIkQysDqkCY4YvrwV_mIfQ_d)" _note="Relevance" colorLabel="4"/>
                    <outline text="Substantially helps us [improve](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mcey5J-t6AUuWU92iqr8Nkqe)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Systematic reasoning (done right) tends to help us improve our reasoning." colorLabel="4" collapsed="true">
                <outline text="It helps us realize when we&apos;ve made reasoning mistakes. " _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="[It&apos;s more falsifiable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gCMDk-EhAY2mxkVNdjEpewnJ)" _note="Likelihood" colorLabel="4"/>
                </outline>
                <outline text="Realizing when you&apos;ve used faulty reasoning is [crucial](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iZyW5tUw6i05PsjXMDoV4nIw) for improving your reasoning." _note="Relevance" colorLabel="4"/>
              </outline>
              <outline text="Unsystematic reasoning is typically very unreliable." colorLabel="4" collapsed="true">
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37) is typically substantially involved in unsystematic reasoning." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Heavy heuristic usage [is typically very unreliable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HX0lYNDX77zlbRkuVQVQONHa)" _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Unsystematic reasoning typically involves a lot of [vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Unsystematic reasoning is typically [imprecise](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=581SfOCyfIekfCaptWzmdIKD) (defined semi-specifically)" _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Argument" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Variables (read first)" heading="3" colorLabel="3" collapsed="true">
                        <outline text="AA: Unthorough and imprecise"/>
                        <outline text="AB: Unthorough and precise"/>
                        <outline text="BA: Thorough and imprecise"/>
                        <outline text="BB: Thorough and precise"/>
                        <outline text="Defining precision and thoroughness (and their opposites) in relation to a cutoff point between &quot;a little&quot; and &quot;substantial&quot;." colorLabel="3" collapsed="true">
                          <outline text="Eg. Right when &quot;substantially precise&quot; becomes &quot;a little precise&quot;, we call it &quot;imprecise&quot;." colorLabel="6"/>
                        </outline>
                      </outline>
                      <outline text="1. Unsystematic reasoning by definition cannot be both thorough and precise (BB)." colorLabel="4"/>
                      <outline text="2. Therefore the only way for someone to be precise and unsystematic is by being unthorough (AB). (1)" colorLabel="4"/>
                      <outline text="C. Unsystematic reasoning is typically imprecise. (See descendants)" colorLabel="4" collapsed="true">
                        <outline text="1. Typically, unsystematic reasoning takes one of the possible forms other than AB (AA or BA)." colorLabel="4" collapsed="true">
                          <outline text="Given some imprecise reasoning of one form, it&apos;s less specific to suppose [AA or BA] than it is to suppose AB." _note="Likelihood" colorLabel="4" collapsed="true">
                            <outline text="Therefore [Occam&apos;s Razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT) supports the former. " _note="Relevance" colorLabel="4"/>
                            <outline text="^ Specifically: the former would have 2x the prior probability as the latter." _note="Relevance" colorLabel="4"/>
                            <outline text="^ ^ Since the former takes up twice the [possibility space](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CWsm9Z1X5Oi2O7vGouwzf91b)" _note="Likelihood" colorLabel="4"/>
                          </outline>
                          <outline text="AA is more common than the other forms." _note="Likelihood" colorLabel="4" collapsed="true">
                            <outline text="Imprecision is correlated with unthoroughness." _note="Likelihood" colorLabel="4"/>
                            <outline text="Usually unsystematic reasoning is caused by significant [reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49), which typically substantially reduce both thoroughness and precision." _note="Likelihood" colorLabel="4"/>
                            <outline text="[We&apos;re typically imprecise](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qCyvK43-Yc-Y7ZQo-Hb_mzeL)" _note="Likelihood" colorLabel="4"/>
                            <outline text="[We&apos;re typically unthorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=E7hTHOqdFuMmgkXsh1PNzKFN)" _note="Likelihood" colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="C. Therefore, typically unsystematic reasoning does not take the AB form, and so typically it isn&apos;t precise. (1)" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="High imprecision usually involves vague wording." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Vague definitions are [very bad](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vZ5DP62BXbbbpK2Q0RvXyKbm) for reasoning." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Unsystematic reasoning typically involves significantly ignoring the [structure of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gtP-VgoAePbzjC3ZrBA3ebs5)" _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="The structure of reasoning [is important for reliable reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UsBZY-Ui3EVYDZzIdBnerV32)" _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="[Much less falsifiable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gCMDk-EhAY2mxkVNdjEpewnJ)" _note="Likelihood" colorLabel="4"/>
                <outline text="[Importance of reliable reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S6T9yuurBVnU-FJVKT8G9hbe)" _note="Relevance" colorLabel="4"/>
              </outline>
              <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                <outline text="**Currently bad:**   Our reasoning is almost always very unsystematic." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Our reasoning is almost always [Informal](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yQVWivooam-CWEWkiSH8D5Gu)" _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="[Informal reasoning is almost always very unsystematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bB6JLP6nZ8-ccbYtk7RCq1Tt)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="[We&apos;re typically imprecise](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qCyvK43-Yc-Y7ZQo-Hb_mzeL)" _note="Likelihood" colorLabel="4"/>
                  <outline text="[We&apos;re typically unthorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=E7hTHOqdFuMmgkXsh1PNzKFN)" _note="Likelihood" colorLabel="4"/>
                </outline>
                <outline text="**Improvable:**   Similar to chess, systematic reasoning is made up of patterns that can be memorized." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="These patterns can be memorized in such a way that we can perform many subconscious calculations with them very quickly." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Precision" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Distinction" heading="3" colorLabel="3">
                  <outline text="Distinct from specificity." collapsed="true">
                    <outline text="It is possible for something to be broad but precisely defined/understood."/>
                    <outline text="It is possible for something to be specific but not precisely defined/understood."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Reasoning systematically well requires a significant amount of precision." colorLabel="4" collapsed="true">
                  <outline text="[Importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=RD-oTBdlq50cfCjfUvC8a3kJ) of good systematic reasoning." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Less [precision](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=581SfOCyfIekfCaptWzmdIKD) leads to a lot of wasted time." colorLabel="4" collapsed="true">
                  <outline text="Less precision leads to a lot of mistakes." _note="Likelihood  |  Provide more support" colorLabel="4" collapsed="true">
                    <outline text="Mistakes lead to a lot of wasted time." _note="Relevance" colorLabel="4"/>
                    <outline text="^ [Importance of time usage in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eWYxopphAFhsy0JM6qET4SM9)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="[Importance of time usage in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=eWYxopphAFhsy0JM6qET4SM9)" _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                  <outline text="**Currently bad:**   Our reasoning is almost always very imprecise." _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Thoroughness" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Consistently accounting for a high ratio of important things."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="If you are not thorough, you can easily fail to address impactful parts of important contrary positions." colorLabel="4" collapsed="true">
                  <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                    <outline text="&quot;Address&quot; (distinction)" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Here defined to mean addressing all the reasoning down to (or very near to) axioms common between the [relevant party(s)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YOd4VHcHzO33_ixJ0g_jzns1)."/>
                      <outline text="&quot;Relevant party(s)&quot;" colorLabel="3" collapsed="true">
                        <outline text="Usually including you and one other person you&apos;re mainly discussing the matter with."/>
                        <outline text="Can also include the audience." collapsed="true">
                          <outline text="Eg. In a debate and trying to convince the audience, you may want to account for the axioms that the audience are likely to be using, therefore they may be a relevant party as well." colorLabel="6"/>
                        </outline>
                      </outline>
                      <outline text="Distinction (important)" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Distinct from addressing every argument other(s) give." collapsed="true">
                          <outline text="If you&apos;ve already addressed their reasoning down to common axioms and they fail to " collapsed="true"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="&quot;Important&quot;" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Important to your goals specifically."/>
                      <outline text="^ &quot;Your goals&quot; as in the goals that you hold, not necessarily selfish/self-interested goals." _note="Maybe create a definition for this, since this is 2nd copy of this?" colorLabel="3"/>
                    </outline>
                  </outline>
                  <outline text="This tends to greatly reduce your ability to [critical piggyback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2J5emCtKut8DRA6avr2C4r87) and [learn](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XwNwxOcZRgH_hY46vX9t5UTb) many important things." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="It can easily lead you to underestimate counterarguments against your position, because of not fully understanding them due to being insufficiently thorough." _note="Likelihood" colorLabel="4"/>
                    <outline text="If you fail to address impactful parts of important contrary positions, then you typically fail to fully understand those positions." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Usually, if you don&apos;t understand important positions, you cannot accurately determine how probable they are." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="Therefore you cannot change your mind to accept them." _note="Relevance" colorLabel="4"/>
                        <outline text="^ Therefore you&apos;re often left with inaccurate beliefs about important topics." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Because if you do understand them, it&apos;s typically easy to address them." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="And when it&apos;s easy to address them, we typically would address them." _note="Relevance" colorLabel="4"/>
                        <outline text="^ instinctually, for satisfaction&apos;s sake." _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="There are many exceptions to this." _note="Likelihood | Create a section in &quot;thoroughness&quot; about when __not__ to be thorough, likely linking this to those sections&apos; importance sections." colorLabel="1" collapsed="true">
                    <outline text="When the reasoning presented is confirmed to consistently ignore relevant axioms, it&apos;s unlikely to be accurate." _note="Likelihood &amp; Relevance" colorLabel="4" collapsed="true">
                      <outline text="**Relevant axioms definition:**   Axioms common between you and the [relevant party(s)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YOd4VHcHzO33_ixJ0g_jzns1)." colorLabel="3"/>
                      <outline text="Therefore it would typically be justified to skip addressing the specific arguments/people that consistently ignore the relevant axioms." _note="Relevance" colorLabel="4"/>
                      <outline text="This typically provides very little evidence against [the position the reasoning is advocating for]." _note="Relevance" colorLabel="1" collapsed="true">
                        <outline text="People can (and frequently do) provide horrible reasoning for true claims." _note="Likelihood | Likely link to how bad people are about &quot;soft&quot; reasoning in &quot;frequently do&quot;." colorLabel="4" collapsed="true">
                          <outline text="[Reversed stupidity is not intelligence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N_EWHi855Un0BfN7zOBsD5ki)" _note="Likelihood" colorLabel="4"/>
                        </outline>
                        <outline text="So this does not justify skipping addressing __any__ reasoning about the position in question." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                  <outline text="**Currently bad:**   Our reasoning is almost always very unthorough." _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Multi-claim" heading="1" colorLabel="5" collapsed="true">
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Reasoning decomposition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2yAdHe2D9cGzozUFdaA-_uR5)" heading="1" colorLabel="5"/>
                  <outline text="[Keeping track of context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lZZ0_vGBUVpwGOUFRwxcpLrf)" heading="1" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Per-claim" heading="1" colorLabel="5" collapsed="true">
                <outline text="Usually involves accounting for [prior probabilities](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WtCnPwTlo9i-Whi4OhvH_ZQd)" heading="3" colorLabel="4"/>
              </outline>
              <outline text="[Medium](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2dQTPlCik_c_rBtzWzSRO68)-specific" heading="2" colorLabel="5" collapsed="true">
                <outline text="[Text-specific](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YqxhIh8cQC3UlXflwRLyqM1B)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Answer each part one at a time.*" collapsed="true">
                    <outline text="\* Probably after reading through it all first, to [check for later context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QeIMagekvKd6sOLwkowZHjP9)."/>
                  </outline>
                  <outline text="Don&apos;t leave any part unanswered."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2"/>
                <outline text="[Accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK)" heading="3" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="Reasoning medium" _note="Link" heading="3" colorLabel="5" collapsed="true">
                <outline text="Reasoning mediums very often [have a significant impact](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gYpqjAAicVIr099LriSpTh4X) on how systematic the reasoning [is and can be]." colorLabel="4"/>
              </outline>
            </outline>
          </outline>
          <outline text="Reasoning mediums" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The non-hardware medium used to read/write the ideas." _note="Make this definition more specific."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2">
              <outline text="Helps do more [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="3" colorLabel="4" collapsed="true">
                <outline text="The medium you reason in usually has a huge impact on how systematic you can be. " _note="Likelihood | Add more" colorLabel="4" collapsed="true">
                  <outline text="Vocal&apos;s impact on systematicness" _note="Likelihood | Add more" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Time limit](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oqD9Ba2cE1m1EAIGqKQLCxEl)" heading="3" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                <outline text="All reasoning takes place on some kind of medium."/>
              </outline>
              <outline text="Avoiding repetition" heading="3" colorLabel="4" collapsed="true">
                <outline text="Some reasoning mediums can substantially help avoid repetition" _note="Likelihood | There should be more added to this." heading="3" colorLabel="4" collapsed="true">
                  <outline text="1. [Canonicality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bvey7bo6o34f5uucFEtBaO-r)"/>
                  <outline text="2. If you pick a structured reasoning medium (eg. [argument mapping](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uSb4_0tF0jO3_fwXZ7rtFxjv)), you can store past points and link it to people who make arguments you&apos;ve already addressed."/>
                </outline>
                <outline text="Normally, most effort in debate is wasted in repetition." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="Because the same reasoning often repeats in multiple places, with multiple overlapping, incomplete sets of information at varying levels of specificity, accuracy and truth." _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Vocal" heading="1" colorLabel="2">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Reasoning via voice."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2">
                <outline text="**Clarifications:**  Typically easier to ask for quick clarifications." colorLabel="4"/>
                <outline text="**Lower dehumanization:**  Typically harder to dehumanize the other person(s) and be unkind." colorLabel="4" collapsed="true">
                  <outline text="This [dehumanization typically encourages bad reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AuuzJ03tHDk4T9CCNgjuoP5o)" _note="Relevance" colorLabel="4" collapsed="true"/>
                  <outline text="**Clearer emotions:**  Typically easier to tonally express emotions clearly, and less opportunity for the emotional tone to be misunderstood." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="[In itself, this is largely unimportant for reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=u9E5oHFZ92jI180s6vkRse7J)" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="**Clearer intuition:**  Voice usually offers a better representation of one&apos;s intuition and internal monologue." colorLabel="4"/>
                <outline text="**Memory:**  Typically harder to know what exactly was previously stated." colorLabel="1" collapsed="true">
                  <outline text="&lt;broken link&gt;" colorLabel="4"/>
                  <outline text="This can easily result in unrecognized contradictions or conditions." colorLabel="4"/>
                  <outline text="Typically harder to correct what you said without causing confusion." colorLabel="4" collapsed="true">
                    <outline text="Especially when the corrections are about things that were stated a while ago." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="&lt;broken link&gt;" colorLabel="4"/>
                    </outline>
                    <outline text="[There are transcription apps and stuff that could help](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kiO5NCzEPhcheUmzQmMBBav_)" colorLabel="1"/>
                  </outline>
                  <outline text="Typically vocal reasoning can&apos;t consistently be reused in future discussions." colorLabel="1" collapsed="true">
                    <outline text="There are transcription apps and stuff that could help." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="**Time limit:**  Typically harder to cover much ground." colorLabel="1" collapsed="true">
                  <outline text="Vocal discussions are usually short and rarely revisited." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Thus, there is typically far less than the required amount of work done to cover all the relevant and important points, to the final important level of detail." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="It&apos;s usually hard to convince people to take a lot of time to be more thorough in vocal discussions." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Social norms encourage fast vocal discussions." _note="Likelihood" colorLabel="4"/>
                    <outline text="Deep dives are typically heavily socially discouraged." _note="Likelihood | Move/replace with relevant deep dive importance section" colorLabel="4"/>
                  </outline>
                  <outline text="Thus important points/sources are often left unscrurinized." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Important [deep dives](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iFjccGMkfI0qrorobVMX02-i) are often not done." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="Reduces systematic reasoning" _note="Relevance | Tie into above | Link systematic reasoning" colorLabel="4"/>
                </outline>
                <outline text="Typically more visceral positive feelings from close mindedness and negative feelings from open mindedness." _note="Expand/change?/fix" colorLabel="1" collapsed="true">
                  <outline text="[The ways in which epistemic self-overconfidence seems like positive confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ityU4yMPEryFxasgaEMZk6tu)" heading="3" colorLabel="4"/>
                  <outline text="[The ways in which epistemic humility seems like a bad kind of lack of confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fbZ_0EpA2GNrjG5Uu_td05-r)" _note="Move to emotions from open-/close-mindedness probably." heading="3" colorLabel="4" collapsed="true">
                    <outline text="Embarrassment is often especially potent in voice, especially when you can see your opponent."/>
                    <outline text="^ It often feels much more real and like you can feel them (or especially the audience, if there is one) judging your mistakes."/>
                  </outline>
                </outline>
                <outline text="**Cooperation:**  Limited number of participants." colorLabel="1" collapsed="true">
                  <outline text="Not many (if even more than 1) people can speak at the same time without making it hard to understand what the individuals are saying. So there&apos;s limited knowledge/calculation that can be efficiently drawn upon from the group." colorLabel="4"/>
                  <outline text="Apollo is open to almost everyone, meaning that the amount of available knowledge and human cognition the platform can potentially draw on is much greater." colorLabel="4"/>
                </outline>
                <outline text="**Sources:**  Typically harder to use [notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=w6iQmvWJNX7o9-hbY80w4yPN)/sources." colorLabel="1"/>
              </outline>
              <outline text="How to view it" heading="3" colorLabel="2"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Speaking for long periods at once](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=20Z4Bm-Z052kEflJkfaxnGWJ)" _note="An expression technique that is largely exclusive to vocal communication." heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Mostly-normal text" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="How to view it" heading="3" colorLabel="2"/>
              <outline text="Importance / limitations" heading="1" colorLabel="2" collapsed="true">
                <outline text="**Thorough:**  Typically easier to be thorough than in [vocal](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G1iy3M7QYVTcnJLmWkvOH-7n) discussions." colorLabel="4"/>
                <outline text="**Systematic:**  Typically easier to be [systematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7) then in https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G1iy3M7QYVTcnJLmWkvOH-7n discussions." colorLabel="4"/>
                <outline text="**Context:**  Typically easier to know what was previously stated." colorLabel="4"/>
                <outline text="**Systematic:**  Typically very [unsystematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)." colorLabel="1" collapsed="true">
                  <outline text="Rather than responding point by point to each point that the other person made, people tend to focus more on addressing the &quot;vibes&quot; or apparent &quot;main point&quot;, often missing a lot of important details."/>
                </outline>
                <outline text="**Clarification:**  Typically harder to ask for quick clarifications than in [vocal](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G1iy3M7QYVTcnJLmWkvOH-7n) discussions." colorLabel="1" collapsed="true">
                  <outline text="People often write long messages when reasoning about important topics via text, and others can&apos;t see the messages mid-formulation."/>
                </outline>
                <outline text="**Kindness:**  Typically easier to dehumanize the other person(s) and be unkind than in [vocal discussions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G1iy3M7QYVTcnJLmWkvOH-7n)" colorLabel="1" collapsed="true">
                  <outline text="Our empathy likely evolved to rely on audible tones a substantial amount." _note="Likelihood" colorLabel="4"/>
                  <outline text="Beneficial because dehumanization and unkindness of this kind typically encourages bad reasoning, both directly and indirectly." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Indirectly via encouraging the other person to respond in kind."/>
                  </outline>
                </outline>
                <outline text="**Emotion:**  Compared to [vocal discussions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G1iy3M7QYVTcnJLmWkvOH-7n), it is typically harder to express/read emotions well." colorLabel="1" collapsed="true">
                  <outline text="There are more opportunities for the emotional tone to be misread." _note="Likelihood" colorLabel="4"/>
                  <outline text="In itself, this is largely unimportant for reasoning." _note="Relevance" colorLabel="1" collapsed="true">
                    <outline text="Better understanding emotions to the degree that this typically offers doesn&apos;t result in a much better understanding of the relevant reasoning." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="When combined with sufficient knowledge/guidance of [how to avoid arguing while trying to get to know someone&apos;s motivations], understanding another&apos;s emotions better often makes one less defensive and more open minded towards that person." _note="Relevance | Link and move" colorLabel="4" collapsed="true">
                    <outline text="The success of [the Enemies Project](https://www.enemiesproject.org/) indicates that with sufficient guidance, this is possible." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="The guidance offers reminders/targeted education, but knowledge and &lt;broken link&gt; could achieve the same effect." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Open-mindedness [is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3JYkrvEjUHYENVJaDqFSq3Cd)." _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="**Deep dive:**  It is hard to [dive deep](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iFjccGMkfI0qrorobVMX02-i) into a single point without seeming to change the subject in a negative way." colorLabel="1"/>
              </outline>
              <outline text="Types" heading="1" colorLabel="5" collapsed="true">
                <outline text="Short text" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Tweets in Twitter/X."/>
                    </outline>
                  </outline>
                  <outline text="Pros / Cons" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Typically harder to be thorough." _note="Link to presumptuous section and explain why." colorLabel="1" collapsed="true">
                      <outline text="There&apos;s little room for nuance."/>
                      <outline text="There&apos;s little room for caveats."/>
                      <outline text="There&apos;s little room for detailed context."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Reply chain" _note="~~Amateur" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Chain of messages replying to other messages."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="New reply" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Adding a new reply to a reply chain."/>
                  </outline>
                  <outline text="Reviewing context" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Look at far back in the reply chain as seems necessary to understand the context thoroughly."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="This tends to be important to do before adding to a reply chain." collapsed="true">
                        <outline text="Otherwise, it is quite easy to forget (and then fail to account for) important details in previous replies."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Checking for other arguments" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Checking that the other person(s) haven&apos;t addressed [what you would add to the chain] in other messages/reply chains."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="This tends to be important to do before adding to a reply chain." collapsed="true">
                        <outline text="Otherwise, you might miss that they already addressed your counterargument. " collapsed="true">
                          <outline text="This might mean wasting time writing your reply."/>
                          <outline text="This might mean not at all realizing that they already addressed your argument until they point it out." collapsed="true">
                            <outline text="If this repeatedly happens, it wastes a lot of time by forcing them to have to point it out many times for the discussion to constructively progress in those areas." collapsed="true">
                              <outline text="This would likely result in the discussion being dropped before it is sufficiently explored for the mistaken person(s) to change their mind(s)."/>
                            </outline>
                            <outline text="This is typically embarrassing."/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Check for later context" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="When it&apos;s important, respond after reading through it all to make sure that there isn&apos;t important context to what&apos;s said earlier that you&apos;re missing later on in the text."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Prevents missing how later context addresses your counters to earlier text." heading="3" collapsed="true">
                    <outline text="Important to avoid embarrassing yourself." colorLabel="4"/>
                    <outline text="Important to be quicker." colorLabel="4"/>
                    <outline text="One can learn to be decently consistent at recognizing when later context addresses their counters." colorLabel="1" collapsed="true">
                      <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KVIlDwqG0oJsf9U7kwCk8GwM" colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="Avoids wasting time" heading="3" collapsed="true">
                    <outline text="If you have to wait until later to find out that what you wrote was addressed, you&apos;ll likely end up writing counter(s) that are doomed to be useless." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ" heading="3" colorLabel="5"/>
                <outline text="[Time usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kcYTc2USwUk8D8GkV6D7xpH2)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Argument mapping" heading="1" colorLabel="2" collapsed="true">
              <outline text="Colors" heading="3" collapsed="true">
                <outline text="I used colors here in a different way than anywhere else, just to fit the theme of the sites mentioned. Sorry."/>
              </outline>
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The systematic mapping of arguments, usually organized into a tree of supporting/contesting arguments."/>
              </outline>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Encourages much more structured reasoning" heading="3" colorLabel="4" collapsed="true">
                  <outline text="We tend to have a ton of mental habits for taking unreliable [Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49), and argument mapping encourages us to reason more consciously and thoroughly." _note="Link for tendency probably" colorLabel="4" collapsed="true">
                    <outline text="Argument mapping encourages us to reason more consciously and thoroughly." _note="Support" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Minimal downtime" heading="3" colorLabel="4" collapsed="true">
                  <outline text="You don&apos;t have to wait for other(s) to think (and if text: write out their responses)." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Argument mapping makes it easier to reason asynchronously, which means you don&apos;t have to wait for thinking/response times." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="This saves time, [which is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="[Clear organization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gPpuYdjQBzNcKQP8OSmbU--A)" heading="3" colorLabel="4"/>
                <outline text="Less context for the reader" heading="3" colorLabel="1" collapsed="true">
                  <outline text="This results in a substantially greater likelihood of misunderstandings." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="This wastes time, [which is impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                    <outline text="The difference in likelihood would not be substantial, as even normally, context misunderstandings about unfamiliar words are very common." _note="Likelihood" colorLabel="1"/>
                    <outline text="A policy of using clearer definitions can be employed, to avoid that consequence." _note="Likelihood" colorLabel="1" collapsed="true">
                      <outline text="The platform can be created around a user-built dictionary." _note="Likelihood" colorLabel="4"/>
                      <outline text="This would be difficult to get used to." _note="Likelihood" colorLabel="1" collapsed="true">
                        <outline text="It would thus be employed inconsistently." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="There can be groups who are willing to take the time to be thorough and apply it consistently." _note="Likelihood" colorLabel="1" collapsed="true">
                            <outline text="Most users would not be willing to do this." _note="Relevance" colorLabel="1" collapsed="true">
                              <outline text="We can slowly teach users such that they feel comfortable doing it, and would be willing to." _note="Likelihood" colorLabel="1"/>
                              <outline text="For many cases, we do not need to appeal to most users." _note="Relevance" colorLabel="1"/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Users would thus not engage, due to the challenge of using the policy being too great." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="[There can be groups who are willing to take the time to be thorough and apply it consistently](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NPvSvJHsb1veKdYIhbw0ESq4)" colorLabel="1"/>
                        </outline>
                      </outline>
                      <outline text="This wastes time, [which is impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="1"/>
                    </outline>
                    <outline text="Among groups who are already familiar with one another&apos;s definitions, the likelihood is not substantially greater." _note="Likelihood" colorLabel="1" collapsed="true">
                      <outline text="Limiting the group size so substantially greatly reduces many of the other benefits of argument mapping." _note="Relevance | link" colorLabel="1"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Contains more reasoning that is unimportant to the reader" heading="3" colorLabel="1" collapsed="true">
                  <outline text="This wastes time, [which is impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="The reader would likely be able to identify most of that reasoning as unimportant from the titles of the arguments in/under which the important reasoning resides." _note="Relevance" colorLabel="1" collapsed="true">
                      <outline text="There wouldn&apos;t be many titles that would have to be recognized for this, therefore not much time would be wasted." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Usually slower back-and-forth" heading="3" colorLabel="1" collapsed="true">
                  <outline text="This means a longer time before misinterpretations can be resolved." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="This wastes time, [which is impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="[Scores](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=RYIGKqcjbIIsUmq-ABVAvGWc)" heading="3" colorLabel="3"/>
                <outline text="[Canonicality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bvey7bo6o34f5uucFEtBaO-r)" heading="3" colorLabel="3"/>
              </outline>
              <outline text="Specific tools" heading="1" colorLabel="5" collapsed="true">
                <outline text="Dynalist" heading="1" colorLabel="5" collapsed="true">
                  <outline text="https://dynalist.io/" heading="3" colorLabel="3"/>
                  <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                    <outline text="While not specifically intended as a reasoning mapping tool (as far as I&apos;m aware), it can work very well as one."/>
                  </outline>
                </outline>
                <outline text="Mind of Apollo" heading="1" colorLabel="3" collapsed="true">
                  <outline text="https://mindofapollo.org/" heading="3" colorLabel="3"/>
                  <outline text="More info here: https://mindofapollo.org/about/"/>
                </outline>
                <outline text="Kialo" heading="1" colorLabel="5" collapsed="true">
                  <outline text="https://www.kialo.com/" heading="3" colorLabel="3"/>
                </outline>
                <outline text="Ameliorate" heading="1" colorLabel="4" collapsed="true">
                  <outline text="https://ameliorate.app/" heading="3" colorLabel="3"/>
                  <outline text="Criteria table" heading="3" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="General considerations" heading="1" colorLabel="2" collapsed="true">
                <outline text="Canonicality" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" _note="Probably pull from CDL" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="In typical debates and debate societies/platforms, past work is not often systematically saved and reused in future works, leading to lots of pointless repetition. In reasoning mapping tools with canonicality, a lot of work can be reused that wouldn&apos;t normally be reusable." colorLabel="4"/>
                      <outline text="^ This can (depending on the size of the userbase) greatly increase the amount of knowledge/human computation available." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Clear organization" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The intuitive categorization of reasoning, especially propositions and logic (eg. arguments)."/>
                    <outline text="In this context: Reasoning mapping tools tend to allow for much more clear information organization than typical methods."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="This allows us to more frequently identify parts that we can likely skip without issue." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="This saves time, [which is substantially important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="This allows us to more often quickly find reasoning that we&apos;ve seen before." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Our brain has an easier time remembering what branches things fall under, than remembering where exactly things are in a linear text thread." _note="Likelihood" colorLabel="4"/>
                      <outline text="This saves time, [which is substantially important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Scores" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[The importance of multi-user scores](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=l40lFCwOdbZfToKN724fTGGZ)" colorLabel="4"/>
                    <outline text="[The importance of roll-up scores](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nqRECYXGIaQ-RjuyfzSWKR6T)" colorLabel="4"/>
                  </outline>
                  <outline text="Roll-up scores" heading="3" colorLabel="5" collapsed="true">
                    <outline text="Definition" _note="Probably pull for CDL" heading="3" colorLabel="3"/>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="In typical debates, unreliable intuitions must be relied on to calculate and combine confidences, giving our cognitive biases a huge opportunity to influence our thinking. But in reasoning mapping tools, there are sometimes roll-up systems that can be used to combine scores in a reliable, mathematical way." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Multi-user scores" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Prioritization: Multi-user scores can substantially improve prioritization of where to reason." colorLabel="4" collapsed="true">
                        <outline text="Multi-user scores make it much easier to know where people disagree, which makes it easier to know where to prioritize reasoning." _note="Likelihood" colorLabel="4"/>
                        <outline text="This makes it easier to avoid providing reasoning in cases where it isn&apos;t needed." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="This allows you to skip writing this reasoning out." colorLabel="4" collapsed="true">
                            <outline text="This saves time, [which is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                          </outline>
                          <outline text="This usually allows other(s) to skip reading that reasoning." colorLabel="4" collapsed="true">
                            <outline text="This saves time, [which is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                          </outline>
                          <outline text="This usually prevents other(s) from adding to that reasoning." colorLabel="4" collapsed="true">
                            <outline text="This saves time, [which is important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FAE5Snb_O1pGzF4zHU-u5_VU)" _note="Relevance" colorLabel="4"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Saving time" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="That time can be spent expanding the reasoning." colorLabel="4"/>
                    <outline text="More time as more users read the reasoning and as the reasoning grows larger." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Future potential" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="If a tool will turn out to be incredibly useful for you in the future, it may be best to start learning it now even if it isn&apos;t in the ideal state currently."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[General software considerations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mQybGtFSpBoxAfGY9y6Y-dIq)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Structure of reasoning" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="The structure of reasoning."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="[Importance of circularity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PUNY_2ce8BRrC3FeVbISYGPU)" heading="3" colorLabel="4"/>
            </outline>
            <outline text="Input and output" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                <outline text="Input" heading="3"/>
                <outline text="Output" heading="3"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Virtually all reasoning can be grown down to functions with inputs and outputs."/>
                </outline>
              </outline>
            </outline>
            <outline text="Inferences" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A conclusion reached by way of evidence and reasoning."/>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="If you notice someone making a disgusted face after they&apos;ve taken a bite of their lunch, you can probably infer that they do not like it."/>
                  <outline text="If a friend walks by with a graded test in her hand and a smile on her face, you can probably infer that she got a good grade on the test."/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Inference)"/>
              </outline>
              <outline text="Deductive inference" _note="Consider moving to definitions" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A deductive inference is an inference that is [valid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa) from its [premises](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0sMGYY-2pbkR4lPQUYVVwZs9), meaning that it is impossible for the premises to be true and the conclusion to be false."/>
                </outline>
              </outline>
            </outline>
            <outline text="Circularity" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Circular reasoning."/>
                <outline text="Reasoning in which the conclusion is present in one of the (stated or implied) premises."/>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Distinct from non-loop circles." collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Circles of reasoning that don&apos;t form a loop, so there&apos;s no justification chain that supports itself."/>
                    </outline>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="A -&gt; B -&gt; D"/>
                      <outline text="A -&gt; C -&gt; D"/>
                      <outline text="When you graph this out, it forms a kind of circle of connections, but the connections don&apos;t run in a &quot;loop&quot; such that the justification chain supports itself."/>
                    </outline>
                  </outline>
                  <outline text="Distinct from relation/category loops (partial or otherwise)." collapsed="true">
                    <outline text="Total relation/category loops"/>
                    <outline text="Partial relation/category loops" collapsed="true">
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="A supports B, B is in the A category."/>
                        <outline text="This isn&apos;t necessarily problematic because non-B things in the A category can support B." collapsed="true">
                          <outline text="i.e. One member of a set can support another member of that same set."/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Importance of non-axiomatic circularity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1zF87KJR0xKJlwgZ38Bmt6GV)" heading="3" colorLabel="4"/>
              </outline>
              <outline text="Recognizing circularity" heading="3" colorLabel="2"/>
              <outline text="Vicious vs non-vicious circularity" heading="3" colorLabel="3" collapsed="true">
                <outline text="Vicious circulatory" heading="3" colorLabel="3" collapsed="true">
                  <outline text="**Synonym:**   Vicious circle fallacy"/>
                </outline>
                <outline text="Non-vicious circulatory" heading="3" colorLabel="3"/>
              </outline>
              <outline text="Non-axiomatic circularity" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="**Synonym:**   Begging the question" colorLabel="3"/>
                  <outline text="Examples" heading="3" colorLabel="6"/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" colorLabel="4"/>
                  <outline text="Unreliable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Inductive counterarguments" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Observed unreliability of circular reasoning" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                        <outline text="We seem to consistently observe that circular reasoning does no better than chance at deriving truths." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="**Truths:**   Defined broadly to include avoided falsehoods." colorLabel="3"/>
                        </outline>
                      </outline>
                      <outline text="Energy counterargument to circular reasoning" _note="Likelihood | [Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="4" collapsed="true">
                        <outline text="Justification functions sort of like energy. You can&apos;t use energy to increase itself without drawing from other energy." _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="**Contradictory circularity:**   Circular reasoning must be limited in such a manner that it cannot be used for any pair of proposition and its negation." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Argument" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                        <outline text="P1. If circular reasoning can be used to deduce a proposition and its negation, then a contradiction is entailed." _note="Likelihood" colorLabel="4"/>
                        <outline text="P2. True logical contradictions [are impossible](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iRkaxeyoE5AgB17FzWOds2C7)." _note="Likelihood" colorLabel="4"/>
                        <outline text="Conclusion derived via P1, P2, [Proof by contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QPYK9FVR9vJVazmsKRYBSnT8)" _note="Likelihood" colorLabel="4"/>
                      </outline>
                      <outline text="Unlikely due to lacking good rules" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                        <outline text="P1. Without sufficient rules for determining when one can/can&apos;t use circular reasoning, contradictions arise." colorLabel="4" collapsed="true">
                          <outline text="[Argument](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xpIkS0WCH9OWWsPkBIwMNj4h)" _note="Likelihood" heading="3" colorLabel="4"/>
                        </outline>
                        <outline text="P2. Therefore either circular reasoning isn&apos;t reliable, or sufficient rules must accurately reflect reality. (P1)" colorLabel="4"/>
                        <outline text="P3. It&apos;s unlikely that sufficient rules accurately reflect reality." colorLabel="4" collapsed="true">
                          <outline text="It seems unclear what plausible rules would be sufficient well for determining when you can/can&apos;t use circular reasoning." _note="Likelihood | Link to dialetheism section" colorLabel="4"/>
                          <outline text="It seems like sufficient rules would have found widespread adoption if they were justified." _note="Likelihood" colorLabel="4" collapsed="true">
                            <outline text="Sufficient rules have not found widespread adoption." _note="Relevance" colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="P4. Therefore it&apos;s likely that circular reasoning isn&apos;t reliable. (P2, P3)" colorLabel="4"/>
                      </outline>
                      <outline text="Unlikely due to specificity" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                        <outline text="**Elaboration:**   Supposing that circular reasoning with only this detail is accurate to reality requires a more specific hypothesis, and is thus less likely compared to the hypothesis that circular reasoning is simply never reliable." colorLabel="3"/>
                        <outline text="[Occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT)" _note="Likelihood" heading="3" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Axiomatic circularity" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Many people (at least claim to) use circularity at the foundation of their epistemology."/>
                </outline>
                <outline text="[Intuition pull](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6Efrp6c3GsagWNAxFomdfD8A)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="There&apos;s no inherent inconsistency in presupposing the validity of certain limited forms of circular reasoning." colorLabel="4"/>
                  <outline text="It&apos;s common for people to unknowingly use axioms to justify circular reasoning to justify axioms." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Arguments for/against circulatory" heading="3" colorLabel="5" collapsed="true">
                <outline text="Premise-circularity is vicious but rule-circularity is not" heading="3" colorLabel="4" collapsed="true">
                  <outline text="It is not necessary to know or even justifiably believe that rule R is reliable in order to move to a justified conclusion using the rule." complete="true" colorLabel="4" collapsed="true">
                    <outline text="As long as R is in fact reliable, one can form a justified belief in the conclusion of an argument relying on R, as long as one has justified belief in the premises." complete="true" colorLabel="4" collapsed="true">
                      <outline text="If one does not have justified belief in the rule of inference, then it is not possible to have justified belief in a conclusion that requires that rule of inference." colorLabel="1"/>
                    </outline>
                    <outline text="This doesn&apos;t work without [its support](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3oTnQJF4XeV7rlmYxWvWn-Cf), which doesn&apos;t work due to the support&apos;s [counter](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=3HO2eD1swi2P5I4S4c-9zwAE)." colorLabel="1"/>
                  </outline>
                  <outline text="Rule-circularity is sufficient to demonstrate the reliability very fundamental rules." complete="true" colorLabel="4" collapsed="true">
                    <outline text="It is unreasonable to require an uncircular demonstration of a very fundamental rule&apos;s reliability. " complete="true" colorLabel="4" collapsed="true">
                      <outline text="There is nowhere more basic to turn for such fundamental rules, so all that we can reasonably demand of a fundamental form of reasoning is that it endorse itself." complete="true" colorLabel="4" collapsed="true">
                        <outline text="Even deductive inference cannot be justified deductively." colorLabel="4"/>
                        <outline text="There is somewhere more basic we can turn." complete="true" colorLabel="1"/>
                        <outline text="We do not a priori owe fundamental forms of reasoning a realistic chance to defend themselves." colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="This is odd (and thus analogically unlikely), because there appears to be an easy interchange between rules and premises." complete="true" colorLabel="4" collapsed="true">
                    <outline text="A rule can always be added as a premise to the argument. " complete="true" colorLabel="4" collapsed="true">
                      <outline text="There is a fundamental difference between being prepared to accept a premise stating a rule and being prepared to use that rule." colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="A circular rule argument does not provide a full justification of the rule, so it is pretty much useless." colorLabel="1" collapsed="true">
                    <outline text="A circular rule argument does not provide a full justification of the rule." colorLabel="4" collapsed="true">
                      <outline text="Less sane inference rules such as counterinduction can support themselves in a similar fashion. The counterinductive rule is CI:Most observed As are Bs.Therefore, it is not the case that most As are Bs.Consider then the following argument CI*:Most CI arguments have been unsuccessfulTherefore, it is not the case that most CI arguments are unsuccessful, i.e., many CI arguments are successful.This argument therefore establishes the reliability of CI in a rule-circular fashion." colorLabel="4"/>
                    </outline>
                    <outline text="[...] so it is pretty much useless." colorLabel="4" collapsed="true">
                      <outline text="It&apos;s useful for showing people who accept inductive inference that it is reliable." complete="true" colorLabel="1" collapsed="true">
                        <outline text="There is some added value in showing that inductive inferences are reliable, even when we already accept that there is nothing problematic about them." colorLabel="4" collapsed="true">
                          <outline text="If &quot;there is nothing problematic about them&quot; is defined to preclude inconsistency, then this is equivalent to saying &quot;there is some value in showing x even when we already know x&quot;, and it&apos;s false." colorLabel="1"/>
                        </outline>
                        <outline text="The inductive justification of induction provides a kind of important consistency check on our existing beliefs." complete="true" colorLabel="4" collapsed="true">
                          <outline text="It doesn&apos;t provide this consistency check because of [ovserved unreliablility of circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kgcU5zacmTUoYtHGYAVsQ6hW)" colorLabel="1"/>
                          <outline text="It doesn&apos;t provide this consistency check because of [energy counterargument to circular reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iz1E432YHazYDQWjizy3SjDl)" colorLabel="1"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Circular reasoning using a sufficiently large circle can provide useful information" heading="3" colorLabel="4"/>
                <outline text="It is generally unclear (given the limited reliability of circular reasoning) what forms of circular reasoning should be considered ok and what forms should not." colorLabel="1" collapsed="true">
                  <outline text="eg. Why is circular reasoning not allowed for establishing the existence of unicorns?" colorLabel="4" collapsed="true">
                    <outline text="Premise 1. Unicorns exist (assumption)"/>
                    <outline text="   Premise 2. If unicorns exist then unicorns exist (law of identity)"/>
                    <outline text="Premise 3. Unicorns exist (Modus ponens 1, 2)"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Trees of knowledge" _note="Maybe combine with reasoning pyramids?" heading="3" colorLabel="5" collapsed="true">
              <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                <outline text="Axioms and presuppositions are the roots."/>
                <outline text="Other beliefs are the branches and leaves."/>
              </outline>
              <outline text="Representing trees of knowledge" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Creating/maintaining dependency maps between beliefs."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Very helpful for more [systematically reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Pyramid of practical reasoning" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Quicker but less reliable reasoning methods built on shower and more reliable methods."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="It allows us to know to (and to some degree how to) default to more reliable methods when the less reliable ones come into sufficient question."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Fitting things together](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FORaGWzKq7OJtxVu6LDAqa11)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Reasoning pyramids" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="An epistemic structure where a proposition is only directly justified via a combination of other propositions, which are in turn likely the same, and likely so on." collapsed="true">
                  <outline text="Technically virtually everything is only justified via a combination of other propositions if we allow for indirect justification." collapsed="true">
                    <outline text="Virtually all proposition justifications at least involve the law of identity and some other proposition."/>
                  </outline>
                </outline>
                <outline text="From now on in this section, &quot;pyramid&quot; will be used as a short-hand for this."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2">
                <outline text="**Common:**   We use reasoning pyramids to justify a vast amount of our beliefs." colorLabel="4"/>
                <outline text="Large pyramids are unstable" heading="3" colorLabel="4" collapsed="true">
                  <outline text="It&apos;s difficult to properly learn what justifies what for a sufficiently large (and important) portion of large reasoning pyramids." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="The lack of already-present maps" _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="We lack many easily-accessible well-structured maps for even much of the most common reasoning we use." _note="Likelihood" colorLabel="4"/>
                    </outline>
                    <outline text="We are typically ignorant of large portions of large reasoning pyramids." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Causes" heading="3"/>
                      <outline text="^ Unstructured reasoning" _note="???"/>
                    </outline>
                    <outline text="We typically have no idea how to." _note="Likelihood" colorLabel="4"/>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Argument mapping](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uSb4_0tF0jO3_fwXZ7rtFxjv)" heading="3"/>
                    </outline>
                  </outline>
                  <outline text="It&apos;s difficult to determine when all known crucial things are justified in a large reasoning pyramid" _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                      <outline text="NASA failure because of metric vs imperial confusion." collapsed="true">
                        <outline text="In retrospect this was a very obvious thing to check for and avoid. But when dealing with the massive pyramid of reasoning involved in making sure everything in the rocket will work, there&apos;s so many things that could go wrong that it&apos;s very hard to thoroughly check everything."/>
                      </outline>
                    </outline>
                    <outline text="Technicality" collapsed="true">
                      <outline text="This is technically slightly misleading since there are situations where there are multiple options for how to justify something and only one is required." collapsed="true">
                        <outline text="None are individually crucial but having at least one is crucial."/>
                      </outline>
                    </outline>
                    <outline text="[Propogation of uncertainty](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=73NTuS0d863Qd-z8AYKHURPc)" _note="Likelihood" heading="3" colorLabel="4"/>
                    <outline text="[Error cascade](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6ZzVQMb1isI3hsKZFaTm88Gu)" _note="Likelihood" heading="3" colorLabel="4"/>
                  </outline>
                  <outline text="We frequently use large reasoning pyramids for important reasoning." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Examples" heading="3" colorLabel="6"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Propagation of uncertainty" heading="3" colorLabel="6" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="In statistics, propagation of uncertainty is the effect of variables&apos; uncertainties on the uncertainty of a function based on them."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="62 crucial justifying propositions that, if true, are all 98% likely to justify their parent." collapsed="true">
                      <outline text="Only ~28.6% likely for the main proposition to be justified, despite all its supporting propositions having such a high likelihood."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Error cascade" heading="3" colorLabel="6" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A single important error upon which many things are built causing a major collapse."/>
                  <outline text="Examples" heading="3" colorLabel="6"/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i31tuKPtyg6pvBWtaDQRlNOp)" _note="Likelihood" heading="3" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Fitting things together](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FORaGWzKq7OJtxVu6LDAqa11)" heading="3" colorLabel="2"/>
                <outline text="[Consistency in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Vyez_NdsDrxZlRnsIUCtQJSI)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Gödel&apos;s incompleteness theorems" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
            </outline>
            <outline text="Reductio ad absurdum" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The form of argument that attempts to establish a claim by showing that following the logic of a proposition or argument would lead to absurdity or [contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CGk4nS-fRre90tF0iZFJB846)."/>
                <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Argumentum ad absurdum"/>
                  <outline text="Apagogical argument"/>
                </outline>
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Reductio_ad_absurdum)"/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Frequently an effective form of [persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)"/>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s very easy to strawman others using this technique." collapsed="true">
                  <outline text="In order to make a reductio ad absurdum, we often have to perform a few steps of reasoning from the other person&apos;s perspective."/>
                  <outline text="And if our understanding of the person&apos;s perspective is wrong such that any of those steps don&apos;t work, we would likely be creating a strawman argument." collapsed="true">
                    <outline text="&quot;Likely&quot; because we could be doing something like using multiple lines of reasoning to justify our ad absurdum, so that if one line doesn&apos;t work, the other could still work."/>
                  </outline>
                  <outline text="Taking care to avoid strawmanning others is important." collapsed="true">
                    <outline text="[People frequently strawman eachother](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d1K4S_SqoO5J7cMB8zmTFkxz) and [strawmans often cause major and quite impactful misunderstandings when people misunderstand each other](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9J3EO8ahD-_oTN6g6gKaOnVa)."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Types" heading="1" colorLabel="6" collapsed="true">
                <outline text="[Proof by contradiction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QPYK9FVR9vJVazmsKRYBSnT8)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="The deductive form."/>
                </outline>
                <outline text="Inductive ad absurdum" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An argument that following the logic of a proposition or argument leads to an overly unlikely outcome, and thus that the proposition/argument is more likely to be flawed than it other would be."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="[Emotional ad absurdum](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HcBO8q0z-StpkEjtE3kNTzMz)"/>
                    </outline>
                  </outline>
                  <outline text="Limitation" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Often largely based on an [emotional ad absurdum](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HcBO8q0z-StpkEjtE3kNTzMz)"/>
                  </outline>
                </outline>
                <outline text="Emotional ad absurdum" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="An argument intended to appeal to our subconscious/intuition about how &quot;absurd&quot; something is."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Different from [inductive ad absurdum](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QwtJDbQokrF5wmiAXN_Pn-RP)"/>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Learning to recognize and avoid this is very important."/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="The unreliability of emotions." _note="Link"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Likelihood and relevance" _note="Move or link to induction" heading="3" colorLabel="4" collapsed="true">
              <outline text="Distinguishing likelihood and relevance" _note="Link(s) to likelihood/relevance, link to semantics somewhere probably" heading="3" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Failing to distinguish between likelihood and relevance can easily lead to substantial misunderstandings." colorLabel="4"/>
                  </outline>
                  <outline text="Improvable" heading="3" collapsed="true">
                    <outline text="It&apos;s common for people to assume that likelihood quantifiers lose almost all weight when combined with a relevance quantifier of sufficiently high or low strength." colorLabel="4" collapsed="true">
                      <outline text="[The norm is for relevance quantifiers to supercede likelihood quantifiers](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8lKqHN0nm2G0QS-nsVBOnoM8)" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="The norm is for relevance quantifiers to supercede likelihood quantifiers" heading="3" colorLabel="2"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Quantification](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YbVdzkes7vVzGEsCil7Rsrze)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Likelihood is often considered more important than value, likely due to our inability to intuit very large or very small things, and the regular upper and lower bounds typically subconsciously placed on likelihood and value." _note="Link the cognitive bias about very large/small values."/>
            </outline>
            <outline text="Excluded Middle" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Structure of deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-M7n-0E2RkvSSvjZYHjLomcH)" heading="2" colorLabel="5"/>
              <outline text="[Reasoning mediums](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2dQTPlCik_c_rBtzWzSRO68)" heading="3" colorLabel="5"/>
              <outline text="[Argument mapping](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uSb4_0tF0jO3_fwXZ7rtFxjv)" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Designing arguments" heading="2" colorLabel="2" collapsed="true">
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="**Common:**   Occurs in essentially all reasoning whatsoever. " colorLabel="4"/>
              <outline text="Crucial to good reasoning." colorLabel="4"/>
            </outline>
            <outline text="Gathering premises" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition (specific) " heading="3" colorLabel="3" collapsed="true">
                <outline text="Thinking of, filtering and remembering premises."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="We [can significantly improve](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HGJvXMB9FfWcYmbnPbbWDJlg) when it comes to discarding irrelevant premises." colorLabel="4"/>
              </outline>
              <outline text="Discarding irrelevant premises" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Avoiding relying on premises that are not relevant to the argument you&apos;re trying to make."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Saves time" heading="3" colorLabel="4" collapsed="true">
                    <outline text="By avoiding including irrelevant premises, you save reader(s)&apos; time." _note="Likelihood" colorLabel="4"/>
                    <outline text="[Saving time importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NYxdL99oO0wiJzLy4FF6TvXs)" _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="**More validity:**   Lesser chance of making an invalid argument." _note="Link validity" colorLabel="4" collapsed="true">
                    <outline text="Saves time" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                      <outline text="You and any other(s) involved can waste less time addressing/defending invalid arguments, if you make less of them." _note="Likelihood" colorLabel="4"/>
                      <outline text="[Saving time importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NYxdL99oO0wiJzLy4FF6TvXs)" _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="**Currently bad:**   Most people are often really bad at this." colorLabel="4" collapsed="true">
                      <outline text="&lt;Link commonness of confirmation bias&gt;" _note="Likelihood" colorLabel="4"/>
                      <outline text="^ &lt;Link(s) for how much it reduces our ability to discard irrelevant premises&gt;" _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="**Can get better:**   The primary causes of [people being bad at discarding irrelevant premises] can be to heavily mitigated. " colorLabel="4" collapsed="true">
                      <outline text="&lt;Link to improvability under confirmation bias&gt;" _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related (includes strategies)" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;Link(s) to strategies against confirmation bias or other similar biases&gt;"/>
                  <outline text="&lt;Link to section about trying to falsify your own reasoning&gt;" _note="I don&apos;t remember what it&apos;s called or if it exists yet."/>
                </outline>
              </outline>
              <outline text="Gathering relevant premises" _note="Expert (because not very useful)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Finding premises relevant to the argument we&apos;re trying to make."/>
                  <outline text="**Typically:** primarily relevant to the commission."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                    <outline text="We already have a great automatic system for finding relevant premises." colorLabel="1" collapsed="true">
                      <outline text="&lt;Link to association memory system&gt;" _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Remembering them" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Saves time" heading="3" colorLabel="4" collapsed="true">
                      <outline text="It saves time in cases where you would otherwise end up re-searching or trying to recall premises that you found before." _note="Likelihood" colorLabel="4"/>
                      <outline text="[Saving time importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NYxdL99oO0wiJzLy4FF6TvXs)" _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Ensures that you won&apos;t lose them permanently." colorLabel="4"/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Link to memory"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Tying the premises together" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The act of finding and arranging formal and informal operations to try to support the argument you&apos;re trying to make." collapsed="true">
                  <outline text="Example operation types:"/>
                  <outline text="Inference rules" _note="Link"/>
                  <outline text="Equivalences" _note="Link"/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Required for validity" heading="3" colorLabel="4"/>
                <outline text="Improvable" heading="3" colorLabel="4"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="Inference rules link"/>
                <outline text="Equivalences link"/>
                <outline text="Heuristics link" collapsed="true">
                  <outline text="Heuristics are essentially informal operations to derive some proposition(s) from other(s)." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Brainstorming](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=M7x3bG-8DhQKdyf9cNUtUfU1)" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Decomposition" heading="1" colorLabel="5" collapsed="true">
            <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
              <outline text="The process of splitting up a bigger concept into smaller ones."/>
            </outline>
            <outline text="Reasoning decomposition" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Decomposition of reasoning."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Practically all reasoning involves at least some decomposition." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Very important for one&apos;s [thoroughness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ)." colorLabel="4"/>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="[Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49) (especially [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)) tends to make it very difficult to decompose in a sufficiently [thorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ) manner to avoid missing tons of very important details." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Accounting for unknowns" heading="1" colorLabel="2" collapsed="true">
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="We have a tendency to focus on only the things that we have explicitly accounted for, without accounting for much of the uncertainty that we would ideally account for." colorLabel="4"/>
                <outline text="[Overconfidence often causes us to lean towards much more extreme probabilities than we really ought to](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=X_nTX0Yfk9EuT8wiLvWk7Yck)" colorLabel="4"/>
              </outline>
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="[Overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6dfZL4s3LjJlqjUv7pk86tV4) often causes us to lean towards much more extreme probabilities than we really ought to." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Reading between the lines" _note="Move to &quot;understanding others&quot; probably." heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Lacking context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lVuocPQtbJr1T1UQTA9_LCyy)" heading="1" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Understand before dismiss" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Thoroughly understand an idea (usually important) before dismissing it."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Without following this, it is virtually guaranteed that out of all the important ideas you will investigate, there will be some that are prematurely rejected."/>
              </outline>
            </outline>
            <outline text="Avoiding missing exceptions" heading="1" colorLabel="2" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="We often fail to account for certain broad possibilities and as a result spend all our calculation in areas that don&apos;t matter." collapsed="true">
                  <outline text="Examples of failing to account for all possibilities" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Classical theism vs atheism" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Atheism" heading="3"/>
                        <outline text="Deism" heading="3"/>
                        <outline text="Theism" heading="3" collapsed="true">
                          <outline text="Classical theism" heading="3"/>
                          <outline text="Non-classical theism" heading="3"/>
                        </outline>
                      </outline>
                      <outline text="A common false dichotomy is between classical theism and atheism. But there are other possibilities:"/>
                      <outline text="Deism" heading="3"/>
                      <outline text="Non-classical theism" heading="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Deductively categorizing possibilities" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Starting with all possibilities and creating categories for mutually exclusive groups of possibilities to check if you&apos;ve missed anything."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s a good way to make sure that we&apos;ve accounted for all possibilities."/>
                </outline>
              </outline>
              <outline text="Involving person(s) with different plausible opinion(s)" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Getting other person(s) with different plausible opinion(s) to look at the topic and see if they can spot any important things that you would miss." collapsed="true">
                    <outline text="Opinion"/>
                  </outline>
                  <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Getting fresh eyes on the topic."/>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Particularly useful when you&apos;re too exhausted/bored but you want the topic to be considered more."/>
                  </outline>
                  <outline text="Common" heading="3"/>
                </outline>
                <outline text="Finding people with different plausible opinion(s)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Contacting fitting people you know" heading="3" colorLabel="2"/>
                  <outline text="Finding people with high [criticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wpVxdpKSZf5aCjKmiiGsbwWh)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
            </outline>
            <outline text="Other-shoe reviews" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Checking how your statement looks from the perspective of the primary side(s) your statement contests."/>
                <outline text="[Distinction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=l8W3XME24iqi21mn6CWaeV6F)" colorLabel="3"/>
                <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Placing yourself in the other person&apos;s shoes." collapsed="true">
                    <outline text="This can have other connotations like emotionally empathizing with others, which can also be useful but isn&apos;t necessarily meant by &quot;other-shoe reviews&quot;."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="This is an incredibly useful technique for catching things you missed and properly accounting for obvious counterarguments before they are given."/>
              </outline>
              <outline text="Always assume you&apos;re wrong" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition (it&apos;s hyperbole)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The idea is to temporarily think almost entirely as though you know you are wrong but don&apos;t know how."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Our brain evolved to argue for one perspective and not adequately account for the other side. This tricks our brain into focusing on treating one side to that luxury, then the other." collapsed="true">
                    <outline text="&lt;broken link&gt;" heading="3" colorLabel="2"/>
                    <outline text="It encourages you to try to look for all the ways in which you could be wrong and give all the promising counterarguments you can find adequate attention."/>
                  </outline>
                </outline>
                <outline text="Applied to cooperative reasoning" heading="1" colorLabel="2" collapsed="true">
                  <outline text="If you disagree" collapsed="true">
                    <outline text="Almost always assume that the other(s) are right at first." collapsed="true">
                      <outline text="Because you should (temporarily) assume that you&apos;re wrong about them being wrong."/>
                    </outline>
                  </outline>
                  <outline text="If you agree" collapsed="true">
                    <outline text="Almost always assume that the other(s) are wrong at first." collapsed="true">
                      <outline text="Because you should (temporarily) assume that you&apos;re wrong about them being right."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Back and forth" heading="1" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s good to switch from acting as though one side is right and then acting like another side is right and so on." collapsed="true">
                    <outline text="But when you do this, you should be careful to account for all possibilities:"/>
                    <outline text="[Avoid missing exceptions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ki9wj7h_kf_1i1KKOgL9aO_X)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Preemptive steelman counter check" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The process of steelmanning your opponent and checking if they&apos;ve already (implicitly or explicitly) accounted for your counterargument(s), concern(s) or similar."/>
                <outline text="Connotation" colorLabel="3" collapsed="true">
                  <outline text="Typically the order of events is:"/>
                  <outline text="1. You see a statement/argument."/>
                  <outline text="2. You think about it."/>
                  <outline text="3. You write counterargument(s)."/>
                  <outline text="4. You carefully [Steelman](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LWB8YQUQupE7UQRtFL7J9g6w) the statement/argument and re-read it, checking for implicit or explicit counter(s) to your counterargument(s)."/>
                </outline>
                <outline text="Distinction" colorLabel="3" collapsed="true">
                  <outline text="[Other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64) are about looking for counterarguments that were neither implicitly nor explicitly given. Whereas PSCCs are about looking for counterarguments that were implicitly or explicitly given. However &quot;implicitly&quot; is defined pretty vaguely, so it&apos;s fair to regard these topics as having some overlap."/>
                </outline>
              </outline>
            </outline>
            <outline text="Multiple checks" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Consequences of not finding flaws" heading="3" collapsed="true">
                    <outline text="[Lacking evidence ≠ false](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PoAcoW2P9Q9L6hiLGzVECWql)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="A lot of people perform multiple checks in a flawed way." heading="3" collapsed="true">
                    <outline text="A lot of people use an unreliable but consistent method, so the multiple checks give the same wrong answer multiple times."/>
                    <outline text="A lot of people overestimate the thoroughness of correctly performed multiple checks." collapsed="true">
                      <outline text="It is often decently effective, but usually far from definitive."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Potential systematic issue" heading="3" collapsed="true">
                  <outline text="If the potential uncaught error emerged from a systematic error (eg. the relevant intuition(s) failing to account for a very important variable), then it is likely that the systematic error will be repeated if the same person(s) analyze(s) the same thing again."/>
                  <outline text="This can be somewhat mitigated by using (at least slightly) different techniques/people for the checks." collapsed="true">
                    <outline text="For example doing an ordinary check, coming up with counterargument(s), then doing a [preemptive steelman counter check](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dlapD9QkEDz8gtBNqJGSpZ_E)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="[Cooperative](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Qlio6RfNJC5UcTvCa9o-7SX) multiple checks" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Ordinary peer-review" heading="3" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2"/>
                </outline>
                <outline text="Conceptual replication" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A research strategy in which the same underlying hypothesis or theoretical concept is tested using different methods, operationalizations, samples, or experimental conditions compared to the original study."/>
                    <outline text="Connotation" colorLabel="3" collapsed="true">
                      <outline text="Has professional and academic connotations, but does not necessarily need to be professional or academic."/>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Preemptive steelman counter check](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dlapD9QkEDz8gtBNqJGSpZ_E)" colorLabel="2"/>
                <outline text="[Other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Lacking evidence ≠ false" heading="3" colorLabel="4" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Lacking evidence in favor of a proposition is not necessarily substantial evidence of that proposition being false."/>
                <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Absence of evidence is not evidence of absence."/>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Lacking evidence against a hypothesis is often not great evidence for that hypothesis." collapsed="true">
                  <outline text="Even if you&apos;ve done multiple checks, depending on the subject it could have a feature that makes it very easy for there to be many checks that would simultaneously fail."/>
                </outline>
                <outline text="This is often particularly relevant when applied to topics where people frequently reason badly." collapsed="true">
                  <outline text="The arguments for/against things that you are aware of are likely not the only possible ones."/>
                  <outline text="As such, if people are not good at finding good arguments, you addressing all the bad ones likely doesn&apos;t tell you much about the reasonable position to take."/>
                </outline>
              </outline>
            </outline>
            <outline text="Unexpected obstacles" heading="1" colorLabel="2" collapsed="true">
              <outline text="Causes" heading="1" colorLabel="6" collapsed="true">
                <outline text="With a sufficiently complex task, it is impossible to account for all the challenges that will be involved."/>
              </outline>
              <outline text="Hofstadter&apos;s law" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="&quot;It always takes longer than you expect, even when you take into account Hofstadter&apos;s law.&quot;"/>
                  <outline text="A law usually used to describe the widely experienced difficulty of accurately estimating the time it will take to complete tasks of substantial complexity."/>
                  <outline text="https://en.wikipedia.org/wiki/Hofstadter&apos;s_law"/>
                </outline>
                <outline text="We have a tendency to focus only on the things that we can explicitly account for." _note="Link to bias(es)"/>
              </outline>
              <outline text="Plan for failure" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Planning for things to go wrong in unexpected ways." collapsed="true">
                    <outline text="Unexpected: Not specifically predicted." collapsed="true">
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="You might expect that trying to build your own submarine would go poorly, but it might be difficult to predict exactly which part(s) of your design would fail." collapsed="true">
                          <outline text="After all, it&apos;s your design, so you would ostensibly prevent any sufficiently specific failures that you could successfully predict."/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Depending on the importance, it may be worth coming up with contingencies for if things go wrong in unexpected ways."/>
                </outline>
                <outline text="Systematically planning contingencies" heading="2" colorLabel="2" collapsed="true">
                  <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=e-rx5GVRcMwUlauim9BgIzme" heading="3" colorLabel="5"/>
                  <outline text="Assigning [time usage in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ix4g1EoGh3HsteZTJwCBMY8E)" heading="3"/>
                  <outline text="Find semi-plausible failures" heading="3" collapsed="true">
                    <outline text="**Experiment method:**   Try to break the components in all the semi-realistic ways you can think to."/>
                  </outline>
                  <outline text="Make contingencies" heading="3" collapsed="true">
                    <outline text="Multiple contingencies" heading="3" collapsed="true">
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Oftentimes you&apos;ll want multiple contingencies if it&apos;s very important not to fail."/>
                      </outline>
                      <outline text="Independence" heading="1" colorLabel="2" collapsed="true">
                        <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="It&apos;s very important to keep the contingencies very independent, so that a common failure of one thing doesn&apos;t cause a failure of multiple contingencies."/>
                        </outline>
                        <outline text="Design independence" heading="3" collapsed="true">
                          <outline text="Different designs so that if one design is faulty (or faultily implemented, etc.) then that&apos;s ok."/>
                        </outline>
                        <outline text="Source independence" heading="3" collapsed="true">
                          <outline text="Different people, manufacturers, companies, etc."/>
                        </outline>
                        <outline text="Implementation independence?" heading="3"/>
                        <outline text="System independence" heading="3" collapsed="true">
                          <outline text="Contingencies that are meant to be independent should not be reliant on a common system."/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Commonly useful contingencies" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Backup time" heading="3"/>
                  <outline text="Backup money" heading="3"/>
                </outline>
                <outline text="Commonly useful areas to plan for failure" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Reasoning" heading="1" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2"/>
                    <outline text="Contingencies" heading="3"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Prior probabilities](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WtCnPwTlo9i-Whi4OhvH_ZQd)" heading="1" colorLabel="4" collapsed="true">
                <outline text="Often one of the most important unknowns to account for. ([source](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=THdiKHErbTGYJvqcfGOasDCk))"/>
              </outline>
              <outline text="[Not accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HqeODo74AAT86530mLDuvEMf)" heading="3" colorLabel="1" collapsed="true">
                <outline text="This explains some of the causes of failing to account for unknowns."/>
              </outline>
              <outline text="[Learning from others](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5Qlio6RfNJC5UcTvCa9o-7SX)" heading="3" colorLabel="2"/>
              <outline text="[Reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7VkGKlZfqI3D-chGqzjjpwn)" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Cooperative reasoning" heading="1" colorLabel="2" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Helps us [improve our reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mcey5J-t6AUuWU92iqr8Nkqe)" _note="Expand" heading="3" colorLabel="4" collapsed="true">
                <outline text="Cooperative reasoning is very useful for getting [reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_raNJnESo8Ou9VQyYZY7wWAQ)" _note="Likelihood" colorLabel="4"/>
                <outline text="[It helps us learn](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4A5HteRemTPGAuXluLQAirau) in general." _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="Useful for [learning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Cf2EDQJtkVrNLpMxmcrhJ6em)" heading="3" colorLabel="4" collapsed="true">
                <outline text="**Faster learning:**   There are many very important details in most areas that would require a significantly greater time to learn about on one&apos;s own than with the help of other(s)." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="**Often lacking info:**   Oftentimes there&apos;s a lack of info (or searchability) about the topic in the widely available resources." _note="Likelihood" colorLabel="4"/>
                  <outline text="**Often misleading info:**   Oftentimes there&apos;s a lot of misleading info about the topic." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="So even in cases where it&apos;s easy to find the correct info, it may be hard to figure out which of the info you found is correct." _note="Relevance" colorLabel="4"/>
                    <outline text="^ Thus it may not be very useful to you without spending a lot more time figuring out what info is correct." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Faster learning means that you can learn more." _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                    <outline text="[Learning importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iotkYGcNyxDt9gMGJJnMhM6_)" _note="Relevance" heading="3" colorLabel="4"/>
                  </outline>
                  <outline text="[Importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vX_9I-ZrMtjLqyAeXBdlaIA4) of cooperation-requiring knowledge when it comes to you learning from others." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="**Human biases** often prevent people from properly learning." _note="Likelihood" colorLabel="1" collapsed="true">
                  <outline text="Humans (at least currently) have [cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9) that can cause many seemingly quite independent humans to perform the same flawed reasoning." colorLabel="4" collapsed="true">
                    <outline text="This is especially common when using [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="**Information exchange limit:**   For a lot of the more complicated and important topics, it is not realistic to share all the most impactful information." _note="Likelihood | Addressed" colorLabel="1" collapsed="true">
                  <outline text="There is too much impactful information to share." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Due to [emergent simplicity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QQDzgaivrRBrqackFuExvxms), it is usually realistic." _note="Likelihood | Arguments will be continued under emergent simplicity&apos;s [importance section](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0p96X6gM6wxgwKdjhfOWrQFN)." colorLabel="1"/>
                  </outline>
                  <outline text="A lot of the impactful information comes from things like personal experience, which cannot be adequately shared." colorLabel="4" collapsed="true">
                    <outline text="Generally, there is a low likelihood that one would be lying about their personal experience in a topic like this. So usually personal experiences can be shared to an adequate degree." colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Learning from others" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition (unusual)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Learning about things other than how to reason better, from others." _note="Here."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Cooperative reasoning importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ToKUH9kZobFdEN-AU6WWmC3G)" heading="3" colorLabel="4"/>
                <outline text="Faster learning" heading="3" colorLabel="4" collapsed="true">
                  <outline text="[General importance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Wco2DdiHFrlyRYH-wKF9WZGR) of faster learning from cooperative reasoning." heading="3" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2"/>
              <outline text="Find good counterarguments" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="To verify that you&apos;re not missing something, you should argue against the best arguments (often given by the strongest advocates)." collapsed="true">
                    <outline text="Arguing against weaker advocates usually proves little, because even the strongest idea will attract weak advocates."/>
                    <outline text="Arguing against weaker arguments usually proves little, because even the strongest idea will have weak arguments used for it."/>
                  </outline>
                </outline>
                <outline text="Find people who disagree" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The practice of finding someone who disagrees and learning why they disagree."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="In order to learn about promising counterarguments/details that you didn&apos;t consider before discussing it with them." collapsed="true">
                      <outline text="This does not require that the people you discuss the subject with are very reasonable." collapsed="true">
                        <outline text="They could have learned promising knowledge about the subject from other people." collapsed="true">
                          <outline text="They could be biased towards the other position and accept any reasoning they find, and happen to have found pretty good reasoning."/>
                        </outline>
                        <outline text="They could have stumbled across a decent argument by chance."/>
                        <outline text="Confirmation bias tends to cause people to calculate in favor of their own position quite a lot, so if there weren&apos;t any subtle counterarguments along the way, they could have a deep line that&apos;s good for justifying their position even if they were heavily subject to confirmation bias, close-mindedness, etc." collapsed="true">
                          <outline text="&lt;broken link&gt;" heading="3" colorLabel="2"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Oftentimes, the people regarded as the best to consult on the topic will not (at least outside of a paper or book) immediately use many of the best counterarguments or mention many of the important nuances relevant to the topic."/>
                    <outline text="Oftentimes the best people to talk to for a given subject will not be available."/>
                  </outline>
                  <outline text="Finding good disagreers" heading="1" colorLabel="1" collapsed="true">
                    <outline text="[Measuring criticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IBGJau5KaVc-QdSibLKAw_4g)" heading="2" colorLabel="2"/>
                    <outline text="Knowledge of the subject" heading="1" colorLabel="2"/>
                    <outline text="Measuring open-mindednese" heading="2" colorLabel="4" collapsed="true">
                      <outline text="Open mindedness generally does not matter as much for finding good disagreers."/>
                    </outline>
                  </outline>
                  <outline text="Learning from counterarguments" heading="1" colorLabel="1" collapsed="true">
                    <outline text="It&apos;s important to focus on understanding and adequately representing their position. The point is __not__ to argue with them or prove them wrong, the point is to learn from them." _note="Link goal and strawmanning here"/>
                    <outline text="Directly" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Learning from them directly, like being in a chat or call with them, or talking with them in-person."/>
                      </outline>
                      <outline text="You might also want to ask them to focus on giving you the best arguments that they&apos;re aware of, if you suspect that they might otherwise give you worse ones that don&apos;t matter as much."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Search for counterarguments themselves" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Search for counterarguments using methods other than looking through the people who make them."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Limitations of finding people who disagree](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HjwbHT3pi8LNlyk5vnnBJIP7)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Facilitate group critical thinking" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition(s?)" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="Questioning others" heading="1" colorLabel="2"/>
                <outline text="Avoiding openly contesting others" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Avoid openly contradicting others in situations where the social consequences of openly contesting the common opinion would likely end unideally."/>
                </outline>
                <outline text="Handling people contesting each other" heading="3" colorLabel="2"/>
                <outline text="Other ways to facilitate objective means of evaluation and critical thinking practices as a group activity." _note="It feels like there should be more." colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Surrounding yourself with reasonable people" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Surrounding yourself with people who have the best effect on your reasoning possible."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[Reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_raNJnESo8Ou9VQyYZY7wWAQ)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Surrounding yourself with reasonable people is likely to increase the average amount of good feedback on how you reason that you get, which would likely help you learn how to reason better." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="[You reason like those around you](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=F58Yc-rkCgLlqPQYN9a1f4Dq)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="So surrounding yourself with more reasonable people will generally make you more reasonable." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="[Learning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Cf2EDQJtkVrNLpMxmcrhJ6em)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Being surrounded by reasonable people likely means having easy access to getting their help with reasoning about important things." _note="Relevance" colorLabel="4"/>
                    <outline text="^ This can help you learn the truth about various important topics." _note="Relevance" colorLabel="4"/>
                    <outline text="^ ^ Virtually any disagreement with sufficiently reasonable people (who hold the same relevant axioms) can be resolved." _note="Likelihood | Probably link in eg. importance of reasoning?" colorLabel="4" collapsed="true">
                      <outline text="[Zipf minimizes required things to consider to resolve a disagreement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QJLZsbFm-mktyktapw2vSK7c)" _note="Likelihood" colorLabel="4"/>
                      <outline text="If people agree on the relevant axioms, then they can theoretically exchange all the substantially relevant information required to have all the same knowledge, thus precluding them from realistically disagreeing after that point." _note="Likelihood"/>
                      <outline text="All disagreements about a particular belief must be entirely caused through disagreements about other beliefs." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="This isn&apos;t to say that things like biases don&apos;t play a role, just that the way in which they play a role must work through other beliefs. Eg. A bias might make someone hold absurd epistemic beliefs for a time, or manifest __as__ an absurd epistemic belief." collapsed="true"/>
                        </outline>
                        <outline text="All beliefs can be expressed in terms of [reasoning pyramids](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dMvgzBqEcT7ia_4DcBqtBeIJ), which is to say that all beliefs are entirely supported by other beliefs, or unsupported by anything ([non-circular axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd))."/>
                        <outline text="Axioms are beliefs."/>
                        <outline text="Supposing people hold the same axioms, differences in beliefs can only arise due to making mistakes or having different knowledge." collapsed="true">
                          <outline text="All mistakes would be resolvable if the one making the mistake had the knowledge that it is a mistake, by getting the relevant knowledge required to come to that conclusion."/>
                        </outline>
                      </outline>
                      <outline text="Likely resulting in one or both sides changing their mind in a way that more likely corresponds to reality." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="^ ^ Many disagreements with sufficiently reasonable people (who don&apos;t hold the same relevant axioms) can still be discussed in a manner that results in substantial learning." _note="Likelihood" colorLabel="4" collapsed="true">
                      <outline text="Oftentimes differences in relevant axioms is only part of the reason for the disagreement." _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="[Scrutiny-driven reasonableness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=L_ujkiY5bfRubhHcMywgm0EV)" heading="3" colorLabel="4" collapsed="true">
                    <outline text="When one is (or believes they will be) under scrutiny from people they perceive to be well-informed and interested in accuracy, they tend to be more reasonable." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Perceived **well-informedness** is correlated with perceived reasonableness." _note="Relevance" colorLabel="4"/>
                      <outline text="Perceived **interest in accuracy** is correlated with perceived reasonableness." _note="Relevance" colorLabel="4"/>
                      <outline text="Perceived **likelihood of being under scrutiny** is correlated with perceived reasonableness." _note="Relevance" colorLabel="4"/>
                      <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[Common requirement: audience scrutiny attributes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ac1UXB7JXCOEwWNKKR0jt6_h)" colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="Unintuitive" heading="3" colorLabel="4" collapsed="true">
                    <outline text="We tend to [believe / feel like] our reasoning is ultimately our resonponsibility, and that we are independent of effects like thsoe that we are surrounded with." colorLabel="4" collapsed="true">
                      <outline text="Particularly because there are many cases where we feel we are forced to be surrounded by much less reasonable people, and yet feel they do not have a substantial negative effect on our reasoning abilities." colorLabel="4" collapsed="true">
                        <outline text="This feeling is unjustified." colorLabel="4"/>
                        <outline text="^ We are almost always very bad at measuring our own reasoning abilities." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="[Difficulty of measuring reasonableness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WTxRFmcWv9yoBL6ew9GFo7Av)" _note="Likelihood" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="How to do" heading="1" colorLabel="2" collapsed="true">
                <outline text="Do not trust your [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) for deciding who to surround yourself with." collapsed="true">
                  <outline text="[Very unintuitive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yUv_lyMWyDMVpOSu7idtaoZc)" colorLabel="4"/>
                </outline>
                <outline text="[Measuring reasonableness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GwE6-NAbRo2iIVWkvYqwdzpK)" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="Reasonable people would provide a much more reasonable social [anchor/frame](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gqfxRHs-DUYtXdVA2pFuNEji), [Overton Window](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uN0SA7RJNS9CHXfwu6uBCV9g), and [in-group](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BO3hgdXGDMPCMKm_AFmDlaEk)." colorLabel="4"/>
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=pqLJHM1DMjTBOlRsyi6vQORW" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Isolating yourself from unreasonable people" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition (relatively)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Isolating yourself from relatively (compared to how reasonable you want to become) unreasonable people."/>
                <outline text="Isolation from them both in real life and online. Not only standard interactions but also things like eg. watching videos / reading books hosting/made by unreasonable people."/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Can heavily reduce the influence of unreasonable people on one&apos;s reasoning." colorLabel="4" collapsed="true">
                    <outline text="Would likely greatly reduce [groupthink](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1krHbDONylAxWz1bingFgOlj)." _note="Likelihood" colorLabel="4"/>
                    <outline text="Would likely reduce our picking up bad reasoning habits from unreasonable people." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="Likely to lead to (near-)complete social isolation." colorLabel="1" collapsed="true">
                    <outline text="There likely aren&apos;t many people at all who are relatively reasonable." _note="Likelihood | Link to section about lack of reasonable people" colorLabel="4" collapsed="true">
                      <outline text="Relatively reasonable compared to how reasonable you want to become." colorLabel="3"/>
                    </outline>
                    <outline text="(Near-)complete social isolation is likely bad for reasoning." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Likely to reduce one&apos;s [self-awareness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=02ErcrGfQIBieY8kw6Fke-Nc)." colorLabel="4" collapsed="true">
                        <outline text="Less opportunity to get feedback from others, to better know of one&apos;s own flaws." _note="Likelihood" colorLabel="4"/>
                        <outline text="[Self-awareness is very important for reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=jAmiCAtQEXf74hKxpluoNgtR)" _note="Relevance" colorLabel="4"/>
                        <outline text="[Self-awareness is already intrinsically difficult to get right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LuCflBI3wMIbWnoW2-SD3hc8)" _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="If one [surrounds themselves with reasonable people](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O2iKsShjtUBDRY5QCc-9lI4b) then it wouldn&apos;t be detrimental to reasoning." colorLabel="1" collapsed="true">
                        <outline text="[It&apos;s very difficult to properly measure reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WTxRFmcWv9yoBL6ew9GFo7Av)" _note="Relevance" colorLabel="1" collapsed="true">
                          <outline text="Therefore it&apos;s likely that in attempting to surround oneself with reasonable people, they would surround themselves with relatively unreasonable people." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="[Information bubbles may tend to be detrimental to reasoning.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kMNpRXMo-vp04h_9eQbkufVk)" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Can be detrimental to one&apos;s social abilities." colorLabel="1" collapsed="true">
                    <outline text="[Charisma is very important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LtcBfo2RuztvWpykt_vhjv1E)" heading="3" colorLabel="4"/>
                    <outline text="If one already has a decent amount of social experience, this should just manifest at becoming temporarily rusty. It shouldn&apos;t be too difficult to get back into &quot;social shape&quot; if/when the need arises, so long as there is some warning ahead of time." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="To do practically anything, we generally must at least frequently briefly interact with many unreasonable people." colorLabel="4" collapsed="true">
                    <outline text="This plausibly isn&apos;t too much interaction to reap many of the benefits from otherwise isolating from unreasonable people." _note="Relevance" colorLabel="1"/>
                  </outline>
                  <outline text="Most people become attached to friends/family/a partner/social interaction in general, such that separating would be a very painful process." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=O2iKsShjtUBDRY5QCc-9lI4b" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Common misconceptions" heading="1" colorLabel="1" collapsed="true">
              <outline text="[The implications of quick conclusions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=c14ZK5bPY5TJo_ZbcQAO99St)" heading="3" colorLabel="1"/>
            </outline>
            <outline text="Misc" heading="1" colorLabel="6" collapsed="true">
              <outline text="The implications of quick conclusions" heading="3" colorLabel="1" collapsed="true">
                <outline text="Very high cognitive speed" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The idea that when someone comes to a quick conclusion, it is due to very quickly consciously calculating many things."/>
                  </outline>
                  <outline text="This typically isn&apos;t true. Usually the person just had [previous thoughts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=10Zg_q4wbC_KG0o0ze6nfb2a) to work with."/>
                </outline>
                <outline text="Previous thoughts" heading="3" colorLabel="1"/>
                <outline text="[Presumptuous reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HN2qrBZiwD6d8vTcEpYp61yo)" heading="3" colorLabel="1"/>
              </outline>
              <outline text="Societal counterfactual thinking" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The idea that on a large scale, we work out the truth via a kind of societal counterfactual thinking, whereby groups/individuals with different beliefs debate until the society is won over by the victors."/>
                </outline>
                <outline text="Importance / Limitation" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="This kind of counterfactual thinking is quite limited by the general open mindedness of the society." colorLabel="1" collapsed="true">
                      <outline text="Sufficient [open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=z7LAOrlY0wVUk3aV25kvfWZe) in a given area is often required to adequately judge the victor of such debates, due to our https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7HyxLRMyYcuGQTUpyV2gLDq" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="1" colorLabel="3"/>
              <outline text="[Reasoning feedback](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7VkGKlZfqI3D-chGqzjjpwn)" heading="1" colorLabel="2"/>
              <outline text="[Reasoning mediums](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=r2dQTPlCik_c_rBtzWzSRO68)" heading="3" colorLabel="5" collapsed="true">
                <outline text="Cooperative reasoning is very different depending on the reasoning medium used."/>
              </outline>
            </outline>
          </outline>
          <outline text="Common errors" heading="1" colorLabel="2" collapsed="true">
            <outline text="Heavy [heuristic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK) usage" _note="Move the &quot;largely based on stupid patterns&quot; kinda stuff into the places dedicated to saying why they&apos;re good/bad, rather than being in the definitions, to make it feel less controversial and more understandable. Also perhaps change the name to &quot;topic-specific heuristics&quot; or create a section for that as well." heading="1" colorLabel="2" collapsed="true">
              <outline text="Definitions (and examples)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Reasoning that&apos;s based on a large collection of heuristics specific to various topics in which the reasoning is applied." _note="Write this (and child) in a better way." collapsed="true">
                  <outline text="Thinking of a subject (or collection of subjects) with intuitive pattern-reaction thinking based on patterns specific to the topic (or collection of topics) for the most part, instead of mostly applying a general reasoning system to all subjects."/>
                </outline>
                <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="People who use different collections of patterns for different kinds of reasoning."/>
                  <outline text="They don&apos;t super generally [apply concepts or learn things] in [abstract and broadly-applicable] ways."/>
                </outline>
                <outline text="[&quot;Act-based reasoning&quot; here refers to reasoning that&apos;s largely based on applying fundamental rules, habits and processes to all subjects.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lbqkfxoLw7gwtVVfwrSghuIv)" heading="3" colorLabel="3"/>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Social rules" collapsed="true">
                    <outline text="Family"/>
                    <outline text="Traditions"/>
                    <outline text="Relationships"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2">
                <outline text="Very unreliable" _note="Support" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Almost always heavily contributes to uncriticalness" _note="Likelihood | Support | Link criticalness" colorLabel="4"/>
                  <outline text="Significantly contributes to [unsystematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="Unsystematic reasoning [is very important to avoid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=RD-oTBdlq50cfCjfUvC8a3kJ)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Failure to broadly apply good reasoning" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                    <outline text="People are often very reasonable in some areas while being very unreasonable in others, in ways that can only be explained by the failure to apply the reasoning typically used in the first area for the second area." _note="Likelihood" colorLabel="4"/>
                    <outline text="^ In other words, a heavy reliance on topic-specific heuristics." colorLabel="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                <outline text="Something to learn to avoid, since it&apos;s much easier to learn good act-based reasoning than to refine rule-based reasoning enough to be as good."/>
              </outline>
              <outline text="Forms of rule-based reasoning" heading="3" colorLabel="2" collapsed="true">
                <outline text="Causes for different forms" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Environment" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="We often learn patterns for rule-based reasoning based on what we feel to be best given our environments."/>
                    </outline>
                    <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Conspiracy theorist" heading="3" collapsed="true">
                        <outline text="In a conspiracy theorist environment, people are much more likely to form positive patterns about claims like the earth being flat, and reasoning common among claims such as that. And negative claims about experts, so-called unquestionable facts, etc."/>
                      </outline>
                      <outline text="Good at critical thinking" heading="3" collapsed="true">
                        <outline text="In an environment that involves good critical thinking, people are much more likely to have positive associations about good critical thinking practices and negative associations with things like fallacious reasoning. "/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Consequences of the diversity of forms" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Rule-based reasoning doesn&apos;t necessarily preclude good reasoning" heading="3" collapsed="true">
                    <outline text="Rule-based reasoning can in some cases come pretty close to typical act-based reasoning on how well the reasoning is performed for some (or occasionally many) particular topics."/>
                  </outline>
                  <outline text="Rule-based reasoning can make [intelligent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hnV8L0txUJ0M9kO0XbPTh7wP) people very bad at reasoning" heading="3" collapsed="true">
                    <outline text="1. People can learn good patterns for some particular areas but not for others."/>
                    <outline text="2. People can learn terrible patterns in general but be highly genetically gifted to be [intelligent](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hnV8L0txUJ0M9kO0XbPTh7wP)."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Convincing rule-based reasoners" heading="3" colorLabel="2" collapsed="true">
                <outline text="Suggested method" _note="Define positive/negative patterns." heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="&quot;good&quot;/&quot;bad&quot; patterns" heading="3" collapsed="true">
                      <outline text="Patterns that a person has associations with that make them want to agree (&quot;good&quot;) or disagree (&quot;bad&quot;)."/>
                      <outline text="This definition is only meant for this context."/>
                    </outline>
                  </outline>
                  <outline text="Isn&apos;t this manipulation?" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Sort of, but:"/>
                    <outline text="1. If using a sufficiently broad definition of &quot;manipulation&quot;, we must conclude that basically any interaction with anyone/anything is a form of manipulation on such people, because they&apos;re usually being irrationally influenced (if influenced at all) by virtually everything due to how flawed rule-based reasoning is. So it isn&apos;t as though leaving them alone would make a substantial difference to how much they get manipulated."/>
                    <outline text="2. You can manipulate people in ways that benefit them. For example, it should theoretically be possible (albeit most likely quite difficult) to manipulate a rule-based reasoner to become an act-based reasoner."/>
                  </outline>
                  <outline text="1. Learn the &quot;good&quot;/&quot;bad&quot; patterns" heading="3"/>
                  <outline text="2. Minimize &quot;bad&quot; patterns" heading="3" collapsed="true">
                    <outline text="Hide the &quot;bad&quot; patterns until near the end of your reasoning" heading="3" collapsed="true">
                      <outline text="If you&apos;re trying to convince them of a point, usually they&apos;ve learned &quot;bad&quot; patterns around the common arguments against their position. So if you&apos;re going to present one of those arguments (or a form of them), it&apos;s usually best to build up most of the reasoning behind your argument in a way that isn&apos;t close enough for them to feel like it&apos;s the same counterargument they&apos;re familiar with. At the end you will usually be forced to use at least some of the &quot;bad&quot; patterns. But you can use the reasoning that they agreed with to minimize the distance you have to take them __after__ revealing the &quot;bad&quot; patterns. Alongside this, you should of course [maximize good patterns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HkDeHy_faRaPRhBO64fnrXlC)"/>
                    </outline>
                    <outline text="Words/phrases" heading="3" collapsed="true">
                      <outline text="Words/phrases are a very common source of &quot;good&quot;/&quot;bad&quot; patterns."/>
                    </outline>
                  </outline>
                  <outline text="3. Maximize &quot;good&quot; patterns" heading="3" collapsed="true">
                    <outline text="[Characterization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-RfRZ7650bJF8cl3dEY8_zE_)" heading="3"/>
                    <outline text="[Words/phrases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MGVb7u212ZC-hOMhZTWtA-AO)" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Act-based reasoning" heading="3" colorLabel="6" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="&quot;Act-based reasoning&quot; here refers to reasoning that&apos;s largely based on applying fundamental rules, habits and processes to all subjects." collapsed="true">
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="This still involves learning patterns and doesn&apos;t mean the absence of sbuconscious/intuition or the learning/application of irrational patterns for certain subjects."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Act-based reasoning can still be irrational if the fundamental rules being applied to all subjects are flawed." collapsed="true">
                    <outline text="The set of fundamental rules doesn&apos;t necessarily have to be the same as the set of axioms that the person accepts."/>
                  </outline>
                </outline>
                <outline text="Indications of act-based reasoning" _note="~Expert" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Asks why a lot maybe? Debates when disagrees even as a child? Maybe caused by parents entertaining questions?"/>
                </outline>
                <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="5"/>
              </outline>
            </outline>
            <outline text="Confirmatory thought" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="A reasoning process focused on justifying a pre-existing belief, where the mind selectively searches for, interprets, and remembers information that supports what it already thinks is true."/>
                <outline text="Distinction" colorLabel="3" collapsed="true">
                  <outline text="In some cases it can appear quite similar to someone who isn&apos;t doing this kind of reasoning, but who&apos;s focused on representing their position with all the arguments they think of first, and who doesn&apos;t acknowledge when they agree or think of counterarguments against their arguments."/>
                </outline>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-) is [common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-ydpOA4gbPjdmKKxg8w6xD8p)." colorLabel="4"/>
                </outline>
                <outline text="[Importance/limitations of starting with conclusion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Cu3RSaK4pPHrIt7Nykla2fjb)" colorLabel="2"/>
                <outline text="[Importance/limitations of assuming that you&apos;re right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8ojZB8gOuk6R2ugB4oFivsU4)" colorLabel="2"/>
                <outline text="[Importance/limitations of assuming that others are wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Rp5c1SqHvNU_BDsfyKqpro2X)" colorLabel="2"/>
                <outline text="[Importance/limitations of reasoning to convince others](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Z8wUBsj-8iBgQFuqtj3eI2xU)" colorLabel="2"/>
              </outline>
              <outline text="1. Starting with conclusion" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Typically" heading="3">
                    <outline text="In large part directed by [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)"/>
                    <outline text="Involving a strong feeling that the conclusion is true."/>
                  </outline>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-) contributes to how common it is." colorLabel="4"/>
                    <outline text="The way that [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I) works contributes to how common it is." colorLabel="4"/>
                    <outline text="You will find plenty of mention of how common it is in the relevant literature." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="High propensity for bad thinking" heading="3" colorLabel="1" collapsed="true">
                      <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" _note="Likelihood" colorLabel="4"/>
                      <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Because this often feels like stronger evidence than it is, and when under the influence of confirmation bias, one will accept this evidence without thinking further to consider the possible counters." colorLabel="4"/>
                      </outline>
                      <outline text="[Cherry-picking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VCYeE_G2-lkwQ6_S-w6A9idu)" _note="Likelihood" colorLabel="4"/>
                      <outline text="**Often causes:**   [assuming that you&apos;re right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oWcWJUZA0MYOjqvk9I0l2G7E)" _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Can sometimes be temporarily helpful" colorLabel="4" collapsed="true">
                      <outline text="Eg. When considering hypotheticals" _note="Link hypotheticals" colorLabel="6" collapsed="true">
                        <outline text="Eg. When [Steelmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LWB8YQUQupE7UQRtFL7J9g6w)" colorLabel="6"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Often causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="[Assuming that you&apos;re right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oWcWJUZA0MYOjqvk9I0l2G7E)" heading="3" colorLabel="1"/>
                  <outline text="Evolutionary social instincts to defend opinion" _note="Expand and link, maybe link to the open mindedness section about emotions or smth" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="2. Assuming that we&apos;re right" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Concluding that we&apos;re right with inadequate justification."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3"/>
                  <outline text="Impactful" heading="3"/>
                  <outline text="^ Often causes [assuming that other(s) are wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=525oYS_TiO4rZW4aUGvWXESU)." colorLabel="1"/>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Typically caused by [starting with the conclusion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PIiCWPph1BqajBwPGPDQGbWC)"/>
                </outline>
              </outline>
              <outline text="3. Assuming that other(s) are wrong" heading="3" colorLabel="1" collapsed="true">
                <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Believing that the other person of wrong without adequate justification."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3"/>
                  <outline text="Limitations" heading="3"/>
                  <outline text="^ Often causes [assuming the worst](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-jUllZ4uoC33mBPDTPjLyI3l)" colorLabel="1"/>
                </outline>
                <outline text="Assuming the worst" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Overconfidently believing that other(s) are stupid or have bad intentions rather than having different knowledge that leads to a different result, or believing otherwise due to a mere minor error."/>
                  </outline>
                  <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                    <outline text="[Assuming that other(s) are wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=525oYS_TiO4rZW4aUGvWXESU)"/>
                  </outline>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Typically largely caused by [assuming that you&apos;re right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oWcWJUZA0MYOjqvk9I0l2G7E)"/>
                  <outline text="Often partially caused by [lacking context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lVuocPQtbJr1T1UQTA9_LCyy)"/>
                </outline>
              </outline>
              <outline text="4. Reasoning to convince others" heading="2" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Reasoning primarily to convince others, rather than to find the truth."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3"/>
                  <outline text="Impactful" heading="3"/>
                  <outline text="^ [Importance / Limitations of &quot;winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=bHYsU7G2hrBNIUdF9-dmDjsv)" colorLabel="1"/>
                </outline>
                <outline text="Causes" heading="1" colorLabel="1" collapsed="true">
                  <outline text="[Assuming that you&apos;re right](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oWcWJUZA0MYOjqvk9I0l2G7E)" heading="3" colorLabel="1"/>
                  <outline text="[Assuming that other(s) are wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=525oYS_TiO4rZW4aUGvWXESU)" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Common causes/excuses" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" heading="3" colorLabel="1"/>
                <outline text="[&quot;Winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDxHpzr99Ib8E5XfGJAHVTzK)" heading="3" colorLabel="2"/>
                <outline text="[Steelmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LWB8YQUQupE7UQRtFL7J9g6w)" _note="???" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" heading="1" colorLabel="1"/>
                <outline text="[Rationalization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NaE-8bpB1ZDuRzcl_T3nNErK)" heading="1" colorLabel="1" collapsed="true">
                  <outline text="The most common form of confirmatory thought, involving beginning with a conclusion that was derived from [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)."/>
                </outline>
                <outline text="[Cherry picking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VCYeE_G2-lkwQ6_S-w6A9idu)" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Confirmatory reading/noting/citing, rather than necessarily or specifically confirmatory thinking."/>
                </outline>
                <outline text="[&quot;Winning&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDxHpzr99Ib8E5XfGJAHVTzK)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Fallacies" _note="Show how almost all of these are reducible to more fundamental mistakes." heading="1" colorLabel="5" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Specific instances of flawed (fallacious) reasoning in arguments*." collapsed="true">
                  <outline text="The arguments can be either formal or informal."/>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Most can be avoided using [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Most fallacies are implicitly avoided if you use systematic reasoning, which you should be doing anyway. So most are not very important to learn about specifically."/>
                </outline>
                <outline text="Learning isn&apos;t enough" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Merely learning about the fallacies will not make you much better at accounting for them. For that, you have to [form habits and practice processes that avoid falling into fallacious reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mwz5Ve2BffIKD_YiMRN4SJOU)"/>
                </outline>
              </outline>
              <outline text="How to view them" heading="3" colorLabel="2" collapsed="true">
                <outline text="Mostly common mistakes that people make. It is much less common for people to intentionally employ fallacies, though it does of course happen."/>
                <outline text="Most of these fallacies are best understood in terms of other, more fundamental reasoning practices, mistakes, etc." collapsed="true">
                  <outline text="They implicitly include most of these fallacies with most of their nuances."/>
                  <outline text="We mostly list all these fallacies so that you can easily find a good definition for them if someone mentions them."/>
                </outline>
              </outline>
              <outline text="Formal fallacies" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Formal fallacies occur when there is a problem with the form, or structure, of the argument, such that the argument is [invalid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa)."/>
                  <outline text="**Etymplogy:**   The word &quot;formal&quot; refers to this link to the __form__ of the argument."/>
                </outline>
                <outline text="Fallacies of presumption" _note="Maybe should be in informal fallacies?" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Fallacies that make presumptions, often in a hidden way. That is, they rely on hidden and unstated assumptions written, as it were, between the lines."/>
                  </outline>
                </outline>
                <outline text="Fallacies of ambiguity" heading="1" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Fallacies that involve one switching between meanings without acknowledging that they are doing so."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Informal fallacies" heading="1" colorLabel="2">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="An informal fallacy is an error in reasoning that occurs due to a problem with the __content__, rather than the form or structure, of the argument."/>
                </outline>
                <outline text="Irrelevance" heading="1" colorLabel="6" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Fallacies that employ irrelevant claims that typically feel relevant."/>
                    <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Fallacies of irrelevance"/>
                      <outline text="Fallacies of relevance"/>
                      <outline text="Relevance fallacies"/>
                    </outline>
                  </outline>
                  <outline text="General countermeasures" heading="1" colorLabel="6" collapsed="true">
                    <outline text="Causes" heading="1" colorLabel="5" collapsed="true">
                      <outline text="These fallacies depend on the use of information that may seem relevant to establishing the conclusion but isn’t really relevant after all."/>
                    </outline>
                  </outline>
                  <outline text="The genetic fallacy" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The fallacy in which arguments or information are dismissed or validated based solely on someone&apos;s or something&apos;s history, origin, or source rather than its current meaning or context."/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Wedding ring" heading="3" collapsed="true">
                          <outline text="You&apos;re not going to wear a wedding ring, are you? Don&apos;t you know that the wedding ring originally symbolized ankle chains worn by women to prevent them from running away from their husbands? I would not have thought you would be a party to such a sexist practice."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Nuances" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Common misconception" heading="3" collapsed="true">
                        <outline text="We should focus on what was said rather than the who said it." heading="3" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="The idea that it&apos;s always more reasonable to figure out if something is true on its own merit rather than to assume one way or the other based on where the information comes from."/>
                          </outline>
                          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                            <outline text="We can&apos;t learn much on our own." colorLabel="1" collapsed="true">
                              <outline text="It&apos;s unlikely that we can learn whether even a small fraction of the most important things are true based only on their own merit." _note="Likelihood" colorLabel="4" collapsed="true">
                                <outline text="We would have to learn enough to have the equivalent of several phds in fields such as logic, mathematics, philosophy, psychology, neurology, etc." _note="Likelihood" colorLabel="4"/>
                              </outline>
                            </outline>
                            <outline text="Focusing on who said what is often reliable." colorLabel="1" collapsed="true">
                              <outline text="If it&apos;s a relevant expert (or collection of experts, or even technology) who has a near-perfect track record about hundreds of similar claims, it seems likely that it will be true. And this often is the case." _note="Likelihood" colorLabel="4"/>
                            </outline>
                          </outline>
                          <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                            <outline text="An oversimplification that shouldn&apos;t be heavily relied on, but not a horrible rule of thumb if you have barely any time to think about something (which is almost never the case)."/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="1. We subconsciously associate things with their histories/origins to enough of an extent that during recollection, we have a very strong intuition that it is best to emphasize feature(s) of the associated history/origin in a way that is irrelevant to the current context. "/>
                      <outline text="2. We decide to follow and defend that intuition without sufficiently questioning it."/>
                      <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="1" colorLabel="2"/>
                      <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
                    </outline>
                    <outline text="Appeal to authority" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Definition (specific)" heading="3" colorLabel="3">
                        <outline text="An appeal to an inappropriate or clearly inadequate authority." collapsed="true">
                          <outline text="Inadequate after taking into account the other evidence presented."/>
                        </outline>
                        <outline text="The issue that the &quot;appeal to authority&quot; fallacy is meant to point out is the overconfidence people often have for certain authorities."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="My friend who is a scientist insists that global warming is not cause for alarm, and for me that is a good enough reason to accept her conclusion."/>
                        </outline>
                        <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Appeal to inappropriate authority."/>
                        </outline>
                        <outline text="Distinctions (important)" heading="3" colorLabel="3">
                          <outline text="&quot;An appeal to an authority.&quot;" heading="3" collapsed="true">
                            <outline text="It is not *intrinsically* unreasonable to &quot;appeal to an authority&quot; as defined here, because the authority in question may have the relevant expertise to be much more likely to be correct than an ordinary person, all else being equal. Therefore the authority&apos;s opinion may actually be very relevant and substantial evidence." colorLabel="1"/>
                            <outline text="^ Especially if the &quot;authority&quot; in question is the complete collection of relevantly qualified experts, as opposed to a specific expert." _note="Relevance" colorLabel="4" collapsed="true">
                              <outline text="Oftentimes, there are so many &quot;experts&quot; (and the process of picking who gets to become an &quot;expert&quot; is so problematic) that there are bound to be some specific so-called &quot;experts&quot; who have absurd views in their relevant field." _note="Likelihood" colorLabel="4"/>
                              <outline text="Example: Polls of the opinions of relevant scientists seem to show a consensus that global warming is a significant cause of alarm." colorLabel="6"/>
                            </outline>
                          </outline>
                          <outline text="[We should focus on what was said rather than the who said it](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OX68H_rbv6ALl6A6E_X2E0Pc)" heading="3" collapsed="true">
                            <outline text="[We should focus on both](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Tcx7-9H6qS3CAP63e4LNp8Lw)" heading="3" colorLabel="1"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="[Ad hominem](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PIhQJrDSFo0Z48InInK-u0Wh)" heading="1" colorLabel="2"/>
                    <outline text="[Naturalistic fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=l772s-XNogR_GYsI8PZBdDZH)" heading="1" colorLabel="2"/>
                  </outline>
                  <outline text="Ad hominem" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="An argumentative strategy that attacks the character, motive etc. of the person(s) associated with the argument, in a way that provides no sufficiently substantive evidence to be plausibly indicative of a relevant and important truth."/>
                      <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Personal attack"/>
                        <outline text="Abusive fallacy"/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Common" heading="3" collapsed="true">
                        <outline text="This fallacy is very common."/>
                      </outline>
                      <outline text="Impactful" heading="3"/>
                    </outline>
                    <outline text="Nuances" heading="3" colorLabel="2" collapsed="true">
                      <outline text="An argument against one&apos;s character can be given for a constructive purpose outside of furthering the primary topic. " collapsed="true">
                        <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Constructive criticism given mid-discussion."/>
                        </outline>
                      </outline>
                      <outline text="An argument against one&apos;s character can be genuinely relevant and impactful to the discussion." _note="Maybe move this limitations into above?" collapsed="true">
                        <outline text="Explanation" heading="3" colorLabel="3" collapsed="true">
                          <outline text="While we should not care intrinsically who gives an argument and should typically focus on the argument&apos;s validity and soundness, oftentimes who gave the argument will be extrinsically substantially relevant to the trustworthiness of the argument."/>
                        </outline>
                        <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Mid-discussion character criticism often causes people to get more defensive."/>
                          <outline text="Mid-discussion character criticism is often seen as a bad faith technique."/>
                        </outline>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="If one person states that they witnessed God, and the other person argues that the supposed witness often takes drugs that cause hallucinations, this attacks the reliability of the witness (at least insofar as the particular claim they made goes) in a relevant and impactful way."/>
                        </outline>
                      </outline>
                      <outline text="[We should focus on what was said rather than the who said it](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OX68H_rbv6ALl6A6E_X2E0Pc)" heading="3"/>
                    </outline>
                    <outline text="&lt;broken link&gt;" colorLabel="1"/>
                  </outline>
                  <outline text="Red herring" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The red herring is a seemingly plausible, though ultimately irrelevant, diversionary tactic."/>
                      <outline text="Examples" heading="3" colorLabel="6"/>
                      <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                        <outline text="This is distinct from red herrings as literary devices for eg. mystery novels."/>
                      </outline>
                    </outline>
                    <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Easily misattributable to genuinely important and relevant [deep dives](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=iFjccGMkfI0qrorobVMX02-i) into important and relevant details primarily involving other topics."/>
                    </outline>
                    <outline text="Nuances" heading="3" colorLabel="2" collapsed="true">
                      <outline text="A red herring may be intentional or unintentional; it is not necessarily a conscious intent to mislead."/>
                    </outline>
                  </outline>
                  <outline text="Appeal to popularity" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Bandwagon fallacy"/>
                      </outline>
                    </outline>
                    <outline text="Nuances" heading="3" colorLabel="2" collapsed="true">
                      <outline text="[We should focus on what was said rather than the who said it](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OX68H_rbv6ALl6A6E_X2E0Pc)" heading="3"/>
                    </outline>
                  </outline>
                  <outline text="Appeal to consequences" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Rejecting some particular viewpoint, theory or idea based on the consequences to which it leads, typically because of a negative emotional reaction to those consequences."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="It is usually irrelevant whether or not we like or want to believe something, truth is indifferent to feelings."/>
                      </outline>
                      <outline text="Common" heading="3"/>
                    </outline>
                  </outline>
                  <outline text="Appeal to emotion" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The fallacy that intends to manipulate the recipient&apos;s emotions in order to win an argument." collapsed="true">
                        <outline text="**Source:**   https://en.wikipedia.org/wiki/Appeal_to_emotion" colorLabel="6"/>
                      </outline>
                      <outline text="**Often:**   In the absence of factual evidence."/>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Charity advertisement" heading="3" collapsed="true">
                          <outline text="A charity advertisement showing a single suffering child, eyes wide, belly descended. Statistics about millions in need remain abstract, but this one face breaks through our defenses. Our wallets open not because we&apos;ve evaluated the charity&apos;s effectiveness or administrative overhead, but because we cannot bear the weight of those eyes. The emotion becomes the argument."/>
                        </outline>
                        <outline text="Crime statistics" heading="3" collapsed="true">
                          <outline text="Crime statistics might show historic lows, but one brutal incident (properly packaged) overrides decades of data. The politician who practices safety from the manufactured threat wins over the one citing improvement trends. Parents clutch their children tighter, vote for harsher measures, support policies they would reject in calmer moments. Fear doesn&apos;t require facts."/>
                        </outline>
                        <outline text="Product commercials" heading="3" collapsed="true">
                          <outline text="A lot of advertising is created and followed not because of a fallacy, but because of social expression. i.e. Socially expressing certain characteristics about one&apos;s self by buying products with advertisements associated with those characteristics." colorLabel="1" collapsed="true">
                            <outline text="[Source](https://www.youtube.com/watch?v=GFYasDoJ-98)" heading="3" colorLabel="6"/>
                          </outline>
                          <outline text="The car commercial doesn&apos;t list specifications or safety ratings, instead, it shows a father driving his daughter to her wedding, both of them crying." colorLabel="4"/>
                          <outline text="The watch advertisement ignores precision engineering, focusing on a grandfather passing his timepiece to his grandson. We buy the emotion, not the product." colorLabel="4"/>
                        </outline>
                        <outline text="Climate change" heading="3" collapsed="true">
                          <outline text="Climate change discussions devolve into pictures of polar bears on shrinking ice vs images of unemployed coal miners."/>
                        </outline>
                        <outline text="Healthcare reform" heading="3" collapsed="true">
                          <outline text="Healthcare reform gets buried under individual tragedies from both sides. The emotional ammunition flies, while substantive policy discussion dies in the crossfire."/>
                        </outline>
                        <outline text="[Source](https://youtu.be/GpFS9pDrNhM)" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Taken virtually verbatim from the linked video."/>
                          <outline text="Seems AI genned, but I think the examples still largely work."/>
                        </outline>
                      </outline>
                      <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                        <outline text="It is only fallacious when the emotions that are elicited are irrelevant to evaluating the truth of the conclusion and serve to distract from rational consideration of relevant premises or information."/>
                        <outline text="Merely including emotions in some premises in an argument is not sufficient to count as a form of appealing to emotions." collapsed="true">
                          <outline text="Eg. If I feel frustrated, then I will likely yell. I feel frustrated, therefore I will likely yell." _note="This is not a fallacious argument, unless perhaps it is implied that the listener(s) ought to do something as a result of this argument." colorLabel="6"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Types" heading="1" colorLabel="5" collapsed="true">
                      <outline text="[Appeal to fear](https://en.wikipedia.org/wiki/Appeal_to_fear)" heading="3" colorLabel="2"/>
                      <outline text="[Appeal to flattery](https://en.wikipedia.org/wiki/Appeal_to_flattery)" heading="3" colorLabel="2"/>
                      <outline text="[Appeal to pity](https://en.wikipedia.org/wiki/Appeal_to_pity)" heading="3" colorLabel="2"/>
                      <outline text="[Appeal to ridicule](https://en.wikipedia.org/wiki/Appeal_to_ridicule)" heading="3" colorLabel="2"/>
                      <outline text="[Appeal to spite](https://en.wikipedia.org/wiki/Appeal_to_spite)" heading="3" colorLabel="2"/>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Appeal to consequences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fYoI4jUDOc5HAoMP_GDmv2PD)" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Often has overlap with this."/>
                      </outline>
                      <outline text="[Wishful thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GSuqwuWjSYY3yCdYSuAEztWz)" heading="3" colorLabel="1" collapsed="true">
                        <outline text="A common bias preyed on by this fallacy."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Misc" heading="1" colorLabel="6" collapsed="true">
                    <outline text="Unimportance" heading="3"/>
                    <outline text="Naturalistic fallacy" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Assuming that something is better because it is natural, without anywhere near sufficient justification for the assumption that natural things are more likely to be better."/>
                      </outline>
                      <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Some people hold beliefs that (at least in their opinion) justify the conclusion that natural things are typically better. This is not an example of the naturalistic fallacy since it is not assuming that natural things are better without any reason."/>
                      </outline>
                    </outline>
                    <outline text="Appeal to force" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3"/>
                    </outline>
                    <outline text="Weak analogy" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="An insufficient analogy."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Galileo and freemasons" heading="3" collapsed="true">
                            <outline text="Galileo was ridiculed because of his views, and these views later proved to be correct."/>
                            <outline text="I too am ridiculed for believing that the Pope is a reptilian alien in league with the Freemasons."/>
                            <outline text="Thus I too will have my day and my views will be accepted."/>
                            <outline text="The issue" heading="3" colorLabel="1" collapsed="true">
                              <outline text="The main issue is the &quot;thus&quot;, since that implies that the preceding statements should substantially support the ending."/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                        <outline text="It&apos;s easy to mistakenly attribute the fallacy to sufficiently strong analogies."/>
                      </outline>
                      <outline text="[Analogical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=y83CLm4PtT9N4Nk3aCZBPJq5)" heading="1" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Ambiguity" heading="1" colorLabel="6" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Fallacies involving switching between meanings without acknowledging that one is doing so."/>
                  </outline>
                  <outline text="Strawman" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A statement that misrepresents (intentionally or unintentionally) other statement(s)."/>
                      <outline text="Memorable" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Prop up a weak argument that&apos;s more easy to knock down, like propping up a person made of straw."/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Common" heading="3" collapsed="true">
                        <outline text="People frequently strawman each other"/>
                      </outline>
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Strawmans often cause major and quite impactful misunderstandings when people misunderstand each other."/>
                      </outline>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Steelmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LWB8YQUQupE7UQRtFL7J9g6w)" heading="1" colorLabel="2"/>
                    </outline>
                  </outline>
                  <outline text="Equivocation" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Equivocation is using multiple meanings of a word as if they were the same." collapsed="true">
                        <outline text="Specifically multiple **non-synonymous** meanings."/>
                      </outline>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Prisoners are free" heading="3" collapsed="true">
                          <outline text="Prisoners are really free. This is because if you can think whatever you want, then you are free and prisoners can certainly think whatever they want."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Reversed stupidity is not intelligence" heading="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="&quot;Reversed stupidity&quot; here means the &quot;opposite&quot; of &quot;stupidity&quot;." collapsed="true">
                          <outline text="[&quot;Opposite&quot; being defined vaguely in one of several ways](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AJBb8wh2Ihx1GcBVC84TTA8O)"/>
                        </outline>
                      </outline>
                      <outline text="Very broken ≠ capable at &quot;opposite&quot;" heading="3" collapsed="true">
                        <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                          <outline text="That something is very bad at doing one thing doesn&apos;t mean it&apos;s very good at doing the &quot;opposite&quot;."/>
                          <outline text="&quot;Opposite&quot; being defined vaguely in one of several ways." collapsed="true">
                            <outline text="It might mean the [inverse](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j3H0k5NrgqqJ2__9SgtP8ngy) / [converse](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hn5cIVc2DKo-2jmUg5S_fwSh) of the belief(s) that were stupidly derived."/>
                            <outline text="It might mean the logical negation of the belief(s) that were stupidly derived."/>
                          </outline>
                          <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                            <outline text="A car with a broken engine cannot drive backward at 200 mph, even if the engine is really really broken."/>
                          </outline>
                        </outline>
                        <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                          <outline text="[Superintelligent stupidity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0TqLxMx-Szy_DkKna7mzLrt_)" heading="3"/>
                        </outline>
                      </outline>
                      <outline text="Superintelligent stupidity" heading="3" collapsed="true">
                        <outline text="If you knew someone who was wrong 99.99% of the time on yes-or-no questions, you could obtain 99.99% accuracy just by reversing their answers. They would need to do all the work of obtaining good evidence entangled with reality, and processing that evidence coherently, just to __anticorrelate__ that reliably. They would have to be superintelligent to be that stupid."/>
                        <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                          <outline text="[Very broken ≠ capable at &quot;opposite&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=4PpU1Sktv3zM589PwF4pUwjv)" heading="3"/>
                        </outline>
                      </outline>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="“The world’s greatest fool may say the Sun is shining, but that doesn’t make it dark out.”"/>
                      </outline>
                    </outline>
                    <outline text="Associating with believers/disbelievers" heading="3" collapsed="true">
                      <outline text="Negative association" heading="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                            <outline text="Some people may be reluctant to believe that God doesn&apos;t exist, not because there is evidence that God does exist, but rather because they are reluctant to affiliate with Richard Dawkins or those darned “strident” atheists who go around publicly saying “God does not exist.”"/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Positive association" heading="3"/>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" heading="3" colorLabel="3"/>
                    </outline>
                  </outline>
                  <outline text="Cherry-picking" _note="Link in induction" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Selectively reading, noting or citing the evidence in favor of your own hypothesis, or “cherry picking” the data to get the parts that support your hypothesis."/>
                      <outline text="**Typically:**   often ignoring things that contradict it."/>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Essentially cherry-picking what you think about, rather than what you read/note/cite."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Texas sharp-shooter" _note="Link in induction" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3"/>
                  </outline>
                  <outline text="Composition" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The inference that something is true of the whole merely because it is true of some part of the whole."/>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Tire, vehicle, rubber" heading="3" collapsed="true">
                          <outline text="This tire is made of rubber; therefore, the vehicle of which it is a part is also made of rubber." collapsed="true">
                            <outline text="This is fallacious, because vehicles are made with a variety of parts, most of which are not made of rubber."/>
                          </outline>
                        </outline>
                        <outline text="Atoms, sets of atoms, life" heading="3" collapsed="true">
                          <outline text="No atoms are alive. Therefore, nothing made of atoms is alive." collapsed="true">
                            <outline text="This is a statement most people would consider incorrect, due to emergence, where the whole possesses properties not present in any of the parts."/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="The [converse](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hFk3VZ444mAV4Q2_NN6-xWr5) of [division](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Clm7YytA7OR8d3E5z9U0OuGf)" heading="3"/>
                    </outline>
                    <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="The fallacy of composition can apply even when a fact is true of every [proper part](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dhDE7pPnq-_CrD9g7LqP-Wcy) of a greater entity." collapsed="true">
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="[Atoms, sets of atoms, life](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=IR9c-gXVAZT1UJQUZ14Bs4_d)"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Division" heading="1" colorLabel="2"/>
                </outline>
                <outline text="Presumption" heading="1" colorLabel="6">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Errors in reasoning where the premises rely on [unstated and insufficiently justified] assumptions."/>
                  </outline>
                  <outline text="Mere assertion" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="An assertion made without any evidence."/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Abortion is just wrong, and that is all there is to it."/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Mere assertions are often very confidently asserted, which can make them feel like much stronger evidence than they really are."/>
                      </outline>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Partially reducible to faulty [heavy heuristic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)"/>
                      <outline text="Partially reducible to a lack of [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" collapsed="true">
                        <outline text="If systematic reasoning was employed, it would likely be quite clear that the statement is unsupported."/>
                      </outline>
                      <outline text="Partially reducible to a lack of [other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)"/>
                    </outline>
                    <outline text="Slippery slope" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3"/>
                    </outline>
                  </outline>
                  <outline text="Appeal to ignorance" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A direct appeal to the lack of evidence in favor of something, with the intent of definitively proving that the something is false."/>
                    </outline>
                    <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="It&apos;s very easy to mistake this with the appeal to the lack of evidence __without__ the intent to definitively disprove it, particularly when they are implicitly relying on [occam&apos;s razor](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UULVW93uPNRrRBC6RL4mTOjT) or something."/>
                    </outline>
                    <outline text="reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Partially reducible to faulty [probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)"/>
                    </outline>
                  </outline>
                  <outline text="False dilemma" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A presented dilemma between an incomplete set of options, without the remaining members being sufficiently implied."/>
                      <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                        <outline text="False dichotomy/trichotomy/etc."/>
                        <outline text="Black or white fallacy"/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="We are typically biased to fall for false dilemmas." collapsed="true">
                          <outline text="[&lt;broken link&gt;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AD9hC2YbbBV8QT-gHvIFussM)" heading="3" colorLabel="1"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Partially reducible to the failure of sufficiently [accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK)"/>
                    </outline>
                    <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  </outline>
                  <outline text="Hasty generalization" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Generalizations made with pretty obviously too little justification."/>
                      <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Law of small numbers"/>
                      </outline>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="All three of my ex-wives always told me what to do. This clearly shows that all women want to control us men all the time."/>
                      </outline>
                      <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Faulty_generalization#Hasty_generalization)" _note="Pull a bunch from this"/>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Partially reducible to faulty [probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)"/>
                    </outline>
                  </outline>
                  <outline text="False cause" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Assuming that because two events are correlated and/or related and/or one precedes the other by a relevant amount of time, that means one causes the other."/>
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="My alarm goes off every morning before sunrise, therefore my alarm causes the sun to rise."/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3"/>
                      <outline text="Common" heading="3"/>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Partially reducible to faulty [heavy heuristic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)"/>
                    </outline>
                    <outline text="Correlation ≠ causation" heading="1" colorLabel="4"/>
                  </outline>
                  <outline text="Secundum quid" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The fallacy of failing to recognize the difference between rules that are generally true (but still leave room for exceptions) and rules that are always true."/>
                      <outline text="Synonyms" colorLabel="3" collapsed="true">
                        <outline text="Since it ignores the limits/qualifications of general rules, this fallacy is also named:"/>
                        <outline text="**Ignoring qualifications**"/>
                        <outline text="**Sweeping generalizations**"/>
                        <outline text="The expression **misuse of a principle** can be used as well."/>
                      </outline>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[Accident fallacy example](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LCZswhmPXsGOVDlE72Cn8kUC)"/>
                        <outline text="[Converse accident fallacy example](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_VgiDs-odwhsR9N4DYr1CXGL)"/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3"/>
                      <outline text="Common" heading="3" collapsed="true">
                        <outline text="Despite being lesser known than many other fallacies, this is still a very common fallacy."/>
                        <outline text="[Examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dupzgbswSnbg0GWH1PkzG-nO)" heading="3" colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="Substantially reducible to faulty [heavy heuristic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)"/>
                    </outline>
                    <outline text="Accident fallacy" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The fallacy of applying a general rule to an exceptional case (one in which some special circumstance (“accident”) makes the rule inapplicable)."/>
                        <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                          <outline text="**Destroying the exception**"/>
                          <outline text="**A dicto simpliciter ad dictum secundum quid**"/>
                        </outline>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Blind people" heading="3" collapsed="true">
                            <outline text="The fact that “people are capable of seeing” is insufficient for the conclusion that “blind people are capable of seeing.”" collapsed="true">
                              <outline text="In this context, &quot;people are capable of seeing&quot; is defined as something like &quot;in general, people are capable of seeing&quot;, which is insufficient (in light of our evidence that blind people exist) to establish that there are no blind people."/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Common" heading="3"/>
                      </outline>
                      <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                        <outline text="https://en.wikipedia.org/wiki/Accident_(fallacy)"/>
                      </outline>
                    </outline>
                    <outline text="Converse accident fallacy" heading="1" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The fallacy of applying a rule (that only applies to some exceptional cases) to all cases in general."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="1. The [Tunguska explosion](https://en.wikipedia.org/wiki/Tunguska_event) happened in Siberia."/>
                          <outline text="2. [Magnitogorsk Iron and Steel Works](https://en.wikipedia.org/wiki/Magnitogorsk_Iron_and_Steel_Works) is in Siberia."/>
                          <outline text="3. This is a bad company to invest in because it&apos;s just going to be destroyed by a meteorite."/>
                          <outline text=""/>
                          <outline text="Here, a general rule is mistakenly made (that places in Siberia are likely to be destroyed by meteors in the foreseeable future) based on one exceptional case."/>
                        </outline>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2"/>
                      <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                        <outline text="https://en.wikipedia.org/wiki/Converse_accident"/>
                      </outline>
                      <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[Slippery slope](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=q8f2vFegczgxQcWuoRciRil1)" heading="3" colorLabel="2"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="[Circularity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ikMYp91GwlvLX0gZwMfCovX_)" heading="1" colorLabel="2"/>
                  <outline text="Anecdotal fallacy" heading="1" colorLabel="2">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The fallacy of placing undue weight on experiences of close peers."/>
                      <outline text="^ Often atypical experiences."/>
                      <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Argument from anecdote"/>
                        <outline text="&quot;person who&quot; fallacy"/>
                      </outline>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                        <outline text="[Anecdotal evidence is common](https://dynalist.io/d/axyUc8EpOb4NEwUA5hpTKBU1#z=dguLUeGiyxzDZakD4UifdIAN)" _note="Likelihood" colorLabel="4"/>
                        <outline text="[Anecdotal evidence is often unreliable](https://dynalist.io/d/axyUc8EpOb4NEwUA5hpTKBU1#z=STq7W1pdf1cJ1xEjskutHmGg)" _note="Likelihood" colorLabel="4"/>
                        <outline text="Thus it&apos;s important to learn how to spot and avoid it." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Reducible" heading="3" colorLabel="5" collapsed="true">
                      <outline text="In cases involving our own anecdotal evidence" heading="3" collapsed="true">
                        <outline text="[Specific/&quot;grounded&quot; bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" heading="3" colorLabel="1" collapsed="true">
                          <outline text="We typically feel like experiences that have happened to us are more real than those that have happened to others, and are thus stronger evidence, even in cases where they aren&apos;t." _note="Likelihood" colorLabel="4" collapsed="true">
                            <outline text="Eg. We sometimes don&apos;t look at it from the perspective of the person we&apos;re sharing the anecdote with, who hasn&apos;t had the experience we have and thus should weight it according to how much they trust our reliability." _note="Likelihood" colorLabel="4"/>
                            <outline text="Eg. We sometimes make generalizations based on our personal experiences even when our personal experiences are pretty limited and reliable statistics indicate otherwise." _note="Likelihood" colorLabel="4"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Common forms" heading="3" colorLabel="2" collapsed="true">
                      <outline text="&quot;I know a person who...&quot;"/>
                      <outline text="&quot;I know of a case where...&quot;"/>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6">
                      <outline text="[Anecdotal evidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rP6G0D6KrdxKx1tz39CYdv-T)" heading="1" colorLabel="4"/>
                      <outline text="[faulty generalization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ecu_HuUAoK7nIZBDmynRINzl)" _note="Probably rename &quot;hasty generalization&quot; section (linked here) to &quot;faulty generalization&quot;. Or else probably change this text." heading="3" colorLabel="1" collapsed="true">
                        <outline text="If an anecdote is used to justify a desired conclusion without the anecdote providing nearly as much support as intended, it is considered a faulty generalization." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Presumptuous reasoning" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Recognizing presumptuous reasoning" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common forms" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Common forms of presumptuous reasoning."/>
                  </outline>
                  <outline text="[Presumption](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=L9ETyQmgiS8qHo_zlxHdFzdm)" heading="2" colorLabel="6"/>
                  <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="1"/>
                </outline>
                <outline text="Commonly confused non-forms" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Forms/types/cases of reasoning that are frequently mistakenly considered to be presumptuous."/>
                  </outline>
                  <outline text="Quick conclusions" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The idea that when someone comes to a quick conclusion, it is due to inadequate thinking about the subject."/>
                    </outline>
                    <outline text="Explanations" heading="1" colorLabel="6" collapsed="true">
                      <outline text="People often have sufficient [previous thoughts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=10Zg_q4wbC_KG0o0ze6nfb2a) that they used to reach their conclusion."/>
                      <outline text="Some seemingly complex matters are much less complex than they seem." collapsed="true">
                        <outline text="So it is possible to arrive at a conclusion much quicker than might otherwise be expected."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Preventing presumptuous reasoning" heading="3" colorLabel="2"/>
              <outline text="Addressing presumptuous reasoning" heading="3" colorLabel="2"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Fallacies of presumption](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=L9ETyQmgiS8qHo_zlxHdFzdm)" heading="3" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49)" heading="3" colorLabel="2"/>
            </outline>
          </outline>
          <outline text="Reasoning self-improvement" heading="1" colorLabel="1" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Literal self-improvement of reasoning. Without some of the common connotations of &quot;self-improvement&quot;."/>
            </outline>
            <outline text="Recognizing mistakes" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Realizing when you&apos;re wrong due to faulty reasoning."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" colorLabel="4"/>
                <outline text="Realizing when you&apos;ve relied on faulty reasoning is crucial for improvement." colorLabel="4"/>
                <outline text="Typically increases general open mindedness" _note="PC fix" colorLabel="4" collapsed="true">
                  <outline text="By more often recognizing mistakes, one typically forms more/stronger associations about their own reasoning being imperfect." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="This generally reduces epistemic self-confidence." _note="Relevance | Link epistemic self-confidence" colorLabel="4" collapsed="true">
                      <outline text="This generally increases open-mindedness." _note="Relevance | Link item about epistemic self-confidence typically being correlated with lesser open-mindedness." colorLabel="4"/>
                    </outline>
                    <outline text="This generally increases self-awareness." _note="Relevance | Link self-awareness" colorLabel="4" collapsed="true">
                      <outline text="By forming habits about the imperfections of one&apos;s own reasoning, one will more often recall it when relevant and then look at their own reasoning more critically in that moment." _note="Likelihood" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Open mind importance" _note="Relevance | Link" colorLabel="4"/>
                  <outline text="Typically increases self-awareness." _note="Relevance | Move" colorLabel="4" collapsed="true">
                    <outline text="Being more open minded to counterarguments typically involves being more open-minded to the possibility of being wrong, which typically involves being more open-minded to the possibility that one&apos;s reasoning is flawed, which typically involves more self-awareness." _note="Likelihood" colorLabel="4"/>
                    <outline text="Self-awareness helps one recognize some of their other mistakes in the future, by helping them recognize how their own reasoning flaws work and impact their own reasoning." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="Self-awareness is awareness of the self, and [how one&apos;s reasoning flaws work and impact one&apos;s own reasoning] is typically a big part of their self." _note="Likelihood" colorLabel="4"/>
                    </outline>
                    <outline text="Self-awareness helps increase self-awareness." _note="Relevance" colorLabel="4"/>
                    <outline text="Self-awareness helps increase general open mindedness." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Typically increases general open mindedness." _note="Relevance | Move" colorLabel="4"/>
                </outline>
                <outline text="Typically increases open mindedness in the moment" _note="Fill out" colorLabel="4" collapsed="true">
                  <outline text="Typically helps with immediate self-awareness." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Acknowledging mistakes" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Admitting that you made mistake(s)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="**Recognizing degree of mistakes:**   Without acknowledgement, we are much more likely to greatly underestimate our mistakes." colorLabel="4" collapsed="true">
                  <outline text="Sometimes even to the degree of not recognizing them as mistakes at all." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="**Remembering:**   Without acknowledgement, we are much more likely to forget about our mistakes." colorLabel="4" collapsed="true">
                  <outline text="We often only have the faintest notion that they might be mistakes, before immediately forgetting via habitual thought suppression." _note="Likelihood &amp; Relevance | Move to rationalization (or similar) and link here" colorLabel="4" collapsed="true">
                    <outline text="We typically have habits to rationalize our position (especially to defend it to others), and this thought suppression is an extremely useful habit for effective rationalization." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="**Compelling improvement:**   Without acknowledgement of mistakes, we typically feel much less compelled to improve on our biggest weaknesses." colorLabel="4" collapsed="true">
                  <outline text="We tend not to naturally feel very compelled to improve on our biggest reasoning weaknesses." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="We typically don&apos;t recognize our biggest weaknesses as such." _note="Likelihood" colorLabel="4"/>
                    <outline text="^ If we did naturally recognize them as such, we would have likely already improved them." _note="Likelihood" colorLabel="4"/>
                    <outline text="Therefore getting into the habit to [do things (such as acknowledge mistakes) in order to further compel ourselves] is very important for making big improvements." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Usually, some of our biggest weaknesses are among the most important areas to improve on." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Internal and external acknowledgement" heading="1" colorLabel="6" collapsed="true">
                <outline text="Internal acknowledgement" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Acknowledging one&apos;s mistake(s) to themselves."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Consciously improving from mistakes requires acknowledging them at least internally." collapsed="true">
                      <outline text="Oftentimes there&apos;s a little feeling/intuition that something might be a mistake, but we haven&apos;t really consciously acknowledged it as such."/>
                      <outline text="If we don&apos;t consciously acknowledge it, the feeling/intuition will typically fade away and leave us with no way to improve."/>
                    </outline>
                    <outline text="[Long-term open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=F2BJsS6OGWLKLX02yY7kMCeM)" heading="3"/>
                    <outline text="[Immediate open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N2Ryo-Ll-udSEK1t6QjA_iNX)" heading="3"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="This typically doesn&apos;t make the mistake(s) feel as real/significant as [external acknowledgement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AcL_5ai3F6ZI2uJnP1Qp3lGG)"/>
                  </outline>
                </outline>
                <outline text="External acknowledgement" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Acknowledging one&apos;s mistake(s) to other(s)."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="This makes it much harder to delude yourself about how many mistakes you actually make." collapsed="true">
                      <outline text="This typically makes it much harder to forget about mistakes."/>
                    </outline>
                    <outline text="[Long-term open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=F2BJsS6OGWLKLX02yY7kMCeM)" heading="3"/>
                    <outline text="[Immediate open-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N2Ryo-Ll-udSEK1t6QjA_iNX)" heading="3"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Consistency" _note="Organize" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s often easy to acknowledge small mistakes, or even major ones (in terms of how bad the reasoning was) if the impact was relatively insignificant."/>
                <outline text="But it&apos;s often significantly harder for us to acknowledge (or even recognize) bigger mistakes, so learning to acknowledge those is really the main importance of acknowledging mistakes in general. Though getting into the habit of acknowledging small mistakes probably helps with acknowledging bigger ones."/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[(Un)conservative claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=clC-svjqyNajpM81R8mrQFEl)" heading="3" colorLabel="2"/>
                <outline text="[Inflammatory statements](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cdf2M2ciEV3h0SaelXqPiXwU)" heading="3" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Analyzing your own discussions" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="There ordinarily isn&apos;t a clear feedback mechanism that works well for reasoning, so analyzing your own discussions can be a very helpful process."/>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2"/>
              <outline text="Analyzing a past discussion" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="We typically miss a lot of our own mistakes in the midst of our discussions, looking back at them (especially with the context of the things that are said later on) can sometimes help us see where our reasoning was flawed, which is useful to learn from our mistakes and change our minds."/>
                  <outline text="It can often be relatively stress-free, since it&apos;s after the discussion is already over. And you can do it alone so that there&apos;s no one to judge you except yourself."/>
                </outline>
              </outline>
              <outline text="Analyzing a current discussion" heading="1" colorLabel="2" collapsed="true">
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This often doesn&apos;t give you the full picture of a lot of things that become clearer after a discussion has finished."/>
                  <outline text="You&apos;re mind is typically pretty occupied with the discussion you&apos;re having. Trying to analyze your discussion at the same time is likely going to involve making significant mistakes in one or both." collapsed="true">
                    <outline text="An exception possibly being when responses are on a very large delay or something."/>
                  </outline>
                </outline>
                <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Typically a much worse way to do it."/>
                </outline>
              </outline>
            </outline>
            <outline text="Solo analysis" _note="~~Mostly expert, some parts belong in lower levels" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Analyzing things on your own."/>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2"/>
              <outline text="Talking to yourself" heading="1" colorLabel="2" collapsed="true">
                <outline text="Plausibly has benefits with remembering." colorLabel="1"/>
                <outline text="Plausibly has benefits with getting into character for multiple sides." colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Questioning old beliefs" _note="~~Advanced, link elsewhere in practical techniques probably." heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Even if you&apos;re perfect at reasoning right now, you&apos;ve surely formed many fundamental beliefs while you were previously not great at reasoning. So revisiting and updating your confidence for those beliefs is very important." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="What beliefs to look for" heading="1" colorLabel="2" collapsed="true">
                <outline text="Old" heading="3" collapsed="true">
                  <outline text="Especially from when you were not very good at reasoning."/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Justifying some very impactful belief(s) of yours."/>
                </outline>
              </outline>
              <outline text="How to question them" heading="1" colorLabel="2" collapsed="true">
                <outline text="Look for hidden premises" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Systematically map out your reasoning for the belief, ideally formally, and don&apos;t settle until the conclusion deductively follows from the premises (though including induction in premise(s) and the conclusion is fine)."/>
                </outline>
                <outline text="Look for unsupported premises" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Look for weaknesses in the premises." _note="Link some stuff here."/>
                </outline>
              </outline>
            </outline>
            <outline text="Finding weaknesses" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Finding your own weaknesses."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Often we are not aware of many of our weaknesses, because the weaknesses we are not aware of are much more likely to remain, whereas we usually solve many that we are aware of."/>
              </outline>
              <outline text="Strategies" heading="1" colorLabel="2" collapsed="true">
                <outline text="Due to [this](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ytCTzGW5GXS9vBDmR1COsbee), getting independent https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=W7VkGKlZfqI3D-chGqzjjpwn is often very important to recognize your weaknesses."/>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                <outline text="Analyzing specific past errors/biases, particularly immediately after they occur."/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Learning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XwNwxOcZRgH_hY46vX9t5UTb)" heading="1" colorLabel="6"/>
              <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Big decisions" heading="1" colorLabel="2" collapsed="true">
            <outline text="Definition (moral/axiological)" heading="3" colorLabel="3" collapsed="true">
              <outline text="Decisions that (based on the probabilities and potential impacts of the possible outcomes) have a significant impact on one&apos;s axiology/morality, if they have one."/>
            </outline>
            <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="Relationships (broad)" heading="3"/>
                <outline text="Jobs" heading="3"/>
                <outline text="Less common than smaller decisions by far." colorLabel="1"/>
              </outline>
              <outline text="**Impactful:**   Very [impactful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sn1OETP9DABbP_q84gS5zdKG) by [definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QsnfXb1j46ZbcbpW776OhzWB)." colorLabel="4"/>
            </outline>
            <outline text="Strategies" heading="3" colorLabel="2" collapsed="true">
              <outline text="If practical, learn reasoning thoroughly or get help from [confirmed](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GwE6-NAbRo2iIVWkvYqwdzpK) very reasonable people before making big decisions."/>
            </outline>
          </outline>
          <outline text="Time usage in reasoning" heading="1" colorLabel="2" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="It&apos;s very important to save time" heading="3" colorLabel="4"/>
              <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                <outline text="We&apos;re often bad at time usage in reasoning" colorLabel="4"/>
                <outline text="We can get better at time usage" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Reasoning short-cuts" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Practices that are intended to skip large portions of reasoning to make the process faster."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Using the wrong short-cuts can often be disastrous for good reasoning on the topic" heading="3"/>
                <outline text="It&apos;s common to use the wrong short-cuts" heading="3"/>
                <outline text="Using the right short-cuts consistently can save a ton of time" heading="3"/>
              </outline>
              <outline text="Heuristics" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" _note="Shorten" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Heuristics is the process by which humans use mental shortcuts to arrive at decisions. Heuristics are simple strategies that humans, animals, organizations, and even machines use to quickly form judgments, make decisions, and find solutions to complex problems."/>
                  <outline text="Often this involves focusing on the most relevant aspects of a problem or situation to formulate a solution."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Uncertain judgments and decisions based on heuristics are often good enough to satisfy a pressing need in situations of uncertainty, where information is incomplete."/>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Everybody relies on heuristics practically all the time."/>
                  </outline>
                </outline>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s very easy to rely too heavily on or overly trust heuristics."/>
                  <outline text="Heuristics can differ from answers given by logic and probability." collapsed="true">
                    <outline text="While heuristic processes are used to find the answers and solutions that are most likely to work or be correct, they are not always right or the most accurate." collapsed="true">
                      <outline text="Heuristics rely on simplificatied rules that try to cut likely unimpactful nuances to more quickly come up with an approach to a problem."/>
                      <outline text="Sometimes impactful nuances are accidentally cut."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Evolutionary cause" heading="3" colorLabel="1" collapsed="true">
                  <outline text="To solve problems, our brains have evolved to employ cognitive heuristics— rough shortcuts that get the right answer often, but not all the time."/>
                </outline>
                <outline text="Representativeness heuristic" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Our tendency to assess phenomena by how representative they seem of various categories."/>
                    <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Representativeness_heuristic)" _note="Pull more from this."/>
                  </outline>
                  <outline text="UNORGANIZED" heading="1" collapsed="true">
                    <outline text="The representativeness heuristic is used when making judgments about the probability of an event being representational in character and essence of a known prototypical event.[1] It is one of a group of heuristics (simple rules governing judgment or decision-making) proposed by psychologists Amos Tversky and Daniel Kahneman in the early 1970s as &quot;the degree to which [an event] (i) is similar in essential characteristics to its parent population, and (ii) reflects the salient features of the process by which it is generated&quot;.[1] The representativeness heuristic works by comparing an event to a prototype or stereotype that we already have in mind. For example, if we see a person who is dressed in eccentric clothes and reading a poetry book, we might be more likely to think that they are a poet than an accountant. This is because the person&apos;s appearance and behavior are more representative of the stereotype of a poet than an accountant."/>
                    <outline text="The representativeness heuristic can be a useful shortcut in some cases, but it can also lead to errors in judgment. For example, if we only see a small sample of people from a particular group, we might overestimate the degree to which they are representative of the entire group. Heuristics are described as &quot;judgmental shortcuts that generally get us where we need to go – and quickly – but at the cost of occasionally sending us off course.&quot;[2] Heuristics are useful because they use effort-reduction and simplification in decision-making.[3]When people rely on representativeness to make judgments, they are likely to judge wrongly because the fact that something is more representative does not actually make it more likely.[4] The representativeness heuristic is simply described as assessing similarity of objects and organizing them based around the category prototype (e.g., like goes with like, and causes and effects should resemble each other). This heuristic is used because it is an easy computation. The problem is that people overestimate its ability to accurately predict the likelihood of an event. Thus, it can result in [neglect of relevant base rates](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=PvpKwaS4egxN1pbrRVVNRd3Z) and other cognitive biases." _note="Link to neglect of relevant base rates"/>
                  </outline>
                  <outline text="Common resulting biases" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Conjunction fallacy" _note="Create section for it and link." heading="3" collapsed="true">
                      <outline text="**Example:**   [Tversky and Kahneman](http://faculty.econ.ucdavis.edu/faculty/nehring/teaching/econ106/readings/Extensional%20Versus%20Intuitive.pdf) found that experimental subjects considered it less likely that a strong tennis player would “lose the first set” than that he would “lose the first set but win the match.”" colorLabel="6"/>
                      <outline text="^  A comeback seems more __typical__ of a strong player, so we overestimate the probability of this complicated-but-sensible-sounding narrative compared to the probability of a superset (and thus more/equally likely) scenario. " colorLabel="6"/>
                    </outline>
                    <outline text="[Base rate fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AqpSpZ3KQtnFLltBRtAslxPF)" heading="3"/>
                  </outline>
                  <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Much of this was pulled from https://www.readthesequences.com/Biases-An-Introduction"/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37)" heading="3" colorLabel="2"/>
                  <outline text="Formal deduction rules" _note="Link" heading="3" colorLabel="5" collapsed="true">
                    <outline text="Heuristics are essentially the informal and less reliable version of formal deductive rules." colorLabel="4"/>
                    <outline text="^ They are both reasoning short-cuts to derive some proposition(s) from other(s)." _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Heavily trusting [intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" heading="1" colorLabel="1" collapsed="true">
                <outline text="[Heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="3" colorLabel="5"/>
                <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="2"/>
              </outline>
              <outline text="Being [unsystematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="5" collapsed="true">
                <outline text="[Heavily trusting intuition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=phG95zAu7XE1iKSMn-2iMv5H)" heading="3" colorLabel="1"/>
                <outline text="[Heuristics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=49rqRClTn-Vx2v-ZXXm90ukK)" heading="3" colorLabel="5"/>
              </outline>
              <outline text="Skipping [multiple checks](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xY0Z4_L3g_saqIIVdvA81Uuh)" heading="1" colorLabel="2"/>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Common errors](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=93xKBOKZAl0tsr5P7wY-ZV3Y)" heading="3" colorLabel="2"/>
                <outline text="Formal deduction rules" _note="Link" heading="3" colorLabel="5" collapsed="true">
                  <outline text="The rules are deductive reasoning short-cuts." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="How our emotions often affect our time usage" heading="1" colorLabel="2" collapsed="true">
              <outline text="Social pressure" heading="1" colorLabel="1" collapsed="true">
                <outline text="We tend to feel pressured to finish our reasoning in a very short amount of time in live discussions, especially when face-to-face with people. One of the biggest advantages of text conversations is that it&apos;s much more socially acceptable to take much longer to think things through properly."/>
              </outline>
              <outline text="Impatience" heading="1" colorLabel="1" collapsed="true">
                <outline text="Types of impatience" heading="1" colorLabel="1" collapsed="true">
                  <outline text="Fatigue" heading="3"/>
                  <outline text="Overwhelm" heading="3"/>
                  <outline text="Frustration" heading="3"/>
                </outline>
                <outline text="We often start using a lot of dubious [reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49)" heading="3" colorLabel="1"/>
                <outline text="We don&apos;t perform a lot of the checks or double-checks that we would normally perform when we&apos;re at our peak. Time usage can be a decent way to measure this, as typically when we&apos;re thinking things through properly on a remotely complex topic, it takes a while for us to properly consider all the important relevant points and overall reason well*__. When we get into an emotional state where we by default stop performing a lot of the checks that are necessary for good reasoning, it will take much shorter amounts of time for us to come up with a response that we feel substantially compelled to send instead of thinking further upon.__" collapsed="true">
                  <outline text="* Assuming we aren&apos;t pulling from our memories of our conclusions from when we previously did the same process on the topic or something."/>
                </outline>
              </outline>
            </outline>
            <outline text="Proper time usage" heading="1" colorLabel="2" collapsed="true">
              <outline text="Strategies for going slower in general" heading="3" colorLabel="2" collapsed="true">
                <outline text="Reasoning alone" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2"/>
                  <outline text="^ Impactful" heading="3"/>
                  <outline text="^ It often makes it easier to take more time with one&apos;s reasoning." colorLabel="4" collapsed="true">
                    <outline text="^ It removes social pressure to reason quickly." _note="Perhaps link sections about how unconfidence lowers social value in many cases. Probably do the same in other places in time usage as well." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Pausing briefly to override [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" heading="3" colorLabel="1" collapsed="true">
                <outline text=" Importance:   Impactful" heading="3" colorLabel="2"/>
                <outline text="^ Taking more time often results in our initial intuitive inclination fading enough for our more reliable reasoning processes to have a fair chance to overrule it." colorLabel="4" collapsed="true">
                  <outline text="There is a tendency for us to trust our initial intuitive inclination far too much, so this is quite important." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="As a result of how our emotions often affect our time usage, it&apos;s important to make yourself take the necessary time and think things through more than you&apos;re tempted to in cases where you know it&apos;s likely necessary, even if you&apos;re very emotionally compelled to take various [short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49) instead." _note="Organize this a bit better." colorLabel="4"/>
              </outline>
              <outline text="Ideal time usage [in text](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YqxhIh8cQC3UlXflwRLyqM1B)" heading="2" colorLabel="5" collapsed="true">
                <outline text="Rereading" heading="3"/>
                <outline text="^ It&apos;s often ideal to reread some key sections a few times in a text conversation." collapsed="true">
                  <outline text="There&apos;s often going to be a lot of useful relevant information that you&apos;ll otherwise forget or fail to notice/deeply understand." _note="Link to consequences of misunderstandings." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Decision-making under pressure" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Making decisions under pressure (especially time pressure)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Typically we will have a lot of time to make the most important decisions in our lives." colorLabel="1"/>
                </outline>
                <outline text="People usually make more instinctual (and thus typically worse) decisions when they are under pressure." colorLabel="4"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Reasoning short-cuts](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QbiCWrDMPM38d8BpMPryvG49)" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Breaks" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
                <outline text="The temporary ceasing of progress towards some objective."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Breaks help with [reducing emotions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j3lG3AEozd127qU6GtNPal82)" colorLabel="4"/>
                  <outline text="Breaks substantially help with thinking of new ideas/solutions." colorLabel="4" collapsed="true">
                    <outline text="Getting a fresh perspective on things often really helps with thinking of solutions that felt impossible to find before." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text=" Recharging [Mental stamina](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GcRDuicbl_3OrCk3NrMQs3Tz)" colorLabel="4"/>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="It&apos;s very feasible to form better habits about taking breaks." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Break techniques" heading="1" colorLabel="2" collapsed="true">
                <outline text="For reducing emotions" _note="Often called &quot;resetting&quot; emotions." heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Helps by temporarily removing the cause](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CfuWJkKuc50Y-Lu3zjvLzZLm)" colorLabel="4"/>
                    <outline text="It&apos;s easy for breaks to turn into [abandonment](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_2Sxqw7l0w28Kd3hd18oTft-)." colorLabel="1" collapsed="true">
                      <outline text="It&apos;s common for breaks to turn into abandonment." _note="Likelihood" colorLabel="4"/>
                      <outline text="It&apos;s easy to forget to come back." _note="Likelihood" colorLabel="4"/>
                      <outline text="It&apos;s easy for it to start feeling more overwhelming the more you think about how you&apos;re not making enough progress, caused by taking more breaks." _note="Likelihood" colorLabel="4"/>
                      <outline text="[Abandoning the task is often harmful](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_2Sxqw7l0w28Kd3hd18oTft-)" _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Typically performing more soothing and distracting things during breaks will help more with reducing emotions."/>
                </outline>
                <outline text="For recharging [mental stamina](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GcRDuicbl_3OrCk3NrMQs3Tz)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
          </outline>
          <outline text="Theoretical reasoning" _note="~~Amateur" heading="1" colorLabel="2" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3"/>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" colorLabel="4" collapsed="true">
                <outline text="Thought experiments" _note="Likelihood" colorLabel="4"/>
                <outline text="Hypotheticals" _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="Often more useful than it seems." _note="Important, should maybe be linked elsewhere. And/or theoretical reasoning should be linked in more places." colorLabel="4" collapsed="true">
                <outline text="Because people often have a mistaken notion that theoretical reasoning is internal and (in itself) unverifiable, in contrast to empirical evidence." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Supposing that we accept axioms like those recommended in [axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd), we can [decompose](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=e-rx5GVRcMwUlauim9BgIzme) the theoretical reasoning and verify it through fundamental operations. This is clear via the chain if reducibility you&apos;ll find throughout the fundamental sections like [standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm) and [induction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OJSQEWGwiRo2syWQyU9FbjoE)" _note="Likelihood (about the &quot;mistaken&quot;)" colorLabel="4"/>
                  <outline text="Empirical evidence is evidence only because we trust things like induction, the semi-reliability of our mental faculties, etc., and reasoning for the trusthworthiness of empirical evidence __from__ those things." _note="Likelihood (about the &quot;mistaken&quot;)" colorLabel="4" collapsed="true">
                    <outline text="Thus, the interpretation of empirical evidence is also internal and (without accounting for specifics) just as (un)verifiable." _note="Relevance" colorLabel="4"/>
                    <outline text="^ [Our theoretical reasoning is typically unsystematic](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xME6gm1S14EoUhLjaab5Fly0)" _note="Relevance" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Because of the [bias towards the &quot;grounded&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="Often the best/only method for finding a good answer" colorLabel="4" collapsed="true">
                <outline text="Many important hypotheses cannot be empirically tested but can be rationally investigated to a sufficient degree to come to a reasonable conclusion." _note="Likelihood" colorLabel="4"/>
              </outline>
              <outline text="Inventions / Innovations" colorLabel="4" collapsed="true">
                <outline text="Virtually all inventions/innovations were based on a good amount of theoretical reasoning, especially the more significant ones." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="Eg. Computers" _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Easy to overlook practical obstacles" colorLabel="1" collapsed="true">
                <outline text="We often fail to properly account for unknown practical challenges." colorLabel="4" collapsed="true">
                  <outline text="&lt;broken link&gt;" _note="Likelihood" colorLabel="4"/>
                  <outline text="[Hofstadter&apos;s law](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zRXP26n914iccTGdJXRxB69C)" _note="Likelihood" colorLabel="4"/>
                </outline>
                <outline text="[It is one of the easiest areas for confirmatory reasoning to creep in [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sslHc9-gXfi27WFQHol-J5hU)" colorLabel="4"/>
                <outline text="We are often biased to assume that the practical obstacles cannot be overcame." colorLabel="1" collapsed="true">
                  <outline text="We [are often biased](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ddzvc06L23MljpQS9N8Fm3rS) to reject some ideas which we cannot understand the full reasoning for." colorLabel="4"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Our theoretical reasoning is typically unsystematic" colorLabel="1" collapsed="true">
                <outline text="There is a general trend for applications of theoretical reasoning to be less systematic and thus less reliable." _note="Likelihood + relevance | Probably split" colorLabel="4"/>
                <outline text="This is mainly due to our cultural propensity to perform theoretical reasoning in a more vague and unsystematic manner than how we typically deal with empirical evidence." _note="Relevance" colorLabel="1" collapsed="true">
                  <outline text="Thus one should not typically heavily rely on heuristics about the reliability of theoretical reasoning vs empirical reasoning, it is better to consider the reliability of theoretical/empirical reasoning on a case-by-case basis." _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Difficult" heading="3" colorLabel="4" collapsed="true">
                <outline text="It is one of the easiest areas for [confirmatory reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy) to creep in (both for and against some theoretical reasoning), because it implicitly involves starting with a conclusion." colorLabel="4" collapsed="true">
                  <outline text="Against because: If one sees theoretical reasoning for a claim they disagree with, they will (typically subconsciously) begin with the conclusion that it is wrong." colorLabel="4"/>
                  <outline text="^ [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
              <outline text="A very important but limited kind of reasoning that must be dealt with carefully, both when using and contesting it."/>
              <outline text="[It is one of the easiest areas for confirmatory thought to creep in [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sslHc9-gXfi27WFQHol-J5hU)"/>
            </outline>
            <outline text="Thinking through how it would work in detail" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Very useful for getting an idea of whether it would work or not, where the primary challenges would be, etc. " colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Testing theoretical reasoning" heading="1" colorLabel="2" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Without testing, it&apos;s typically very [hard to do it accurately](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hlPnhGG0gvaaehk_0ztVINAl)"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Experiments](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=l4ypO5YkR15Gt6nG4SYw6KKi)" heading="3" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Bias towards the specific/&quot;grounded&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mks1gpdiHB01sMtJ2DSU-1Xn)" heading="3" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Values / Goals" heading="1" colorLabel="2" collapsed="true">
            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
              <outline text="Ethics/morality/axiology/etc."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Important for nihilists" heading="3" colorLabel="4" collapsed="true">
                <outline text="It&apos;s important to properly understand morality/ethics/axiology even for nihilists." colorLabel="3"/>
                <outline text="The consequences of nihilism are frequently not properly followed/understood." _note="Likelihood" colorLabel="4"/>
                <outline text="Values influences the decision-making of so many people." _note="Likelihood" colorLabel="4" collapsed="true">
                  <outline text="Eg. Religious people" _note="Likelihood" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Goals of reasoning" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Semi-primary goals (especially emotional goals) of reasoning."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="&lt;broken link&gt;"/>
                  </outline>
                </outline>
                <outline text="Improvable" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Most people are pretty bad at having good mindsets for reasoning" heading="3"/>
                </outline>
              </outline>
              <outline text="Practicing reasoning" heading="1" colorLabel="2" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Very important goal for establishing good habits."/>
                </outline>
              </outline>
              <outline text="Understanding" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Heavily prioritizing understanding others&apos; points."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Helps balance criticalness and &lt;broken link&gt;" collapsed="true">
                      <outline text="Prioritizing understanding often involves accounting for:"/>
                      <outline text="    more or less likely **interpretations**."/>
                      <outline text="    potential supporting and contesting **arguments**."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="How to focus on understanding a lot of the time" heading="3" colorLabel="2" collapsed="true">
                  <outline text=""/>
                </outline>
              </outline>
              <outline text="Cooperation" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2"/>
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
              <outline text="Immediate correctness" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Being correct about the immediate thing."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Immediate correctness doesn&apos;t matter as much as correctness in general." heading="3" colorLabel="1" collapsed="true">
                      <outline text="Correctness in general is dependent on overall reasoning performance rather than immediate correctness." collapsed="true">
                        <outline text="The way to improve overall reasoning performance is by looking at how you reason in the short-term."/>
                      </outline>
                    </outline>
                    <outline text="[Correctness ≠ good reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7CPFMBYoWL3Y9vzhHpyxUynq)" colorLabel="1"/>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="[People tend to think being correct entails that they used good reasoning to get there](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ivsAcg-6ZeX4rW9rr47C2YFf)" colorLabel="1"/>
                    <outline text="Immediate correctness is usually less important than the reasoning used to get there." collapsed="true">
                      <outline text="The reasoning used to get there: How well you reasoned to arrive at your conclusion."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Correctness ≠ good reasoning" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3"/>
                    <outline text="Common" heading="3" collapsed="true">
                      <outline text="[People tend to think being correct entails that they used good reasoning to get there](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ivsAcg-6ZeX4rW9rr47C2YFf)" colorLabel="1"/>
                    </outline>
                  </outline>
                  <outline text="People tend to think being correct entails that they used good reasoning to get there." heading="3" colorLabel="1" collapsed="true">
                    <outline text="People give themselves feedback in accordance with how close/far they believe they are from the truth, rather than how well they reasoned." collapsed="true">
                      <outline text="This usually leads them to do behaviors that make them feel closer to the truth, which often don&apos;t actually get them closer to the truth."/>
                      <outline text="Types" heading="3" colorLabel="6" collapsed="true">
                        <outline text="Reason well but still far from truth" heading="3" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="We sometimes go &quot;ah, I was wrong&quot; and think of it as a mistake, when really it was just bad luck or lacking important evidence."/>
                          </outline>
                          <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                            <outline text="This is much less common than [reasoning badly but still close to the truth](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HW8-uQkaHQKIem3_7Y7ti_K8) because we tend to be biased towards &lt;broken link&gt;, at least intellectually."/>
                          </outline>
                        </outline>
                        <outline text="Reason badly but still close to truth" heading="3" collapsed="true">
                          <outline text="We often go &quot;ah, so I was right!&quot; and focus on that, regardless of whether we reasoned well to get there."/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
              <outline text="&quot;Winning&quot;" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition (broad)" heading="3" colorLabel="3"/>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="People often focus on &quot;beating the opponent&quot;, &quot;winning the debate&quot;, etc." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="**Prioritizes bad reasoning and deprioritizes good reasoning:**   &quot;Winning&quot; debates is typically measured in terms of metrics that significantly differ from good reasoning. So focusing on &quot;winning&quot; typically entails deprioritizing good reasoning to some extent, and prioritizing those other metrics." colorLabel="1" collapsed="true">
                      <outline text="How convinced the audience is" heading="3" collapsed="true">
                        <outline text="[Persuasion strategies that don&apos;t prioritize reasoning tend to convince people more](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0WKmMK8w3_icwUoGQAzc3vT9)" colorLabel="4" collapsed="true">
                          <outline text="Most debates involve a lot of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ)" colorLabel="4" collapsed="true">
                            <outline text="Therefore people are much more likely to be irrational about them." _note="Relevance | Link to a section about how people tend to be more irrational about soft reasoning, once it&apos;s available." colorLabel="4"/>
                          </outline>
                          <outline text="Therefore we&apos;re encouraged to use such strategies, especially subconsciously from past experiences of them working better." colorLabel="4"/>
                          <outline text="We&apos;re often taught to use these strategies in thinks like debate classes." colorLabel="4"/>
                          <outline text="Eg. [Characterization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-RfRZ7650bJF8cl3dEY8_zE_)" colorLabel="6"/>
                        </outline>
                      </outline>
                      <outline text="How stumped the opponent is" heading="3" collapsed="true">
                        <outline text="Stumping the opponent is much easier with rhetoric and fallacies than with good reasoning/solid sources." _note="This has to do with how unreasonable opponents and the audience tend to be." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="[Encourages confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="1" collapsed="true">
                      <outline text="&quot;Winning&quot; in this context means successfully defending a certain conclusion, so the natural instinct is to start with that conclusion in one&apos;s thinking and try to justify/defend it." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related (many very related sections)" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Not a good indication of truth" heading="3" collapsed="true">
                        <outline text="Most people (probably even among groups who you would expect to be exceptions) are pretty uncritical, so convincing them is not a good indication of your point being correct." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="[Competition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=436tjnAmv5CrbzS3opf2Vin_)" heading="1" colorLabel="2"/>
                  <outline text="[Refutation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vGnU05OJtfhN092NcMo2TQ36)" heading="1" colorLabel="2"/>
                  <outline text="[Correctness ≠ good reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7CPFMBYoWL3Y9vzhHpyxUynq)" heading="1" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Refutation" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Prioritizing refuting others&apos; points."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3"/>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Often we get into a mindset of prioritizing finding what&apos;s wrong with opposing arguments and counterarguments." collapsed="true">
                      <outline text="This isn&apos;t necessarily a bad thing."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="How to view it" _note="Depends on rank." heading="3" colorLabel="2" collapsed="true">
                  <outline text="A mindset to largely avoid for now." _note="≤ ~Adept"/>
                  <outline text="A useful tool that should usually be used when there are important ideas that aren&apos;t being questioned much." _note="≥ ~Advanced"/>
                </outline>
                <outline text="Pros / Cons" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Prioritizing refutation tends to reduce the amount of effort we put into understanding and being open to opposing ideas." colorLabel="1" collapsed="true">
                    <outline text="It is crucial for good reasoning to often heavily prioritize &lt;broken link&gt; such claims."/>
                  </outline>
                  <outline text="Can help a lot with finding hard-to-find flaws or counterarguments." _note="~Advanced" colorLabel="4"/>
                </outline>
                <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
              </outline>
            </outline>
            <outline text="Goals of discussions" _note="Maybe combine with goals of reasoning or something?" heading="1" colorLabel="2" collapsed="true">
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Goalless discussion" heading="3" collapsed="true">
                    <outline text="Discussion without a goal often doesn&apos;t provide much benefit."/>
                  </outline>
                  <outline text="&quot;Winning&quot;" heading="3"/>
                </outline>
              </outline>
              <outline text="[Goals of reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yDRmT592xGeslYb-hvYp2ujH)" heading="1" colorLabel="1"/>
            </outline>
          </outline>
          <outline text="Memory" heading="1" colorLabel="1" collapsed="true">
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" colorLabel="4"/>
              <outline text="Improvable" heading="3" colorLabel="4" collapsed="true">
                <outline text="Currently bad" heading="3" colorLabel="4" collapsed="true">
                  <outline text="The vast majority of people aren&apos;t very good at memory" _note="Likelihood" colorLabel="4"/>
                  <outline text="People are typically substantially overconfident about memory." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="They&apos;re typically much more forgetful than they assume themselves to be." colorLabel="3"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Keeping track of context" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Keeping track of what arguments support what other arguments."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="It&apos;s very common for people to keep track of the context at least a bit." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Useful for seeing if argument(s) (whether your own or someone(s) else&apos;s) provide sufficient weight (whether for or against) to their target." colorLabel="4" collapsed="true">
                    <outline text="Helpful for [reasoning self improvement](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mcey5J-t6AUuWU92iqr8Nkqe)" _note="Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Improvable" heading="3" collapsed="true">
                  <outline text="It&apos;s rare for people to systematically keep track of the context, and thus very common for people to fail to keep track of it in major ways." colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Techniques" heading="1" colorLabel="2" collapsed="true">
                <outline text="[[Mostly-normal text](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=YqxhIh8cQC3UlXflwRLyqM1B)]-specific" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Techniques that are largely only useful for mostly-normal text."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Importance of mostly-normal text](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ztxLHqTD5SAcfKIwE5GTmXz9)" heading="3" colorLabel="2"/>
                  </outline>
                  <outline text="Frequently checking message history" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Frequently checking previous messages to better understand how the arguments fit together."/>
                    </outline>
                    <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Very important for [thoroughness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ) in mostly-normal text discussions." colorLabel="4" collapsed="true">
                          <outline text="[Importance of thoroughness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=v06MMtLk-l69FN8yrpApO2BV)" _note="Relevance" heading="3" colorLabel="4"/>
                        </outline>
                        <outline text="Takes a lot of extra time" colorLabel="1" collapsed="true">
                          <outline text="Can often be done while waiting for other person(s)&apos;s response(s)." _note="Relevance" colorLabel="1"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="[Habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rbfReKt_odNwwwIDWESiYqq-)" heading="3" colorLabel="1"/>
                      <outline text="^ Realistically this would likely have to be a habit to be performed consistently enough to be substantially helpful." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Linking relevant messages" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Definitions" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Adding links in your text responses, that allow you and the person(s) you&apos;re messaging with to quickly find relevant past message(s)."/>
                      <outline text="**Message history:**   By message history, we just mean the messages that were sent a bit more than slightly previously." collapsed="true">
                        <outline text="Maybe messages sent at least [500 characters] or [1 hour] ago."/>
                      </outline>
                    </outline>
                    <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Often useful for immediately clearly showing context." colorLabel="4" collapsed="true">
                          <outline text="Useful for resolving situations where other person(s) aren&apos;t properly keeping track of the context." _note="Relevance" colorLabel="4" collapsed="true">
                            <outline text="It allows the other person to look back at their own message(s)." _note="Likelihood" colorLabel="4"/>
                            <outline text="[Cost of misunderstandings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1qtW0Q9lO1KZeMzP6UFlafQo)" _note="Relevance" colorLabel="4"/>
                          </outline>
                          <outline text="Takes time to find messages to link." _note="Relevance" colorLabel="1" collapsed="true">
                            <outline text="It takes barely any extra time if you&apos;re already [frequently checking message history](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HvFzVSKgZMdfLOLgOwq2DPux)" _note="Relevance" colorLabel="4"/>
                          </outline>
                        </outline>
                        <outline text="Often useful to later you." colorLabel="4" collapsed="true">
                          <outline text="Eg. For finding a particular message/quote." _note="Likelihood" colorLabel="4"/>
                          <outline text="^ Allows you to double-check context that&apos;s relatively important to get right." _note="Relevance" colorLabel="4" collapsed="true">
                            <outline text="Eg. Another person&apos;s message." _note="Relevance" colorLabel="4" collapsed="true"/>
                            <outline text="^ [Cost of misunderstandings](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1qtW0Q9lO1KZeMzP6UFlafQo)" _note="Relevance" colorLabel="4" collapsed="true"/>
                          </outline>
                        </outline>
                        <outline text="Getting into the habit of doing this implicitly helps get into the habit of [frequently checking message history](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HvFzVSKgZMdfLOLgOwq2DPux)." colorLabel="4" collapsed="true">
                          <outline text="[Habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rbfReKt_odNwwwIDWESiYqq-)" _note="Likelihood" heading="3" colorLabel="4"/>
                          <outline text="You often have to check the message history in order to find the one you&apos;re wanting to link." _note="Likelihood" colorLabel="4"/>
                        </outline>
                        <outline text="Not always possible." colorLabel="1" collapsed="true">
                          <outline text="Depending on the platform, it may not allow you to link to a particular message." _note="Likelihood" colorLabel="4"/>
                          <outline text="Most platforms allow for message linking in some form." _note="Relevance" colorLabel="1" collapsed="true">
                            <outline text="**Reply-link only:**   If you&apos;re restricted to only being able to link to messages you&apos;re replying to, you can send several messages that each reply to particular messages you&apos;re wanting to link to." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="It works" _note="Relevance" colorLabel="4"/>
                              <outline text="It&apos;s awkward" _note="Relevance" colorLabel="1"/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Quoting relevant messages" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Definition (important distinction)" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Adding a quote of previous text in your text responses."/>
                      <outline text="Distinction (important)" heading="3" colorLabel="3" collapsed="true">
                        <outline text="This doesn&apos;t necessarily mean making a quote in text separate from the reply preview."/>
                        <outline text="Depending on the platform and the length of the message being replied to, sometimes the little preview thing showing the message that&apos;s being replied to is sufficient to act as a quote, and that would count as &quot;quoting relevant message&quot; here."/>
                      </outline>
                    </outline>
                    <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="[Importance of linking relevant messages](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=kwz4a6-vQlUvJS8gQtGZuTXH)" heading="3" colorLabel="2"/>
                        <outline text="^ Has virtually the same importance arguments as this section would have, except of course for saying things like &quot;link&quot;/&quot;message&quot; instead of things like &quot;quote&quot;." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related (very)" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Lacking context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lVuocPQtbJr1T1UQTA9_LCyy) (very related)" heading="1" colorLabel="3" collapsed="true">
                  <outline text="A big part of keeping track of the context is effectively resolving situations where you&apos;re lacking some context." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Chunking" _note="Look into this and likely move it into one or multiple of the categories." heading="1" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Chunking_(psychology))"/>
              </outline>
            </outline>
            <outline text="Evolutionary explanation for memorability" heading="1" colorLabel="1" collapsed="true">
              <outline text="We evolved to pay special attention and carefully memorize things like stories, people, landmarks, visual features in general, etc."/>
              <outline text="We did not at all evolve to memorize it focus on abstract concepts or values like numbers, words or anything like that."/>
              <outline text="This is why encoding abstract things we didn&apos;t evolve to memorize into things we did evolve to memorize can be so effective."/>
            </outline>
            <outline text="Compression" heading="1" colorLabel="6" collapsed="true">
              <outline text="Memorizing results" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="While trying to find an ultimate answer to a complicated question involving many smaller parts, after solving each smaller problem, focus on remembering only the result of that part."/>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Remember only whether a conclusion is true or false, and then move on to the next small question."/>
                    <outline text="Remember only the cost and value of the object you are comparing to others, then move on to evaluating the next object."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Single word technique" _note="Not an official name." heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The memory technique where each item in a list of things (typically tasks) is boiled down to one word."/>
                </outline>
              </outline>
            </outline>
            <outline text="Increasing memorability" heading="1" colorLabel="6" collapsed="true">
              <outline text="Notable specificity" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The technique of imagining a specific instance of something with very memorable features."/>
                  <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Hairbrush" collapsed="true">
                      <outline text="Think of a specific hairbrush you use or something."/>
                      <outline text="Imagine fiery flames on the handle."/>
                      <outline text="Imagine the bristles as hair."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Absurdity" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Typically the more absurd something is, the more memorable it is, even if it&apos;s fictitious. So adding absurd, fictitious specificity in your head can help a lot with memorability."/>
                </outline>
                <outline text="[Practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7uTPFcFISeOZWgi6CC8b3Q50)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This improves memory in general, because it becomes easier to encode things with specific, memorable details."/>
                </outline>
              </outline>
              <outline text="Add relations" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Relations between memory items" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Adding relations between multiple things that you want to memorize."/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Combining a hairbrush, soy sauce, socks, giraffe and biplane by imagining the girafe bathing in a bathtub of soy sauce brushing its hair with the hairbrush, all on top of a biplane."/>
                    </outline>
                  </outline>
                  <outline text="Memory palace" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3"/>
                    <outline text="Categories" heading="3" colorLabel="2" collapsed="true">
                      <outline text="If there&apos;s a risk of you getting categories confused with each other, imagine some kind of entrance/container for knowledge in those categories and add distinctive details to that entrance/container so the categories are memorable from each other."/>
                      <outline text="Ideally it should feel natural and obvious to you."/>
                    </outline>
                    <outline text="Refinement" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Spending time &quot;walking around&quot; your memory palace to solidify it and refine relations, to prevent forgetting important details and practice using it to make it more easy to deal with in the future."/>
                      </outline>
                    </outline>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Rooms" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Imagining a room for each topics you want to store memories about."/>
                        </outline>
                        <outline text="Doors" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Give each room a distinct door so that they don&apos;t blend together."/>
                        </outline>
                        <outline text="Containers" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                              <outline text="Drawers"/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Memory items" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                            <outline text="A tiny river with a beaver dam to memorize the process a beaver uses to build the dam."/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="&lt;broken link&gt;" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Specific and memorable relations are especially effective."/>
                </outline>
                <outline text="[Practice](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7uTPFcFISeOZWgi6CC8b3Q50)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This improves memory in general, by making it easier to form creative relations between things."/>
                </outline>
              </outline>
              <outline text="Repetition" heading="1" colorLabel="2"/>
              <outline text="Oral statement" heading="1" colorLabel="2"/>
              <outline text="Sources" heading="3" colorLabel="6" collapsed="true">
                <outline text="A lot of information about this was pulled from this video: [&quot;The simple memory trick that changed my life&quot;](https://www.youtube.com/watch?v=w8JuHaRQmUs)"/>
              </outline>
            </outline>
            <outline text="Memory types and type-specific techniques" heading="1" colorLabel="6" collapsed="true">
              <outline text="[Mental checklists](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nY_hswN_fMDJXDa9duEygP0I)" heading="3" colorLabel="1"/>
              <outline text="Encoding systems" heading="1" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Use an encoding system to encode numbers into other concepts."/>
                </outline>
                <outline text="Numbers" heading="1" colorLabel="6"/>
              </outline>
            </outline>
            <outline text="Recalling recent memories" heading="3" colorLabel="2" collapsed="true">
              <outline text="Go through the same thoughts you went through before."/>
            </outline>
            <outline text="Combining techniques" heading="1" colorLabel="2" collapsed="true">
              <outline text="Common combinations" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Exterior tools" heading="1" colorLabel="6" collapsed="true">
              <outline text="Notes" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A record (usually written) to aid memory."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance of "/>
                </outline>
                <outline text="Mental notes" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3" colorLabel="4"/>
                    <outline text="Fast" heading="3" colorLabel="4"/>
                    <outline text="Unreliable" heading="3" colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Efficient note-taking" heading="1" colorLabel="2"/>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Checklists](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UIOFokR-YXIMhKjWiMDs4NlZ)" heading="3" colorLabel="1" collapsed="true">
                    <outline text="A common and useful type of note." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Checklists" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A structured list of tasks, items, or steps that need to be completed, verified, or remembered."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Very useful for [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" colorLabel="4" collapsed="true">
                    <outline text="Especially in cases where you would likely otherwise be subject to over-reliance on [system 1 thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Ya-MUAgoHP7_PEgC9ypSAe9I)" _note="Likelihood" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Mental checklists" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The memories of a thoroughly memorized checklist."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Importance of mental notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ITs_C9xDfSxFESOwEv5hVjsw)" heading="3" colorLabel="4" collapsed="true">
                      <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_3v6UqI-k_1DVKioI-m8R7Bc" _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Mental notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uYoZTkgDo5ZBbbW7Wmu_CW4l)" heading="3" colorLabel="2" collapsed="true">
                      <outline text="A mental checklist is a type of mental note." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Notes](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TIMo7f2lvAVe3DI9LMSZNHyw)" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Usually a checklist is a type of note." _note="Relevance" colorLabel="4"/>
                    <outline text="^ Although there are also [mental checklists](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nY_hswN_fMDJXDa9duEygP0I)" _note="Relevance" colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Consistency in reasoning" heading="3" colorLabel="2" collapsed="true">
            <outline text="Definition" _note="Improve" heading="3" colorLabel="3" collapsed="true">
              <outline text="How consistent one can reason."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Becomes especially important in the context of [reasoning pyramids](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dMvgzBqEcT7ia_4DcBqtBeIJ)" colorLabel="4" collapsed="true">
                <outline text="Consistency or inconsistency can result in radically different chances of successfully computing a reasoning pyramid, due to the compounding chances."/>
              </outline>
              <outline text="[It&apos;s usually easy to blunder in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vVak2mVU77754LQY5rltVT1_)" colorLabel="1"/>
            </outline>
            <outline text="Blunders" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s usually easy to blunder in reasoning" heading="3" colorLabel="4" collapsed="true">
                  <outline text="[The instability of large reasoning pyramids](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wF3wChw5a-nl2FeRaQTbTP7Q)" heading="3" colorLabel="2"/>
                  <outline text="Analogies" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Chess is like reasoning, and it&apos;s easy to blunder in chess." heading="3"/>
                  </outline>
                </outline>
                <outline text="It&apos;s often very consequential" _note="Should include more or something" heading="3" colorLabel="4" collapsed="true">
                  <outline text="[Reasoning blunders in crucial areas are common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0SbisTdpRtnWks8DNCqswDYR)" heading="3"/>
                </outline>
                <outline text="Feedback is not guaranteed" heading="3" colorLabel="4" collapsed="true">
                  <outline text="It&apos;s quite possible (and common) for people to use reasoning built on a blunder for important decisions all throughout their entire life without ever realizing it." collapsed="true">
                    <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Religious people"/>
                    </outline>
                  </outline>
                  <outline text="So it is incredibly important to do many thorough and varied checks for blunders in your own reasoning."/>
                </outline>
              </outline>
              <outline text="Avoiding blunders" heading="1" colorLabel="2" collapsed="true">
                <outline text="Checking past reasoning" heading="3" colorLabel="2" collapsed="true">
                  <outline text="What beliefs to check" heading="3" collapsed="true">
                    <outline text="The fundamental beliefs that underly many important beliefs."/>
                    <outline text="The beliefs that there is not clear feedback for being right/wrong."/>
                    <outline text="The beliefs that require a lot of [&quot;soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) to arrive at." collapsed="true">
                      <outline text="Why?" heading="3" collapsed="true">
                        <outline text="These kinds of beliefs tend to be where we make the most errors, because we cannot use solid reasoning (eg. math) for them."/>
                      </outline>
                      <outline text="Examples" colorLabel="6" collapsed="true">
                        <outline text="Religion/spirituality"/>
                        <outline text="Politics"/>
                        <outline text="Most philosophy"/>
                        <outline text="Some psychology"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="How to check" heading="3"/>
                </outline>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" heading="1" colorLabel="5" collapsed="true">
                <outline text="An extremely useful practice for increasing consistency." colorLabel="4"/>
              </outline>
              <outline text="[Multiple checks](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xY0Z4_L3g_saqIIVdvA81Uuh)" heading="2" colorLabel="2" collapsed="true">
                <outline text="A very useful technique for increasing consistency." colorLabel="4"/>
              </outline>
            </outline>
          </outline>
          <outline text="Measuring reasonableness" heading="3" colorLabel="5" collapsed="true">
            <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="**Measuring own reasoning:**   Being able to accurately measure reasoning likely means being able to measure your own reasoning." colorLabel="4" collapsed="true">
                  <outline text="Measuring your own reasoning likely means being less overconfident, undercontident, and ignorant about what helps/harms your reasoning." _note="???" colorLabel="4"/>
                  <outline text="Measuring one&apos;s own reasoning accurately is very difficult." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="**Learning limitations:**   Learning about the limitations of method commonly used to measure reasoning will allow you to avoid relying on those methods, allowing you to avoid drastic mistakes involving overestimating your own reasoning or underestimating others&apos; reasoning (or vise versa)." colorLabel="4"/>
              </outline>
              <outline text="Difficult" heading="3" collapsed="true">
                <outline text="Most of the common methods are very unreliable." _note="Move?" colorLabel="4"/>
                <outline text="It is very difficult to do reliably." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="Measuring [epistemic humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gh0FW_-AcyLbpnuFvEWm45Ke)" heading="1" colorLabel="4"/>
            <outline text="Measuring [criticalness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CDQTVmFBdUrFvIU4T3JfvdWZ)" heading="3" colorLabel="1"/>
            <outline text="Measuring reasonableness in general" heading="3" colorLabel="2" collapsed="true">
              <outline text="IQ" heading="3" colorLabel="5" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Intellectual quotient"/>
                </outline>
                <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="IQ is very commonly used as a measurement of reasoning." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="IQ is not very highly correlated with reasoning." colorLabel="1" collapsed="true">
                      <outline text="IQ does not appear to have mechanisms for measuring [soft reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) biases." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Soft reasoning biases have a significant impact on our general ability to change our mind when our current beliefs are adequately challenged." colorLabel="4" collapsed="true">
                          <outline text="Thus they have a significant impact on our [intellectual humility](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=gh0FW_-AcyLbpnuFvEWm45Ke), thus they have a significant impact on our reasoning abilities." colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Misc" heading="1" colorLabel="6" collapsed="true">
            <outline text="[Enthymemes](https://en.wikipedia.org/wiki/Enthymeme)" heading="3" colorLabel="5" collapsed="true">
              <outline text="**Definition:**   Arguments with hidden premise(s)." colorLabel="3" collapsed="true">
                <outline text="Hidden premises:" heading="3" colorLabel="3"/>
                <outline text="^ Unstated propositions that are required for an argument to be valid and/or sound." collapsed="true">
                  <outline text="The unstated propositions can be ordinary premises, or inference rules (because an inference rule can be thought of as a type of premise)." _note="Explain why in the section for inference rules, which will likely be in [Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd), and then link that explanation here."/>
                </outline>
                <outline text="^ **Synonym:**  Unstated assumptions" colorLabel="3"/>
                <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&quot;**Socrates is mortal because he&apos;s human**.&quot;"/>
                  <outline text="^ The complete formal syllogism" _note="Relevance" heading="3" colorLabel="4" collapsed="true">
                    <outline text="All humans are mortal. (major premise – unstated)"/>
                    <outline text="Socrates is human. (minor premise – stated)"/>
                    <outline text="Therefore, Socrates is mortal. (conclusion – stated)"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" colorLabel="4"/>
              </outline>
            </outline>
            <outline text="General software considerations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Centralization" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The software (and/or the server(s) for it) being centralized."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Your data is potentially at risk since the servers could shut down at any time, especially if they&apos;re meant for a small site/service that doesn&apos;t make much money."/>
                </outline>
              </outline>
            </outline>
            <outline text="AI" heading="3" colorLabel="5"/>
            <outline text="Creativity" heading="1" colorLabel="2" collapsed="true">
              <outline text="Brainstorming" _note="~~Novice level" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Blue-sky brainstorming" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Brainstorming without any bounds or limitations from current thinking, beliefs or conditions."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Incredibly useful for exploring very good but at-first-unintuitive ideas."/>
                  </outline>
                </outline>
                <outline text="Intuitive brainstorming" _note="~~Adept level" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Related" heading="3" colorLabel="6" collapsed="true">
            <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="1" colorLabel="3"/>
            <outline text="[Cooperative reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tIkQysDqkCY4YvrwV_mIfQ_d)" heading="3" colorLabel="6"/>
            <outline text="[Accounting for unknowns](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=cXfd8G1zK1UZ_HGp2aSVkGmK)" heading="3" colorLabel="6"/>
            <outline text="[Time usage in reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ix4g1EoGh3HsteZTJwCBMY8E)" heading="3" colorLabel="2"/>
            <outline text="[Informal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=CvMDwUIL5fxIDNIZ8RavnfNb)" heading="3" colorLabel="2" collapsed="true">
              <outline text="[Informal fallacies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6st1-KXaZblwemZ5T7fTZ59X)" heading="3" colorLabel="2"/>
            </outline>
            <outline text="[Information bubbles](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Mb-QFAcGf_sctWRPSrJ6Ubpp)" heading="3" colorLabel="1"/>
          </outline>
        </outline>
        <outline text="Expression/interpretation" heading="2" colorLabel="3" collapsed="true">
          <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
            <outline text="Impactful" heading="3"/>
            <outline text="^ Reduce misunderstandings" _note="Both your own and others&apos;" heading="1" colorLabel="4" collapsed="true">
              <outline text="**Relevance of the interpretation/expression section:**   Misunderstandings are caused by lacking expression/interpretation abilities. This section is about expression and interpretation." _note="Relevance" colorLabel="4"/>
              <outline text="Cost of misunderstandings" heading="3" colorLabel="4" collapsed="true">
                <outline text="**Exponential misunderstandings:**   While trying to resolve a misunderstanding, more misunderstanding(s) can arise, at a rate faster than they are resolved." _note="Relevance" colorLabel="4" collapsed="true">
                  <outline text="When this happens, it&apos;s easy for the amount of required work to resolve the original misunderstanding to grow exponentially until a massive amount of terms have had to be defined, a massive amount of ideas have had to be clarified, etc." _note="Relevance" colorLabel="4" collapsed="true">
                    <outline text="Where there is one misunderstanding, there is often ample room for many more." _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="Learning interpretation/expression can greatly reduce the rate of misunderstandings arising, and the speed at which you can resolve them." _note="Relevance" colorLabel="4"/>
                </outline>
                <outline text="Cost of unresolved misunderstandings (high)" heading="3" colorLabel="4" collapsed="true">
                  <outline text="Often, some misunderstandings are crucial to resolve in order to  efficiently continue with the reasoning interaction where the misunderstandings arose." colorLabel="4" collapsed="true">
                    <outline text="Knowledge piggybacking" _note="Create and link" heading="3" collapsed="true">
                      <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ab0k5w-abYxOLCZM9aOYOhgR" colorLabel="4"/>
                    </outline>
                    <outline text="[Critical piggybacking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2J5emCtKut8DRA6avr2C4r87)" heading="3" colorLabel="2" collapsed="true">
                      <outline text="In order to consistently and effectively perform this piggybacking, you cannot back out of discussions where misunderstandings arise." colorLabel="4" collapsed="true">
                        <outline text="Often even if there are lots of them, and lots are primarily caused by other party(s)." _note="Relevance" colorLabel="4"/>
                        <outline text="Because most people are not very good at interpretation/expression, even people who have great counterarguments that you haven&apos;t heard before." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="So it&apos;s important to learn to be the primary driver of resolving misunderstandings." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
          <outline text="Interpretation" heading="1" colorLabel="3" collapsed="true">
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="Interpretation underlies virtually all communication." colorLabel="4"/>
              </outline>
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="Being able to properly understand others is extremely important for finding the truth." colorLabel="4" collapsed="true">
                  <outline text="It&apos;s extremely important for [cooperative reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tIkQysDqkCY4YvrwV_mIfQ_d), and cooperative reasoning is [extremely important](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ToKUH9kZobFdEN-AU6WWmC3G) for finding the truth." colorLabel="4"/>
                  <outline text="&lt;Costs of misunderstandings&gt;" colorLabel="4" collapsed="true">
                    <outline text="[Critical piggybacking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2J5emCtKut8DRA6avr2C4r87)" _note="Move to costs of misunderstandings" heading="3" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Important for [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)." colorLabel="4"/>
              </outline>
              <outline text="Difficult" heading="3" collapsed="true">
                <outline text="Not properly understanding even one of the key sections here can make it practically impossible to change your mind when it&apos;s reasonable to in many scenarios. So a lot of learning is required to properly follow this section." colorLabel="4" collapsed="true">
                  <outline text="__Not properly understanding even a couple of the key sections here can__ multiply the [time required to resolve disagreements] by a very large number." _note="Likelihood" colorLabel="4" collapsed="true">
                    <outline text="&lt;Link to cost of disagreements&gt;" _note="Likelihood" colorLabel="4"/>
                  </outline>
                  <outline text="&lt;Link to cost of disagreements&gt;" _note="Relevance" colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Semantics" _note="Reorganize. Especially definitions, conflations and being clear." heading="1" colorLabel="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Semantics is the study of words, sentences and phrases and the meaning that is drawn from them in different contexts."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Semantics underlie virtually all communication whatsoever, even a lot of internal communication with yourself." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Good reasoning often requires good semantics." colorLabel="4" collapsed="true">
                    <outline text="[Conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" heading="3" colorLabel="4" collapsed="true">
                      <outline text="It&apos;s very hard to consistently avoid conflations without understanding semantics deeper than average." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="[How conflations arise](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mDA22AS-AvwyVGg9b3bT9m8y)" colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="&lt;Link to the costs of misunderstandings&gt;" colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Vague wording" heading="1" colorLabel="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="The topic of vague wording. How to recognize it, what to do about it, etc."/>
                  <outline text="**Especially:**   Vague definitions/meanings."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" colorLabel="4"/>
                  <outline text="Very bad for reasoning" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Vague definitions frequently cause [conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)." _note="Likelihood &amp; Relevance" colorLabel="4" collapsed="true">
                      <outline text="Conflations are [very bad](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FbaBK4fH-iKO0a1B7o5S5QFf) for reasoning." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Vague definitions typically cause a lot of [definitional differences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vMjtaIQiRY359z8Zq6mtQRGc)" _note="Likelihood &amp; Relevance" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="&quot;Or similar&quot; definitions" heading="1" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Definitions in which (a) major component(s) are paired with a qualifier such as &quot;such as&quot;, &quot;or similar&quot;, &quot;or something like that&quot;, etc. without adequate clarification on which concepts would be regarded as &quot;similar&quot;/etc." collapsed="true">
                      <outline text="&quot;Adequate clarification&quot; meaning sufficient clarification that it can be reasonably expected (from the perspective of the definition-giver, with &gt;75% confidence) that the definition-receiver will adequately understand which concepts would be regarded as &quot;similar&quot;/etc." collapsed="true">
                        <outline text="&quot;Adequately understand&quot; meaning understand well enough to avoid significant misunderstanding(s)."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Recognizing vague wording" heading="3" colorLabel="2"/>
                <outline text="Dealing with vague wording" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Asking what they mean" heading="3" colorLabel="2"/>
                  <outline text="Accounting for definitional possibilities" _note="This might be repeat section. Check and link and resolve if so." heading="3" colorLabel="2" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2"/>
                    <outline text="^ Impactful" heading="3"/>
                    <outline text="^ Good reading comprehension by accounting for different possibilities when other people use vague wording."/>
                  </outline>
                </outline>
                <outline text="Avoiding vague wording" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Use the longer clearly-spelled-out version" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Importance / Limitations" heading="3" colorLabel="2"/>
                    <outline text="^ Impactful" heading="3"/>
                    <outline text="^ Not always practical." colorLabel="1" collapsed="true">
                      <outline text="Spelled-out version is sometimes much longer." colorLabel="4"/>
                      <outline text="The same idea is sometimes used many times." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="That, this, it, them, those, etc."/>
                  <outline text="Example [free speech](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8bbYQqmSaf6jvExF2SzbW9vU) definition misunderstanding" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Two statements using different definitions:"/>
                    <outline text="^ &quot;Free speech is sacred&quot; meaning &quot;Government censorship should be minimal&quot;."/>
                    <outline text="^ &quot;Free speech has limits&quot; meaning &quot;Private platforms can moderate content&quot;."/>
                    <outline text="Here it appears that either &quot;free speech&quot; or &quot;sacred/limits&quot; is being defined differently between the two parties, likely causing them to talk past each other."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=trb9nqsaLcvBK2O1-HBNApOW)" heading="2" colorLabel="6"/>
                  <outline text="[Definition via analogy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wqjHe0ETccAnBhGoYUCfWKtS)" heading="3" colorLabel="3"/>
                </outline>
              </outline>
              <outline text="Definitions" heading="1" colorLabel="6" collapsed="true">
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="So incredibly often, disagreements and misunderstandings arise simply because of people using subtly different definitions and bring unable to resolve it (at least in a timely manner)." colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Specific definitions" heading="1" colorLabel="3" collapsed="true">
                  <outline text="Note" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Unless otherwise stated, each definition also applies (although usually with slight modifications) to very similar words." collapsed="true">
                      <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                        <outline text="The definitions for &quot;know&quot; apply (except for the obvious change about how the word would be used) to &quot;known&quot;."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2"/>
                  <outline text="Formal and informal" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Reasoning" heading="2" colorLabel="3" collapsed="true">
                      <outline text="[Informal reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=o4Kl-VNmNYvxA36KNy3kmjie)" heading="3" colorLabel="3"/>
                      <outline text="Formal reasoning" _note="Move, probably to informal reasoning. Make sure that backlinks are preserved in the process." heading="3" colorLabel="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="The process of drawing valid inferences in a well-structured and irrefutable (given certain axioms) manner."/>
                          <outline text="Distinctions" heading="3" colorLabel="3" collapsed="true">
                            <outline text="This is not to suggest that the premises we begin with in this process necessarily need to be irrefutable."/>
                            <outline text="Nor is it to suggest that we cannot make mistakes in determining whether an argument is valid or not while using formal reasoning, just that under normal conditions validity is technically ensured."/>
                          </outline>
                        </outline>
                        <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Very important for [systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)." colorLabel="4" collapsed="true">
                            <outline text="Helps a lot with [precision](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=581SfOCyfIekfCaptWzmdIKD)." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="Representing ideas formally tends to require representing them precisely, without ambiguity." _note="Likelihood" colorLabel="4" collapsed="true">
                                <outline text="Formalisms tend to be completely unambiguous." colorLabel="4"/>
                                <outline text="It&apos;s possible (and common) to represent the informal aspect as eg. a premise in a formal argument." colorLabel="1" collapsed="true">
                                  <outline text="By having the knowledge to represent the rest of it in a formal manner, one would likely have a much easier time representing or supporting the informal parts in a more formal manner upon request." _note="Relevance" colorLabel="1" collapsed="true">
                                    <outline text="Therefore the knowledge of formal reasoning could still help a lot with precision." _note="Relevance" colorLabel="4"/>
                                  </outline>
                                  <outline text="Even in this case, much of the reasoning is likely made formal in transforming the processes from the premises to the conclusion into a formal argument." _note="Relevance" colorLabel="1"/>
                                </outline>
                              </outline>
                            </outline>
                            <outline text="Helps a lot with [thoroughness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ)." _note="Likelihood" colorLabel="4" collapsed="true">
                              <outline text="If one skips over an important step of the formal process, it tends be obvious and able to be pointed out easily." _note="Likelihood" colorLabel="4" collapsed="true">
                                <outline text="Therefore it would often help a lot with being thorough, by making it easy to see where one is not thorough and where one must be more thorough to completely represent their position formally." _note="Relevance" colorLabel="4"/>
                              </outline>
                            </outline>
                            <outline text="[Importance of systematic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=XUvhNLQybh6UlJJgJCSnbDU7)" _note="Relevance" colorLabel="4"/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[Epistemic rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZcLNKNmVyYYwMjNA5z_NhQs)" heading="3" colorLabel="3"/>
                      </outline>
                    </outline>
                    <outline text="Debate" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Formal debates often involve specific preparation, timers and rounds, a moderator, etc."/>
                      <outline text="Informal debate is typically spontaneous, unmoderated, untimed and unstructured."/>
                    </outline>
                    <outline text="Colloquial" heading="3" colorLabel="3" collapsed="true">
                      <outline text="This typically has to do with something like social atmosphere."/>
                    </outline>
                    <outline text="Argument" heading="3" colorLabel="3" collapsed="true">
                      <outline text="A process of reasoning consisting of one or more premises (statements providing evidence or support) that lead to a conclusion (the claim being proven)."/>
                      <outline text="In formal contexts, &quot;argument&quot; is usually used to specify a structured version of the above, where the premises, conclusion and inferences are all explicitly represented as such."/>
                    </outline>
                    <outline text="Rationality" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Epistemic rationality" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The practice of systematically aligning your beliefs with the truth and updating your worldview based on objective evidence."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="[Instrumental rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=7F1Qi_G5J8CUa-W8lMXPlNHs)" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Epistemic rationality is often quite useful for instrumental rationality, but some specific aspects of epistemic rationality don&apos;t improve instrumental rationality much." collapsed="true">
                              <outline text="Eg. In some cases one knows what would be the best way to act to achieve their goals, but they don&apos;t actually do it." colorLabel="6" collapsed="true">
                                <outline text="Eg. One might know that the best way to convince another person is by speaking calmly with them, but then still end up shouting at them." colorLabel="6"/>
                              </outline>
                            </outline>
                            <outline text="Sometimes it even reduces it." collapsed="true">
                              <outline text="Eg. Deluding yourself into thinking that you&apos;re more attractive than you are might make you feel more confident, which might make you more effective at achieving your goals." colorLabel="6"/>
                              <outline text="However this is likely quite rare." colorLabel="1" collapsed="true">
                                <outline text="Long-term, there are typically other strategies for achieving emotional effects like confidence, without the potentially huge cost of getting into the habit of deluding yourself in an emotionally pleasant manner."/>
                                <outline text="^ The habit of emotionally deluding one&apos;s self in a pleasant manner tends to frequently cause of a ton of [cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9)." collapsed="true">
                                  <outline text="[Wishful thinking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GSuqwuWjSYY3yCdYSuAEztWz)" colorLabel="1"/>
                                  <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" colorLabel="1"/>
                                  <outline text="[Groupthink](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1krHbDONylAxWz1bingFgOlj)" colorLabel="1"/>
                                  <outline text="[Rationalization](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=NaE-8bpB1ZDuRzcl_T3nNErK)" colorLabel="1"/>
                                  <outline text="[Sunk cost fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MLF635GdLKFJg35pZZA-ER2r)" colorLabel="1"/>
                                  <outline text="[Gambler&apos;s fallacy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Z811xW5hpftJOBiJ4nLo12ez)" colorLabel="1"/>
                                </outline>
                              </outline>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Instrumental rationality" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Acting in accordance with your fundamental goals, whatever those are."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="&quot;your [...] goals&quot; as in the goals that you hold, not necessarily selfish/self-interested goals."/>
                        </outline>
                      </outline>
                      <outline text="Emotionless rationality" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Lacking emotion or passion."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="[Epistemic rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZcLNKNmVyYYwMjNA5z_NhQs)" heading="3" colorLabel="3" collapsed="true">
                            <outline text="Trying to repress one&apos;s emotions tends to lead to lots of issues that get in the way of [epistemic rationality](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZcLNKNmVyYYwMjNA5z_NhQs), and it tends to be correlated with a conflation of epistemic rationality with emotionless rationality, which would of course be correlated with a lack of epistemic rationality." _note="Link to section about repression"/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[What is rationality? Short video](https://www.youtube.com/watch?v=iloTS0wU9qM)"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Logic" heading="1" colorLabel="5" collapsed="true">
                    <outline text="0 order (prop)" heading="1" colorLabel="6" collapsed="true">
                      <outline text="[True and false (standard)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=J0b6o4lhMZ0f_F8xHttCI-ng)" heading="3" colorLabel="3"/>
                      <outline text="Inverse" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Adds a &quot;NOT&quot; to both sides of a syllogism." _note="Check if it actually is a syllogism, link whatever it really is, and link NOT."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="The inverse of P→Q is ¬P→¬Q."/>
                        </outline>
                        <outline text="Notes" heading="3" colorLabel="2" collapsed="true">
                          <outline text="The inverse of a statement is logically equivalent to the [converse](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=hn5cIVc2DKo-2jmUg5S_fwSh) of that statement."/>
                        </outline>
                        <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Inverse_(logic))"/>
                      </outline>
                      <outline text="Converse" heading="3" colorLabel="2" collapsed="true">
                        <outline text="[Parent definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Wac9sjLWcR3Fq8BN9O3Kqvb6)" heading="3" colorLabel="3"/>
                        <outline text="The result of reversing the two variables." _note="Maybe change the term &quot;variables&quot; to wherever the standard term is in prop log."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="For the implication P → Q, the converse is Q → P."/>
                        </outline>
                        <outline text="[Nuance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AP6i_jhyeBECDrnuYTZKz1OE)" heading="3" colorLabel="2"/>
                        <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Converse_(logic))"/>
                      </outline>
                      <outline text="Contrapositive" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The inference of going from a conditional statement into its logically equivalent contrapositive."/>
                        <outline text="The contrapositive of a statement has its antecedent and consequent negated and swapped." collapsed="true">
                          <outline text="The contrapositive of P→Q is ¬Q→¬P." collapsed="true">
                            <outline text="If P, Then Q. — If not Q, Then not P."/>
                          </outline>
                        </outline>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="&quot;If it is raining, then I wear my coat.&quot; — &quot;If I don&apos;t wear my coat, then it isn&apos;t raining.&quot;"/>
                        </outline>
                        <outline text="The law of contraposition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="The law of contraposition says that a conditional statement is true if, and only if, its contrapositive is true."/>
                          <outline text="[Proof by contrapositive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tTENdpA_M33m5Fl4CRqQiy98)" heading="3" colorLabel="5"/>
                        </outline>
                        <outline text="Synonym" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Transposition"/>
                        </outline>
                        <outline text="https://en.wikipedia.org/wiki/Contraposition"/>
                      </outline>
                      <outline text="Well-defined proposition" _note="Reconcile with [well-defined propositions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ewojo1Kk7SCQ_tTLnAMkJeio)" heading="3" colorLabel="5" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="A proposition whose definition is assigns it a single correct truth value."/>
                          <outline text="Synonym:   [Well-formed formula](https://en.wikipedia.org/wiki/Well-formed_formula)" colorLabel="3"/>
                          <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                            <outline text="[Well-defined expression](https://en.wikipedia.org/wiki/Well-defined_expression)"/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Inference rule" heading="3" colorLabel="5" collapsed="true">
                        <outline text="**Definition:**   A logical pattern that allows one to deduce a valid conclusion from a set of given premise(s)." colorLabel="3"/>
                      </outline>
                    </outline>
                    <outline text="1 order (pred)" heading="1" colorLabel="6" collapsed="true">
                      <outline text="Proper part" heading="3" colorLabel="3" collapsed="true">
                        <outline text="A part of something that is not the whole of that thing."/>
                      </outline>
                      <outline text="Converse" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The result of reversing its two constituent statements."/>
                        <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                          <outline text="[Prop example](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TXNXLJutVGKGljMNwLlbjzPX)" colorLabel="6"/>
                          <outline text="For the categorical proposition &quot;All S are P&quot;, the converse is &quot;All P are S&quot;."/>
                        </outline>
                        <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="The truth of the converse is generally independent from that of the original statement."/>
                        </outline>
                        <outline text="[Wikipedia](https://en.wikipedia.org/wiki/Converse_(logic))"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Probabilities" heading="1" colorLabel="4" collapsed="true">
                    <outline text="Probability" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="**Difficulty:**   It&apos;s very easy to conflate many of these definitions of probability." colorLabel="4" collapsed="true">
                          <outline text="This can result in making bad decisions based on conflating the definitions." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="Plausibility" heading="3" colorLabel="3" collapsed="true">
                        <outline text="A quantification of how plausible an event or proposition is, given our state of knowledge/ignorance."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Fair coin toss" heading="3">
                            <outline text="Given the plausibility definition, the coin toss has a 50% probability of landing on each side because we don&apos;t have any reason to pick one over the other. i.e. The [principle of indifference](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=nwdnsuvq_ylA7Zc7YVfSoowC) combined with the knowledge that there are two possible outcomes."/>
                            <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                              <outline text="We&apos;re talking about an idealized scenario where you have absolutely no evidence for the coin tending to land on one side or the other."/>
                              <outline text="In reality, [coins are slightly more likely to land on the side that starts facing up](https://www.youtube.com/watch?v=9VwOn5x7VAs)."/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Plausibility school of thought" _note="Maybe create a section for this?" heading="3" collapsed="true">
                            <outline text="This definitions falls under the plausibility school of thought."/>
                          </outline>
                          <outline text="[Bayesian inference](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wnbqSpA8PlB1hhUg-ZjkDFj9)" heading="3" colorLabel="4" collapsed="true">
                            <outline text="It&apos;s the definition typically used in bayesian reasoning.">
                              <outline text="Although it&apos;s possible to use bayesian reasoning with [propensity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FSrVYvon6XRX2Q4b71AMcYhc) as well."/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Credence" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The subjective probability we assign to things based (in part) on the evidence available to us as individuals."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Dice" collapsed="true">
                            <outline text="Typically has an equal subjective probability (or credence) of landing on any particular side."/>
                            <outline text="While the physics likely objectively at-least-virtually determine the result once the dice is thrown, given our human limitations, we do not typically have the means to predict the result with more-than-extremely-slightly-better-than-random accuracy."/>
                          </outline>
                        </outline>
                        <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Confidence" heading="3" collapsed="true">
                            <outline text="Confidence in a proposition/event X."/>
                            <outline text="Distinctions" heading="3" colorLabel="3" collapsed="true">
                              <outline text="Different from one&apos;s &quot;confidence&quot; in propositions/events __in general__ like in [epistemic self-confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Y9tqRoYVuJ-Fx4nqtdo3klx9)." collapsed="true"/>
                              <outline text="Different from one&apos;s &quot;confidence&quot;, as in [self-esteem](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5mmCXq5NdWjuCdTW4wQgRgGE)." collapsed="true"/>
                              <outline text="Different from one&apos;s &quot;confidence&quot;, as in how confident they appear, such as during some kind of [persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)."/>
                            </outline>
                          </outline>
                          <outline text="Subjective probability"/>
                          <outline text="Epistemic probability"/>
                        </outline>
                      </outline>
                      <outline text="Frequentist probability" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Defined in terms of the limit of the frequency of an event occurring."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Fair coin toss" heading="3" collapsed="true">
                            <outline text="Given the frequentist definition, the coin would have a 50% probability of landing on each side because if we would keep flipping it, the ratio of the two outcomes would approach 1/1, so the fraction of either one happening takes up half the total possibility space."/>
                            <outline text="[Distinction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=N78C3EULjx6kCZjoayqK6AlG)" heading="3" colorLabel="3" collapsed="true"/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Propensity" _note="Consider combining this with [frequentist probability](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vdQH8d59lQKL0q68J2ZjZvH_). I&apos;m unsure about it because the definition of &quot;frequentist probability&quot; I came across (in 3swap video) would seem to consider a coinflip in terms of repeated __very similar__ events, whereas the definition I have here seems to only be about events/propositions that are __exactly the same__. Should probably look into it deeper at some point." heading="3" colorLabel="3">
                        <outline text="The actual, real probability of events occurring / propositions being true."/>
                        <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Dice" collapsed="true">
                            <outline text="Typically has a ~100% propensity to land on the side it lands on, at least once it&apos;s thrown. Because:" collapsed="true">
                              <outline text="(&quot;At least once it&apos;s thrown&quot;, because we don&apos;t intend to make claims against free will in this example.)"/>
                            </outline>
                            <outline text="Dice are typically atleast nearly entirely determined by the laws of physics while falling through the air, in such a way that the final result is typically at least virtually guaranteed, given the exact same starting conditions."/>
                          </outline>
                          <outline text="Determinism" collapsed="true">
                            <outline text="If determinism is true, everything is entirely determined to occur from previous events and there is no randomness, so each event objectively either has 0% or 100% propensity to occur."/>
                          </outline>
                          <outline text="Quantum mechanics" collapsed="true">
                            <outline text="Might involve interactions that follow genuinely random probability distributions, so the propensity of different quantum events may be quite varied."/>
                          </outline>
                        </outline>
                        <outline text="Synonyms" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Objective probability"/>
                          <outline text="Chance"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Informal" heading="1" colorLabel="2" collapsed="true">
                    <outline text="[True and false (standard)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=J0b6o4lhMZ0f_F8xHttCI-ng)" heading="3" colorLabel="3"/>
                    <outline text="True and false (probability)" heading="3" colorLabel="3" collapsed="true">
                      <outline text="True: Usually high-probability beliefs, occasionally axioms."/>
                      <outline text="False: Low-probability beliefs."/>
                      <outline text="These definitions are uncommon." collapsed="true">
                        <outline text="Typically the uncertainty in statements like &quot;I know it&apos;s true that we have bread.&quot; lies in the word &quot;know&quot; rather than the word &quot;true&quot;." collapsed="true">
                          <outline text="[Know (probability)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TnFde8i_liH0vcSg8sIc-HEA)" heading="3"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="&quot;Soft&quot; reasoning" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Reasoning that cannot easily be broken down to a formal process using any typical methods, and that thus requires an unorthodox and/or informal process."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3" collapsed="true">
                          <outline text="&quot;Soft&quot; reasoning makes up a large portion of important reasoning."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Hot/cold biases" _note="Improve" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Hot biases" _note="Link a bunch of biases here to categorize them, and maybe add this to related under cognitive biases." heading="3" collapsed="true">
                        <outline text="Motivated irrationality where our interests, emotional responses or visceral reactions to things influences our thinking process."/>
                        <outline text="Related: [Cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9)" heading="3" colorLabel="6"/>
                      </outline>
                      <outline text="Cold biases" _note="Link a bunch of biases here to categorize them, and maybe add this to related under cognitive biases." heading="3" collapsed="true">
                        <outline text="Unmotivated irrationality which are a result of certain mental shortcuts and routines we rely on even in situations where they do not really apply."/>
                        <outline text="Related: [Cognitive biases](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=a4amRVifCY8jNCgNpW6j6zB9)" heading="3" colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Free speech" heading="3" colorLabel="3" collapsed="true">
                      <outline text="" colorLabel="3"/>
                      <outline text="&quot;Free speech&quot; is a vague term that should ideally be defined very explicitly before engaging in a serious discussion that uses it." colorLabel="2" collapsed="true">
                        <outline text="[Example misunderstanding](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=DRI9Yp8qNoAXyRwU-LhqBfAr)" heading="3" colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Ad hoc" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Science and philosophy definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The addition of extraneous [hypotheses](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lelHmq5_RA_nj89mdbd500nr) to save another hypothesis from being falsified." _note="Link to falsification" collapsed="true"/>
                        <outline text="Ad hoc hypotheses compensate for anomalies not anticipated by the theory in its unmodified form." collapsed="true"/>
                      </outline>
                      <outline text="[Source](https://en.wikipedia.org/wiki/Ad_hoc)" heading="3" colorLabel="6"/>
                    </outline>
                    <outline text="Informal operations" heading="1" colorLabel="5" collapsed="true">
                      <outline text="OR" heading="3" collapsed="true">
                        <outline text="Depending on the context, it can mean https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=n7OMAZ2eLgm2YIZTBh-L2db8 or [standard OR](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TKmTc0y15-zDJqP-9eeA6L5Z)."/>
                      </outline>
                      <outline text="IF-THEN" heading="3" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Usually a [material conditional](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw) with the added requirement that there be some causal or epistemic relation between the condition and consequence."/>
                          <outline text="Sometimes instead a [IF-AND-ONLY-IF (material biconditional)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EllGLMOpw-VRb31hYJiNtBhw)." collapsed="true">
                            <outline text="Example: &quot;I&apos;ll buy you a new wallet if you need one&quot; may be interpreted as a [biconditional](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EllGLMOpw-VRb31hYJiNtBhw) (&quot;if and only if&quot;), since the speaker doesn&apos;t intend a valid outcome to be buying the wallet whether or not the wallet is needed (as in a [conditional](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=uzxNZgNX8Jlzb09GO2ZXwiQw))." colorLabel="6"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Misc" heading="1" colorLabel="6" collapsed="true">
                    <outline text="Know" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Know (certainty)" heading="3" colorLabel="3"/>
                      <outline text="Know (probability)" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Know: Have more than C credence in something being true."/>
                        <outline text="Typically C is more than 85% and less than 100%."/>
                        <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                          <outline text="Distinct from [know (certainty)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ytpWye4oZ5q5dogPtKSCz111)" collapsed="true">
                            <outline text="Less than 100%."/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Good/bad/etc." heading="3" colorLabel="3" collapsed="true">
                      <outline text="Moral/axiological" heading="3"/>
                      <outline text="For reasoning" heading="3" collapsed="true">
                        <outline text="Good for reasoning, bad for reasoning, etc." colorLabel="3"/>
                        <outline text="This definition is uncommon, but for this particular context (a reasoning guide) we use it for convenience."/>
                      </outline>
                    </outline>
                    <outline text="Philosophical logic" heading="3" colorLabel="3" collapsed="true">
                      <outline text="The mathematical investigation of basic notions of logic."/>
                      <outline text="The deployment of logic to help with mathematical problems, so ‘philosophical logic’ means both (a) the philosophical investigation of the basic notions of logic and (b) the deployment of logic to help with philosophical problems."/>
                      <outline text="In the context of this guide, in largely includes these sections:" collapsed="true">
                        <outline text="[Axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)" heading="3" colorLabel="5"/>
                        <outline text="[Standard deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ENg9uidRSS0t3eQBEFX4pGmm)" heading="3" colorLabel="5"/>
                        <outline text="[Probabilistic reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i_iQ7vvMYVnf1xdY5Ymr8--m)" heading="3" colorLabel="4"/>
                        <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="3" colorLabel="3"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Unusual but used here" heading="3" colorLabel="6" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definitions that are unusual for the term they are defining, but used in this reasoning guide."/>
                    </outline>
                    <outline text="[Dynalist &quot;items&quot;](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ysqXDunJUGkagJZq3yN87Atd)" colorLabel="5"/>
                    <outline text="[Good/bad/etc. for reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=usvA1OYDq8EbicyYgXaCGS7k)" colorLabel="1"/>
                    <outline text="General Reasoning Guide" heading="3" colorLabel="5" collapsed="true">
                      <outline text="**Definition:**   The title of this guide." colorLabel="3"/>
                      <outline text="[General Reasoning Guide        Pre-Alpha v0.1.7.4](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd)" heading="1"/>
                      <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                        <outline text="[FAQs](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=zKXsMJmmMm-VEFAVMo0P4xWB) - For more misc info about this guide." heading="3"/>
                      </outline>
                    </outline>
                    <outline text="Made-up terms" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Some relevant terms that we&apos;ve made up, to make it easier to talk about certain concepts."/>
                        <outline text="Note that this probably doesn&apos;t include all the made-up terms used throughout the guide, but hopefully most of them."/>
                      </outline>
                      <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Probably not very useful since nobody uses these terms." heading="1" colorLabel="1"/>
                        <outline text="Could maybe be nice for communities wanting to adopt some misc handy short-cut terms." colorLabel="4"/>
                      </outline>
                      <outline text="[Critical piggybacking](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2J5emCtKut8DRA6avr2C4r87)" heading="3" colorLabel="1"/>
                      <outline text="[Other-shoe reviews](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d7AlWLW-6EAuja2PutdZEj64)" heading="3" colorLabel="1"/>
                      <outline text="RAC" colorLabel="2" collapsed="true">
                        <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                          <outline text="RAC is an acronym for &quot;rationally action-compelling&quot;, which means:"/>
                          <outline text="Truly better to have/do (all else being equal) in a sense that is action-compelling to a perfectly rational agent, without needing any moral/axiological axioms/presuppositions."/>
                          <outline text="i.e. / expounding" heading="3" collapsed="true">
                            <outline text="In other words, a proposed kind of ought that can be derived epistemically from non-oughts, and which would, if its potential existence is known by a perfectly rational agent, compel that perfectly rational agent to &quot;act in accordance with&quot; it, for rational reasons.&quot;"/>
                            <outline text="&quot;Act in accordance with&quot; being defined as &quot;attempt to (in the absence of sufficient competing RAC or potentially RAC things) maximize the average* (or mean, etc.) completion of&quot;. &quot;Action-compelling&quot; being defined similarly."/>
                            <outline text="`*` &quot;Average completion&quot; or alternatives typically being defined in terms of subjective probability, rather than objective probability. However this might change depending on the context."/>
                          </outline>
                        </outline>
                      </outline>
                      <outline text="Literaloo" colorLabel="3" collapsed="true">
                        <outline text="**Definition:**   Literally literally" colorLabel="3"/>
                        <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="There are a decent number of situations where you want to clarify that you mean something literally, but there isn&apos;t an easy way to do so because the normal explicit methods have other connotations." colorLabel="1" collapsed="true">
                            <outline text="For example it might be interpreted as rude, and prefacing what you say with &quot;literally&quot; is likely just going to sound like emphasis of the rude thing." colorLabel="4"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Definitional options" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Recommended options" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Most common definition" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The current most common definition in the world."/>
                      </outline>
                      <outline text="Should be the default choice in most situations."/>
                    </outline>
                    <outline text="Most common definition (given broad context)" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The current most common definition given the broad context. " collapsed="true">
                          <outline text="Broad context" heading="3" colorLabel="3"/>
                        </outline>
                        <outline text="Examples" heading="3" colorLabel="6"/>
                      </outline>
                    </outline>
                    <outline text="Other&apos;s definition" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="The definition that the person(s) you&apos;re having the discussion with appear(s) to be using."/>
                      </outline>
                      <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Difficulty of guessing definitions" heading="3"/>
                        <outline text="Potential conflations" heading="3" collapsed="true">
                          <outline text="The other person may be conflating multiple definitions, meaning using their definition may cause more confusion."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Making one up" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                        <outline text="If there is an already-present definition, it can cause a lot of confusion to make one up instead."/>
                      </outline>
                      <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                        <outline text="If no definition fitting one of the other options works well, writing your own may be the most efficient option despite the potential confusion."/>
                      </outline>
                    </outline>
                    <outline text="How to choose" heading="1" colorLabel="2"/>
                  </outline>
                  <outline text="Unrecommended options" heading="1" colorLabel="2" collapsed="true">
                    <outline text="[Vague definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Why to avoid" heading="3" colorLabel="2" collapsed="true">
                        <outline text="To avoid [conflating ideas](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" collapsed="true">
                          <outline text="[Vague definitions frequently cause conflations.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wsPeD0rbc6QiT5c6ud5AwvkB)"/>
                        </outline>
                        <outline text="To avoid confusing them"/>
                      </outline>
                    </outline>
                    <outline text="Etymology-based definition" heading="1" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Definition based primarily on the etymology of the word."/>
                      </outline>
                      <outline text="Why to avoid" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Confusion" heading="1" colorLabel="2"/>
                        <outline text="Reasons to adopt" heading="1" colorLabel="2" collapsed="true">
                          <outline text="&quot;Deeper truths&quot;" heading="3" collapsed="true">
                            <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                              <outline text="The view that the etymology of words hide deeper truths about those words."/>
                              <outline text="This is a semi-common view, particularly among conspiracy theorists."/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="How to avoid" heading="1" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Definitional consistency" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Changing a definition mid-discussion often causes insane amounts of confusion (usually for both parties)." collapsed="true">
                      <outline text="Exceptions" heading="3" colorLabel="2" collapsed="true">
                        <outline text="If you make it very clear when you&apos;re using a different definition and what that other definition is, most confusion can usually be avoided."/>
                      </outline>
                    </outline>
                    <outline text="Unknowingly using multiple definitions is called &quot;conflation&quot; and is one of the biggest causes for faulty reasoning ever."/>
                  </outline>
                  <outline text="Methods" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Pick a definition and stick with it" heading="3" collapsed="true">
                      <outline text="This is the most reliable way to avoid conflations and semantic confusion."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Definitional differences" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="When you and the other person are using different definitions, it&apos;s very important to recognize and fix this, otherwise you could end up talking past each other for a long time."/>
                  </outline>
                  <outline text="Types of definitional differences" heading="1" colorLabel="3" collapsed="true">
                    <outline text="Different definitions" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="This is the typical case where people have different definitions for the same word."/>
                      </outline>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="The hot dog ran" collapsed="true">
                          <outline text="The dog (animal) that was hot (temperature) ran."/>
                          <outline text="The dog (animal) that was hot (attractive) ran."/>
                          <outline text="The &quot;hot dog&quot; (food) ran."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Different sub-definitions" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Sub-definition" heading="3"/>
                        <outline text="^ A definition for a (word that is inside of a definition for the main word in question)."/>
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="Two people may appear to be using the same standard definition for a classical God, but define one of the relevant properties (eg. omnipotence) differently. One might define it as maximally powerful (as powerful as possible within logical constraints), while another may define it as having power over absolutely everything, including logic."/>
                          <outline text="^ The definition for classical theism just mentions &quot;omnipotence&quot;, so they can both point to the same definition and think they&apos;re talking about the same concept, but due to the different definition of the term *inside* the definition for classical theism, they are actually talking about different concepts."/>
                        </outline>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3"/>
                        <outline text="^ People can seem to agree on the main definition due to using the same words, but they can actually mean separate things due to defining part(s) of the definition for the main word differently." colorLabel="4" collapsed="true">
                          <outline text="This can lead to a significant amount of time wasted from misunderstandings, perhaps making the difference between changing someone&apos;s mind / understanding someone, and not." colorLabel="4"/>
                          <outline text="[Example](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=p6U8FY4qOsccNJ3l8cqZaaD2)" _note="Likelihood" heading="3" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Different &quot;orders of operations&quot;" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Abiguity due to not knowing which parts to read as connected to which other parts."/>
                      </outline>
                      <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                        <outline text="A definition for a word that is inside of a definition for the main word in question." collapsed="true">
                          <outline text="A definition for a (word that is inside of a definition for the main word in question)."/>
                          <outline text="(A definition for a word) that is inside of a definition for the main word in question."/>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Assumed details" heading="3" colorLabel="2" collapsed="true">
                      <outline text="People sometimes assume details for a term that weren&apos;t explicitly given."/>
                      <outline text="These assumed details can often differ from the intended details, if there were even intended details in the first place."/>
                    </outline>
                  </outline>
                  <outline text="Recognizing when definitional differences occur" heading="1" colorLabel="3" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3"/>
                      <outline text="^ When people say things that seem very obviously wrong, it is very often due to some definitional difference." colorLabel="4"/>
                    </outline>
                    <outline text="Checking for possible interpretations" _note="Reorganize or split this into other sections here? Not sure" heading="2" colorLabel="3" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Checking for different ways that a person could be using terminology."/>
                        <outline text="Example: Using a different definition." colorLabel="6"/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Impactful" heading="3"/>
                        <outline text="^ Likely to save a substantial amount of time to catch misunderstandings sooner rather than later." _note="Link to section on the cost of misunderstandings." colorLabel="4"/>
                      </outline>
                      <outline text="Definitions" heading="2" colorLabel="6" collapsed="true">
                        <outline text="Maybe try to think of all the common definitions that could plausibly be used for the circumstance."/>
                      </outline>
                    </outline>
                    <outline text="Topics with a lot of confusing/alternative definitions" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Example" heading="3" colorLabel="6"/>
                      <outline text="[&quot;Soft&quot; reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=VqyTyvLNbJ6WtfifAe0egZtQ) topics" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Tentative explanation" heading="3" colorLabel="1" collapsed="true">
                          <outline text="People tend to reason about these topics in a vibes-based way, so they tend to talk about the topics in a vibes-based way, so the definitions common within these topics primarily developed to capture those vibes, rather than the logic content." collapsed="true">
                            <outline text="This is why for example &quot;morality&quot; can mean a million different things to different people, but the vast majority of those meanings have a similar vibe."/>
                          </outline>
                        </outline>
                        <outline text="Specific topics" heading="2" colorLabel="2" collapsed="true">
                          <outline text="Philosophy" heading="3" colorLabel="3"/>
                        </outline>
                        <outline text="How to deal with this" heading="3" colorLabel="2"/>
                      </outline>
                      <outline text="The topics you specialize in" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Expert terminology tends to differ from colloquial terminology, so you can expect that laypersons will often not be able to understand you very well if you start using a topic&apos;s expert terminology to talk about the topic." colorLabel="4" collapsed="true">
                            <outline text="**Misc note:**   Sometimes this expert terminology is to make it easier for experts to speak with each other, and sometimes just to sound more knowledgable/intelligent or because of tradition."/>
                          </outline>
                        </outline>
                        <outline text="How to deal with this" heading="3" colorLabel="2"/>
                      </outline>
                    </outline>
                    <outline text="People likely to have definitional differences" heading="3" colorLabel="1" collapsed="true">
                      <outline text="People who use a lot of niche definitions" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                          <outline text="When people use niche definitions in many other areas, there&apos;s a good chance they&apos;ll use niche definitions in the area you&apos;re talking about." colorLabel="4"/>
                        </outline>
                        <outline text="How to deal with this" heading="3" colorLabel="2"/>
                      </outline>
                      <outline text="People who likely are(n&apos;t) very familiar with relevant niche definitons" heading="3" colorLabel="1" collapsed="true">
                        <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                          <outline text="One philosopher and one layperson talking about ethics. The philosopher uses terminology that&apos;s standard among philosophers, but non-standard to lay-people, or has a different meaning. For example a philosopher may use the word &quot;utilitarianism&quot; to refer to the ethical framework, while the layperson might interpret this to be referring to the advocacy of &quot;utility&quot; as in &quot;practical usefulness&quot;, rather than pleasure minus suffering or similar."/>
                        </outline>
                        <outline text="Importance" heading="3" colorLabel="2"/>
                        <outline text="How to deal with this" heading="3" colorLabel="2" collapsed="true">
                          <outline text="Internalizing that some groups will be (un)familiar with some terms" heading="3" collapsed="true">
                            <outline text="**Unfamiliar:**   It&apos;s recommended to internalize that certain groups will be unfamiliar with certain types of terminology and likely to use other terminology to talk about the same concepts." collapsed="true">
                              <outline text="**You:**   Highly recommended to account for the fact that __you__ are likely in many groups that are unfamiliar with certain types of terms."/>
                              <outline text="^ And as such, in contexts that you are unfamiliar with, you should account for the fact that you likely do not know many of the definitions being used."/>
                              <outline text="^ Even (and especially!) for words that you otherwise believe yourself to be familiar with."/>
                            </outline>
                            <outline text="**Familiar:**   Recommended to internalize that certain groups will be familiar with certain types of terminology that __you__ are unfamiliar with."/>
                          </outline>
                          <outline text="Memorizing specific groups&apos; definitional behavior" heading="3" collapsed="true">
                            <outline text="Recommended (and most crucial) to internalize what many of these specfic groups and types of terminology are (within reason)."/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                    <outline text="Seemingly absurd statements" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Statements that on the surface seem absurd, based on the way you are interpreting them."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Oftentimes, statements will seem absurd because they are absurd given the interpretation we have of them, but not the interpretation that the author intended." colorLabel="4" collapsed="true">
                          <outline text="One might be tempted to argue that &quot;they said something absurd either way&quot;, and that the statement should be counterargued regardless of the intention. Depending on the context, this may make sense. But I would argue that more often than not, it is more productive to ask for clarification/definitions in order to try to understand what the author __meant__ to say, to be able to address their actual reasoning." _note="Probably move this somewhere else and link it here, like a section about debate habits or something."/>
                        </outline>
                      </outline>
                      <outline text="How to deal with this" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Rewrite in simpler words" heading="3" collapsed="true">
                          <outline text="**Definition:**   Asking them to rewrite the seemingly absurd statement in simpler words." colorLabel="3"/>
                          <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                            <outline text="This often makes it clear what they were trying to say." colorLabel="4"/>
                            <outline text="It often isn&apos;t sufficient to make it clear what they meant to say, in which case this can be a waste of time." colorLabel="1"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Identifying specific definitional differences" heading="1" colorLabel="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Identifying exactly a specific definitional difference is, often after you start to suspect that one might be at play."/>
                    </outline>
                    <outline text="Source-specific strategies" heading="2" colorLabel="2" collapsed="true">
                      <outline text="[&quot;Soft&quot; reasoning topics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8m3MqZop7Pb3nhhIztdrl5QV)" colorLabel="3"/>
                      <outline text="[The topics you specialize in](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=B_jt2866Yy6ze7tDdBi8QIMF)" colorLabel="3"/>
                      <outline text="[Their irrelevant niche definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=30mwyyR810FVMCCHgg70LleJ)" colorLabel="1"/>
                      <outline text="[Your/their relevant niche definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lRl7dZEQ3At4v8nMIf1S-8h-)" colorLabel="1"/>
                      <outline text="[Seemingly absurd statements](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OhpvmWu7R-vlitQvn-Yr7pZP)" colorLabel="2"/>
                    </outline>
                    <outline text="Check/think about the context to see if you can figure out where they&apos;re coming from."/>
                    <outline text="Check for different definition(s) for key term(s)." collapsed="true">
                      <outline text="Unlearn the habit of assuming what is meant for key terms when it isn&apos;t obvious."/>
                    </outline>
                    <outline text="Check for insinuated details that weren&apos;t technically included."/>
                  </outline>
                  <outline text="Dealing with definitional differences" heading="1" colorLabel="3" collapsed="true">
                    <outline text="Adopt their definition(s) for the purposes of the discussion, if it wouldn&apos;t be too confusing."/>
                    <outline text="Ask them to use different definition(s) if it would otherwise be too confusing."/>
                    <outline text="Try to adapt to their contextual style of speaking."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="1" colorLabel="3"/>
                  <outline text="[Ostensive definition](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wqjHe0ETccAnBhGoYUCfWKtS)" heading="3" colorLabel="3"/>
                </outline>
              </outline>
              <outline text="Conflations" heading="1" colorLabel="1" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="When a term is used or interpreted to mean two incompatible concepts without the user/interpreter in question realizing."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="[Easy to conflate similar things](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KaE9B3mvc-wTDPji-Nvg8k_6)" _note="Likelihood" colorLabel="4"/>
                    <outline text="^ Multiple very similar concepts often arise." _note="Relevance" colorLabel="4" collapsed="true">
                      <outline text="It&apos;s common for multiple very similar concepts to (at least on the surface) fit a situation well." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Thus common for multiple of them to arise in someone&apos;s mind." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Thus common for people to think of something slightly different than what they were intending, or what would actually work for the situation." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Very bad for reasoning" heading="3" collapsed="true">
                    <outline text="Conflations can easily result in [invalid](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=UUAfcY2vsb-7FyMTvOmfclqa) [deductive](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-n8BacOsj9yIbpLxsbz4df8M) arguments" heading="3" colorLabel="4" collapsed="true">
                      <outline text="**Common:**   Deductive arguments are common" _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Standard deductive arguments [are common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=t4q5dF-TXwNiSrdGj3N4glkf)" _note="Likelihood" colorLabel="4"/>
                        <outline text="All arguments can be reduced to deductive arguments (&quot;deductive&quot; defined broadly)" _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="[All reasoning can be reduced to deduction](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6TylIep-sVpCiTF65ZAxoq0c)" _note="Likelihood" colorLabel="4"/>
                        </outline>
                      </outline>
                      <outline text="In a deductive argument, a conflation typically renders the argument invalid." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="This is because there usually aren&apos;t many irrelevant premises/steps in a deductive argument, so everything is typically necessary for the conclusion. (i.e. All the reasoning gets &quot;combined&quot; somewhere along the way to eventually result in the conclusion.)" _note="Likelihood" colorLabel="4"/>
                        <outline text="^ This means that for whatever premise(s)/step(s) involve the conflation(s), there&apos;s probably a dependency on the conflating term(s)&apos; meanings staying the same." _note="Relevance" colorLabel="4"/>
                      </outline>
                      <outline text="Invalid deductive arguments are very bad for reasoning." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="Invalid deductive arguments [are completely unreliable](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LVGFzurb72Xhx0qvbtlONVLW)." _note="Likelihood" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Improvable" heading="3" collapsed="true">
                    <outline text="It&apos;s extremely easy to conflate very similar concepts." colorLabel="1" collapsed="true">
                      <outline text="[Similar concepts often arise](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6RsbW8g7gipVhGNbuWkJreJ9)" _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="This link a bit more relevant stuff than might initially be expected." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="How conflations arise" heading="1" colorLabel="2" collapsed="true">
                  <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Step 2 (assuming that we&apos;re right) causes us to spend much less time/effort ensuring that our reasoning does not contain errors such as conflations." colorLabel="4"/>
                  </outline>
                  <outline text="[Vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="3" colorLabel="3"/>
                  <outline text="Complex reasoning" heading="3" colorLabel="6"/>
                </outline>
                <outline text="Others&apos; [conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Make sure a key definition doesn&apos;t shift during the discussion."/>
                  <outline text="If something doesn&apos;t seem to add up, you may want to check to see if they used a key term differently in different places."/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6"/>
              </outline>
              <outline text="Being clear" heading="1" colorLabel="2" collapsed="true">
                <outline text="Stating the obvious" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Stating what you believe the other person(s) present likely know(s)."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Useful for making sure that others understand." collapsed="true">
                      <outline text="Especially when you&apos;re only like 60% confident that they know it."/>
                    </outline>
                    <outline text="Useful for persuasion" _note="~~Advanced   Link, support"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Often wastes time."/>
                  </outline>
                </outline>
                <outline text="Quantification" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Providing a specific quantity of relevant values/variables."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Helps with [being clear](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=odVF3W0ppNwcbM8PMavDS92J)" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Quantifying confidence" heading="2" colorLabel="4" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3"/>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Helpful for applying more systematic inductive reasoning. "/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Quantifying error margin" heading="3" colorLabel="4" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Helpful for applying more systematic inductive reasoning."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Quantifying relevance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Helpful for more systematic decision-making" colorLabel="4"/>
                    </outline>
                    <outline text="[Reducing usage of very high/low relevance quantifiers](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sbJ4JFvrTiAhx6-UlX0VfqiK)"/>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[(Un)conservative claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=clC-svjqyNajpM81R8mrQFEl)" heading="3" colorLabel="2"/>
                    <outline text="[Distinguishing likelihood and relevance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yhNvheql8sUOE-_HhGsNwMvd)" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Reducing usage of very high/low relevance quantifiers" _note="~~expert" heading="3" colorLabel="2" collapsed="true">
                  <outline text="[Norm: relevance &gt; likelihood](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8lKqHN0nm2G0QS-nsVBOnoM8)" heading="3" colorLabel="2"/>
                </outline>
                <outline text="Slowly walking people through reasoning" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="People tend to skim reasoning, especially if there&apos;s a lot of it given at once." colorLabel="4"/>
                    </outline>
                    <outline text="Improvable" heading="3" collapsed="true">
                      <outline text="People tend to go away too fast for other people to properly, systematically understand." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Parentheses/brackets" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Using () and [] to make the logical structure of claims more clear."/>
                  </outline>
                  <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                    <outline text="We can learn much more consistent means of accounting for [past reasoning that may have been forgotten]."/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="1" colorLabel="3"/>
                  <outline text="[Lacking context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lVuocPQtbJr1T1UQTA9_LCyy)" heading="1" colorLabel="2"/>
                  <outline text="[Distinguishing likelihood and relevance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yhNvheql8sUOE-_HhGsNwMvd)" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Sentences" heading="1" colorLabel="3" collapsed="true">
                <outline text="Declarative vs interrogative vs imperative sentences" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Declarative sentences" heading="3" collapsed="true">
                    <outline text="Declarative sentences express what is the case." colorLabel="3"/>
                    <outline text="&quot;The door is open.&quot;" colorLabel="6"/>
                    <outline text="Different declarative sentences can express the same idea." collapsed="true">
                      <outline text="The English sentence &quot;Snow is white&quot; and the German sentence &quot;Schnee ist weiß&quot; express the same idea." colorLabel="6"/>
                    </outline>
                  </outline>
                  <outline text="Interrogative sentences" heading="3" collapsed="true">
                    <outline text="Interrogative sentences request information." colorLabel="3"/>
                    <outline text="&quot;Is the door open?&quot;" colorLabel="6"/>
                  </outline>
                  <outline text="Imperative sentences" heading="3" collapsed="true">
                    <outline text="Imperative sentences issue command(s)." colorLabel="3"/>
                    <outline text="&quot;Open the door!&quot;" colorLabel="6"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6"/>
            </outline>
            <outline text="Requesting info" heading="1" colorLabel="6" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="It&apos;s very common for people to request info in one way or another." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="When used correctly, asking for info can be very useful for understanding what others mean." colorLabel="4"/>
                  <outline text="People often give vague/inadequate info" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Because of [attempted anticipation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GiYDKlicnNc1dQVnntzf_w58)" heading="3" colorLabel="4" collapsed="true">
                      <outline text="Often very hard to solve." colorLabel="4"/>
                    </outline>
                    <outline text="Often relatively easy to get clearer info" heading="3" colorLabel="1" collapsed="true">
                      <outline text="It&apos;s often relatively simple to see where the info was inadequate and ask for more clear/specific info about a particular part." colorLabel="4"/>
                      <outline text="When [attempted anticipation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GiYDKlicnNc1dQVnntzf_w58) is involved, the clearer info is often not clear enough." colorLabel="1"/>
                    </outline>
                    <outline text="Can easily waste time" heading="3" colorLabel="4" collapsed="true">
                      <outline text="If people cannot give sufficiently clear info sufficiently quickly, then often very little progress is made per info request." collapsed="true">
                        <outline text="In such cases it&apos;s typically better to either try to work with the vague info or abandon the matter altogether."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="**Slow:**   It&apos;s often a little slow for people to give the info." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Requesting definition(s) / meaning(s)" _note="Possibly move importance/limitations from here to [definitions and/or definitional differences] or vise versa. Or maybe just move this under definitions." heading="2" colorLabel="3" collapsed="true">
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3"/>
                  <outline text="^ Definitions are usually not as confusing as examples or elaboration, so it&apos;s often easier to ask for clarification on part(s) of a definition to get a clearer definition." colorLabel="4"/>
                  <outline text="^ People often don&apos;t provide a definition." colorLabel="1" collapsed="true">
                    <outline text="They often perform [attempted anticipation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GiYDKlicnNc1dQVnntzf_w58)" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Reflecting for feedback" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Restating what someone says and asking if you&apos;ve correctly understood what they said."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="&quot;Reflecting for feedback&quot; is distinct from reflecting for other reasons. Sometimes people will often restate things just because it feels natural to them to converse that way. This tends to be a form of [useless fluff](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sPAxqgULVQRZjeQCtlm63eWQ), and as a result we don&apos;t recommend it."/>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="1" colorLabel="2" collapsed="true">
                    <outline text="When used correctly, this can be a useful technique for understand what other people mean." colorLabel="4"/>
                    <outline text="Slow   (major)" heading="3" colorLabel="1" collapsed="true">
                      <outline text="This tends to slow down the conversation a lot, since you have to think about and rewrite what they said using different wording each time you perform this technique." colorLabel="4"/>
                      <outline text="Asking for definition(s), elaboration or an example is often quicker." colorLabel="4"/>
                    </outline>
                    <outline text="Unreliable feedback   (major)" heading="3" colorLabel="1" collapsed="true">
                      <outline text="They might answer &quot;yes&quot; even when you haven&apos;t quite correctly understood what they meant." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Especially if they don&apos;t have the best reading comprehension or if they aren&apos;t accounting for some subtle detail(s)." colorLabel="4"/>
                      </outline>
                      <outline text="They might answer &quot;no&quot; even if you have correctly understood what they meant." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Because they might not understand how what you said is ultimately synonymous with what they said, because they don&apos;t have the best reading comprehension or they aren&apos;t accounting for some inbetween steps or something." colorLabel="4"/>
                      </outline>
                      <outline text="This is especially problematic because it can give a false sense of understanding, which can lead to much worse misunderstandings down the road." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=trb9nqsaLcvBK2O1-HBNApOW)" heading="3" colorLabel="6"/>
                  <outline text="[Definitional differences](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vMjtaIQiRY359z8Zq6mtQRGc)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Requesting elaboration" heading="2" colorLabel="2" collapsed="true">
                <outline text="Definition (broad)" heading="3" colorLabel="3"/>
                <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Difficult" heading="3" collapsed="true">
                    <outline text="We sometimes have habits to ask for elaboration broadly, without specifying what should be elaborated on." colorLabel="4" collapsed="true">
                      <outline text="Problematic [because [...]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fVv8LmYSq7UF-r-ZRWTdDk_h)" _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Directed questions" heading="1" colorLabel="2" collapsed="true">
                  <outline text="It&apos;s usually best to ask for elaboration on some specific element, rather than with no specification of what should be elaborated."/>
                  <outline text="^ Because asking for elaboration with no specification of what should be elaborated on usually requires the other person(s) to spend longer coming up with said elaboration, and makes their elaboration much more likely to be [inadequate](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0UemICqNB8TRAw4MmGRYhAFK)."/>
                </outline>
              </outline>
              <outline text="Requesting example(s)/[analogies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fB49ZDXwTg85jeD3n0Jft40n)" heading="2" colorLabel="4" collapsed="true">
                <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="It&apos;s very common for people to ask for examples in order to better understand something." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="[It&apos;s very easy to accidentally use analogies that are compatible with multiple mutually exclusive plausibly-intended definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Q-fGc4yRaoE0tqnoNGmH85VW)" colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Checking for different axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=24EaczWHJrg69lrWn8-3oZp5)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Implications" heading="1" colorLabel="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Heavily relying on implied premises" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Avoiding explicitly mentioning many premises that one&apos;s relying on. " collapsed="true">
                    <outline text="&quot;Many&quot; relative to how many premises others tend to mention."/>
                  </outline>
                  <outline text="Especially premises that one is unsure that they&apos;ll need to mention, but that could plausibly be useful to mention."/>
                </outline>
                <outline text="Impactful" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Many people do it without even realizing it, so it&apos;s likely more common than it seems." colorLabel="4"/>
                    <outline text="People often forget the reasons for their opinions and work their way back to them in real time as the discussion progresses." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="**Feels like bad reasoning:**   This often results in others feeling like the reasoning is bad." colorLabel="4"/>
                    <outline text="^ It feels [ad hoc](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=sw6xvo_v_jLChEOrQ4rLMNfJ)" _note="Likelihood" heading="3" colorLabel="4" collapsed="true">
                      <outline text="It seems as though much of the reasoning is created on the spot." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="When using this approach, a lot of reasoning is often not given until requested or a new counter needs addressed." _note="Likelihood" colorLabel="4"/>
                        <outline text="During discussions, people often fail to account for the possibility that other person(s) are heavily relying on implied [premises](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=8N8O3Nl7p9LzdQj3g2-MltaY)." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="i.e. Not revealing or recalling all their points immediately." colorLabel="3"/>
                        </outline>
                      </outline>
                      <outline text="It being ad hoc makes it seem as though the reasoning is much less reliable than it could otherwise seem." _note="Relevance" colorLabel="4" collapsed="true">
                        <outline text="If it was created on the spot, it couldn&apos;t have been thought through very much." _note="Likelihood" colorLabel="4"/>
                        <outline text="When one is using ad hoc reasoning, their confidence often feels disproportionate to their evidence, given the limited support provided for their claims." _note="Relevance | Maybe create an ad hoc section and put this there, and link it here." colorLabel="4" collapsed="true">
                          <outline text="This often makes it seem as though the person using this technique is more [over-confident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB) and [close-minded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr) than they are." _note="Relevance" colorLabel="4" collapsed="true">
                            <outline text="This often causes others to grow over-confident that the person using this technique isn&apos;t worth taking seriously on the discussion topic." colorLabel="4" collapsed="true">
                              <outline text="This causes others to be much more close-minded about it." colorLabel="4"/>
                            </outline>
                            <outline text="This seeming [often doesn&apos;t go away even once sufficient evidence is given.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KqtoMb3Ji1U25L-4DgR1RYQE)" colorLabel="4" collapsed="true">
                              <outline text="Meant to be about the parent claim, even though the link leads elsewhere. Link given because of its children." colorLabel="3"/>
                            </outline>
                          </outline>
                        </outline>
                        <outline text="The feeling often doesn&apos;t go away even once sufficient evidence is given." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="[Confirmation bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=_Dn0UzSi_JF-Rno7Uvb0luL-)" heading="3" colorLabel="4" collapsed="true">
                            <outline text="[Defensiveness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i0kpUe1-nmMVRJvGlS8C4Jif)" heading="3" colorLabel="4" collapsed="true">
                              <outline text="&quot;If someone is using ad hoc reasoning, they shouldn&apos;t be able to beat me!&quot;" colorLabel="4"/>
                            </outline>
                          </outline>
                          <outline text="[Myside bias](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ANSY8wKwUA6n4_4bLjV_DKCI)" heading="3" colorLabel="4" collapsed="true">
                            <outline text="[Defensiveness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=i0kpUe1-nmMVRJvGlS8C4Jif)" heading="3" colorLabel="4" collapsed="true">
                              <outline text="&quot;If someone is using ad hoc reasoning, they shouldn&apos;t be able to beat me!&quot;" colorLabel="4"/>
                            </outline>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="How to view / strategies" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Doing it yourself" heading="3" collapsed="true">
                    <outline text="**State that you&apos;re using it:**   You can explicitly state that you have a lot of reasoning that you&apos;ll present only after the relevant counters have been given." collapsed="true">
                      <outline text="This is likely going to be difficult to remember to do, so you might want to practice it and ensure that it will become a habit."/>
                    </outline>
                    <outline text="**State why:**   To make it more memorable that you&apos;re doing it, and to somewhat avoid them feeling like you&apos;re stupid for doing it, you can explain why you&apos;re doing it." collapsed="true">
                      <outline text="Eg. To save time by efficiently give only the relevant info to the person you&apos;re discussing the topic with." colorLabel="6"/>
                    </outline>
                    <outline text="**Act less confident:**   By acting less confident than you actually are while using this technique, you can avoid [these issues](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HVoJ-SL7wOMBjecV8O0ahHqz)."/>
                    <outline text="**Don&apos;t do it:**   Without accounting for others assuming the worst when you use this technique, it&apos;s generally more efficient to use it. But at the cost of that efficiency, you can avoid problems caused by it by simply not using it." collapsed="true">
                      <outline text="To avoid using this technique, do more [argument premoves](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QLfbU4dDp6Me-Vt_xT5qvkwk) and go a layer or so deeper in your reasoning, even if it involves accounting for responses than the opponent might not give."/>
                      <outline text="^ Just be careful not to account for things that you know none of the other person(s) present would argue/think, as this is likely [addressing irrelevant reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KOPPXTY3kepYJVMbJ9RL4sXR)." collapsed="true">
                        <outline text="This is bad for reasons that might not be immediately apparent if you haven&apos;t visited the link." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Others doing it" heading="3" collapsed="true">
                    <outline text="Due to the propensity for people to use this technique, it is very important to account for this by keeping in mind that people very often have deeper reasoning that they haven&apos;t presented yet, which may justify their position in a way we hadn&apos;t considered."/>
                    <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                      <outline text="Steelmanning" heading="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Analogies" heading="1" colorLabel="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Figures of speech that compare two different things to highlight a shared relationship or principle." colorLabel="3"/>
                <outline text="Its purpose is usually to explain a complex or unfamiliar concept by comparing it to something simple and well-known."/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="[Limitations of analogical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TTnjcORtghPD5rcCtsFRyuN3)" heading="3" colorLabel="1"/>
                  <outline text="[Limitations of [definitions via analogies]](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LZ1F1M2zhslFZ0S_kU8QvszS)" heading="3" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2"/>
              <outline text="Examples" heading="1" colorLabel="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="A specific instance or case that is used to illustrate a general rule or clarify an idea."/>
                  <outline text="Type of analogy?" heading="3" collapsed="true">
                    <outline text="While examples are not typically regarded as a type of analogy, they always implicitly involve a comparison of two different things (the specific case with the general principle) to highlight a shared relationship (that the specific case belongs to the general rule&apos;s domain)."/>
                    <outline text="Therefore, at least for the purposes of this guide with the definitions provided, examples are considered a type of analogy."/>
                  </outline>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Examples tend to be a very good way to get a broad intuition of roughly what something means / how something works." colorLabel="4"/>
                    <outline text="Examples tend to leave a concept somewhat [vaguely defined](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LgcHPaKj_x7CzWpHlY2E9Dt6) in a manner that can [easily result in misinterpretations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9gz76ZvBBCkWJrfBEtN5y5Ij)." colorLabel="1"/>
                  </outline>
                </outline>
                <outline text="Detailed examples" heading="2" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Examples that are detailed, typically enough so to make it clear what the relevant attributes of the specific case are, and what general rule it&apos;s being claimed to be a part of."/>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Good for catching/conveying details that wouldn&apos;t otherwise be thought of even with [vague examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LgcHPaKj_x7CzWpHlY2E9Dt6)" colorLabel="4" collapsed="true">
                        <outline text="For very important issues, taking the extra time to carefully account for things like this is often worthwhile." colorLabel="4"/>
                        <outline text="More often than not, vague examples or no example whatsoever is sufficient to catch/convey all the important details." colorLabel="1"/>
                      </outline>
                      <outline text="Often quite time consuming to produce." colorLabel="1" collapsed="true">
                        <outline text="It depends on the circumstance how much time is required to come up with a detailed example, there are exceptions." colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Techniques" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Anticipating misinterpretations" heading="3" collapsed="true">
                      <outline text="In order to give a sufficiently detailed example to reliably demonstrate a target general principle, it&apos;s typically ideal to try to anticipate possible ways in which an example could be misinterpreted to be about a different relevant general principle." collapsed="true"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Vague examples" heading="2" colorLabel="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Examples that are vague, typically enough so to leave some room for plausibly misinterpretation of either some relevant properties of the specific case, or what general rule/category the specific case is meant to fall under."/>
                    <outline text="Example" colorLabel="6" collapsed="true">
                      <outline text="Trolley problem" collapsed="true">
                        <outline text="It&apos;s not very realistic or detailed, but it&apos;s an example scenario that&apos;s (typically) targetted at comparing consequentialism and deontology."/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3" collapsed="true">
                      <outline text="It&apos;s very common for people to give vague examples." colorLabel="4"/>
                    </outline>
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Vague examples can usually be thought up pretty quickly." colorLabel="4" collapsed="true">
                        <outline text="Vague examples are usually easy to come up with." colorLabel="4"/>
                      </outline>
                      <outline text="Vague examples tend to be very easily misinterpreted." _note="Link a section about the consequences of misunderstandings." colorLabel="1"/>
                      <outline text="Some people refuse to accept vague hypotheticals." _note="Link to a section on accepting the hypothetical in hypothetical thinking or something." colorLabel="1"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Ostensive definitions" heading="2" colorLabel="3" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Definitions which convey the meaning of a term by pointing out [examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rWwkVHO702PBy1aoUtBw-bBU)."/>
                  <outline text="They assume the questioner has sufficient understanding to recognize the type of information being given."/>
                  <outline text="They are usually accompanied with a gesture pointing to the object serving as an example, and for this reason is also often referred to as &quot;definition by pointing&quot;."/>
                </outline>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Common when a term is difficult to define verbally." colorLabel="4" collapsed="true">
                      <outline text="Very common when teaching someone a language." colorLabel="4" collapsed="true">
                        <outline text="eg. a child or a non-native speaker." colorLabel="6"/>
                      </outline>
                      <outline text="Common when the nature of the term intrinsically makes it very difficult to define straightforwardly." colorLabel="4" collapsed="true">
                        <outline text="Eg. colors, sensations." colorLabel="6"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Useful when the nature of the thing being described makes it very difficult to describe with other terms." colorLabel="4" collapsed="true">
                      <outline text="A color itself." colorLabel="6" collapsed="true"/>
                    </outline>
                    <outline text="Often leads to misunderstandings" heading="3" colorLabel="1" collapsed="true">
                      <outline text="It&apos;s very easy to accidentally use analogies that are compatible with multiple mutually exclusive plausibly-intended definitions." colorLabel="4" collapsed="true">
                        <outline text="Especially when the concept is very abstract, like in philosophy, and cannot simply be pointed to." colorLabel="4"/>
                      </outline>
                      <outline text="The risk of misunderstandings can be somewhat mitigated by using it *alongside* a more explicit definition." colorLabel="1" collapsed="true">
                        <outline text="Although this often wastes time if the explicit definition was sufficient." colorLabel="1"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="You should probably try to avoid it where possible" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Most people interested enough in reasoning to be reading this guide probably intend to have a lot of atypical abstract conversations." colorLabel="4" collapsed="true">
                    <outline text="It&apos;s often a bad technique to make a habit of using in such conversations." colorLabel="4"/>
                    <outline text="^ [It often leads to misunderstandings in such conversations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=DhUWv-VqXiijdjrPKsa9Eexa)" colorLabel="4"/>
                  </outline>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Vague definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Using analogies to indicate a definition tends to result in the definition being left vague." collapsed="true">
                      <outline text="Using analogies to indicate a definition tends to allow for multiple possible interpretations by defualt, which means that the definition is left vague." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Source" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Mostly taken from [the wikipedia page](https://en.wikipedia.org/wiki/Ostensive_definition)."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Analogical reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=y83CLm4PtT9N4Nk3aCZBPJq5)" heading="1" colorLabel="4"/>
                <outline text="[Definition via analogy](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wqjHe0ETccAnBhGoYUCfWKtS)" heading="3" colorLabel="3"/>
              </outline>
            </outline>
            <outline text="Lacking context" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Lacking important information for how to interpret thing(s)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
                <outline text="Impactful" heading="3"/>
              </outline>
              <outline text="Common causes" heading="1" colorLabel="2" collapsed="true">
                <outline text="[Short text](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=MTNBA6DR899h5WVs7L3FRYVR)" heading="3" colorLabel="5" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="When short messages/posts are used, some important context is almost bound to be omitted."/>
                  </outline>
                  <outline text="[Harder to be thorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WzDwubH_Kp-yOOV_tquOO2dT)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Keeping track of context](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lZZ0_vGBUVpwGOUFRwxcpLrf)" heading="1" colorLabel="2"/>
                <outline text="[Definitions](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=trb9nqsaLcvBK2O1-HBNApOW)" heading="2" colorLabel="6" collapsed="true">
                  <outline text="Lacking knowledge about how the other person is defining a term."/>
                </outline>
                <outline text="[Reading between the lines](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KaDyeeVFr1IIgG0vEZVR9Xsa)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Steelmanning" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The dialectical technique of restating an opponent&apos;s argument in its strongest, most charitable, and/or most convincing form before offering a counterargument."/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="People frequently make major mistakes due to using an unideal version of it."/>
                  <outline text="[People frequently strawman eachother](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=d1K4S_SqoO5J7cMB8zmTFkxz) and this is a technique that (if used properly) helps with avoiding strawmanning."/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="If used well, it can be very handy for properly understanding other people." colorLabel="4" collapsed="true">
                    <outline text="[Being able to properly understand others is very important for finding the truth](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=onj8rRmxJ98s8azkTPHBnfWT)" colorLabel="4"/>
                  </outline>
                  <outline text="Often involves [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="What to avoid doing" heading="1" colorLabel="2" collapsed="true">
                <outline text="Overly literal interpretations" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Often when taking into account the context, a clear line of reasoning can be followed and you can see where people are making small mistakes in expressing what they mean, which helps you understand their position, avoid misunderstanding key aspects of it, and makes the discussion more productive and makes it more likely that you&apos;ll reach a consensus with them on the matter." _note="Link this to understanding and maybe some other places."/>
                    </outline>
                    <outline text="Common" heading="3" collapsed="true">
                      <outline text="Very often, people will interpret the arguments that other people make too literally."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Strength over all else" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Representing others&apos; statement(s) in the strongest possible way (in the opinion of the representer)."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="This conceptually differs from representing others&apos; statements in the strongest __plausibly intended__ way, or anything similar."/>
                      <outline text="^ It is thus typically not the most convincing interpretation."/>
                    </outline>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="This kind of interpretation can run completely obviously contrary to what the statement maker could have plausibly intended, or what they said." colorLabel="1" collapsed="true">
                        <outline text="The motivation for this often comes from a thought process like &quot;I addressed an even stronger version of your position than you gave&quot;." colorLabel="3"/>
                        <outline text="Oftentimes we do not know whether the opponent&apos;s position is stronger before we argue against it and see what their counterarguments are." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="So by trying to form a stronger position for them before we&apos;ve tried to address their stated one, we can easily fail to address the actual strongest position." _note="Relevance" colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Reading between the lines](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KaDyeeVFr1IIgG0vEZVR9Xsa)" heading="3" colorLabel="2"/>
                <outline text="[Expression/interpretation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=K_SHB0cGTZkUKMGU-ep5cX4R)" heading="1" colorLabel="3" collapsed="true">
                  <outline text="One of the most important parts of adequately representing (and thus one of the most important parts of actually addressing) others&apos; positions is in having good expression/interpretation techniques/knowledge." collapsed="true">
                    <outline text="[So incredibly often, disagreements and misunderstandings arise simply because of people using subtly different definitions and can&apos;t resolve it (at least in a timely manner)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lyVNrMthlK0SThNSDsjeylD5)"/>
                  </outline>
                </outline>
                <outline text="[Always assume you&apos;re wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5FpEUfYQc79UAVREiyCpvvFr)" heading="1" colorLabel="2"/>
                <outline text="https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QLfbU4dDp6Me-Vt_xT5qvkwk" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Argument premoves are a very common technique used when attempting to steelman others."/>
                </outline>
              </outline>
            </outline>
            <outline text="[Strawman](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j7YUoP-36fiXLnITfI6f1Tl5)" _note="Probably move the actual strawman section here?" heading="1" colorLabel="2"/>
            <outline text="Checking for different [axioms](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=HTSBFQMP49xI2F7tHDD5P1pd)" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Checking (usually by asking) if other person(s) have different axiom(s)."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="It often takes a while before a disagreement from differing axioms can be recognized as such naturally." collapsed="true">
                  <outline text="Axioms are typically at the end of the argument lines and are often not brought up even if you try to dig all the way down into someone else (s)&apos; epistemology." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Attempted anticipation" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="The process of attempting to anticipate what other people mean, how other people are getting confused, etc. and address that directly."/>
              </outline>
              <outline text="Importance / Limitations" _note="~~Advanced" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="People very often try to anticipate what other people are saying in some form or another." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Can save time if done well." colorLabel="4"/>
                  <outline text="Often involves prioritizing anticipation over providing clear definitions, examples, etc." colorLabel="1" collapsed="true">
                    <outline text="Very often wastes a lot of time because they often can&apos;t properly anticipate it." colorLabel="4" collapsed="true">
                      <outline text="The ideas of the other person(s) are often too different to easily anticipate. " colorLabel="4"/>
                      <outline text="Often involves an over-reliance on [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37) which makes it harder to anticipate unfamiliar ideas." colorLabel="4"/>
                    </outline>
                    <outline text="Even when the person has explicitly asked for a clearer definition, example, etc." colorLabel="4" collapsed="true">
                      <outline text="[Often it&apos;s so deeply embedded in their habits that it&apos;s difficult to resist attempted anticipation](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Fk5Klas8UYKP0fzQzQVctECA)" colorLabel="4"/>
                      <outline text="[Often they are so reliant on heavy heuristic usage that they don&apos;t really have a more fundamental form of reasoning they can default to in order to more easily avoid their flawed habits](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rZIkJYFv771hrHmoI5JkBGcv)" colorLabel="4"/>
                    </outline>
                    <outline text="Even when the person has explicitly requested that they don&apos;t perform attempted anticipation." colorLabel="4" collapsed="true">
                      <outline text="Often it&apos;s so deeply embedded in their habits that it&apos;s difficult to resist attempted anticipation." colorLabel="4"/>
                      <outline text="Often they are so reliant on [heavy heuristic usage](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=waIk3BhYJ4eBaM4bzQtwem37) that they don&apos;t really have a more fundamental form of reasoning they can default to in order to more easily avoid their flawed habits." colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Extremely prone to overconfident assumptions about what others mean." colorLabel="1"/>
                  <outline text="It&apos;s very easy to go too far with this, resulting in [strawmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j7YUoP-36fiXLnITfI6f1Tl5)." colorLabel="1"/>
                  <outline text="Extremely prone to [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" colorLabel="1"/>
                </outline>
              </outline>
              <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                <outline text="A technique to be very careful with."/>
                <outline text="Usually best to avoid prioritizing it over asking for clear definitions, examples, etc. when possible."/>
                <outline text="Typically best to only use it for situations where it&apos;s likely very easy and simple to anticipate what others mean."/>
              </outline>
            </outline>
            <outline text="Translating natural language to formal logic" heading="3" colorLabel="5" collapsed="true">
              <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
                <outline text="This includes partial translations, such as merely mentally translating the rough structure."/>
                <outline text="Examples" heading="3" colorLabel="6" collapsed="true">
                  <outline text="Because of these, that has to be true."/>
                  <outline text="If this then that, otherwise this."/>
                  <outline text="All of the above is true so this means…"/>
                  <outline text="This is the only option that makes sense."/>
                  <outline text="If we assume that this is true we get a ridiculous result so it can’t be true."/>
                </outline>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Being able to better understand the logical structure of natural language arguments is extremely useful." colorLabel="4" collapsed="true">
                    <outline text="Being able to explicitly translate natural language into formal logic often allows for better understanding the logical structure of natural language." _note="Relevance" colorLabel="4"/>
                  </outline>
                  <outline text="Typically very time consuming, so generally best to reserve this for more important problems." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Standard form](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WBGbs-oyLu2VHlBm5Vkh-KAb)" heading="3" colorLabel="5"/>
              </outline>
            </outline>
            <outline text="[Others&apos; conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=Z21ktWdhCyJ6qxMqpX3z2if4)" heading="3" colorLabel="2"/>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Vague wording](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0gOG4jQ-x49IDTjJn9kHifS6)" heading="3" colorLabel="3"/>
              <outline text="[Conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" heading="3" colorLabel="1"/>
              <outline text="[Confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)" heading="3" colorLabel="2"/>
              <outline text="[Fitting things together](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FORaGWzKq7OJtxVu6LDAqa11)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Mentally fitting concepts together in a logical way is crucial for being able to interpret what other people mean when they don&apos;t explain it in ways that you&apos;re most familiar with."/>
              </outline>
            </outline>
          </outline>
          <outline text="Expression" heading="2" colorLabel="3" collapsed="true">
            <outline text="Definition (broad)" heading="3" colorLabel="3" collapsed="true">
              <outline text="The art and study of using language effectively and persuasively to inform, influence, or motivate."/>
            </outline>
            <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
              <outline text="Common" heading="3" collapsed="true">
                <outline text="Rhetoric underlies virtually all communication." colorLabel="4"/>
              </outline>
              <outline text="Impactful" heading="3" collapsed="true">
                <outline text="Being able to be properly understood by others is extremely important for finding the truth." colorLabel="4" collapsed="true">
                  <outline text="&lt;Costs of misunderstandings&gt;" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Difficult" heading="3" collapsed="true">
                <outline text="Not properly understanding even one of the key sections here can make it practically impossible to change your mind when it&apos;s reasonable to in many scenarios. So a lot of learning is required to properly follow this section." colorLabel="4"/>
              </outline>
            </outline>
            <outline text="[Semantics](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ZmfzjbSatYIkqkAdbWF-KQ9E)" heading="1" colorLabel="3"/>
            <outline text="Thinking before speaking" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                <outline text="Thinking more thoroughly before expressing your thoughts."/>
                <outline text="Distinction: Doesn&apos;t necessarily have to be vocally, could be thinking before sending a message, etc."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2"/>
              <outline text="Critical emotional mindset" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="An emotional mindset in which you&apos;re very skeptical of the statement(s) in question."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="Our emotions typically aren&apos;t by default in an ideal state for critical analysis."/>
                  </outline>
                </outline>
                <outline text="Techniques" heading="3" collapsed="true">
                  <outline text="Dissociating the statement from yourself" heading="3" collapsed="true">
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Helps with utilizing habits you formed for investigating other peoples&apos; statements." collapsed="true">
                        <outline text="Those habits tend to be more critical than the ones meant for investigating your own statements." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Imagine that someone else (especially someone untrustworthy) said the statement." collapsed="true">
                      <outline text="&quot;Untrustworthy&quot;, to help with [assuming it&apos;s wrong](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=161mB5BefEZd8MFvTIzlD30o)"/>
                    </outline>
                  </outline>
                  <outline text="Assuming it&apos;s wrong" heading="3" collapsed="true">
                    <outline text="Definition (specific)" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Imagining that you know for certain that it&apos;s wrong, but don&apos;t know how."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="This helps with really dedicating one&apos;s self to trying to figure out how it could be wrong." collapsed="true">
                        <outline text="When we feel like we don&apos;t know if a statement is wrong, we typically don&apos;t check it very thoroughly." colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Getting into the habit" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Getting into the habit of thinking more thoroughly before expressing your thoughts."/>
                </outline>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="This is an incredibly important habit to have for &lt;broken link&gt;"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="1" colorLabel="1"/>
                </outline>
              </outline>
            </outline>
            <outline text="Fluff" heading="1" colorLabel="3" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Material that has (almost) no epistemic impact on the relevant reasoning at hand." collapsed="true">
                  <outline text="I.e. It provides virtually no information about what&apos;s true in the relevant reasoning."/>
                </outline>
                <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Different from eg: person X says thing(s) to make person(s) Y feel better so that person(s) Y can reason better."/>
                  <outline text="^ While we would consider this to be a form of fluff, it is not the __definition__ of fluff, since it is specifically a form of [useful fluff](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=2RcwsvFOWBXB8vA2oeUdwqIh)."/>
                </outline>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="It&apos;s extremely common for people to use at least a little of this in what they say." colorLabel="4"/>
                  <outline text="It&apos;s virtually impossible to completely avoid." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Typically for important reasoning, fluff should be kept close to a minimum." colorLabel="1"/>
                </outline>
              </outline>
              <outline text="How to view it" heading="3" colorLabel="2" collapsed="true">
                <outline text="[Typically for important reasoning, fluff should be kept close to a minimum.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QAE5aecsnBJaz6vWW4OmaWK5)"/>
              </outline>
              <outline text="Useless fluff" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Fluff tends to be almost if not entirely useless." colorLabel="4"/>
                  </outline>
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="**Wastes time:**   It usually wastes time that could be used on more important calculations." colorLabel="1" collapsed="true">
                      <outline text="If the fluff is made optional to view with sufficient indication of its uselessness, it may only waste the writer&apos;s time." colorLabel="1"/>
                      <outline text="^ In situations where the writer does not know if something is useless (eg. [argument premoves](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QLfbU4dDp6Me-Vt_xT5qvkwk)), it may be beneficial to include it just in case. Though it&apos;s usually advisable in these situations to include some indication of what a section&apos;s relevance is conditional on." colorLabel="3"/>
                    </outline>
                    <outline text="**Contributes to [overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB)**" colorLabel="1" collapsed="true">
                      <outline text="Useless fluff often gives the feeling of having addressed more points than it actually does." _note="Likelihood" colorLabel="4" collapsed="true">
                        <outline text="Thus often making one feel overconfident about rejecting what they believe they addressed." _note="Relevance" colorLabel="4"/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Primary causes" heading="3" colorLabel="1" collapsed="true">
                  <outline text="Unsystematic reasoning"/>
                </outline>
                <outline text="Pointless repetition" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2"/>
                </outline>
                <outline text="Addressing irrelevant reasoning" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Addressing reasoning that&apos;s irrelevant to the present person(s) reasoning."/>
                  </outline>
                  <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="It often feels like supporting one&apos;s perspective or justifying it to the other present person(s) when it actually isn&apos;t." colorLabel="1" collapsed="true">
                        <outline text="Addressing positions that one feels the other person(s) __might__ hold often feels like being [thorough](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=lj9jejrk2s5bCXgZLKLHwWkZ), which can easily make one feel like they addressed other person(s) reasoning better than they actually did." _note="Likelihood" colorLabel="4" collapsed="true">
                          <outline text="This can easily lead to [overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB)." _note="Relevance" colorLabel="4"/>
                        </outline>
                        <outline text="This often leads to believing that one has supported their perspective or justified it to the other present person(s) when they haven&apos;t, which is usually a form of [strawmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=j7YUoP-36fiXLnITfI6f1Tl5)." _note="Relevance" colorLabel="4" collapsed="true">
                          <outline text="This can easily lead to [overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB)." _note="Relevance" colorLabel="4"/>
                        </outline>
                        <outline text="Addressing positions that one feels the other person(s) __might__ hold often feels like addressing positions that they actually hold." _note="Likelihood | Unsure about this one" complete="true" colorLabel="4"/>
                      </outline>
                      <outline text="It can often make it feel more like you&apos;re not properly listening to/remembering/understanding the person(s) who the reasoning is not relevant for." colorLabel="1" collapsed="true">
                        <outline text="This can make the person feel like their reasoning isn&apos;t being accounted for, which can make them more [close-minded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr) about the matter." colorLabel="4" collapsed="true">
                          <outline text="Feeling like the reasoning isn&apos;t being addressed can make the person feel like their emotions are being disregarded, which can make them more frustrated towards the one who&apos;s addressing irrelevant reasoning." _note="Link to frustration section" colorLabel="4" collapsed="true">
                            <outline text="Link to section of frustration about increasing short-term general [close-mindedness](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=TBDKCqfm_SEQfc4szPkt4Aqr)." colorLabel="4"/>
                          </outline>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Argument premoves](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QLfbU4dDp6Me-Vt_xT5qvkwk)" heading="1" colorLabel="2" collapsed="true">
                      <outline text="The most common cause of &quot;addressing irrelevant reasoning&quot;." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Useful fluff" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance / Limitations" heading="3" colorLabel="2"/>
                <outline text="Emotional softening" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Adding extra fluff can at times act as padding that makes the concepts more emotionally tenable."/>
                </outline>
                <outline text="Entertainment" heading="2" colorLabel="1" collapsed="true">
                  <outline text="Even purely from the perspective of getting people to do the best reasoning possible on a subject, presenting it in an entertaining manner is important. And inserting the right kind of fluff can contribute to that entertainment in many cases."/>
                </outline>
                <outline text="Over-explaining" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Can be useful to make it clearer for people who can&apos;t focus or think well."/>
                  </outline>
                  <outline text="Nuance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="In many cases it&apos;s better if this it&apos;s optional whether or not one gets the over-explaining."/>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Monologuing for long periods at once](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=20Z4Bm-Z052kEflJkfaxnGWJ)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Changing the topic" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Changing the focus of the discussion."/>
              </outline>
              <outline text="Deep lines" heading="1" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
                <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Impactful" heading="3" collapsed="true">
                    <outline text="The topic seeming to shift in deep lines [is common](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=1bwx0FfaQQW4k14Jtd2K1gED) and not necessarily a bad thing, as oftentimes relevant and important details will be in deep lines that seem to run far into very different topic(s)."/>
                  </outline>
                  <outline text="Common" heading="3" collapsed="true">
                    <outline text="Oftentimes when exploring deep lines, the topic being focused on will seem to change because the important details being discussed will largely involve a different topic."/>
                  </outline>
                </outline>
                <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                  <outline text="[The instability of large reasoning pyramids](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=wF3wChw5a-nl2FeRaQTbTP7Q)" heading="3" colorLabel="2"/>
                </outline>
                <outline text="How to view them" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Often important to explore, even when it seems like the topic shifts." collapsed="true">
                    <outline text="So allow others to change the topic, as long as they are still bringing up sufficiently relevant and important points." collapsed="true">
                      <outline text="Even if the relevance involves a long line of reasoning that involves very different subject(s))."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="[Red herrings (fallacy)](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=ccQrVI4W9Eu4C8_Kpq8QUiu9)" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Adversarial debates" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3"/>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3"/>
                <outline text="Common" heading="3"/>
              </outline>
              <outline text="[Persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)" heading="1" colorLabel="2"/>
            </outline>
            <outline text="Persuasion" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Changing other people&apos;s minds."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Prioritizing or building habits around persuasion tends to reduce one&apos;s reasoning abilities." colorLabel="4" collapsed="true">
                    <outline text="This section teaches how to avoid such pitfalls." colorLabel="4"/>
                    <outline text="Prioritizing persuasion tends to lead to prioritizing persuasion habits over reasoning habits." colorLabel="4" collapsed="true">
                      <outline text="[The best habits for persuasion are often mutually exclusive with the best habits for reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=G3IdGIcMXCsjB6-ieacDNTW3)"/>
                    </outline>
                    <outline text="The best habits for persuasion are often mutually exclusive with the best habits for reasoning." colorLabel="4"/>
                  </outline>
                  <outline text="Being irrationally persuaded  via these strategies can be quite bad." colorLabel="4"/>
                  <outline text="Persuading people to do irrational things that are significantly beneficial for your goals is extremely useful." colorLabel="4"/>
                  <outline text="&lt;broken link&gt;, so persuasion strategies separate from good reasoning practices tend to work best for persuading the vast majority of people." colorLabel="4" collapsed="true">
                    <outline text="Especially rhetoric, stumping the opponent and charisma." collapsed="true">
                      <outline text="Stumping the opponent has some indication of good reasoning, but not as much as you might think." collapsed="true">
                        <outline text="[Stumping the opponent is much easier with rhetoric and fallacies than with good reasoning/solid sources](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=-qqF1DsUzMf8BCVtftfrFUVM)"/>
                      </outline>
                    </outline>
                    <outline text="Avoiding risky opinions (even if they are more reasonable)."/>
                  </outline>
                  <outline text="&lt;broken link&gt;, so persuasion is often difficult" colorLabel="1"/>
                </outline>
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Marketing" heading="3" collapsed="true">
                    <outline text="Advertising" heading="3"/>
                  </outline>
                  <outline text="Politics" heading="3"/>
                </outline>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2"/>
              <outline text="Broad" heading="1" colorLabel="6">
                <outline text="Acting confident" _note="Maybe change to &quot;behaving confident&quot;, if so then change backlinks accordingly." heading="3" colorLabel="2">
                  <outline text="Definition (&apos;acting&apos; distinction)" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Behaving confidently, as though one is [confident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b7Bok7q_3RRYjHHYt4aer1bH)."/>
                    <outline text="Distinctions" heading="3" colorLabel="3" collapsed="true">
                      <outline text="**Acting:**   Not necessarily a form of __faking__ confidence." collapsed="true">
                        <outline text="One could be acting confident because of genuine confidence." colorLabel="4"/>
                      </outline>
                      <outline text="Different from actually __being__ [confident](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b7Bok7q_3RRYjHHYt4aer1bH)." collapsed="true">
                        <outline text="Although the two are correlated." colorLabel="3"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Often effective in persuasion, by frequently making unsuspecting people feel like one must have very good info / reasoning to justify their confidence." colorLabel="4" collapsed="true">
                      <outline text="Important to learn how to avoid being influenced by this." _note="Relevance" colorLabel="4"/>
                    </outline>
                    <outline text="Contributes to [epistemic self-overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=BXkvTggpu62KYL_Vo7PXrNnB)." colorLabel="1" collapsed="true">
                      <outline text="Acting confident is correlated with [confident claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=R5pa44kr5Rew69QsnuVi9P00), which contributes to epistemic self-overconfidence." _note="Likelihood" colorLabel="4"/>
                      <outline text="Likely important to learn to avoid, because of [the issues with epistemic self-overconfidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=EKKuzqAi5PnZjjg05WAch6nP)." _note="Relevance" colorLabel="4"/>
                    </outline>
                  </outline>
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Confidence](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=b7Bok7q_3RRYjHHYt4aer1bH)" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Acting confident is correlated with confidence for obvious reasons." colorLabel="4"/>
                    </outline>
                    <outline text="[Appeal to authority](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6-bhxoeIKHPMK7dTfB7qHqsk)" heading="3" collapsed="true">
                      <outline text="Somewhat similar and often paired with this." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Understand who you are persuading" _note="Link to relevant psychology sections" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Understand their positions" heading="3" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Esure you understand their relevant positions."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="Impactful" heading="3" collapsed="true">
                        <outline text="Without doing this, it&apos;s extremely easy to use premises that they don&apos;t accept, or fail to use useful premises which they do accept." colorLabel="4"/>
                      </outline>
                    </outline>
                    <outline text="Understanding their values" heading="3" colorLabel="1" collapsed="true">
                      <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                        <outline text="Understand their relevant values."/>
                      </outline>
                      <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                        <outline text="Improvable" heading="3" collapsed="true">
                          <outline text="It&apos;s very common for people to frequently presume (with inadequate evidence) that other people share their own values." colorLabel="4"/>
                        </outline>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Avoiding pure reasoning" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Avoiding primarily relying on reasoning and counterarguments (however reasonable) to counter other(s) opinions."/>
                  </outline>
                  <outline text="Why?" heading="3" colorLabel="1" collapsed="true">
                    <outline text="The reasons that people give for their positions (especially on matters of &quot;soft&quot; reasoning) are often [rationalizations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=5TnHzpOj7Ow-1Cg9CBDf1XBc) and the products of https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy" collapsed="true">
                      <outline text="Thus they will typically unconsciously assume that they are right and that you are wrong with a very high degree of confidence before even considering your reasoning."/>
                      <outline text="So when they investigate the counterarguments that you present, they will be looking for any ways in which they could be wrong, even the tiniest hints. Because they &quot;know&quot; that you&apos;re wrong and that they are right, they &quot;just have to find out how&quot;."/>
                      <outline text="It&apos;s very rare for someone to run out of tiny hints to pursue, or to gain the self-awareness to realize how flawed their epistemic process is." collapsed="true">
                        <outline text="So they will typically continue looking for things until they either:"/>
                        <outline text="^ Forget how their initial reasons were flawed (and thus start repeating arguments that you already addressed)"/>
                        <outline text="^ Or feel too stuck from not being able to justify themselves to continue (they&apos;ll get a very strong desire to resolve the tension and end the discussion, and since they can&apos;t address your reasoning, they&apos;ll end it another way)."/>
                      </outline>
                    </outline>
                  </outline>
                </outline>
                <outline text="Don&apos;t begin with the conclusion" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Why?" heading="3" colorLabel="1" collapsed="true">
                    <outline text="Starting with your conclusion makes it much easier for people to engage in [confirmatory thought](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OrIjqF9wWhAuAxUvnk078FOy)"/>
                  </outline>
                  <outline text="Instead go as far as you can with reasoning, bringing them along on a journey they don&apos;t know the exact destination of." _note="Pull from/link to a section somewhere where I talked about this."/>
                </outline>
                <outline text="Intuition pull" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="A statement made primarily for convincing intuition(s)."/>
                    <outline text="Distinction" heading="3" colorLabel="3" collapsed="true">
                      <outline text="It doesn&apos;t necessarily have to use epistemic justification for convincing the intuition(s)."/>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="[Importance of convincing your subconscious to agree with you conscious beliefs](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=AFqSS9YtLBDH1Qu463LR3QhX)"/>
                  </outline>
                </outline>
                <outline text="Ambiguity" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Ambiguity as a persuasion technique."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Allows for appealing to a larger subset of people."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Consistency" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Consistency of one&apos;s opinions."/>
                    <outline text="Consistency both across time and across different beliefs."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3" collapsed="true">
                      <outline text="Inconsistency is one of the most noticable things to most people."/>
                    </outline>
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Inconsistency is one of the biggest deal-breakers for most people. Hypocrites are quite hated."/>
                    </outline>
                  </outline>
                  <outline text="[Ambiguity](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=X3waYZP7G7HGeRMzg8i6w5vF)" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Expressing things in an ambiguous way allows one to remain consistent with their previous statements despite changing their mind."/>
                  </outline>
                </outline>
                <outline text="Biased simplification" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="When a subject is simplified in a way that is substantially biased towards particular option(s)."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="Particularly impactful when misleading people to agree with detailed proposals based on the biased simplification(s)."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Characterization" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Characterizing what something looks like by talking about a specific hypothetical or example that feels realistic and gets person(s) immersed in a scenario."/>
                    <outline text="**Typically:**   To emotionally push a certain idea."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Common" heading="3"/>
                    <outline text="Impactful" heading="3" collapsed="true">
                      <outline text="[This is something that most people are affected by.](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=tOQ3CvwNx0k-5upcWt8KuMNO)" colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Gish galloping" heading="1" colorLabel="2" collapsed="true">
                  <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                    <outline text="[Monologuing for long periods of time](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=20Z4Bm-Z052kEflJkfaxnGWJ)" heading="3" colorLabel="2"/>
                  </outline>
                </outline>
                <outline text="Eloquence" heading="1" colorLabel="2"/>
                <outline text="When things go wrong, wait a while before trying again" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Emotional associations (like all associations) fade over time" _note="Split and move to psychology, and link here" heading="3" colorLabel="1"/>
                </outline>
                <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                  <outline text="[Decision-making under pressure](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=OlKQC8Exx5M6Tn-FOycliz_7)" heading="1" colorLabel="1"/>
                  <outline text="[Convincing rule-based reasoners](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=vlN1XO_FsOzTYDbZ1Le638y5)" heading="3" colorLabel="2"/>
                  <outline text="[Appeal to emotion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=46mpVW0_OGgmaf4_XshfIb0a)" heading="3" colorLabel="2"/>
                </outline>
              </outline>
              <outline text="Specific" heading="1" colorLabel="6" collapsed="true">
                <outline text="[(Un)conservative claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=clC-svjqyNajpM81R8mrQFEl)" heading="3" colorLabel="2"/>
                <outline text="Street epistemology" heading="2" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3"/>
                  <outline text="Importance" heading="3" colorLabel="2"/>
                  <outline text="Methods" heading="1" colorLabel="2"/>
                </outline>
                <outline text="[Reductio ad absurdum](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6LOKFZ350qqORVV4R48gcQ2O)" heading="3" colorLabel="2"/>
                <outline text="Marketing" heading="1" colorLabel="6" collapsed="true">
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                  <outline text="&lt;broken link&gt;" heading="3" colorLabel="1"/>
                </outline>
                <outline text="[Absusing their bias towards their own ideas] &lt;broken link&gt;" heading="3" colorLabel="2"/>
                <outline text="Small talk -&gt; Deep talk" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="The transition from small talk to deep talk."/>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Useful for more efficiently getting to know people better, which can allow for getting to know more people better, which can increase the odds of finding better people."/>
                  </outline>
                  <outline text="Ask about them" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                      <outline text="Ask about the other person(s) in a positive or neutral way."/>
                    </outline>
                    <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                      <outline text="People usually like to talk about themselves, so people will often be open to talking about themselves, which usually allows for getting the conversation into a deeper and more meaningful place."/>
                    </outline>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Accounting for other(s)&apos; abilities" heading="1" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Accounting for other(s) abilities when driving the discussion forward."/>
              </outline>
              <outline text="Giving more/less explanation" heading="3" colorLabel="2" collapsed="true">
                <outline text="Probably largely based on knowledge/criticalness."/>
              </outline>
            </outline>
            <outline text="Following your thought associations" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Following your thought associations while expressing your thoughts."/>
              </outline>
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="This can easily lead to lots of useless tangents."/>
              </outline>
              <outline text="Types" heading="3" collapsed="true">
                <outline text="Instead of structuring it and focusing on long-term conversation goals."/>
                <outline text="With the intent to try to bring it back to the main topic, but without a clear idea of how to do that at first."/>
              </outline>
            </outline>
            <outline text="Monologuing for long periods at once" _note="Specific to vocal." heading="3" colorLabel="2" collapsed="true">
              <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Can easily lead to not being able to hear clarification or nuance that the person(s) listening could give."/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Fluff](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=6YMhtK0wmxrvHgXZuxAenoI1)" heading="3" colorLabel="3" collapsed="true">
                  <outline text="Speaking for long periods of time tends to be the result of adding a lot of fluff to what&apos;s being said."/>
                </outline>
                <outline text="[Gish galloping](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=9bjGLTI6yLdpJc8ut1b6wtOd)" _note="Definitely not exactly the same, but loosely related." heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Committing to falsification condition(s)" _note="Shorten the name" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Explicitly committing to condition(s) under which the commiter would consider a hypothesis falsified."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Helpful for making it easier to change your mind without losing face." colorLabel="4"/>
                  <outline text="Helpful for turning the common desire for making &quot;strong&quot; statements (confident-sounding ones) into a boon by directing it towards making a commitment on what conditions would make you change your mind." colorLabel="4"/>
                </outline>
              </outline>
            </outline>
            <outline text="Criticism" _note="Research and add to this" heading="3" colorLabel="2" collapsed="true">
              <outline text="Constructive criticism" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3"/>
              </outline>
              <outline text="Gentle start up" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="To talk about one&apos;s feelings using &quot;I&quot; statements and talk about a positive need."/>
                </outline>
              </outline>
              <outline text="Destructive criticism" heading="3" colorLabel="2" collapsed="true">
                <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                  <outline text="An attack on a person at the core of their character. In effect, dismantling their whole being with very insufficient (if any) guidance on how to improve."/>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Inviting critiques](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=QtnlkhxukB15LPOzBdWLLGWi)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Inviting critiques" heading="3" colorLabel="2" collapsed="true">
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Criticism](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=oC412QUUYO_Sc23fzJdz1gmB)" heading="3" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="(Un)conservative claims" heading="2" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Claims and how broad and/or confident they are."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="It&apos;s important to form good habits about what kind of claims to make, to be more [open minded](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=z7LAOrlY0wVUk3aV25kvfWZe)" colorLabel="4"/>
                  <outline text="Useful for [persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)" _note="~~Expert" colorLabel="4"/>
                </outline>
              </outline>
              <outline text="Unconservative claims" heading="1" colorLabel="2" collapsed="true">
                <outline text="Confident claims" heading="3" collapsed="true">
                  <outline text="Importance" heading="3" colorLabel="2">
                    <outline text="Typically very important to avoid due to [limitations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=xsu2gMpUxsR6ewr50RhWVW_9)"/>
                    <outline text="Can be useful for [persuasion](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=S-S1oq4cZbPSPeH4eYJKd9K7)" _note="~~Adept, support"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2">
                    <outline text="Even if we are justified in having more confident beliefs about more major claims, doing so is often not ideal because it &quot;closes the doors behind us&quot;. If we&apos;re pushed back with evidence, we emotionally have nowhere to go and are often prone to get defensive and more likely to refuse the truth. ([Source](https://youtu.be/CkJc6c3nKMw))" collapsed="true">
                      <outline text="Video chosen because it&apos;s the best quick and straightforward demonstration I&apos;m aware of, not because of the atheist angle the video creator chooses to take with it."/>
                    </outline>
                  </outline>
                </outline>
                <outline text="Major claims" heading="3" collapsed="true">
                  <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                    <outline text="Claims which are very broad."/>
                    <outline text="Example" heading="3" colorLabel="6" collapsed="true">
                      <outline text="All squares have four 90° angles."/>
                      <outline text="All Nazis were 100% evil."/>
                      <outline text="2 + 2 always equals 4."/>
                    </outline>
                  </outline>
                  <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                    <outline text="It&apos;s very important to be able to discriminate from justified major claims and unjustified major claims, as the can often appear far more or less justified than they really are."/>
                    <outline text="^ Typically because of failing to adequately account for the [prior probability](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WtCnPwTlo9i-Whi4OhvH_ZQd)"/>
                  </outline>
                  <outline text="Limitations" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Often mistaken" heading="3" collapsed="true">
                      <outline text="It&apos;s rare that practical things are entirely black and white / all or nothing, usually (unless dealing with purely abstract concepts or something) there is some nuance/exception."/>
                    </outline>
                    <outline text="Encourages defensiveness" heading="3" collapsed="true">
                      <outline text="Major claims are often made (or seem to be made) confidently." collapsed="true">
                        <outline text="[Confident claims](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=R5pa44kr5Rew69QsnuVi9P00)" heading="3"/>
                        <outline text="^ Made more damaging by the fact that major claims are [often mistaken](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=dIqzMY64S7pUDKKhP5VdhBRD)"/>
                      </outline>
                    </outline>
                  </outline>
                  <outline text="How to view" heading="3" colorLabel="2" collapsed="true">
                    <outline text="Aside from statements like [this](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=mlhLMUmKfAicTAN3-3-egkYg) where you have a solid deductive proof to back the broad claims up, or in situations where the evidence is quite overwhelming, it is usually best to avoid making such major claims."/>
                    <outline text="And even in the exceptional cases where you&apos;re likely right, it is typically best to speak less confidently than you feel, so as to make the process of changing your mind more comfortable if the situation happens to call for it."/>
                  </outline>
                  <outline text="Justified major claims" heading="1" colorLabel="2" collapsed="true">
                    <outline text="Deductive [proofs](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FkzQqkwmEP9ECLN3x7wo6x_O)" heading="3" colorLabel="5"/>
                    <outline text="Overwhelming evidence" heading="3" collapsed="true">
                      <outline text="Overwhelming evidence for the generalization being very reliable" colorLabel="3"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Distinguishing likelihood and relevance](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=yhNvheql8sUOE-_HhGsNwMvd)" colorLabel="2"/>
              </outline>
            </outline>
            <outline text="Argument premoves" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Attempting to account for possible counterarguments before they are given."/>
              </outline>
              <outline text="Importance / limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="At least small examples of this are very common." colorLabel="4"/>
                </outline>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="It often feels like addressing relevant position(s) when it actually isn&apos;t." colorLabel="1" collapsed="true">
                    <outline text="[Limitations of addressing irrelevant reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GpDBQ5VtNgWsY6aQCQ8MESNG)" colorLabel="4"/>
                  </outline>
                  <outline text="Can save time" colorLabel="4" collapsed="true">
                    <outline text="You really have to know what you&apos;re doing to consistently save time." colorLabel="1"/>
                    <outline text="It can also waste a lot of time from [issues resulting from addressing irrelevant reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GpDBQ5VtNgWsY6aQCQ8MESNG)" colorLabel="1"/>
                  </outline>
                </outline>
              </outline>
              <outline text="Recommended alternative" heading="3" colorLabel="2" collapsed="true">
                <outline text="It&apos;s usually better to ask what one believes and mostly only respond to what you can be very confident is their position."/>
                <outline text="^ [Limitations of addressing irrelevant reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=GpDBQ5VtNgWsY6aQCQ8MESNG)" colorLabel="4"/>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="[Addressing irrelevant reasoning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=KOPPXTY3kepYJVMbJ9RL4sXR)" heading="2" colorLabel="2" collapsed="true">
                  <outline text="A very common downside of argument premoves."/>
                </outline>
                <outline text="[Steelmanning](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=LWB8YQUQupE7UQRtFL7J9g6w)" heading="3" colorLabel="2" collapsed="true">
                  <outline text="Argument premoves are a very common technique used when attempting to steelman others."/>
                </outline>
              </outline>
            </outline>
            <outline text="Inflammatory statements" heading="2" colorLabel="1" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Provocative or emotionally charged remarks."/>
                <outline text="**Often:**   Intended to provoke strong reactions (typically negative), often anger or outrage."/>
              </outline>
              <outline text="Importance / Limitations" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3"/>
                <outline text="Impactful" heading="3" collapsed="true">
                  <outline text="Using inflammatory statements often causes people to launch inflammatory statements back, intended to make you feel a similarly negative way." colorLabel="4" collapsed="true">
                    <outline text="If these attempts are even remotely successful, it&apos;s typically an epistemic problem because it could easily cause you to misunderstand and/or unintentionally strawman their position." _note="Link how mood (especially anger) effects our reasoning." colorLabel="4" collapsed="true">
                      <outline text="We often believe that it wouldn&apos;t influence us when it actually would." _note="Try to find the study on how people cared about what other people thought of them even when they expected otherwise." colorLabel="4"/>
                    </outline>
                    <outline text="This can lead you to further dehumanize them and take what they say even less seriously, often less than make sense." colorLabel="4"/>
                  </outline>
                </outline>
              </outline>
            </outline>
            <outline text="Informal arguments" heading="3" colorLabel="2" collapsed="true">
              <outline text="Definition" heading="3" colorLabel="3" collapsed="true">
                <outline text="Arguments which are given in ordinary language."/>
              </outline>
              <outline text="Importance" heading="3" colorLabel="2" collapsed="true">
                <outline text="Common" heading="3" collapsed="true">
                  <outline text="Most arguments are informal, as opposed to [formal](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=0At0cZGMuQERz1v4oedfKRza)." colorLabel="4"/>
                </outline>
                <outline text="Difficult" heading="3" collapsed="true">
                  <outline text="In an informal argument, it is often difficult to see what the premises and the conclusion are." colorLabel="4" collapsed="true">
                    <outline text=" Informal arguments often contains material which is inessential to the argument." colorLabel="4" collapsed="true">
                      <outline text="Much of what people say or write has a rhetorical purpose." colorLabel="4"/>
                    </outline>
                  </outline>
                </outline>
              </outline>
              <outline text="Related" heading="3" colorLabel="6" collapsed="true">
                <outline text="As opposed to [standard form arguments](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=WBGbs-oyLu2VHlBm5Vkh-KAb)" heading="3" colorLabel="5"/>
              </outline>
            </outline>
            <outline text="Related" heading="3" colorLabel="6" collapsed="true">
              <outline text="[Conflations](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rkFEurnAxeGlEmMJ8RQUkGO2)" heading="3" colorLabel="1"/>
              <outline text="[Fitting things together](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=FORaGWzKq7OJtxVu6LDAqa11)" heading="3" colorLabel="2" collapsed="true">
                <outline text="Mentally fitting concepts together in a logical way is crucial for being able to explain your position to people who are not accustomed to your mental map of concepts." collapsed="true">
                  <outline text="You may need to explain it in completely different terms and in relation to completely different concepts than you&apos;re accustomed to."/>
                  <outline text="^ Being able to follow connections to those alternative areas is very important for this."/>
                </outline>
              </outline>
              <outline text="[Examples](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=rWwkVHO702PBy1aoUtBw-bBU)" heading="3" colorLabel="3"/>
              <outline text="[Analogies](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=fB49ZDXwTg85jeD3n0Jft40n)" heading="3" colorLabel="3"/>
              <outline text="[Heavily relying on implied premises](https://dynalist.io/d/nBfl0bh1yEuK5cktkexuu8Xd#z=qmBqfPbnbOqR5hgHr1RnIegw)" heading="3" colorLabel="2"/>
            </outline>
          </outline>
        </outline>
      </outline>
    </outline>
  </body>
</opml>
